---
const rules = {
  prerender: [{
    where: {
      and: [
        { href_matches: '/*' },
        { not: { href_matches: '/api/*' } },
        { not: { selector_matches: '[data-no-prerender]' } },
      ],
    },
    eagerness: 'moderate',
  }],
}
---

<script type="speculationrules" set:html={JSON.stringify(rules)} />
