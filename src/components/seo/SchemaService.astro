---
import { serviceSchema } from '@/lib/schema'

interface Props {
  name: string
  description: string
  serviceType: string
  url: string
  image?: string
}

const { name, description, serviceType, url, image } = Astro.props
const schema = serviceSchema({ name, description, serviceType, url, image })
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
