---
import { siteConfig } from '@/data/site'
import type { PageMeta } from '@/lib/metadata'

interface Props {
  meta: PageMeta
}

const { meta } = Astro.props
const canonicalURL = new URL(meta.canonical, siteConfig.url)
const ogImage = meta.ogImage ? new URL(meta.ogImage, siteConfig.url).href : new URL(siteConfig.og.image, siteConfig.url).href

// i18n: compute hreflang alternates
const currentLocale = Astro.currentLocale || 'es'
const esPath = currentLocale === 'en' ? (meta.alternateEs ?? null) : meta.canonical
const enPath = currentLocale === 'en' ? meta.canonical : (meta.alternateEn ?? null)
const esUrl = esPath ? new URL(esPath, siteConfig.url).href : null
const enUrl = enPath ? new URL(enPath, siteConfig.url).href : null
const ogLocale = currentLocale === 'en' ? 'en_GB' : 'es_ES'
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#ffffff" />
<title>{meta.title}</title>
<meta name="description" content={meta.description} />
<link rel="canonical" href={canonicalURL.href} />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon-48x48.png" sizes="48x48" type="image/png" />
<link rel="icon" href="/icon-192x192.png" sizes="192x192" type="image/png" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" sizes="192x192" href="/icon-192x192.png" />
<link rel="mask-icon" href="/favicon.svg" color="#E54D1F" />
<meta name="robots" content={meta.noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
{import.meta.env.PUBLIC_GOOGLE_VERIFICATION && (
  <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION} />
)}
<meta name="author" content="Pladur Menorca" />
<meta name="geo.region" content="ES-IB" />
<meta name="geo.placename" content={siteConfig.geoPlacename} />
<meta name="geo.position" content={`${siteConfig.serviceGeo.lat};${siteConfig.serviceGeo.lng}`} />
<meta name="ICBM" content={`${siteConfig.serviceGeo.lat}, ${siteConfig.serviceGeo.lng}`} />
{esUrl && <link rel="alternate" hreflang="es" href={esUrl} />}
{enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
<link rel="alternate" hreflang="x-default" href={esUrl ?? canonicalURL.href} />

<!-- Open Graph -->
<meta property="og:type" content={meta.type ?? 'website'} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={meta.title} />
<meta property="og:locale" content={ogLocale} />
{currentLocale === 'en' && <meta property="og:locale:alternate" content="es_ES" />}
{currentLocale !== 'en' && enUrl && <meta property="og:locale:alternate" content="en_GB" />}
<meta property="og:site_name" content={siteConfig.name} />
{meta.publishedTime && <meta property="article:published_time" content={meta.publishedTime} />}
{meta.modifiedTime && <meta property="article:modified_time" content={meta.modifiedTime} />}
{meta.articleSection && <meta property="article:section" content={meta.articleSection} />}
{meta.articleTags && meta.articleTags.map(tag => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={meta.title} />

{meta.preloadImage && (
  <link rel="preload" as="image" href={meta.preloadImage} fetchpriority="high" />
)}

<!-- Font (self-hosted, preload critical weights) -->
<link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-400.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-500.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-600.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin-700.woff2" crossorigin />
