---
// WebMCP — expone herramientas del sitio a agentes IA en el navegador.
// Spec: https://webmachinelearning.github.io/webmcp/
// Feature-detecta `navigator.modelContext` y registra tools si está soportado.
// En navegadores sin soporte (hoy la mayoría), no hace nada.
---

<script is:inline>
  ;(function registerWebMCP() {
    if (typeof navigator === 'undefined') return
    var mc = navigator.modelContext
    if (!mc || typeof mc.provideContext !== 'function') return

    var SITE = 'https://www.pladurmenorca.com'
    var PHONE = '627 829 723'
    var WHATSAPP = '34627829723'

    var SERVICES = {
      'falsos-techos': { url: '/falsos-techos-pladur-menorca', label: 'Falsos techos de pladur' },
      'tabiques': { url: '/tabiques-pladur-menorca', label: 'Tabiques de pladur' },
      'aislamiento-acustico': { url: '/aislamiento-acustico-menorca', label: 'Aislamiento acústico' },
      'aislamiento-termico': { url: '/aislamiento-termico-menorca', label: 'Aislamiento térmico' },
      'reformas-interiores': { url: '/reformas-interiores-pladur-menorca', label: 'Reformas interiores' },
      'escayola': { url: '/escayola-menorca', label: 'Escayola' },
      'pladur-ignifugo': { url: '/pladur-ignifugo-menorca', label: 'Pladur ignífugo' },
      'pladur-hidrofugo': { url: '/pladur-hidrofugo-menorca', label: 'Pladur hidrófugo' },
      'hoteles': { url: '/pladur-hoteles-menorca', label: 'Hoteles' },
      'apartamentos-turisticos': { url: '/pladur-apartamentos-turisticos-menorca', label: 'Apartamentos turísticos' },
      'obra-nueva': { url: '/pladur-obra-nueva-menorca', label: 'Obra nueva (B2B)' },
      'precios': { url: '/precios-pladur-menorca', label: 'Tabla de precios' },
      'presupuesto': { url: '/presupuesto-pladur', label: 'Solicitar presupuesto' },
      'contacto': { url: '/contacto', label: 'Contacto' },
    }

    var tools = [
      {
        name: 'request_quote',
        description:
          'Envía una solicitud real de presupuesto o contacto a Pladur Menorca. Llega al email del negocio; responden en <24h laborables. Rate limit: 20/día por IP.',
        inputSchema: {
          type: 'object',
          required: ['nombre', 'telefono'],
          properties: {
            nombre: { type: 'string', minLength: 2, maxLength: 100, description: 'Nombre completo del solicitante' },
            telefono: { type: 'string', minLength: 7, maxLength: 20, description: 'Teléfono de contacto' },
            email: { type: 'string', format: 'email', description: 'Email (recomendado)' },
            descripcion: { type: 'string', maxLength: 2000, description: 'Descripción del proyecto' },
            tipo: { type: 'string', enum: ['presupuesto', 'contacto', 'rapido'] },
          },
        },
        execute: async function (args) {
          try {
            var res = await fetch('/api/contacto', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                nombre: args.nombre,
                telefono: args.telefono,
                email: args.email,
                descripcion: args.descripcion,
                tipo: args.tipo || 'presupuesto',
                paginaOrigen: 'webmcp://' + (location && location.pathname) || '/',
              }),
            })
            var json = await res.json()
            if (!res.ok || !json.success) {
              return 'Error al enviar solicitud: ' + (json.error || res.status) + '. Contacto directo: ' + PHONE
            }
            return 'Solicitud enviada correctamente. Pladur Menorca contactará a ' + args.nombre + ' al ' + args.telefono + ' en <24h laborables.'
          } catch (err) {
            return 'Error de red al enviar solicitud. Contacto directo: ' + PHONE
          }
        },
      },

      {
        name: 'navigate_to_service',
        description: 'Navega a la página de un servicio específico del sitio (dentro del mismo navegador del usuario).',
        inputSchema: {
          type: 'object',
          required: ['service'],
          properties: {
            service: {
              type: 'string',
              enum: Object.keys(SERVICES),
              description: 'Identificador del servicio al que navegar',
            },
          },
        },
        execute: function (args) {
          var s = SERVICES[args.service]
          if (!s) return 'Servicio desconocido: ' + args.service
          location.href = s.url
          return 'Navegando a ' + s.label + ' (' + s.url + ')'
        },
      },

      {
        name: 'open_whatsapp_chat',
        description: 'Abre una conversación de WhatsApp con Pladur Menorca en una pestaña nueva, opcionalmente con mensaje pre-rellenado.',
        inputSchema: {
          type: 'object',
          properties: {
            message: { type: 'string', maxLength: 500, description: 'Mensaje inicial opcional' },
          },
        },
        execute: function (args) {
          var base = 'https://wa.me/' + WHATSAPP
          var url = args.message ? base + '?text=' + encodeURIComponent(args.message) : base
          window.open(url, '_blank', 'noopener,noreferrer')
          return 'WhatsApp abierto en pestaña nueva.'
        },
      },

      {
        name: 'call_phone',
        description: 'Inicia una llamada telefónica a Pladur Menorca (dispara el manejador tel: del sistema operativo).',
        inputSchema: { type: 'object', properties: {} },
        execute: function () {
          location.href = 'tel:+34' + WHATSAPP
          return 'Iniciando llamada a ' + PHONE
        },
      },

      {
        name: 'get_page_context',
        description: 'Devuelve información sobre la página que el usuario está viendo en este momento (URL, título, servicio asociado si aplica).',
        inputSchema: { type: 'object', properties: {} },
        execute: function () {
          var path = location.pathname
          var current = null
          for (var key in SERVICES) {
            if (SERVICES[key].url === path) { current = { key: key, label: SERVICES[key].label }; break }
          }
          return JSON.stringify({
            url: location.href,
            path: path,
            title: document.title,
            currentService: current,
            site: SITE,
          })
        },
      },

      {
        name: 'get_business_info',
        description: 'Devuelve información básica del negocio (contacto, horario, valoración).',
        inputSchema: { type: 'object', properties: {} },
        execute: function () {
          return JSON.stringify({
            name: 'Pladur Menorca',
            phone: PHONE,
            email: 'info@plaquistas.com',
            website: SITE,
            whatsapp: 'https://wa.me/' + WHATSAPP,
            opening_hours: 'L-V 8:00-18:00, S 8:00-14:00',
            founded: 2004,
            rating: '4.7/5 Google',
            service_area: 'Toda la isla de Menorca, Islas Baleares',
          })
        },
      },
    ]

    try {
      mc.provideContext({ tools: tools })
    } catch (err) {
      if (console && console.warn) console.warn('[WebMCP] Error registrando tools:', err)
    }
  })()
</script>
