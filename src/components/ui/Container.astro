---
import { cn } from '@/lib/utils'

type ContainerSize = 'sm' | 'md' | 'lg' | 'xl' | 'full'

interface Props {
  class?: string
  size?: ContainerSize
}

const { class: className = '', size = 'lg' } = Astro.props

const sizeClasses: Record<ContainerSize, string> = {
  sm: 'max-w-2xl',
  md: 'max-w-4xl',
  lg: 'max-w-6xl',
  xl: 'max-w-7xl',
  full: 'w-full',
}

const classes = cn(
  'mx-auto px-4 sm:px-6 lg:px-8',
  sizeClasses[size],
  className,
)
---

<div class={classes}>
  <slot />
</div>
