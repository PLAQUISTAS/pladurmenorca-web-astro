---
import { cn } from '@/lib/utils'

type CardPadding = 'sm' | 'md' | 'lg'

interface Props {
  class?: string
  hover?: boolean
  padding?: CardPadding
}

const { class: className = '', hover = false, padding = 'md' } = Astro.props

const paddingClasses: Record<CardPadding, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
}

const baseClasses = 'bg-white border border-gray-100 rounded-2xl'

const hoverClasses = hover
  ? 'transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-accent/20 cursor-pointer'
  : ''

const classes = cn(baseClasses, hoverClasses, paddingClasses[padding], className)
---

<div class={classes}>
  <slot />
</div>
