---
import type { Testimonio } from '@/data/testimonios'

interface Props {
  testimonio: Testimonio
}

const { testimonio } = Astro.props

function getInitials(name: string): string {
  return name.split(' ').slice(0, 2).map(w => w[0]).join('').toUpperCase()
}
---

<div class="group bg-white hover:bg-warm-100 rounded-3xl border border-warm-border/40 p-7 flex flex-col shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow,background-color] duration-300 h-full">

  {/* Stars */}
  <div class="flex items-center gap-0.5 mb-4">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`size-3.5 ${i < testimonio.rating ? 'text-star' : 'text-warm-border'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  {/* Quote */}
  <p class="text-foreground text-sm leading-relaxed flex-1 mb-6 line-clamp-4">
    &ldquo;{testimonio.texto}&rdquo;
  </p>

  {/* Author */}
  <div class="flex items-center gap-2.5 mt-auto">
    <div class="size-8 rounded-full bg-foreground-dark flex items-center justify-center shrink-0">
      <span class="text-white text-[10px] font-bold leading-none">{getInitials(testimonio.nombre)}</span>
    </div>
    <div class="min-w-0">
      <p class="font-semibold text-foreground text-sm leading-snug truncate">{testimonio.nombre}</p>
      <p class="text-xs text-muted">{testimonio.servicio}</p>
    </div>
  </div>
</div>
