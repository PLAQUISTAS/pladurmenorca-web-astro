---
import { siteConfig } from '@/data/site'

interface Props {
  variant?: 'default' | 'compact' | 'inline'
}

const { variant = 'default' } = Astro.props
const rating = siteConfig.aggregateRating.ratingValue
const reviews = siteConfig.aggregateRating.reviewCount
---

{variant === 'default' && (
  <div class="inline-flex items-center gap-2 rounded-xl bg-warm-200 border border-warm-border/60 px-4 py-2.5 shadow-card">
    <div class="flex items-center gap-0.5">
      {[...Array(5)].map(() => (
        <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
    <span class="text-xs font-bold text-foreground">{rating}/5</span>
    <span class="text-xs text-muted">en Google</span>
  </div>
)}

{variant === 'compact' && (
  <div class="inline-flex items-center gap-1.5">
    <div class="flex items-center gap-0.5">
      {[...Array(5)].map(() => (
        <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
    <span class="text-xs text-muted">{rating}/5 en Google</span>
  </div>
)}

{variant === 'inline' && (
  <div class="flex items-center gap-2">
    <div class="flex items-center gap-0.5">
      {[...Array(5)].map(() => (
        <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
    <span class="text-2xl font-bold text-foreground">{rating}</span>
    <span class="text-muted text-lg">/5</span>
  </div>
)}
