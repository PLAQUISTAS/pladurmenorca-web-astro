---
import { cn } from '@/lib/utils'

type BadgeVariant = 'success' | 'primary' | 'accent' | 'neutral'

interface Props {
  variant?: BadgeVariant
  class?: string
}

const { variant = 'neutral', class: className = '' } = Astro.props

const variantClasses: Record<BadgeVariant, string> = {
  success: 'bg-green-50 text-green-700 border border-green-200',
  primary: 'bg-nav-bg text-foreground border border-nav-border',
  accent: 'bg-surface text-foreground border border-nav-border',
  neutral: 'bg-gray-100 text-gray-700',
}

const classes = cn(
  'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium',
  variantClasses[variant],
  className,
)
---

<span class={classes}>
  <slot />
</span>
