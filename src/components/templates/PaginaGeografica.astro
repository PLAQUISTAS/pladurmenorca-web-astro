---
import PreciosTable from '@/components/sections/PreciosTable.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import Button from '@/components/ui/Button.astro'
import { siteConfig } from '@/data/site'

interface Zona {
  nombre: string
  descripcion: string
}

interface FichaItem {
  label: string
  valor: string
}

interface SchemaServiceData {
  name: string
  description: string
  serviceType: string
  url: string
}

interface Props {
  municipio: string
  zonas: Zona[]
  faqKey: string

  /* Hero */
  heroBadge?: string
  heroTitle?: string
  heroDescription?: string

  /* Intro */
  introLabel?: string
  introTitle?: string

  /* Servicios */
  serviciosBadge?: string
  serviciosTitulo?: string
  serviciosSubtitulo?: string

  /* Proyecto destacado */
  proyectoTitulo?: string
  proyectoBadge?: string
  proyectoTextos?: string[]
  proyectoFicha?: FichaItem[]

  /* FAQ */
  faqTitulo?: string
  faqSubtitulo?: string

  /* CTA */
  ctaTitulo?: string
  ctaSubtitulo?: string

  /* Schema */
  schemaService?: SchemaServiceData
}

const {
  municipio,
  zonas,
  faqKey,
  heroBadge,
  heroTitle,
  heroDescription,
  introLabel,
  introTitle,
  serviciosBadge,
  serviciosTitulo,
  serviciosSubtitulo,
  proyectoTitulo,
  proyectoBadge,
  proyectoTextos,
  proyectoFicha,
  faqTitulo,
  faqSubtitulo,
  ctaTitulo,
  ctaSubtitulo,
} = Astro.props

const badge = heroBadge ?? `${municipio} · Menorca`
const title = heroTitle ?? `Pladur en ${municipio} — Instaladores Profesionales`
const iLabel = introLabel ?? `Conocemos ${municipio}`
const iTitle = introTitle ?? `Especialistas en las viviendas de ${municipio}`
const sBadge = serviciosBadge ?? `Nuestras soluciones en ${municipio}`
const sTitulo = serviciosTitulo ?? `Qué hacemos específicamente en ${municipio}`
const sSub = serviciosSubtitulo ?? `Cada zona de ${municipio} tiene sus propias características constructivas. Estas son las soluciones que más aplicamos según el tipo de vivienda.`
const pTitulo = proyectoTitulo ?? `Reforma integral con pladur en ${municipio}`
const pBadge = proyectoBadge ?? 'Proyecto destacado'
const pTextos = proyectoTextos ?? [
  `Proyecto de reforma integral de una vivienda de 95 m² en ${municipio}: falso techo continuo en todas las estancias con integración de iluminación LED, dos tabiques de redistribución para crear un dormitorio adicional y zona de trabajo, y trasdosado de fachada con aislamiento térmico.`,
  `El resultado fue una vivienda completamente transformada, con distribución moderna adaptada a las necesidades actuales de la familia, mejora significativa del confort térmico (reducción de 6°C en temperatura interior en verano) y acabados de alta calidad listos para pintar.`,
  `El trabajo se completó en 8 días hábiles, con los propietarios pudiendo habitar la vivienda durante la mayor parte de la reforma gracias a nuestra metodología de trabajo por zonas que minimiza las molestias.`,
]
const pFicha = proyectoFicha ?? [
  { label: 'Superficie', valor: '95 m²' },
  { label: 'Ubicación', valor: municipio },
  { label: 'Trabajos', valor: 'Techo + Tabiques + Trasdosado' },
  { label: 'Duración', valor: '8 días hábiles' },
  { label: 'Resultado', valor: 'Distribución nueva + aislamiento' },
]
const fTitulo = faqTitulo ?? `Preguntas frecuentes sobre pladur en ${municipio}`
const fSub = faqSubtitulo ?? `Respuestas a las dudas más habituales sobre nuestros servicios de pladur en ${municipio}.`
const cTitulo = ctaTitulo ?? `¿Necesitas pladur en ${municipio}?`
const cSub = ctaSubtitulo ?? 'Solicita tu presupuesto gratuito y sin compromiso. Respuesta en 24 horas.'

/* Default servicios data */
const defaultServicios = [
  {
    titulo: `Falsos techos en ${municipio}`,
    descripcion: 'Instalación de falsos techos continuos y registrables para viviendas, oficinas y locales comerciales. Mejora la estética, oculta instalaciones e integra iluminación LED empotrada. Ideal para modernizar espacios con techos altos o deteriorados.',
    iconPath: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
    link: { href: '/falsos-techos-pladur-menorca', texto: 'Más sobre falsos techos' },
  },
  {
    titulo: `Tabiques de distribución en ${municipio}`,
    descripcion: 'Redistribuye tu vivienda o local sin obra pesada. Creamos dormitorios, vestidores, zonas de trabajo y separaciones con tabiques de pladur rápidos, limpios y con acabado perfecto listo para pintar.',
    iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
    link: { href: '/tabiques-pladur-menorca', texto: 'Más sobre tabiques' },
  },
  {
    titulo: `Aislamiento acústico en ${municipio}`,
    descripcion: 'Sistemas de pladur desacoplado con lana mineral de alta densidad que reducen el ruido entre viviendas en 45-55 dB. Solución definitiva para problemas de ruido con vecinos, locales o tráfico.',
    iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z',
    link: { href: '/aislamiento-acustico-menorca', texto: 'Más sobre aislamiento acústico' },
  },
  {
    titulo: `Aislamiento térmico en ${municipio}`,
    descripcion: 'Trasdosados con aislamiento térmico que mejoran la eficiencia energética de tu vivienda. Reducción de hasta 8°C en temperatura interior en verano y ahorro significativo en climatización durante todo el año.',
    iconPath: 'M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z',
    iconPath2: 'M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1.001A3.75 3.75 0 0012 18z',
    link: { href: '/aislamiento-termico-menorca', texto: 'Más sobre aislamiento térmico' },
  },
  {
    titulo: `Locales y hostelería en ${municipio}`,
    descripcion: 'Reformas con pladur en locales comerciales, restaurantes y hoteles. Creamos ambientes diferenciados, mejoramos la acústica y cumplimos normativas de aislamiento entre local y viviendas colindantes.',
    iconPath: 'M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z',
  },
  {
    titulo: `Reformas interiores con pladur en ${municipio}`,
    descripcion: 'Reformas integrales que combinan falsos techos, tabiques y trasdosados para transformar completamente tu vivienda. Coordinamos con electricistas, fontaneros y pintores para un resultado llave en mano.',
    iconPath: 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
    link: { href: '/reformas-interiores-pladur-menorca', texto: 'Más sobre reformas' },
  },
]

/* Default enlaces internos */
const defaultEnlaces = [
  {
    href: '/instalacion-pladur-menorca',
    label: 'Instalación de Pladur en Menorca',
    descripcion: 'Todo sobre nuestros servicios de instalación de pladur en la isla.',
    iconPath: 'M11.42 15.17l-5.384-3.065A1.5 1.5 0 005.25 13.5v5.25a1.5 1.5 0 001.786 1.47l5.384-1.436a1.5 1.5 0 001.08-1.442V15.17zm0 0l5.384-3.065A1.5 1.5 0 0018.75 10.5V5.25a1.5 1.5 0 00-1.786-1.47l-5.384 1.436a1.5 1.5 0 00-1.08 1.442v8.512z',
  },
  {
    href: '/falsos-techos-pladur-menorca',
    label: 'Falsos Techos de Pladur',
    descripcion: 'Techos lisos, decorativos y con aislamiento para todo tipo de espacios.',
    iconPath: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  },
  {
    href: '/tabiques-pladur-menorca',
    label: 'Tabiques de Pladur',
    descripcion: 'Redistribuye tu vivienda o local con tabiques de pladur rápidos y limpios.',
    iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
  {
    href: '/precios-pladur-menorca',
    label: 'Precios de Pladur en Menorca',
    descripcion: 'Consulta nuestras tarifas y precios orientativos por m².',
    iconPath: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z',
  },
  {
    href: '/aislamiento-acustico-menorca',
    label: 'Aislamiento Acústico',
    descripcion: 'Soluciones profesionales de insonorización con pladur para viviendas y locales.',
    iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z',
  },
]
---

<!-- 1. Hero — Glassmorphism -->
<section class="pt-24 pb-20 lg:pt-32 lg:pb-28 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm">
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-warm-200 text-foreground border border-warm-border/60 text-xs font-semibold tracking-wide mb-6">
          {badge}
        </span>
        <h1 aria-label={title} class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
          {title}
        </h1>
        {heroDescription && (
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto mb-8">
            {heroDescription}
          </p>
        )}
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button href="/presupuesto-pladur" variant="primary" size="lg" withArrow>
            Presupuesto gratis en 24h
          </Button>
          <Button href={`tel:${siteConfig.phoneRaw}`} variant="secondary" size="lg">
            <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {siteConfig.phone}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 2. Intro + Zonas -->
<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mb-6">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
        {iLabel}
      </span>
      <h2 aria-label={iTitle} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
        {iTitle}
      </h2>
    </div>
    <div class="max-w-3xl mb-14">
      <slot name="intro-text">
        <div class="text-lg text-muted leading-relaxed">
          <p>
            Trabajamos en todas las zonas de {municipio}. Conocemos las particularidades constructivas de cada barrio y adaptamos nuestras soluciones de pladur a las necesidades específicas de cada zona: falsos techos, tabiques de distribución, aislamiento acústico y térmico.
          </p>
        </div>
      </slot>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {zonas.map((zona, i) => (
        <div class="group bg-white/70 rounded-2xl border border-warm-border/50 p-7 hover:shadow-card hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 h-full">
          <span class="inline-flex items-center justify-center size-10 rounded-xl bg-surface text-sm font-bold text-foreground-dark tabular-nums mb-4">
            {String(i + 1).padStart(2, '0')}
          </span>
          <p class="font-bold text-foreground mb-1.5">{zona.nombre}</p>
          <p class="text-sm text-muted leading-relaxed">{zona.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 3. Texto SEO adicional (slot) -->
<slot name="texto-seo" />

<!-- 4. Servicios locales -->
<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-14 max-w-3xl">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
        {sBadge}
      </span>
      <h2 aria-label={sTitulo} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
        {sTitulo}
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        {sSub}
      </p>
    </div>

    <slot name="servicios">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {defaultServicios.map((servicio) => (
          <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 group h-full">
            <div class="size-12 bg-surface border border-nav-border rounded-2xl group-hover:bg-foreground-dark group-hover:border-foreground-dark flex items-center justify-center mb-6 transition-[transform,box-shadow,background-color,border-color] duration-300">
              <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={servicio.iconPath} />
                {servicio.iconPath2 && <path stroke-linecap="round" stroke-linejoin="round" d={servicio.iconPath2} />}
              </svg>
            </div>
            <h3 aria-label={servicio.titulo} class="font-bold text-foreground text-lg mb-3">{servicio.titulo}</h3>
            <div class="text-muted text-sm leading-relaxed">
              <p>{servicio.descripcion}</p>
            </div>
            {servicio.link && (
              <a
                href={servicio.link.href}
                class="mt-5 inline-flex items-center gap-2 text-foreground font-semibold text-sm hover:text-foreground-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2 rounded-lg"
               aria-label={servicio.link.texto}>
                {servicio.link.texto}
                <svg class="size-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </slot>
  </div>
</section>

<!-- 5. PreciosTable resumen -->
<PreciosTable variant="resumen" />

<!-- 6. Proyecto destacado -->
<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-14 max-w-3xl">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
        {pBadge}
      </span>
      <h2 aria-label={pTitulo} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
        {pTitulo}
      </h2>
    </div>
    <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-soft overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-12">
        <div class="lg:col-span-8 p-8 lg:p-12">
          <slot name="proyecto-contenido">
            <div class="max-w-none text-muted space-y-4">
              {pTextos.map((texto) => (
                <p>{texto}</p>
              ))}
            </div>
          </slot>
        </div>
        <div class="lg:col-span-4 bg-warm-200/50 p-8 lg:p-10 lg:border-l border-t lg:border-t-0 border-warm-border/50">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-5">
            Ficha técnica
          </span>
          <div class="space-y-0">
            {pFicha.map((item) => (
              <div class="flex justify-between items-start gap-4 py-3.5 border-b border-warm-border/60 last:border-0">
                <span class="text-muted text-sm">{item.label}</span>
                <span class="text-foreground font-semibold text-sm text-right">{item.valor}</span>
              </div>
            ))}
            <Button href="/presupuesto-pladur" variant="primary" size="md" block class="mt-6">
              Pide tu presupuesto gratis
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 7. FaqAccordion -->
<FaqAccordion
  client:visible
  categoria={faqKey}
  titulo={fTitulo}
  subtitulo={fSub}
/>

