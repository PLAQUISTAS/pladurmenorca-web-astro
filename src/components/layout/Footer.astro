---
import { Image } from 'astro:assets'
import { siteConfig } from '@/data/site'
import GoogleRatingBadge from '@/components/ui/GoogleRatingBadge.astro'

const services = [
  { label: 'Instalación de Pladur', href: '/instalacion-pladur-mallorca' },
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques de Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Escayola', href: '/escayola-mallorca' },
  { label: 'Precios de Pladur', href: '/precios-pladur-mallorca' },
]

const zonas = [
  { label: 'Pladur en Palma', href: '/pladur-palma' },
  { label: 'Pladur en Calvià', href: '/pladur-calvia' },
  { label: 'Pladur en Inca', href: '/pladur-inca' },
  { label: 'Pladur en Manacor', href: '/pladur-manacor' },
  { label: 'Pladur en Alcúdia', href: '/pladur-alcudia' },
]

const empresa = [
  { label: 'Sobre Nosotros', href: '/sobre-nosotros' },
  { label: 'Proyectos', href: '/proyectos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
]
---

<footer class="text-foreground" aria-label="Pie de página">
  {/* Main footer content */}
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-8 sm:px-10 lg:px-14 pt-12 pb-8 shadow-warm animate-fade-up">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-14">

      {/* Col 1: Logo + description + social */}
      <div class="lg:col-span-3 space-y-5">
        <a href="/" aria-label="Pladur Mallorca — Inicio" class="inline-block rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2">
          <Image
            src="/images/pladur-mallorca-logo.png"
            alt="Pladur Mallorca"
            width={48}
            height={48}
            class="h-12 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-muted text-sm leading-relaxed max-w-xs">
          Especialistas en instalación de pladur en Mallorca. Falsos techos, tabiques y aislamiento con más de {siteConfig.experience} años de experiencia.
        </p>

        {/* Google rating badge */}
        <GoogleRatingBadge />

        {/* Social icons */}
        <div class="flex items-center gap-2.5">
          <a
            href={siteConfig.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de Pladur Mallorca"
            class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
          >
            <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
          <a
            href={siteConfig.social.google}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Google Business de Pladur Mallorca"
            class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
          >
            <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972a6.033 6.033 0 110-12.064c1.498 0 2.866.549 3.921 1.453l2.814-2.814A9.969 9.969 0 0012.545 2C7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013z" />
            </svg>
          </a>
          {siteConfig.social.facebook && (
            <a
              href={siteConfig.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook de Pladur Mallorca"
              class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
            </a>
          )}
          {siteConfig.social.linkedin && (
            <a
              href={siteConfig.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn de Pladur Mallorca"
              class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          )}
          {siteConfig.social.youtube && (
            <a
              href={siteConfig.social.youtube}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="YouTube de Pladur Mallorca"
              class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
              </svg>
            </a>
          )}
          {siteConfig.social.tiktok && (
            <a
              href={siteConfig.social.tiktok}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok de Pladur Mallorca"
              class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
              </svg>
            </a>
          )}
          {siteConfig.social.pinterest && (
            <a
              href={siteConfig.social.pinterest}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Pinterest de Pladur Mallorca"
              class="size-10 rounded-xl bg-warm-200 border border-warm-border/60 hover:bg-warm-border-light hover:border-warm-border hover:-translate-y-0.5 transition-[background-color,border-color,transform] duration-300 flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-4 fill-current text-muted" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641 0 12.017 0z" />
              </svg>
            </a>
          )}
        </div>
      </div>

      {/* Col 2: Servicios */}
      <div class="lg:col-span-2">
        <h3 class="text-xs font-bold uppercase tracking-widest text-muted mb-5">
          Servicios
        </h3>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a
                href={s.href}
                class="group text-sm text-muted hover:text-foreground transition-colors duration-200 inline-flex items-center gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
              >
                <span>{s.label}</span>
                <svg class="size-3 opacity-0 -translate-x-1 group-hover:opacity-60 group-hover:translate-x-0 transition-[opacity,transform] duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Col 3: Zonas */}
      <div class="lg:col-span-2">
        <h3 class="text-xs font-bold uppercase tracking-widest text-muted mb-5">
          Zonas
        </h3>
        <ul class="space-y-3">
          {zonas.map((z) => (
            <li>
              <a
                href={z.href}
                class="group text-sm text-muted hover:text-foreground transition-colors duration-200 inline-flex items-center gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
              >
                <span>{z.label}</span>
                <svg class="size-3 opacity-0 -translate-x-1 group-hover:opacity-60 group-hover:translate-x-0 transition-[opacity,transform] duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
        <a
          href="/pladur-en-mallorca"
          class="group inline-flex items-center gap-1.5 text-xs font-semibold text-muted hover:text-foreground transition-colors duration-200 mt-4"
        >
          Ver todas las zonas
          <svg class="size-3 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      {/* Col 4: Empresa */}
      <div class="lg:col-span-2">
        <h3 class="text-xs font-bold uppercase tracking-widest text-muted mb-5">
          Empresa
        </h3>
        <ul class="space-y-3">
          {empresa.map((e) => (
            <li>
              <a
                href={e.href}
                class="group text-sm text-muted hover:text-foreground transition-colors duration-200 inline-flex items-center gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
              >
                <span>{e.label}</span>
                <svg class="size-3 opacity-0 -translate-x-1 group-hover:opacity-60 group-hover:translate-x-0 transition-[opacity,transform] duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Col 5: Contacto (NAP) */}
      <div class="lg:col-span-3">
        <h3 class="text-xs font-bold uppercase tracking-widest text-muted mb-5">
          Contacto
        </h3>
        <address class="not-italic space-y-4">
          {/* Dirección */}
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-warm-200 border border-warm-border/60 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="size-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="text-sm text-muted leading-relaxed pt-1.5">
              {siteConfig.address.street}<br />
              {siteConfig.address.postalCode} {siteConfig.address.city}
            </span>
          </div>

          {/* Teléfono */}
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-warm-200 border border-warm-border/60 flex items-center justify-center shrink-0">
              <svg class="size-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="text-sm text-muted hover:text-foreground transition-colors duration-200 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              {siteConfig.phone}
            </a>
          </div>

          {/* Email */}
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-warm-200 border border-warm-border/60 flex items-center justify-center shrink-0">
              <svg class="size-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-sm text-muted hover:text-foreground transition-colors duration-200 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              {siteConfig.email}
            </a>
          </div>

          {/* Horario */}
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-warm-200 border border-warm-border/60 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="size-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="text-sm text-muted leading-relaxed pt-1.5">
              Lun&ndash;Vie: 8:00&ndash;18:00<br />
              Sábados: 8:00&ndash;14:00
            </span>
          </div>
        </address>

        {/* Displacement note */}
        <p class="mt-6 text-xs text-muted leading-relaxed rounded-xl bg-warm-200 border border-warm-border/40 px-4 py-3">
          Servicio en toda la isla de Mallorca sin suplemento por desplazamiento en obras desde 500&euro;.
        </p>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-warm-border pt-6 pb-6 px-2 sm:px-0 flex flex-col sm:flex-row items-center justify-between gap-4 sm:gap-6">
      <p class="text-xs text-muted">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-5">
        <a href="/politica-de-privacidad" class="text-xs text-muted hover:text-foreground transition-colors duration-200 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2">
          Política de privacidad
        </a>
        <span class="size-1 rounded-full bg-warm-border" aria-hidden="true" />
        <a href="/aviso-legal" class="text-xs text-muted hover:text-foreground transition-colors duration-200 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2">
          Aviso legal
        </a>
      </div>
    </div>
    </div>
  </div>
</footer>
