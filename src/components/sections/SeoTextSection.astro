---
import Container from '@/components/ui/Container.astro'
import Button from '@/components/ui/Button.astro'
import { siteConfig } from '@/data/site'
import { localizedHref } from '@/i18n'

interface Props {
  lang?: 'es' | 'en'
}

const { lang = 'es' } = Astro.props
const p = (h: string) => localizedHref(h, lang)
const presupuestoHref = p('/presupuesto-pladur')

const t = lang === 'en' ? {
  badge: 'All about drywall in Menorca',
  h2: 'Installing drywall in Menorca',
  lead: 'Dry construction has replaced brick as the standard for interior renovations in Menorca — faster, cleaner and better suited to the island\'s seasonality.',
  trust: '22 years · 6,000+ projects · 8 municipalities',
  ctaQuote: 'Request a free quote',
  ctaCall: 'Call',
  items: [
    {
      tag: 'The material',
      title: 'What drywall is and why it works in Menorca',
      body: 'Plasterboard screwed to a galvanised metal frame: no mortar, no drying times. The standard choice in Menorca because it lets owners refurbish holiday homes between seasons in days instead of weeks — no wet works, no rubble, paint-ready in the same week.',
    },
    {
      tag: 'Our services',
      titleRich: 'Four specialist pillars',
      bodyRich: 'From <a href="/en/falsos-techos-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">suspended ceilings</a> and <a href="/en/tabiques-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">partitions</a> for layout changes to <a href="/en/aislamiento-acustico-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">acoustic and thermal insulation</a> to CTE standards, plus <a href="/en/escayola-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">hand-applied plasterwork</a> for premium finishes and heritage restoration.',
    },
    {
      tag: 'Pricing',
      titleRich: 'From €29/m² — all-in, VAT itemised',
      bodyRich: 'Ceilings from <strong class="text-foreground">€29/m²</strong>, partitions from <strong class="text-foreground">€45/m²</strong>, acoustic partitions from <strong class="text-foreground">€52/m²</strong>. Prices run 10-20% above mainland Spain due to shipping — still 25-40% below traditional brick when total cost is factored in. <a href="/en/precios-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">Full price table →</a>',
    },
    {
      tag: 'Performance',
      title: 'Rw 50 dB+ acoustic · 30-40% thermal gain reduction',
      body: 'Our decoupled wall linings with mineral wool exceed CTE-HR requirements between dwellings. Thermal linings with mineral wool or XPS on sun-exposed façades measurably lower AC consumption during Mediterranean summers.',
    },
    {
      tag: 'Local factors',
      title: 'Coastal salinity, heritage stock, tourist seasons',
      body: 'Three factors shape every Menorca project: salinity within 500 m of the sea (reinforced profiles + H moisture board even in dry areas); ageing housing in Maó and Ciutadella requiring antivibration wall linings; and the October-April refurbishment window that demands 3-6 months of advance planning.',
    },
    {
      tag: 'Our commitment',
      title: 'Plaquistas y Acabados SL · since 2004',
      body: '22 years in drywall and plaster, 6,000+ projects across the Balearics, Placo · Knauf · Lafarge exclusively, installers trained by the manufacturers. Fixed-price quotes, 1-year workmanship warranty on top of manufacturer warranty.',
    },
  ],
} : {
  badge: 'Todo sobre el pladur en Menorca',
  h2: 'Instalar pladur en Menorca',
  lead: 'La construcción en seco ha sustituido al ladrillo como estándar para reformas interiores en Menorca: más rápida, más limpia y mejor adaptada a la estacionalidad de la isla.',
  trust: '22 años · +6.000 proyectos · 8 municipios',
  ctaQuote: 'Solicitar presupuesto gratuito',
  ctaCall: 'Llamar',
  items: [
    {
      tag: 'El material',
      title: 'Qué es el pladur y por qué funciona en Menorca',
      body: 'Placa de yeso laminado atornillada sobre perfilería metálica galvanizada: sin mortero, sin tiempos de secado. Es la opción estándar en Menorca porque permite reformar viviendas vacacionales entre temporadas en días en lugar de semanas, sin obra húmeda ni escombros y lista para pintar la misma semana.',
    },
    {
      tag: 'Servicios',
      titleRich: 'Cuatro pilares especializados',
      bodyRich: 'De <a href="/falsos-techos-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">falsos techos</a> y <a href="/tabiques-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">tabiques</a> para redistribuciones, a <a href="/aislamiento-acustico-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">aislamiento acústico y térmico</a> según CTE, más <a href="/escayola-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">escayola artesanal</a> para acabados premium y restauración patrimonial.',
    },
    {
      tag: 'Precios',
      titleRich: 'Desde 29 €/m² · todo incluido, IVA desglosado',
      bodyRich: 'Techos desde <strong class="text-foreground">29 €/m²</strong>, tabiques desde <strong class="text-foreground">45 €/m²</strong>, tabiques acústicos desde <strong class="text-foreground">52 €/m²</strong>. Los precios son un 10-20 % superiores a Península por transporte marítimo, aun así 25-40 % más económicos que la obra tradicional en coste total. <a href="/precios-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">Tabla completa de precios →</a>',
    },
    {
      tag: 'Rendimiento',
      title: 'Rw 50 dB+ acústico · 30-40 % menos ganancia térmica',
      body: 'Nuestros trasdosados desvinculados con lana mineral superan los requisitos del CTE-HR entre viviendas. Los trasdosados térmicos con lana mineral o XPS en fachadas soleadas bajan medible el consumo de aire acondicionado durante los veranos mediterráneos.',
    },
    {
      tag: 'Factores locales',
      title: 'Salinidad costera, parque antiguo, temporalidad turística',
      body: 'Tres factores condicionan cada proyecto en Menorca: la salinidad a menos de 500 m del mar (perfilería reforzada + placa hidrófuga H incluso en zonas secas); el parque antiguo de Maó y Ciutadella que exige trasdosados antivibratorios; y la ventana real de reforma octubre-abril que obliga a planificar con 3-6 meses de antelación.',
    },
    {
      tag: 'Nuestro compromiso',
      title: 'Plaquistas y Acabados SL · desde 2004',
      body: '22 años en pladur y escayola, +6.000 proyectos en Baleares, uso exclusivo de Placo, Knauf y Lafarge con instaladores formados por los fabricantes. Presupuestos cerrados, garantía de 1 año en mano de obra sobre la garantía de fabricante.',
    },
  ],
}
---

<section class="w-full py-20 lg:py-28">
  <Container size="md">
    <div class="max-w-3xl mx-auto">

      {/* Header */}
      <div class="mb-16">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.badge}
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-[1.05] text-balance mb-5">
          {t.h2}
        </h2>
        <p class="text-lg text-muted leading-relaxed max-w-2xl">
          {t.lead}
        </p>
        <p class="mt-6 text-xs font-semibold uppercase tracking-[0.18em] text-muted/70">
          {t.trust}
        </p>
      </div>

      {/* Editorial numbered sections — linear, clean, all text in DOM for SEO */}
      <ol class="space-y-10 lg:space-y-12">
        {t.items.map((item, i) => (
          <li class="grid grid-cols-[auto_1fr] gap-x-5 sm:gap-x-8 items-baseline">
            <span class="text-sm font-bold text-foreground-dark tabular-nums tracking-wider select-none">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-muted mb-2">
                {item.tag}
              </p>
              {item.titleRich ? (
                <h3 class="text-xl sm:text-2xl font-bold text-foreground leading-snug mb-3" set:html={item.titleRich} />
              ) : (
                <h3 class="text-xl sm:text-2xl font-bold text-foreground leading-snug mb-3">{item.title}</h3>
              )}
              {item.bodyRich ? (
                <p class="text-muted leading-relaxed" set:html={item.bodyRich} />
              ) : (
                <p class="text-muted leading-relaxed">{item.body}</p>
              )}
            </div>
          </li>
        ))}
      </ol>

      {/* CTAs */}
      <div class="mt-16 pt-10 border-t border-warm-border/50 flex flex-col sm:flex-row gap-3">
        <Button href={presupuestoHref} variant="primary" size="lg">
          {t.ctaQuote}
        </Button>
        <Button href={`tel:${siteConfig.phoneRaw}`} variant="ghost" size="lg">
          {t.ctaCall}: {siteConfig.phone}
        </Button>
      </div>

    </div>
  </Container>
</section>
