---
import { Image } from 'astro:assets'

interface ImagenGaleria {
  src: string
  alt: string
}

interface Props {
  imagenes?: ImagenGaleria[]
}

const defaultImagenes: ImagenGaleria[] = [
  { src: '', alt: 'Falso techo continuo de pladur con integración LED en vivienda de Mallorca' },
  { src: '', alt: 'Tabiques de pladur para distribución open space en oficina de Mallorca' },
  { src: '', alt: 'Aislamiento acústico con pladur en apartamento turístico de Calvià, Mallorca' },
  { src: '', alt: 'Reforma integral con pladur en piso de Santa Catalina, Palma de Mallorca' },
]

const { imagenes: imagenesProp } = Astro.props
const imagenes = imagenesProp ?? defaultImagenes
---

<section class="w-full py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="mb-12 lg:mb-14 max-w-xl animate-fade-up">
      <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
        Nuestro trabajo
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
        Galería de trabajos
      </h2>
      <p class="mt-4 text-lg text-muted leading-relaxed">
        Fotos reales de proyectos ejecutados en toda Mallorca.
      </p>
    </div>

    {/* Desktop grid -- 2 cols */}
    <div class="hidden sm:grid sm:grid-cols-2 gap-4 auto-rows-[260px] stagger-children">
      {imagenes.map((imagen) => (
        <div class="h-full">
          <div class="relative w-full h-full overflow-hidden rounded-3xl group shadow-card hover:shadow-card-hover border border-warm-border/50 transition-shadow duration-300">
            {!imagen.src ? (
              <div class="absolute inset-0 bg-gradient-to-br from-placeholder to-nav-bg flex flex-col items-center justify-center gap-3">
                <svg
                  class="size-10 text-muted group-hover:text-foreground transition-colors"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <span class="text-muted text-xs font-medium text-center px-4 leading-snug">
                  {imagen.alt}
                </span>
              </div>
            ) : (
              <Image
                src={imagen.src}
                alt={imagen.alt}
                width={600}
                height={260}
                class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            )}

            <div class="absolute bottom-0 left-0 right-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-300 rounded-b-3xl">
              <p class="text-white text-xs font-medium px-4 py-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 leading-snug">
                {imagen.alt}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Mobile grid -- 1 col */}
    <div class="grid sm:hidden grid-cols-1 gap-4 auto-rows-[220px] stagger-children">
      {imagenes.map((imagen) => (
        <div class="h-full">
          <div class="relative w-full h-full overflow-hidden rounded-3xl group shadow-card hover:shadow-card-hover border border-warm-border/50 transition-shadow duration-300">
            {!imagen.src ? (
              <div class="absolute inset-0 bg-gradient-to-br from-placeholder to-nav-bg flex flex-col items-center justify-center gap-3">
                <svg
                  class="size-10 text-muted group-hover:text-foreground transition-colors"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
                <span class="text-muted text-xs font-medium text-center px-4 leading-snug">
                  {imagen.alt}
                </span>
              </div>
            ) : (
              <Image
                src={imagen.src}
                alt={imagen.alt}
                width={600}
                height={220}
                class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            )}

            <div class="absolute bottom-0 left-0 right-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-300 rounded-b-3xl">
              <p class="text-white text-xs font-medium px-4 py-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 leading-snug">
                {imagen.alt}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Info banner */}
    <div class="mt-10 p-5 bg-white/70 rounded-3xl border border-warm-border/50 shadow-card flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="shrink-0">
        <svg class="size-6 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
        </svg>
      </div>
      <p class="text-sm text-muted">
        Todas las imágenes corresponden a <strong class="text-foreground">proyectos reales</strong> ejecutados por nuestro equipo en viviendas y locales de Mallorca.
      </p>
    </div>

    {/* CTA */}
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-6 p-8 bg-foreground rounded-3xl">
      <div>
        <p class="font-bold text-white text-lg">
          ¿Quieres ver más proyectos?
        </p>
        <p class="text-white/60 text-sm mt-1">
          Tenemos más de 6.000 proyectos ejecutados en toda Mallorca.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0">
        <a
          href="/proyectos"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl border-2 border-white/30 hover:border-white text-white font-bold text-sm tracking-wide transition-[border-color] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-foreground"
        >
          Ver todos los proyectos
        </a>
        <a
          href="/presupuesto-pladur"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide shadow-lg shadow-accent/30 transition-[background-color] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-foreground"
        >
          Pedir presupuesto
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
