---
import { servicios, type Servicio } from '@/data/servicios'
import { localizedHref } from '@/i18n'

interface Props {
  lang?: 'es' | 'en'
  servicios?: Servicio[]
}

const { lang = 'es', servicios: serviciosProp } = Astro.props
const items = (serviciosProp ?? servicios).map((s) => ({
  ...s,
  href: localizedHref(s.href, lang),
}))
const ctaHref = localizedHref('/presupuesto-pladur', lang)

const t = lang === 'en' ? {
  eyebrow: 'What we do',
  title: 'Our Services',
  intro: 'Specialists in drywall systems (known in Spain as "pladur") for homes, commercial spaces and offices across Menorca. Professional installation, premium materials and fixed pricing.',
  ctaText: "Can't find what you're looking for?",
  ctaLink: "Tell us about your project and we'll advise you",
} : {
  eyebrow: 'Lo que hacemos',
  title: 'Nuestros Servicios',
  intro: 'Especialistas en sistemas de pladur para viviendas, locales y oficinas en toda Menorca. Instalación profesional, materiales premium y precio cerrado.',
  ctaText: '¿No encuentras lo que buscas?',
  ctaLink: 'Cuéntanos tu proyecto y te asesoramos',
}

const iconCls = 'size-6'
---

<section class="w-full py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="mb-14 lg:mb-16 max-w-2xl animate-fade-up">
      <p class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
        {t.eyebrow}
      </p>
      <h2 aria-label={t.title} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
        {t.title}
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        {t.intro}
      </p>
    </div>

    {/* Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {items.slice(0, 6).map((servicio) => (
        <a
          href={servicio.href}
          aria-label={servicio.nombre}
          class="group bg-white rounded-3xl border border-warm-border/40 p-8 flex flex-col gap-5 h-full shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300"
        >
          {/* Icon */}
          <div class="size-12 flex items-center justify-center rounded-2xl bg-foreground-dark [&_svg]:text-white">
            {servicio.icon === 'techo' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" />
              </svg>
            )}
            {servicio.icon === 'tabique' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
              </svg>
            )}
            {servicio.icon === 'acustico' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            )}
            {servicio.icon === 'termico' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
              </svg>
            )}
            {servicio.icon === 'precio' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185zM9.75 9h.008v.008H9.75V9zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 4.5h.008v.008h-.008V13.5zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
            )}
            {servicio.icon === 'escayola' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
              </svg>
            )}
            {!['techo', 'tabique', 'acustico', 'termico', 'precio', 'escayola'].includes(servicio.icon) && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
              </svg>
            )}
          </div>

          {/* Content */}
          <div class="flex flex-col gap-3 flex-1">
            <h3 aria-label={servicio.nombre} class="font-semibold text-lg text-foreground leading-snug group-hover:text-muted transition-colors">
              {servicio.nombre}
            </h3>
            <p class="text-sm text-muted leading-relaxed line-clamp-2">
              {servicio.descripcion}
            </p>
          </div>

          {/* Arrow */}
          <div class="mt-auto">
            <svg
              class="size-4 text-muted group-hover:text-foreground group-hover:translate-x-1 transition-[color,transform] duration-200"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    {/* Bottom CTA */}
    <div class="mt-12 text-center">
      <p class="text-muted mb-4">{t.ctaText}</p>
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 text-foreground font-bold border-b-2 border-warm-border pb-0.5 hover:text-muted hover:border-muted transition-colors rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
       aria-label={t.ctaLink}>
        {t.ctaLink}
        <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
