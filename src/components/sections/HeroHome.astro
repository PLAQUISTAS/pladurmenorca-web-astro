---
import { Image } from 'astro:assets'
import Button from '@/components/ui/Button.astro'
import heroImage from '@/assets/images/instaladores-pladur-menorca-hero.webp'
import { siteConfig } from '@/data/site'
import { localizedHref } from '@/i18n'

interface Props {
  lang?: 'es' | 'en'
  subtitle?: string
  ctaPrimario?: { texto: string; href: string }
  ctaSecundario?: { texto: string; href: string }
}

const { lang = 'es', subtitle: subtitleProp, ctaPrimario, ctaSecundario } = Astro.props

const ratingValue = siteConfig.aggregateRating?.ratingValue ?? siteConfig.parentCompany.rating

const t = lang === 'en' ? {
  badge: 'Drywall specialists · Menorca',
  titleLines: ['Drywall Installers', 'in Menorca'],
  defaultSubtitle: 'Leading company with 20+ years of experience. False ceilings, partitions, acoustic and thermal insulation across Menorca.',
  categories: [
    { label: 'Ceilings', href: localizedHref('/falsos-techos-pladur-menorca', lang) },
    { label: 'Partitions', href: localizedHref('/tabiques-pladur-menorca', lang) },
    { label: 'Insulation', href: localizedHref('/aislamiento-acustico-menorca', lang) },
    { label: 'Plastering', href: localizedHref('/escayola-menorca', lang) },
    { label: 'Renovations', href: localizedHref('/reformas-interiores-pladur-menorca', lang) },
  ],
  stats: [
    { value: '+6,000', label: 'Projects' },
    { value: '+20', label: 'Years exp.' },
    { value: `${ratingValue}★`, label: 'Google' },
  ],
  scroll: 'Scroll',
} : {
  badge: 'Especialistas en pladur · Menorca',
  titleLines: ['Instaladores de', 'Pladur en Menorca'],
  defaultSubtitle: 'Empresa líder con +20 años de experiencia. Falsos techos, tabiques, aislamiento acústico y térmico en toda Menorca.',
  categories: [
    { label: 'Techos', href: localizedHref('/falsos-techos-pladur-menorca', lang) },
    { label: 'Tabiques', href: localizedHref('/tabiques-pladur-menorca', lang) },
    { label: 'Aislamiento', href: localizedHref('/aislamiento-acustico-menorca', lang) },
    { label: 'Escayola', href: localizedHref('/escayola-menorca', lang) },
    { label: 'Reformas', href: localizedHref('/reformas-interiores-pladur-menorca', lang) },
  ],
  stats: [
    { value: '+6.000', label: 'Proyectos' },
    { value: '+20', label: 'Años exp.' },
    { value: `${ratingValue}★`, label: 'Google' },
  ],
  scroll: 'Scroll',
}

const ctaPrimarioHref = ctaPrimario ? localizedHref(ctaPrimario.href, lang) : undefined
const ctaSecundarioHref = ctaSecundario ? localizedHref(ctaSecundario.href, lang) : undefined

const subtitle = subtitleProp ?? t.defaultSubtitle
const titleLines = t.titleLines
const categories = t.categories
const stats = t.stats
---

<section class="w-full flex flex-col items-center overflow-hidden relative bg-hero-dark min-h-[100svh]">

  <!-- Image background -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      widths={[480, 800, 1200, 1600, 2000, 2400]}
      sizes="100vw"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      quality={72}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
  </div>

  <!-- Grain texture -->
  <div
    class="absolute inset-0 z-[1] opacity-[0.03] pointer-events-none mix-blend-overlay"
    aria-hidden="true"
    style="background-image:url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);background-repeat:repeat;background-size:128px 128px"
  ></div>

  <!-- Main content -->
  <div class="relative z-10 w-full flex-1 flex flex-col items-center justify-center px-4 sm:px-6 pt-28 md:pt-32 pb-8">

    <!-- Top badge -->
    <div class="mb-8 md:mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.08] backdrop-blur-sm border border-white/[0.08] text-white/70 text-xs font-medium tracking-wide">
        <span class="size-1.5 rounded-full bg-white/60 animate-pulse motion-reduce:animate-none"></span>
        {t.badge}
      </span>
    </div>

    <!-- Large stacked heading -->
    <h1 aria-label={titleLines.join(' ')} class="text-center w-full mb-8 md:mb-10">
      {titleLines.map((line) => (
        <span class="block text-5xl sm:text-7xl md:text-8xl lg:text-[110px] font-bold text-white leading-[0.95] tracking-tighter">
          {line}
        </span>
      ))}
    </h1>

    <!-- Subtitle -->
    {subtitle && (
      <p class="text-base sm:text-lg text-white/50 text-center leading-relaxed max-w-lg mb-8 md:mb-10 text-balance">
        {subtitle}
      </p>
    )}

    <!-- Service category pills -->
    <div class="hero-pills grid grid-cols-2 sm:flex items-center justify-center gap-2 sm:gap-3 mb-10 md:mb-12 hero-fade" style="--delay:0.8s">
      {categories.map((cat, i) => (
        <a
          href={cat.href}
          aria-label={cat.label}
          class:list={[
            'px-4 py-2 rounded-xl text-sm font-medium tracking-wide transition-colors duration-300 border text-center',
            i === 0
              ? 'hero-pill-active bg-white/15 text-white backdrop-blur-sm border-white/10'
              : 'hero-pill text-white/40 border-transparent',
          ]}
        >
          {cat.label}
        </a>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-3 hero-fade" style="--delay:0.95s">
      {ctaPrimario && ctaPrimarioHref && (
        <Button href={ctaPrimarioHref} variant="primary" size="md" withArrow ariaLabel={ctaPrimario.texto} class="shadow-accent-glow">
          {ctaPrimario.texto}
        </Button>
      )}

      {ctaSecundario && ctaSecundarioHref && (
        <Button href={ctaSecundarioHref} variant="ghost-dark" size="md" ariaLabel={ctaSecundario.texto}>
          {ctaSecundario.texto}
        </Button>
      )}
    </div>
  </div>

  <!-- Bottom trust strip -->
  <div class="relative z-10 w-full border-t border-white/[0.06] hero-fade" style="--delay:1.2s">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between">
      <div class="flex items-center gap-6 sm:gap-10">
        {stats.map((stat) => (
          <div class="flex items-baseline gap-1.5">
            <span class="text-white font-bold text-sm sm:text-base tabular-nums">{stat.value}</span>
            <span class="text-white/30 text-xs font-medium hidden sm:inline">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-white/25 text-xs font-medium tracking-wide">{t.scroll}</span>
        <div class="w-[1.5px] h-8 rounded-full bg-white/10 relative overflow-hidden">
          <div class="w-full h-3 bg-white/40 rounded-full hero-scroll-dot"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.6s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-scroll-dot {
    animation: heroScrollDot 2s ease-in-out infinite;
  }

  @keyframes heroScrollDot {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(20px); }
  }

  .hero-pills:hover .hero-pill-active:not(:hover) {
    background: transparent;
    color: rgb(255 255 255 / 0.4);
    backdrop-filter: none;
    border-color: transparent;
  }
  .hero-pills a:hover {
    background: rgb(255 255 255 / 0.15);
    color: white;
    backdrop-filter: blur(4px);
    border-color: rgb(255 255 255 / 0.1);
  }
  .hero-pill:not(:hover) {
    color: rgb(255 255 255 / 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-scroll-dot {
      animation: none;
    }
  }
</style>
