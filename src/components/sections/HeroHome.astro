---
interface Props {
  subtitle?: string
  ctaPrimario?: { texto: string; href: string }
  ctaSecundario?: { texto: string; href: string }
}

const { subtitle: subtitleProp, ctaPrimario, ctaSecundario } = Astro.props

const categories = [
  { label: 'Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento', href: '/aislamiento-acustico-mallorca' },
  { label: 'Escayola', href: '/escayola-mallorca' },
  { label: 'Reformas', href: '/reformas-interiores-pladur-mallorca' },
]

import { siteConfig } from '@/data/site'

const titleLines = ['Instaladores de', 'Pladur en Mallorca']
const defaultSubtitle = 'Empresa líder con +20 años de experiencia. Falsos techos, tabiques, aislamiento acústico y térmico en toda Mallorca.'
const subtitle = subtitleProp ?? defaultSubtitle

const stats = [
  { value: '+6.000', label: 'Proyectos' },
  { value: '+20', label: 'Años exp.' },
  { value: `${siteConfig.aggregateRating.ratingValue}★`, label: 'Google' },
]
---

<section class="w-full flex flex-col items-center overflow-hidden relative bg-hero-dark min-h-[100svh]">

  <!-- Video background -->
  <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
      style="width:max(100%,177.78vh);height:max(100%,56.25vw);object-fit:cover"
      title="Pladur Mallorca — Instaladores de pladur en Mallorca"
    >
      <source src="/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
  </div>

  <!-- Grain texture -->
  <div
    class="absolute inset-0 z-[1] opacity-[0.03] pointer-events-none mix-blend-overlay"
    aria-hidden="true"
    style="background-image:url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;);background-repeat:repeat;background-size:128px 128px"
  ></div>

  <!-- Main content -->
  <div class="relative z-10 w-full flex-1 flex flex-col items-center justify-center px-4 sm:px-6 pt-28 md:pt-32 pb-8">

    <!-- Top badge -->
    <div class="mb-8 md:mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.08] backdrop-blur-sm border border-white/[0.08] text-white/70 text-xs font-medium tracking-wide">
        <span class="size-1.5 rounded-full bg-white/60 animate-pulse motion-reduce:animate-none"></span>
        Especialistas en pladur · Mallorca
      </span>
    </div>

    <!-- Large stacked heading — no opacity animation so it counts as LCP -->
    <h1 class="text-center w-full mb-8 md:mb-10">
      {titleLines.map((line) => (
        <span class="block text-5xl sm:text-7xl md:text-8xl lg:text-[110px] font-bold text-white leading-[0.95] tracking-tighter">
          {line}
        </span>
      ))}
    </h1>

    <!-- Subtitle — immediately visible for LCP -->
    {subtitle && (
      <p class="text-base sm:text-lg text-white/50 text-center leading-relaxed max-w-lg mb-8 md:mb-10 text-balance">
        {subtitle}
      </p>
    )}

    <!-- Service category pills -->
    <div class="hero-pills grid grid-cols-2 sm:flex items-center justify-center gap-2 sm:gap-3 mb-10 md:mb-12 hero-fade" style="--delay:0.8s">
      {categories.map((cat, i) => (
        <a
          href={cat.href}
          class:list={[
            'px-4 py-2 rounded-xl text-sm font-medium tracking-wide transition-colors duration-300 border text-center',
            i === 0
              ? 'hero-pill-active bg-white/15 text-white backdrop-blur-sm border-white/10'
              : 'hero-pill text-white/40 border-transparent',
          ]}
        >
          {cat.label}
        </a>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-3 hero-fade" style="--delay:0.95s">
      {ctaPrimario && (
        <a
          href={ctaPrimario.href}
          class="group inline-flex items-center gap-2.5 bg-accent hover:bg-accent-600 text-white px-7 py-3.5 rounded-xl text-sm font-bold tracking-wide transition-[background-color,box-shadow,transform] duration-200 ease-out active:scale-[0.97] shadow-accent-glow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-hero-dark"
        >
          {ctaPrimario.texto}
          <svg class="size-4 opacity-60 group-hover:translate-x-0.5 transition-transform duration-200" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" />
          </svg>
        </a>
      )}

      {ctaSecundario && (
        <a
          href={ctaSecundario.href}
          class="inline-flex items-center gap-2 bg-white/[0.06] hover:bg-white/[0.12] backdrop-blur-sm text-white px-7 py-3.5 rounded-xl text-sm font-bold tracking-wide transition-[background-color,border-color,transform] duration-200 ease-out active:scale-[0.97] border border-white/10 hover:border-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60 focus-visible:ring-offset-2 focus-visible:ring-offset-hero-dark"
        >
          {ctaSecundario.texto}
        </a>
      )}
    </div>
  </div>

  <!-- Bottom trust strip -->
  <div class="relative z-10 w-full border-t border-white/[0.06] hero-fade" style="--delay:1.2s">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex items-center justify-between">
      <div class="flex items-center gap-6 sm:gap-10">
        {stats.map((stat) => (
          <div class="flex items-baseline gap-1.5">
            <span class="text-white font-bold text-sm sm:text-base tabular-nums">{stat.value}</span>
            <span class="text-white/30 text-xs font-medium hidden sm:inline">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="hidden md:flex items-center gap-3">
        <span class="text-white/25 text-xs font-medium tracking-wide">Scroll</span>
        <div class="w-[1.5px] h-8 rounded-full bg-white/10 relative overflow-hidden">
          <div class="w-full h-3 bg-white/40 rounded-full hero-scroll-dot"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.6s ease-out forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-scroll-dot {
    animation: heroScrollDot 2s ease-in-out infinite;
  }

  @keyframes heroScrollDot {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(20px); }
  }

  /* Category pills: first pill active by default, hover overrides */
  .hero-pills:hover .hero-pill-active:not(:hover) {
    background: transparent;
    color: rgb(255 255 255 / 0.4);
    backdrop-filter: none;
    border-color: transparent;
  }
  .hero-pills a:hover {
    background: rgb(255 255 255 / 0.15);
    color: white;
    backdrop-filter: blur(4px);
    border-color: rgb(255 255 255 / 0.1);
  }
  .hero-pill:not(:hover) {
    color: rgb(255 255 255 / 0.4);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-scroll-dot {
      animation: none;
    }
  }
</style>


