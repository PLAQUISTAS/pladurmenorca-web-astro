---
import Button from '@/components/ui/Button.astro'
import { localizedHref } from '@/i18n'

interface Diferenciador {
  titulo: string
  descripcion: string
  icon: string
}

interface Props {
  lang?: 'es' | 'en'
  items?: Diferenciador[]
}

const { lang = 'es', items: itemsProp } = Astro.props

const defaultItemsEs: Diferenciador[] = [
  { titulo: '+20 años de experiencia', descripcion: 'En Menorca desde 2004. Conocemos cada tipología de edificio de la isla, desde pisos históricos en el centro de Maó hasta villas de lujo en Ciutadella.', icon: 'experiencia' },
  { titulo: 'Presupuesto en 24h', descripcion: 'Visita técnica sin compromiso. Medimos in situ y enviamos el presupuesto detallado en menos de 24 horas.', icon: 'reloj' },
  { titulo: 'Precio cerrado', descripcion: 'Sin sorpresas en la factura final. El precio acordado es el precio que pagas. Cualquier cambio se acuerda por escrito antes de ejecutarse.', icon: 'precio' },
  { titulo: 'Materiales premium', descripcion: 'Trabajamos exclusivamente con Placo, Knauf y Lafarge. Marcas líderes con garantía del fabricante en todos los materiales instalados.', icon: 'materiales' },
  { titulo: 'Obra limpia', descripcion: 'Sin escombros, mínima molestia para ti y tus vecinos. El pladur es un sistema en seco que genera un 80% menos de residuos que la obra tradicional.', icon: 'limpieza' },
  { titulo: 'Garantía 1 año', descripcion: 'En toda la mano de obra. Si surge cualquier incidencia durante ese período, la resolvemos sin coste adicional. Tu tranquilidad es nuestra prioridad.', icon: 'garantia' },
]

const defaultItemsEn: Diferenciador[] = [
  { titulo: '20+ years of experience', descripcion: 'Operating in Menorca since 2004. We know every building type on the island, from historic apartments in central Maó to luxury villas in Ciutadella.', icon: 'experiencia' },
  { titulo: 'Quote within 24 hours', descripcion: 'On-site technical visit with no obligation. We measure in person and send a detailed quote in under 24 hours.', icon: 'reloj' },
  { titulo: 'Fixed-price contracts', descripcion: 'No surprises on the final invoice. The agreed price is the price you pay. Any change is approved in writing before execution.', icon: 'precio' },
  { titulo: 'Premium materials', descripcion: 'We work exclusively with Placo, Knauf and Lafarge. Leading brands with manufacturer warranty on every material installed.', icon: 'materiales' },
  { titulo: 'Clean job site', descripcion: 'No rubble, minimal disruption for you and your neighbours. Drywall is a dry-build system that generates 80% less waste than traditional works.', icon: 'limpieza' },
  { titulo: '1-year warranty', descripcion: 'Full workmanship warranty. Any incident during the warranty period is fixed at no additional cost. Your peace of mind is our priority.', icon: 'garantia' },
]

const t = lang === 'en' ? {
  eyebrow: 'What makes us different',
  title: 'Why choose us?',
  intro: 'Not a generic renovation company. Drywall specialists exclusively — with more than two decades installing across the Balearic Islands.',
  statsProjects: 'projects delivered',
  statsYears: 'years in Menorca',
  statsRating: 'average rating',
  ctaLabel: 'Request a free quote',
} : {
  eyebrow: 'Nuestra diferencia',
  title: '¿Por qué elegirnos?',
  intro: 'No somos una empresa genérica de reformas. Somos especialistas exclusivamente en sistemas de pladur, con más de dos décadas instalando en Menorca.',
  statsProjects: 'proyectos completados',
  statsYears: 'años en Menorca',
  statsRating: 'valoración media',
  ctaLabel: 'Solicitar presupuesto gratis',
}

const items = itemsProp ?? (lang === 'en' ? defaultItemsEn : defaultItemsEs)
const ctaHref = localizedHref('/presupuesto-pladur', lang)

const iconCls = 'size-5'
---

<section class="w-full py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="mb-14 lg:mb-16 max-w-2xl animate-fade-up">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
        {t.eyebrow}
      </span>
      <h2 aria-label={t.title} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
        {t.title}
      </h2>
      <p class="text-lg text-muted leading-relaxed">
        {t.intro}
      </p>
    </div>

    {/* Features grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {items.map((item) => (
        <dl class="group bg-white rounded-3xl border border-warm-border/40 p-8 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default h-full">

          {/* Icon */}
          <div class="mb-5 flex size-11 items-center justify-center rounded-xl bg-surface border border-nav-border [&_svg]:text-foreground" aria-hidden="true">
            {item.icon === 'experiencia' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            )}
            {item.icon === 'reloj' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {item.icon === 'precio' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185z" />
              </svg>
            )}
            {item.icon === 'materiales' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
              </svg>
            )}
            {item.icon === 'limpieza' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
              </svg>
            )}
            {item.icon === 'garantia' && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            )}
            {!['experiencia', 'reloj', 'precio', 'materiales', 'limpieza', 'garantia'].includes(item.icon) && (
              <svg class={iconCls} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            )}
          </div>

          {/* Content */}
          <dt class="font-bold text-lg text-foreground leading-snug mb-2">
            {item.titulo}
          </dt>
          <dd class="text-sm text-muted leading-relaxed">
            {item.descripcion}
          </dd>
        </dl>
      ))}
    </div>

    {/* Trust bar */}
    <div class="mt-16 sm:mt-20">
      <div class="rounded-3xl bg-white border border-warm-border/40 shadow-card p-8 lg:p-10 animate-fade-up">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8">

          {/* Stats grid */}
          <div class="grid grid-cols-3 gap-6 lg:gap-10 flex-1 w-full lg:w-auto">
            <div class="text-center">
              <div class="text-3xl lg:text-4xl font-bold text-foreground-dark tabular-nums">{lang === 'en' ? '+6,000' : '+6.000'}</div>
              <div class="text-sm text-muted mt-1">{t.statsProjects}</div>
            </div>
            <div class="text-center relative">
              <div class="hidden lg:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-12 bg-warm-border" />
              <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-px h-12 bg-warm-border" />
              <div class="text-3xl lg:text-4xl font-bold text-foreground-dark tabular-nums">+20</div>
              <div class="text-sm text-muted mt-1">{t.statsYears}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl lg:text-4xl font-bold text-foreground-dark tabular-nums">4.7<span class="text-muted text-2xl">/5</span></div>
              <div class="text-sm text-muted mt-1">{t.statsRating}</div>
            </div>
          </div>

          {/* CTA */}
          <Button href={ctaHref} variant="primary" size="lg" withArrow class="shrink-0">
            {t.ctaLabel}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
