---
interface Props {
  articulos: { slug: string; titulo: string; descripcion: string }[]
}

const { articulos } = Astro.props
---

{articulos.length > 0 && (
  <section class="w-full py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-3">
          Blog
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground">
          Artículos relacionados
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {articulos.map((a) => (
          <a
            href={`/blog/${a.slug}`}
            class="group bg-white rounded-2xl border border-warm-border p-6 shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 transition-[box-shadow,transform] duration-300"
          >
            <h3 class="text-base font-bold text-foreground group-hover:text-accent transition-colors duration-200 mb-2 leading-snug">
              {a.titulo}
            </h3>
            <p class="text-sm text-muted leading-relaxed line-clamp-2">
              {a.descripcion}
            </p>
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-accent mt-4">
              Leer artículo
              <svg class="size-3 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
