---
import { testimonios as defaultTestimonios, type Testimonio } from '@/data/testimonios'
import { siteConfig } from '@/data/site'
import GoogleRatingBadge from '@/components/ui/GoogleRatingBadge.astro'
import TestimonioCard from '@/components/ui/TestimonioCard.astro'
import Button from '@/components/ui/Button.astro'
import { localizedHref } from '@/i18n'

interface Props {
  lang?: 'es' | 'en'
  testimonios?: Testimonio[]
}

const { lang = 'es', testimonios: testimoniosProp } = Astro.props
const items = testimoniosProp ?? defaultTestimonios
const ctaHref = localizedHref('/presupuesto-pladur', lang)

const t = lang === 'en' ? {
  eyebrow: 'Happy clients',
  title: 'What our clients say',
  verifiedReviews: 'Verified Google reviews',
  leaveReview: 'Leave us a Google review',
  ctaLabel: 'Request a free quote',
} : {
  eyebrow: 'Clientes satisfechos',
  title: 'Lo que dicen nuestros clientes',
  verifiedReviews: 'Reseñas verificadas en Google',
  leaveReview: 'Déjanos tu reseña en Google',
  ctaLabel: 'Pide presupuesto gratis',
}
---

<section class="w-full py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="mb-14 lg:mb-16 animate-fade-up">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div class="max-w-xl">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            {t.eyebrow}
          </span>
          <h2 aria-label={t.title} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
            {t.title}
          </h2>
        </div>

        {/* Aggregate rating */}
        <div class="flex items-center gap-4 lg:flex-col lg:items-end">
          <GoogleRatingBadge variant="inline" />
          <div class="flex items-center gap-1.5">
            <svg class="size-4 text-foreground" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-muted font-medium">{t.verifiedReviews}</span>
          </div>
        </div>
      </div>
    </div>

    {/* Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
      {items.map((testimonio) => (
        <TestimonioCard testimonio={testimonio} />
      ))}
    </div>

    {/* Bottom CTA */}
    <div class="mt-12">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        {siteConfig.googleReviewsUrl && (
          <a
            href={siteConfig.googleReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-white border-2 border-warm-border hover:border-google hover:shadow-google text-foreground font-bold text-base tracking-wide transition-[border-color,box-shadow,transform] duration-300 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-google focus-visible:ring-offset-2"
           aria-label={t.leaveReview}>
            <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            {t.leaveReview}
            <svg class="size-4 text-muted group-hover:text-google group-hover:translate-x-0.5 transition-[color,transform]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        )}
        <Button href={ctaHref} variant="primary" size="lg" withArrow>
          {t.ctaLabel}
        </Button>
      </div>
    </div>
  </div>
</section>
