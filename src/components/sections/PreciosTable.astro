---
import { preciosResumen, preciosCategorias } from '@/data/precios'
import Button from '@/components/ui/Button.astro'
import { localizedHref } from '@/i18n'

interface Props {
  lang?: 'es' | 'en'
  variant?: string
  hideHeader?: boolean
}

const { lang = 'es', variant = 'resumen', hideHeader = false } = Astro.props

const isResumen = variant === 'resumen'

const categoriaData = !isResumen
  ? preciosCategorias.find(
      (c) =>
        c.categoria.toLowerCase().replace(/\s+/g, '-') === variant ||
        c.categoria === variant
    )
  : null

const titulosH2Es: Record<string, string> = {
  'resumen': 'Precios pladur Menorca 2026',
  'Falsos Techos': 'Precio falsos techos pladur 2026',
  'Tabiques y Particiones': 'Precio tabiques pladur 2026',
  'Aislamiento Acústico': 'Precio aislamiento acústico 2026',
  'Aislamiento Térmico': 'Precio aislamiento térmico 2026',
}

const titulosH2En: Record<string, string> = {
  'resumen': 'Drywall prices in Menorca 2026',
  'Falsos Techos': 'Suspended ceiling prices 2026',
  'Tabiques y Particiones': 'Drywall partition prices 2026',
  'Aislamiento Acústico': 'Acoustic insulation prices 2026',
  'Aislamiento Térmico': 'Thermal insulation prices 2026',
}

const titulosH2 = lang === 'en' ? titulosH2En : titulosH2Es
const fallbackTitle = lang === 'en' ? `${variant} price 2026` : `Precio ${variant.toLowerCase()} 2026`
const tituloH2 = titulosH2[variant] ?? titulosH2[categoriaData?.categoria ?? ''] ?? fallbackTitle

const items = isResumen ? null : categoriaData?.items ?? []
const presupuestoHref = localizedHref('/presupuesto-pladur', lang)

const t = lang === 'en' ? {
  eyebrow: 'Updated pricing 2026',
  introResumen: 'Indicative price guide by service type. Exact quote after the on-site visit.',
  introFallback: 'Pricing per service. Free consultation with no obligation.',
  noteStrong: 'Materials + labour included.',
  noteMuted: ' VAT not included (21%). Indicative 2026 pricing; final price depends on surface area, access and complexity.',
  thService: 'Service',
  thFrom: 'Price from',
  thUpTo: 'Up to',
  thUnit: 'Unit',
  thIncludes: 'Includes',
  labelFrom: 'From',
  footerTitle: 'Want to know the exact price of your project?',
  footerSub: "You'll receive a detailed quote within 24-48 hours of the site visit.",
  footerCta: 'Get your exact quote',
} : {
  eyebrow: 'Tarifas actualizadas 2026',
  introResumen: 'Guía orientativa por tipo de servicio. El presupuesto exacto lo recibirás tras la visita técnica.',
  introFallback: 'Precios por servicio. Consulta gratuita y sin compromiso.',
  noteStrong: 'Materiales + mano de obra incluidos.',
  noteMuted: ' IVA no incluido (21%). Precio orientativo 2026; el definitivo depende de superficie, acceso y complejidad.',
  thService: 'Servicio',
  thFrom: 'Precio desde',
  thUpTo: 'Hasta',
  thUnit: 'Unidad',
  thIncludes: 'Incluye',
  labelFrom: 'Desde',
  footerTitle: '¿Quieres saber el precio exacto de tu proyecto?',
  footerSub: 'Recibirás el presupuesto detallado en 24-48 horas tras la visita técnica.',
  footerCta: 'Pide tu presupuesto exacto',
}

const intro = isResumen ? t.introResumen : (categoriaData?.descripcion ?? t.introFallback)
---

<section class:list={[hideHeader ? 'w-full' : 'w-full py-20 lg:py-28']}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {!hideHeader && (
      <div class="mb-10 lg:mb-14 max-w-2xl">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.eyebrow}
        </span>
        <h2 aria-label={tituloH2} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
          {tituloH2}
        </h2>
        <p class="text-lg text-muted leading-relaxed">
          {intro}
        </p>
      </div>
    )}

    {/* Note pill */}
    <div class="flex items-start gap-3 p-4 bg-white/60 border border-warm-border/50 rounded-2xl mb-6 backdrop-blur-sm">
      <svg aria-hidden="true" class="size-5 text-foreground-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
      </svg>
      <p class="text-sm text-foreground leading-relaxed">
        <strong>{t.noteStrong}</strong>
        <span class="text-muted">{t.noteMuted}</span>
      </p>
    </div>

    {/* ═══ Desktop table ═══ */}
    <div class="hidden md:block">
      <div class="rounded-3xl border border-warm-border/80 bg-white/60 shadow-card overflow-hidden backdrop-blur-sm">
        <table class="w-full">
          <thead>
            <tr class="bg-foreground-dark">
              <th class="px-6 py-4 text-left text-[11px] font-bold text-white/90 uppercase tracking-[0.08em]">{t.thService}</th>
              <th class="px-6 py-4 text-left text-[11px] font-bold text-white/90 uppercase tracking-[0.08em] whitespace-nowrap">{t.thFrom}</th>
              {!isResumen && (
                <th class="px-6 py-4 text-left text-[11px] font-bold text-white/90 uppercase tracking-[0.08em] whitespace-nowrap">{t.thUpTo}</th>
              )}
              <th class="px-6 py-4 text-left text-[11px] font-bold text-white/90 uppercase tracking-[0.08em] whitespace-nowrap">{t.thUnit}</th>
              {!isResumen && (
                <th class="px-6 py-4 text-left text-[11px] font-bold text-white/90 uppercase tracking-[0.08em]">{t.thIncludes}</th>
              )}
            </tr>
          </thead>
          <tbody>
            {isResumen
              ? preciosResumen.map((item, i) => (
                  <tr class={`border-t border-warm-border/50 transition-colors duration-200 hover:bg-surface/40 ${i % 2 === 0 ? 'bg-white/40' : 'bg-transparent'}`}>
                    <td class="px-6 py-5">
                      <div class="font-semibold text-foreground">{item.servicio}</div>
                    </td>
                    <td class="px-6 py-5">
                      <div class="flex items-baseline gap-1">
                        <span class="text-[11px] font-medium text-muted uppercase tracking-wider mr-1">{t.labelFrom}</span>
                        <span class="text-2xl font-bold text-foreground tabular-nums">{item.desde}</span>
                        <span class="text-lg font-bold text-foreground">€</span>
                      </div>
                    </td>
                    <td class="px-6 py-5 text-sm text-muted whitespace-nowrap">{item.unidad}</td>
                  </tr>
                ))
              : items?.map((item, i) => (
                  <tr class={`border-t border-warm-border/50 transition-colors duration-200 hover:bg-surface/40 ${i % 2 === 0 ? 'bg-white/40' : 'bg-transparent'}`}>
                    <td class="px-6 py-5 align-top max-w-xs">
                      <div class="font-semibold text-foreground leading-snug">{item.servicio}</div>
                      <div class="text-xs text-muted font-normal mt-1 leading-relaxed">{item.descripcion}</div>
                    </td>
                    <td class="px-6 py-5 align-top whitespace-nowrap">
                      <div class="flex items-baseline gap-1">
                        <span class="text-2xl font-bold text-foreground tabular-nums">{item.precioMin}</span>
                        <span class="text-lg font-bold text-foreground">€</span>
                      </div>
                    </td>
                    <td class="px-6 py-5 align-top whitespace-nowrap">
                      <div class="flex items-baseline gap-1 text-muted">
                        <span class="text-base font-semibold tabular-nums">{item.precioMax}</span>
                        <span class="text-sm font-semibold">€</span>
                      </div>
                    </td>
                    <td class="px-6 py-5 align-top text-sm text-muted whitespace-nowrap">{item.unidad}</td>
                    <td class="px-6 py-5 align-top">
                      <div class="flex flex-wrap gap-1.5 max-w-md">
                        {item.incluye.map((inc) => (
                          <span class="inline-flex items-center gap-1 text-[11px] px-2 py-0.5 rounded-lg bg-surface/80 text-foreground font-medium border border-warm-border/40">
                            <svg aria-hidden="true" class="size-3 text-foreground-dark shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                            {inc}
                          </span>
                        ))}
                      </div>
                    </td>
                  </tr>
                ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* ═══ Mobile cards ═══ */}
    <div class="md:hidden space-y-3">
      {isResumen
        ? preciosResumen.map((item) => (
            <article class="rounded-2xl border border-warm-border/60 bg-white/70 shadow-card p-5 backdrop-blur-sm">
              <div class="flex items-start justify-between gap-4">
                <h3 aria-label={item.servicio} class="font-semibold text-foreground text-base leading-snug flex-1">{item.servicio}</h3>
              </div>
              <div class="mt-4 flex items-baseline justify-between border-t border-warm-border/40 pt-4">
                <div class="flex items-baseline gap-1">
                  <span class="text-[11px] font-semibold text-muted uppercase tracking-wider mr-1">{t.labelFrom}</span>
                  <span class="text-3xl font-bold text-foreground tabular-nums">{item.desde}</span>
                  <span class="text-xl font-bold text-foreground">€</span>
                </div>
                <span class="text-xs text-muted font-medium">{item.unidad}</span>
              </div>
            </article>
          ))
        : items?.map((item) => (
            <article class="rounded-2xl border border-warm-border/60 bg-white/70 shadow-card p-5 backdrop-blur-sm">
              <h3 aria-label={item.servicio} class="font-semibold text-foreground text-base leading-snug">{item.servicio}</h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">{item.descripcion}</p>

              <div class="mt-4 flex items-end justify-between gap-3 border-y border-warm-border/40 py-4">
                <div>
                  <span class="block text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">{t.labelFrom}</span>
                  <div class="flex items-baseline gap-0.5">
                    <span class="text-3xl font-bold text-foreground tabular-nums leading-none">{item.precioMin}</span>
                    <span class="text-xl font-bold text-foreground leading-none">€</span>
                  </div>
                </div>
                <div class="text-right">
                  <span class="block text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">{t.thUpTo}</span>
                  <div class="flex items-baseline gap-0.5 justify-end text-muted">
                    <span class="text-lg font-semibold tabular-nums leading-none">{item.precioMax}</span>
                    <span class="text-sm font-semibold leading-none">€</span>
                  </div>
                </div>
                <div class="text-right">
                  <span class="block text-[10px] font-semibold text-muted uppercase tracking-wider mb-0.5">{t.thUnit}</span>
                  <span class="text-sm font-semibold text-foreground">{item.unidad}</span>
                </div>
              </div>

              <div class="mt-4 flex flex-wrap gap-1.5">
                {item.incluye.map((inc) => (
                  <span class="inline-flex items-center gap-1 text-[11px] px-2 py-1 rounded-lg bg-surface/80 text-foreground font-medium border border-warm-border/40">
                    <svg aria-hidden="true" class="size-3 text-foreground-dark shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                    {inc}
                  </span>
                ))}
              </div>
            </article>
          ))}
    </div>

    {/* Footer CTA */}
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-6 p-6 sm:p-8 bg-gradient-to-br from-white/80 to-white/60 rounded-3xl border border-warm-border/50 shadow-card backdrop-blur-sm">
      <div class="text-center sm:text-left">
        <p class="font-bold text-foreground text-lg">
          {t.footerTitle}
        </p>
        <p class="text-muted text-sm mt-1">
          {t.footerSub}
        </p>
      </div>
      <Button href={presupuestoHref} variant="primary" size="lg" withArrow class="whitespace-nowrap shrink-0">
        {t.footerCta}
      </Button>
    </div>
  </div>
</section>
