---
import Button from '@/components/ui/Button.astro'

interface CtaLink {
  texto: string
  href: string
}

interface Props {
  title: string
  subtitle?: string
  description?: string
  ctaPrimario?: CtaLink
  ctaSecundario?: CtaLink
  badges?: string[]
  dark?: boolean
}

const {
  title,
  subtitle,
  description,
  ctaPrimario,
  ctaSecundario,
  badges,
} = Astro.props

const isTel = ctaSecundario?.href.startsWith('tel:') ?? false
---

<section class="pt-24 pb-20 lg:pt-32 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 shadow-warm">
      <div class="relative max-w-4xl mx-auto text-center">
        {badges && badges.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2 mb-6">
            {badges.map((badge) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-warm-200 text-foreground border border-warm-border/60">
                {badge}
              </span>
            ))}
          </div>
        )}

        <h1 aria-label={title} class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
          {title}
        </h1>

        {(description || subtitle) && (
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto mb-8">
            {description || subtitle}
          </p>
        )}

        {(ctaPrimario || ctaSecundario) && (
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            {ctaPrimario && (
              <Button href={ctaPrimario.href} variant="primary" size="lg" withArrow>
                {ctaPrimario.texto}
              </Button>
            )}
            {ctaSecundario && (
              <Button href={ctaSecundario.href} variant="secondary" size="lg">
                {isTel && (
                  <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                )}
                {ctaSecundario.texto}
              </Button>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
