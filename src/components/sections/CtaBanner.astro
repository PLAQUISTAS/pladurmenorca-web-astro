---
import FormContactoRapido from '@/components/forms/FormContactoRapido'
import GoogleRatingBadge from '@/components/ui/GoogleRatingBadge.astro'
import CtaButtons from '@/components/ui/CtaButtons.astro'

interface Props {
  lang?: 'es' | 'en'
  titulo?: string
  subtitulo?: string
  showForm?: boolean
  dark?: boolean
}

const {
  lang = 'es',
  titulo: tituloProp,
  subtitulo: subtituloProp,
  showForm = false,
} = Astro.props

const t = lang === 'en' ? {
  defaultTitulo: 'Ready to start your project?',
  defaultSubtitulo: 'Free quote within 24 hours. No obligation.',
  quickContact: 'Quick contact',
  startToday: 'Start today',
  trustItems: [
    'On-site visit across Menorca',
    'Detailed quote within 24-48 hours',
    'Fixed price, no surprises',
    '1-year workmanship warranty',
  ],
  formTitle: 'Tell us about your project',
  formSubtitle: "We'll call you to schedule the site visit.",
  ctaPrimary: 'Request a free quote',
  socialProof1: '6,000+ projects in Menorca',
  socialProof2: 'Since 2004',
} : {
  defaultTitulo: '¿Listo para tu proyecto?',
  defaultSubtitulo: 'Presupuesto gratuito en 24 horas. Sin compromiso.',
  quickContact: 'Contacto rápido',
  startToday: 'Empieza hoy',
  trustItems: [
    'Visita técnica en toda Menorca',
    'Presupuesto detallado en 24-48 horas',
    'Precio cerrado, sin sorpresas',
    'Garantía de 1 año en mano de obra',
  ],
  formTitle: 'Cuéntanos tu proyecto',
  formSubtitle: 'Te llamamos nosotros para concertar la visita.',
  ctaPrimary: 'Pide presupuesto gratis',
  socialProof1: '+6.000 proyectos en Menorca',
  socialProof2: 'Desde 2004',
}

const titulo = tituloProp ?? t.defaultTitulo
const subtitulo = subtituloProp ?? t.defaultSubtitulo
---

<section class="w-full py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/70 border border-warm-border/50 rounded-3xl py-16 lg:py-24 px-6 sm:px-10 lg:px-16 shadow-warm animate-fade-up">
      <div>
    {showForm ? (
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
          {/* Left: copy */}
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              {t.quickContact}
            </p>
            <h2 aria-label={titulo} class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
              {titulo}
            </h2>
            <p class="text-xl text-muted leading-relaxed">
              {subtitulo}
            </p>

            {/* Trust signals */}
            <div class="mt-8 flex flex-col gap-3">
              {t.trustItems.map((item) => (
                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                    <svg class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-foreground text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Right: form */}
          <div class="bg-white/50 border border-warm-border/60 p-8 rounded-2xl backdrop-blur-sm">
            <h3 aria-label={t.formTitle} class="font-bold text-foreground text-lg mb-1">{t.formTitle}</h3>
            <p class="text-muted text-sm">{t.formSubtitle}</p>
            <FormContactoRapido client:visible className="mt-4" />
          </div>
        </div>
      </div>
    ) : (
      <div>
        <div class="flex flex-col items-center text-center gap-8">
          <div class="max-w-2xl">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              {t.startToday}
            </p>
            <h2 aria-label={titulo} class="text-3xl sm:text-4xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-4">
              {titulo}
            </h2>
            <p class="text-xl text-muted leading-relaxed">
              {subtitulo}
            </p>
          </div>

          <CtaButtons primaryText={t.ctaPrimary} />

          {/* Social proof */}
          <div class="flex flex-wrap items-center justify-center gap-6 pt-4 border-t border-warm-border w-full max-w-lg">
            <GoogleRatingBadge variant="compact" />
            <span class="text-warm-border">&middot;</span>
            <span class="text-muted text-xs">{t.socialProof1}</span>
            <span class="text-warm-border">&middot;</span>
            <span class="text-muted text-xs">{t.socialProof2}</span>
          </div>
        </div>
      </div>
    )}
      </div>
    </div>
  </div>
</section>
