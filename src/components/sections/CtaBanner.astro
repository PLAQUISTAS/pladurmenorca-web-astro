---
import { siteConfig } from '@/data/site'
import FormContactoRapido from '@/components/forms/FormContactoRapido'
import GoogleRatingBadge from '@/components/ui/GoogleRatingBadge.astro'

interface Props {
  titulo?: string
  subtitulo?: string
  showForm?: boolean
  dark?: boolean
}

const {
  titulo = '¿Listo para tu proyecto?',
  subtitulo = 'Presupuesto gratuito en 24 horas. Sin compromiso.',
  showForm = false,
} = Astro.props
---

<section class="w-full py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white/70 border border-warm-border/50 rounded-3xl py-16 lg:py-24 px-6 sm:px-10 lg:px-16 shadow-warm animate-fade-up">
      <div>
    {showForm ? (
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
          {/* Left: copy */}
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              Contacto rápido
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
              {titulo}
            </h2>
            <p class="text-xl text-muted leading-relaxed">
              {subtitulo}
            </p>

            {/* Trust signals */}
            <div class="mt-8 flex flex-col gap-3">
              {[
                'Visita técnica gratuita en toda Mallorca',
                'Presupuesto detallado en 24-48 horas',
                'Precio cerrado, sin sorpresas',
                'Garantía de 2 años en mano de obra',
              ].map((item) => (
                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                    <svg class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-foreground text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Right: form */}
          <div class="bg-white/50 border border-warm-border/60 p-8 rounded-2xl backdrop-blur-sm">
            <h3 class="font-bold text-foreground text-lg mb-1">Cuéntanos tu proyecto</h3>
            <p class="text-muted text-sm">Te llamamos nosotros para concertar la visita.</p>
            <FormContactoRapido client:visible className="mt-4" />
          </div>
        </div>
      </div>
    ) : (
      <div>
        <div class="flex flex-col items-center text-center gap-8">
          <div class="max-w-2xl">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              Empieza hoy
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-4">
              {titulo}
            </h2>
            <p class="text-xl text-muted leading-relaxed">
              {subtitulo}
            </p>
          </div>

          {/* Action buttons */}
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <a
              href="/presupuesto-pladur"
              class="inline-flex items-center gap-2 px-10 py-4 bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide transition-[background-color,box-shadow] duration-200 active:scale-95 rounded-xl shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            >
              Pide presupuesto gratis
              <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>

            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="inline-flex items-center gap-2 px-10 py-4 border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-[background-color,border-color,color,transform] duration-200 active:scale-95 rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Llámanos: {siteConfig.phone}
            </a>

            <a
              href={`https://wa.me/${siteConfig.whatsapp}?text=${siteConfig.whatsappText}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 bg-warm-200 hover:bg-warm-border-light text-foreground font-bold text-base tracking-wide transition-[background-color,transform] duration-200 active:scale-95 rounded-xl border border-warm-border/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp
            </a>
          </div>

          {/* Social proof */}
          <div class="flex flex-wrap items-center justify-center gap-6 pt-4 border-t border-warm-border w-full max-w-lg">
            <GoogleRatingBadge variant="compact" />
            <span class="text-warm-border">&middot;</span>
            <span class="text-muted text-xs">+6.000 proyectos en Mallorca</span>
            <span class="text-warm-border">&middot;</span>
            <span class="text-muted text-xs">Desde 2004</span>
          </div>
        </div>
      </div>
    )}
      </div>
    </div>
  </div>
</section>
