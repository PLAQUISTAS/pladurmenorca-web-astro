---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import { apartamentosTuristicosFaqs } from '@/data/faqs/apartamentos-turisticos'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur Apartamentos Turísticos Mallorca | Desde 45€/m²',
  description: 'Reforma tu apartamento turístico con pladur en Mallorca. Aislamiento acústico, redistribución y acabados en 3-5 días. Temporada baja ideal. Desde 45€/m².',
  canonical: '/pladur-apartamentos-turisticos-mallorca',
}

const zonasReforma = [
  { zona: "S'Arenal / Playa de Palma", tipo: 'Apartamentos de playa, bloques años 70-80', demanda: 'Aislamiento acústico, techos modernos, redistribución' },
  { zona: 'Magaluf / Palmanova', tipo: 'Aparthoteles, estudios turísticos', demanda: 'Reformas rápidas, insonorización, modernización integral' },
  { zona: 'Alcúdia / Can Picafort', tipo: 'Apartamentos costeros, residencial-turístico', demanda: 'Falsos techos, aislamiento térmico, redistribución' },
  { zona: 'Cala Millor / Porto Cristo', tipo: 'Bloques turísticos, apartamentos vacacionales', demanda: 'Techos con LED, aislamiento acústico, actualización general' },
  { zona: 'Puerto Pollença / Pollença', tipo: 'Apartamentos premium, casas de pueblo', demanda: 'Acabados alta gama, trasdosados térmicos, techos decorativos' },
]

const procesoTrabajo = [
  { paso: '01', titulo: 'Contacto y visita técnica', descripcion: 'Nos contactas por teléfono, WhatsApp o formulario. Concertamos una visita técnica gratuita al apartamento para evaluar el proyecto, tomar medidas y entender tus necesidades y plazos.' },
  { paso: '02', titulo: 'Presupuesto cerrado en 24-48h', descripcion: 'Enviamos un presupuesto detallado y desglosado con precio cerrado, plazo de ejecución garantizado y lista de materiales. Sin sorpresas. Sin costes ocultos.' },
  { paso: '03', titulo: 'Planificación y reserva de fechas', descripcion: 'Acordamos las fechas de inicio y fin de la obra. Coordinamos con tu calendario de reservas para no perder ni un día de ocupación. Reservamos materiales con antelación.' },
  { paso: '04', titulo: 'Ejecución con plazos garantizados', descripcion: 'Nuestro equipo ejecuta la reforma en el plazo acordado. Trabajamos de lunes a viernes en jornada completa. Si hay retraso por nuestra causa, aplicamos penalización.' },
  { paso: '05', titulo: 'Entrega y limpieza', descripcion: 'Entregamos el apartamento completamente terminado, limpio y listo para poner en servicio. Realizamos inspección conjunta y firmamos acta de entrega. Garantía de 2 años.' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaService
      name="Reforma de Apartamentos Turísticos con Pladur en Mallorca"
      description="Servicio especializado en reforma de apartamentos turísticos con pladur en Mallorca. Plazos garantizados de 1-2 semanas. Aislamiento acústico, falsos techos modernos y redistribución de espacios."
      serviceType="Reforma de Apartamentos Turísticos"
      url="/pladur-apartamentos-turisticos-mallorca"
     
    />
    <SchemaFAQ faqs={apartamentosTuristicosFaqs} />
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Apartamentos Turísticos', href: '/pladur-apartamentos-turisticos-mallorca' }]} />
    <SchemaHowTo
      name="Cómo reformar un apartamento turístico con pladur"
      description="Proceso completo de reforma de apartamento turístico con pladur en 5 pasos: desde el contacto inicial hasta la entrega llave en mano."
      totalTime="P14D"
      steps={procesoTrabajo.map((p) => ({ name: p.titulo, text: p.descripcion }))}
    />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — reforma de apartamentos turísticos con pladur en Mallorca. Plazos de 3-5 días, aislamiento acústico para mejorar valoraciones. Temporada baja ideal. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <section class="pt-24 pb-20 lg:pt-32 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-4xl mx-auto text-center">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-warm-200 text-foreground border border-warm-border/60 text-xs font-semibold tracking-wide mb-6">
            Apartamentos turísticos · Mallorca
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            Pladur para Apartamentos Turísticos en Mallorca — Reforma Rápida en Temporada Baja
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto mb-8">
            Moderniza tu apartamento turístico antes de temporada. Falsos techos con LED, aislamiento acústico para mejorar valoraciones y redistribución de espacios en 1-2 semanas. Plazos garantizados por contrato.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/presupuesto-pladur"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 transition-[background-color,box-shadow] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            >
              Pide presupuesto gratis
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-[background-color,border-color,color] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 1. Por qué el pladur es ideal para reformas turísticas -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div>
        <div class="max-w-3xl mb-10 animate-fade-up">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Por qué pladur
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            ¿Por qué el pladur es la mejor opción para reformar apartamentos turísticos?
          </h2>
        </div>
      </div>
      <div class="max-w-3xl space-y-5 text-muted leading-relaxed mb-12">
        <p>
          Mallorca cuenta con más de 40.000 plazas turísticas reguladas según datos del Govern Balear. La reforma con pladur es la opción preferida por propietarios de <strong>apartamentos turísticos</strong> gracias a su velocidad de ejecución: una redistribución completa de un apartamento de 60-80m² se completa en 3-5 días laborables, permitiendo minimizar la pérdida de ingresos durante la <strong>temporada baja</strong> (noviembre-marzo).
        </p>
        <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
          <p>"La normativa de alojamiento turístico de las Islas Baleares establece requisitos específicos de <strong>aislamiento acústico</strong> entre unidades, que el pladur con lana de roca de 48mm cumple con creces, alcanzando 43-52 dBA de reducción"</p>
          <cite class="block mt-2 text-sm not-italic text-muted/70">— <strong>Decreto 20/2015</strong>, Reglamento de alojamientos turísticos de las Islas Baleares</cite>
        </blockquote>
        <p>
          El pladur cumple los tres requisitos de forma óptima. Es un sistema de construcción en seco que no genera escombros significativos, no requiere tiempo de secado y no produce el polvo de cemento que impregna todo durante semanas. Un apartamento turístico de 50-60 m² puede tener un falso techo completamente nuevo, con iluminación LED empotrada y acabado listo para pintar, en tan solo 2-3 días de trabajo.
        </p>
        <p>
          Frente a la obra tradicional, el pladur ofrece un ahorro de tiempo del 60-75% y un ahorro de coste del 25-40% cuando se calcula el coste total (materiales + mano de obra + limpieza + gestión de escombros + días sin alquilar). Cada día que un apartamento turístico en Mallorca no puede alquilarse durante temporada alta supone una pérdida de entre 80 y 300€, dependiendo de la zona y la categoría del alojamiento.
        </p>
        <p>
          La versatilidad del pladur permite abordar múltiples mejoras en una sola intervención: modernizar el techo con iluminación integrada, mejorar el aislamiento acústico entre vecinos, redistribuir el espacio para crear un dormitorio adicional o integrar un vestidor, y mejorar el aislamiento térmico de fachada para reducir el consumo de aire acondicionado. Todo en una sola reforma, en un solo plazo.
        </p>
        <p>
          Si tu apartamento turístico necesita cumplir normativa de protección contra incendios, consulta nuestro servicio de <a href="/pladur-ignifugo-mallorca" class="text-foreground font-semibold underline underline-offset-2">pladur ignífugo en Mallorca</a> con certificación EI-60 y EI-120.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 stagger-children">
        {[
          { titulo: 'Rapidez', items: ['Reforma completa en 1-2 semanas', 'Plazos garantizados por contrato'] },
          { titulo: 'Limpieza', items: ['Sin escombros ni polvo de cemento', 'Listo para alquilar de inmediato'] },
          { titulo: 'Confort', items: ['Aislamiento acústico profesional', 'Iluminación LED que fotografía bien'] },
          { titulo: 'Ahorro', items: ['25-40% más económico que obra', 'Garantía de 2 años incluida'] },
        ].map((card) => (
          <div>
            <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 p-6 h-full cursor-default">
              <p class="text-xs font-bold uppercase tracking-wider text-foreground-dark mb-3">{card.titulo}</p>
              <ul class="space-y-2">
                {card.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted">
                    <div class="shrink-0 w-4 h-4 bg-foreground-dark rounded-full flex items-center justify-center mt-0.5">
                      <svg aria-hidden="true" class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 2. Ventana de reforma: octubre-marzo -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-5 order-2 lg:order-1">
          <div class="sticky top-28">
            <div>
              <div class="bg-foreground rounded-3xl p-7">
                <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-5">Calendario óptimo</p>
                <div class="space-y-4">
                  {[
                    { mes: 'Sep-Oct', accion: 'Contacto y visita técnica', activo: false },
                    { mes: 'Oct-Nov', accion: 'Presupuesto y reserva de fechas', activo: false },
                    { mes: 'Nov-Feb', accion: 'Ejecución de la reforma', activo: true },
                    { mes: 'Mar', accion: 'Entrega lista para temporada', activo: false },
                  ].map((item, index) => (
                    <div class="flex items-center gap-3">
                      <div class="flex flex-col items-center shrink-0">
                        <div class:list={['w-2.5 h-2.5 rounded-full', item.activo ? 'bg-white' : 'bg-white/30']} />
                        {index < 3 && <div class="w-px h-4 bg-white/15 mt-1" />}
                      </div>
                      <div class="flex-1">
                        <span class="block text-xs font-bold text-white/80 tabular-nums">{item.mes}</span>
                        <span class="text-sm text-white/60">{item.accion}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 order-1 lg:order-2">
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
              Planificación
            </span>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              La ventana de reforma: octubre a marzo
            </h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>
              La temporada turística en Mallorca marca el calendario de reformas. Entre octubre y marzo la ocupación es baja, los plazos son más flexibles y el apartamento puede estar fuera de servicio sin pérdida significativa de ingresos.
            </p>
            <p>
              La planificación es clave para una reforma turística exitosa. Recomendamos contactar en septiembre o principios de octubre para hacer la visita técnica, aprobar el presupuesto y reservar las fechas de ejecución. El material se encarga con antelación para evitar demoras por falta de stock —un problema habitual en Mallorca, donde los suministros dependen del transporte marítimo desde la Península.
            </p>
            <p>
              La ejecución óptima se concentra entre noviembre y febrero, cuando la disponibilidad de nuestro equipo es mayor y los plazos se pueden ajustar con más flexibilidad. Las reformas planificadas para marzo o abril pueden sufrir más presión de plazos y tienen menos margen para imprevistos.
            </p>
            <p>
              Para propietarios con varios apartamentos, ofrecemos planificación en cadena: reformamos un apartamento mientras el siguiente sigue en servicio, y rotamos hasta completar toda la cartera. Este sistema maximiza los ingresos durante la reforma y minimiza el impacto en la operativa global.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Aislamiento acústico para mejorar ratings -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div>
        <div class="max-w-3xl mb-10 animate-fade-up">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Aislamiento acústico
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            Mejora tus valoraciones con aislamiento acústico profesional
          </h2>
        </div>
      </div>
      <div class="max-w-3xl space-y-5 text-muted leading-relaxed mb-10">
        <p>
          El ruido es la queja más frecuente en las reseñas de apartamentos turísticos en Mallorca. Los edificios de los años 60-80, que concentran la mayor parte de la oferta turística de la isla, fueron construidos con estándares acústicos muy inferiores a los actuales. Las paredes medianeras de ladrillo hueco sencillo transmiten conversaciones, música y especialmente el ruido de impacto (pasos, caídas de objetos).
        </p>
        <p>
          Una sola reseña negativa mencionando el ruido puede disuadir a decenas de potenciales huéspedes. En plataformas como Airbnb y Booking, los filtros por puntuación hacen que un alojamiento con 4.2 estrellas reciba significativamente menos visibilidad que uno con 4.5. La mejora del aislamiento acústico puede ser la inversión con mayor retorno para un apartamento turístico.
        </p>
        <p>
          Nuestros sistemas de pladur para aislamiento acústico utilizan lana mineral de alta densidad entre los montantes metálicos y, en los casos más exigentes, estructura desacoplada con bandas antivibratorias que cortan la transmisión del sonido a través de la estructura del edificio. El resultado es una reducción de ruido de 45-55 dB, que convierte un apartamento ruidoso en un espacio notablemente tranquilo.
        </p>
        <p>
          La inversión en aislamiento acústico para un apartamento turístico de 50 m² oscila entre 1.800 y 4.000€ dependiendo del número de paredes a tratar y el nivel de aislamiento requerido. Con un incremento de precio por noche del 10-15% y una mejora en la tasa de ocupación, la amortización suele producirse en 1-2 temporadas.
        </p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        {[
          { metrica: 'Reducción de ruido', valor: '45-55 dB' },
          { metrica: 'Mejora puntuación', valor: '+0.3 a +0.5 ★' },
          { metrica: 'Precio/noche', valor: '+10-15%' },
          { metrica: 'Amortización', valor: '1-2 temporadas' },
        ].map((item) => (
          <div>
            <div class="bg-foreground rounded-2xl p-5 text-center cursor-default">
              <p class="text-lg sm:text-xl font-bold text-white mb-1">{item.valor}</p>
              <p class="text-[11px] text-white/50 uppercase tracking-wider font-semibold">{item.metrica}</p>
            </div>
          </div>
        ))}
      </div>
      <a
        href="/aislamiento-acustico-mallorca"
        class="inline-flex items-center gap-2 text-foreground font-semibold underline underline-offset-2 text-sm transition-colors"
      >
        Ver soluciones de aislamiento acústico
        <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- 4. Modernización de techos con iluminación LED -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 mb-10">
        <div>
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
              Iluminación moderna
            </span>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              Falsos techos con iluminación LED: el cambio que se ve en las fotos
            </h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>
              Un falso techo de pladur con iluminación LED empotrada transforma completamente la imagen de un apartamento turístico. Las fotos del alojamiento mejoran dramáticamente, lo que se traduce directamente en más clics y más reservas.
            </p>
            <p>
              Los apartamentos turísticos con techos antiguos —plafones amarillentos, lámparas de techo expuestas, manchas de humedad— transmiten una imagen de abandono que penaliza el precio y la ocupación. Un falso techo de pladur continuo con focos LED empotrados crea un ambiente moderno, luminoso y acogedor que fotografía mucho mejor y atrae a huéspedes dispuestos a pagar más.
            </p>
          </div>
        </div>
        <div>
          <div class="space-y-5 text-muted leading-relaxed lg:mt-[72px]">
            <p>
              El falso techo también resuelve problemas funcionales: oculta cableado antiguo, permite integrar el aire acondicionado por conductos (eliminando los antiestéticos splits de pared), mejora la eficiencia del climatizador (al reducir el volumen de aire a refrigerar) y puede incorporar aislamiento acústico en su interior.
            </p>
            <p>
              Un falso techo básico con 6-8 focos LED para un apartamento de 50 m² cuesta entre 1.500 y 2.500€ sin IVA. Es una de las inversiones con mejor relación coste-impacto visual en la reforma de un apartamento turístico.
            </p>
          </div>
        </div>
      </div>
      <div>
        <div class="bg-foreground rounded-3xl p-7 sm:p-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-2">Beneficios del falso techo</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-8 gap-y-2">
                {[
                  'LED empotrada moderna',
                  'Oculta cableado antiguo',
                  'Integra A/C por conductos',
                  'Reduce coste climatización',
                  'Mejores fotos del anuncio',
                  'Instalación en 2-3 días',
                ].map((item) => (
                  <div class="flex items-center gap-2 text-sm text-white/70">
                    <div class="shrink-0 w-1.5 h-1.5 rounded-full bg-white/40" />
                    {item}
                  </div>
                ))}
              </div>
            </div>
            <a
              href="/falsos-techos-pladur-mallorca"
              class="inline-flex items-center gap-2 text-white font-semibold underline underline-offset-2 text-sm shrink-0 transition-colors"
            >
              Ver falsos techos
              <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
