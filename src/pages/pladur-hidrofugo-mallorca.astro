---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import { hidrofugoFaqs } from '@/data/faqs/hidrofugo'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur Hidrófugo Mallorca | Placa Verde Baños y Cocinas',
  description: 'Instala pladur hidrófugo (placa verde) en Mallorca. Ideal para baños, cocinas y zonas húmedas. Absorción de agua <5%. Desde 28€/m². Presupuesto gratis.',
  canonical: '/pladur-hidrofugo-mallorca',
}

const aplicaciones = [
  { titulo: 'Baños y aseos', descripcion: 'Detrás de azulejo o con pintura antihumedad Clase 3. La aplicación más habitual de la placa verde en Mallorca.' },
  { titulo: 'Cocinas', descripcion: 'Zona de fregadero y encimera. Protección contra salpicaduras y vapor de cocción.' },
  { titulo: 'Sótanos y garajes', descripcion: 'Especialmente en zonas costeras de Mallorca con alta humedad relativa (Arenal, Cala Major, Puerto Pollença).' },
  { titulo: 'Lavaderos', descripcion: 'Protección contra la humedad generada por lavadoras y secadoras en espacios cerrados.' },
  { titulo: 'Piscinas cubiertas', descripcion: 'Techos y paredes de zonas de piscina en hoteles y villas. Ambiente con humedad relativa superior al 70%.' },
  { titulo: 'Apartamentos turísticos en primera línea', descripcion: 'Baños y cocinas de apartamentos en zonas costeras con alta exposición a la humedad marina.' },
]

const sistemas = [
  { sistema: 'Trasdosado hidrófugo', descripcion: 'Placa verde adosada a pared existente con estructura metálica. Ideal para renovar baños sin demoler. Permite integrar aislamiento térmico o acústico.', cuando: 'Reformas de baños y cocinas sobre pared existente.' },
  { sistema: 'Tabique hidrófugo', descripcion: 'Tabique autoportante con placa verde en ambas caras. Para crear nuevas divisiones en zonas húmedas: baños, cocinas, lavaderos.', cuando: 'Redistribución que incluye nuevos baños o cocinas.' },
  { sistema: 'Falso techo hidrófugo', descripcion: 'Falso techo con placa verde para baños, cocinas y zonas de piscina. Permite integrar iluminación LED, extracción y ocultar instalaciones.', cuando: 'Techos de baños, cocinas y zonas con vapor.' },
]

const precios = [
  { sistema: 'Trasdosado hidrófugo', desde: '28€/m²', hasta: '40€/m²', incluye: 'Estructura + placa H1 + sellado perímetro' },
  { sistema: 'Tabique con placa verde', desde: '35€/m²', hasta: '50€/m²', incluye: 'Estructura + placa H1 ambas caras + acabado' },
  { sistema: 'Falso techo hidrófugo', desde: '30€/m²', hasta: '45€/m²', incluye: 'Estructura + placa H1 + acabado' },
]

const ventajas = [
  { ventaja: '3× más rápido', detalle: 'Instalación en horas vs. días del azulejo tradicional' },
  { ventaja: '2× más económico', detalle: 'Menor coste de material y mano de obra' },
  { ventaja: 'Redistribución futura', detalle: 'Se puede modificar sin obra de derribo' },
  { ventaja: 'Pintura Clase 3', detalle: 'Compatible con acabados antihumedad certificados' },
  { ventaja: 'Menor peso', detalle: 'Ideal para forjados antiguos que no soportan azulejo pesado' },
  { ventaja: 'LED integrado', detalle: 'Permite focos empotrados en techos de baño' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaService
      name="Instalación de Pladur Hidrófugo en Mallorca"
      description="Servicio de instalación de pladur hidrófugo (placa verde tipo H1) en Mallorca. Baños, cocinas, zonas húmedas. Absorción de agua inferior al 5%. Presupuesto gratuito."
      serviceType="Instalación de Pladur Hidrófugo"
      url="/pladur-hidrofugo-mallorca"
    />
    <SchemaFAQ faqs={hidrofugoFaqs} />
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Pladur Hidrófugo', href: '/pladur-hidrofugo-mallorca' }]} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instalación de pladur hidrófugo (placa verde) en Mallorca. Baños, cocinas y zonas húmedas. Absorción agua inferior al 5%. Desde 28€/m². Presupuesto gratis en 24h. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <section class="pt-24 pb-20 lg:pt-32 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-4xl mx-auto text-center">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-warm-200 text-foreground border border-warm-border/60 text-xs font-semibold tracking-wide mb-6">
            Zonas húmedas · Mallorca
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            Pladur Hidrófugo en Mallorca — Especialistas en Zonas Húmedas
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto mb-8">
            Más del 30% de nuestros proyectos en Mallorca incluyen placa hidrófuga, especialmente en reformas de baños de hoteles durante la temporada baja y en <a href="/pladur-apartamentos-turisticos-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">apartamentos turísticos</a> de primera línea. El clima húmedo de la isla hace que la placa verde sea imprescindible en cualquier zona con contacto directo o indirecto con agua.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/presupuesto-pladur"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 transition-[background-color,box-shadow] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            >
              Pide presupuesto gratis
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-[background-color,border-color,color] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Qué es la placa hidrófuga -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div class="animate-fade-up">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Material
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            ¿Qué es la placa hidrófuga (verde)?
          </h2>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>
              La <strong>placa hidrófuga</strong> es una placa de yeso laminado cuyo núcleo incorpora aditivos hidrófugos y celulosa tratada que reducen drásticamente la absorción de agua. Se identifica por su color verde y se clasifica como <strong>tipo H1</strong> según la norma europea <strong>EN 520</strong>.
            </p>
            <p>
              La diferencia con la placa estándar es determinante: mientras la placa blanca normal absorbe más del 30% de su peso en agua tras 2 horas de inmersión, la <strong>placa verde</strong> absorbe menos del 5%. Esta resistencia la hace imprescindible en <a href="/reformas-interiores-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">reformas de baños y cocinas</a> y cualquier zona donde la humedad ambiental supere el 70%.
            </p>
            <p>
              En Mallorca, la placa hidrófuga se utiliza sobre todo en <a href="/falsos-techos-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">falsos techos de baños</a> y cocinas, donde el vapor se acumula con mayor intensidad. Nuestro equipo de <a href="/instalacion-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">instalación profesional de pladur</a> garantiza un sellado perimetral correcto y el uso de cintas y masillas específicas para zonas húmedas.
            </p>
            <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
              <p>"Las placas de yeso laminado tipo H1 según EN 520 presentan una absorción total de agua inferior al 5% de su masa, lo que las hace aptas para su uso en locales húmedos"</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">— Norma EN 520:2004+A1:2009, Placas de yeso laminado</cite>
            </blockquote>
          </div>
        </div>
        <div>
          <div class="bg-foreground rounded-3xl p-7 lg:mt-12">
            <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-5">Marcas que instalamos</p>
            <div class="space-y-0">
              {[
                { marca: 'Knauf Green', tipo: 'Placa H1 hidrófuga', absorcion: '< 5%' },
                { marca: 'Placo Hydro', tipo: 'Placa H1 hidrófuga', absorcion: '< 5%' },
                { marca: 'Pladur WA', tipo: 'Placa H1 hidrófuga', absorcion: '< 5%' },
              ].map((m) => (
                <div class="flex justify-between items-center gap-4 py-3.5 border-b border-white/10 last:border-0">
                  <div>
                    <span class="text-sm font-bold text-white">{m.marca}</span>
                    <span class="block text-xs text-white/50">{m.tipo}</span>
                  </div>
                  <span class="text-sm font-bold text-white shrink-0">Absorción {m.absorcion}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dónde se usa -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Aplicaciones
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
          ¿Dónde se usa en Mallorca?
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        {aplicaciones.map((a) => (
          <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 p-6 cursor-default">
            <div class="flex items-center gap-3 mb-3">
              <div class="size-3 rounded-full bg-emerald-500" />
              <p class="font-bold text-foreground text-sm">{a.titulo}</p>
            </div>
            <p class="text-sm text-muted leading-relaxed">{a.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sistemas de instalación -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Sistemas
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
          Sistemas de instalación
        </h2>
        <p class="text-lg text-muted leading-relaxed">
          Tres configuraciones principales según el tipo de intervención y la zona a tratar.
        </p>
      </div>
      <div class="space-y-3">
        {sistemas.map((s) => (
          <div class="group flex items-start gap-5 bg-white/70 border border-warm-border/50 rounded-3xl p-6 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
            <div class="shrink-0 size-11 bg-emerald-50 border border-emerald-200 rounded-xl flex items-center justify-center group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-all duration-300">
              <svg aria-hidden="true" class="size-5 text-emerald-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-foreground text-base mb-1">{s.sistema}</h3>
              <p class="text-sm text-muted leading-relaxed mb-2">{s.descripcion}</p>
              <p class="text-xs text-foreground-dark font-semibold">Cuándo usar: {s.cuando}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Precios -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Precios
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
          Precio pladur hidrófugo en Mallorca 2026
        </h2>
        <p class="text-lg text-muted leading-relaxed">
          Precios de instalación completa (material + mano de obra), IVA no incluido.
        </p>
      </div>
      <div class="space-y-3">
        {precios.map((p) => (
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 bg-white/70 rounded-2xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 px-5 py-4 cursor-default">
            <div class="sm:w-56 shrink-0">
              <p class="text-sm font-bold text-foreground">{p.sistema}</p>
            </div>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 sm:flex-1">
              <div class="flex items-baseline gap-2">
                <span class="text-lg font-bold text-foreground-dark">{p.desde}</span>
                <span class="text-muted">—</span>
                <span class="text-lg font-bold text-foreground-dark">{p.hasta}</span>
              </div>
              <p class="text-xs text-muted sm:ml-auto">{p.incluye}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8">
        <a href="/precios-pladur-mallorca" class="inline-flex items-center gap-2 text-foreground font-semibold underline underline-offset-2 text-sm transition-colors">
          Ver tabla de precios completa
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Ventajas frente al azulejo -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Comparativa
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">
          Ventajas frente al azulejo tradicional
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 stagger-children">
        {ventajas.map((v) => (
          <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card p-6 cursor-default">
            <p class="text-lg font-bold text-foreground-dark mb-1">{v.ventaja}</p>
            <p class="text-sm text-muted">{v.detalle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <FaqAccordion
    client:visible
    categoria="hidrofugo"
    titulo="Preguntas frecuentes sobre pladur hidrófugo"
    subtitulo="Resolvemos las dudas más habituales sobre la placa verde y su uso en zonas húmedas."
  />

  <!-- CTA -->
  <CtaBanner
    titulo="¿Necesitas pladur hidrófugo para tu baño o cocina?"
    subtitulo="Presupuesto gratuito en 24 horas. Materiales certificados. Garantía de 2 años."
  />

  <ServiciosRelacionados currentPath="/pladur-hidrofugo-mallorca" />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
