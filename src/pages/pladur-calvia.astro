---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import PaginaGeografica from '@/components/templates/PaginaGeografica.astro'
import ArticulosRelacionados from '@/components/sections/ArticulosRelacionados.astro'
import { faqs } from '@/data/faqs'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur Calvià | Instalación y Reformas | Presupuesto Gratis',
  description: 'Instala pladur en Calvià. Especialistas en chalets de lujo, villas y apartamentos turísticos en Santa Ponça, Palmanova, Portals Nous y Peguera. Desde 29€/m².',
  canonical: '/pladur-calvia',
}

const zonas = [
  {
    nombre: 'Santa Ponça',
    descripcion: 'Una de las zonas más activas de Calvià. Mezcla de apartamentos turísticos, residencias de lujo y urbanizaciones familiares. Alta demanda de aislamiento acústico y reformas entre temporadas.',
  },
  {
    nombre: 'Palmanova',
    descripcion: 'Núcleo turístico consolidado con gran volumen de apartamentos y hoteles. Proyectos de mejora acústica para cumplir normativas de ruido en alojamientos turísticos.',
  },
  {
    nombre: 'Portals Nous',
    descripcion: 'Zona residencial premium junto al puerto deportivo. Villas y chalets de alto standing que demandan instalaciones de pladur de la máxima calidad y acabados exclusivos.',
  },
  {
    nombre: 'Peguera',
    descripcion: 'Destino turístico de alta densidad. Apartamentos y hoteles que requieren renovaciones completas con plazos ajustados antes de cada temporada.',
  },
  {
    nombre: 'Illetes y Bendinat',
    descripcion: 'Las zonas más exclusivas del municipio. Villas de lujo frente al mar con proyectos de alta complejidad: techos de diseño, máximo aislamiento acústico y eficiencia energética premium.',
  },
  {
    nombre: 'Magaluf',
    descripcion: 'Destino de turismo de entretenimiento en transformación. Hoteles y apartamentos en proceso de renovación y mejora de categoría que requieren soluciones de pladur a gran escala.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Pladur en Calvià', href: '/pladur-calvia' },
]

const pageFaqs = faqs['calvia'] ?? []

/* Custom servicios for Calvià */
const serviciosCalvia = [
  {
    titulo: 'Aislamiento acústico en apartamentos turísticos',
    descripcion: 'Tabiques de pladur con estructura desacoplada y lana mineral de alta densidad (40 kg/m³) que alcanzan reducciones de 50-55 dB, muy por encima de la normativa CTE-HR. Propietarios en Santa Ponça, Palmanova y Peguera han mejorado 0,5-1 punto en Booking y Airbnb tras la intervención, con impacto directo en ocupación e ingresos.',
    iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z',
    link: { href: '/aislamiento-acustico-mallorca', texto: 'Ver soluciones de aislamiento acústico' },
  },
  {
    titulo: 'Falsos techos de diseño en villas de lujo',
    descripcion: 'En Portals Nous, Illetes, Bendinat y Santa Ponça el falso techo es un elemento de diseño arquitectónico. Ejecutamos cofres escalonados, iluminación LED indirecta, techos curvos en doble altura y cofres con integración de altavoces y domótica. Coordinación directa con arquitectos de interiores e interioristas.',
    iconPath: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
    link: { href: '/falsos-techos-pladur-mallorca', texto: 'Más sobre falsos techos' },
  },
  {
    titulo: 'Redistribución de chalets y cambio de uso',
    descripcion: 'Chalets de los años 80-90 que se reconvierten en alquileres turísticos o se adaptan a nuevos propietarios. Con tabiques de pladur creamos habitaciones adicionales, dividimos suites en unidades independientes y añadimos zonas de office o entretenimiento. Instalación rápida y limpia, sin afectar a la estructura.',
    iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
    link: { href: '/tabiques-pladur-mallorca', texto: 'Ver soluciones de tabiquería' },
  },
  {
    titulo: 'Reformas de hostelería entre temporadas',
    descripcion: 'Hoteles y apartamentos turísticos de Calvià tienen entre octubre y marzo para reformar. El pladur es ideal para plazos ajustados: sin tiempos de secado, sin escombros, equipos en paralelo por zonas. Trabajamos habitación por habitación y entregamos cada unidad lista para pintura y mobiliario.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    titulo: 'Techos antivibración contra ruido de impacto',
    descripcion: 'Complemento al aislamiento de paredes: falsos techos con suspensión antivibratoria que reducen significativamente el ruido de impacto procedente del piso superior (pasos, caídas de objetos, arrastre de muebles). Solución imprescindible en bloques turísticos donde el confort nocturno determina las valoraciones.',
    iconPath: 'M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15',
    link: { href: '/falsos-techos-pladur-mallorca', texto: 'Más sobre falsos techos' },
  },
  {
    titulo: 'Acabados premium y coordinación técnica',
    descripcion: 'En los proyectos de alta gama de Calvià el acabado lo es todo: juntas invisibles, ángulos milimétricos, superficies perfectamente planas aptas para pinturas y revestimientos de calidad. Trabajamos exclusivamente con Placo y Knauf, y nos coordinamos con interioristas, arquitectos y otros gremios para cumplir las especificaciones más exigentes.',
    iconPath: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
  },
]

const proyectoFicha = [
  { label: 'Superficie', valor: '85 m²' },
  { label: 'Ubicación', valor: 'Santa Ponça, Calvià' },
  { label: 'Trabajos', valor: 'Tabiques acústicos + Techo antivibración' },
  { label: 'Duración', valor: '5 días hábiles' },
  { label: 'Reducción acústica', valor: '51 dB' },
  { label: 'Mejora valoración', valor: '3,8 → 4,6 estrellas' },
]

const enlacesCalvia = [
  { href: '/instalacion-pladur-mallorca', label: 'Instalación de Pladur en Mallorca', descripcion: 'Todo sobre nuestros servicios de instalación de pladur en la isla.', iconPath: 'M11.42 15.17l-5.384-3.065A1.5 1.5 0 005.25 13.5v5.25a1.5 1.5 0 001.786 1.47l5.384-1.436a1.5 1.5 0 001.08-1.442V15.17zm0 0l5.384-3.065A1.5 1.5 0 0018.75 10.5V5.25a1.5 1.5 0 00-1.786-1.47l-5.384 1.436a1.5 1.5 0 00-1.08 1.442v8.512z' },
  { href: '/aislamiento-acustico-mallorca', label: 'Aislamiento Acústico', descripcion: 'Soluciones profesionales de aislamiento acústico con pladur en Mallorca.', iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z' },
  { href: '/precios-pladur-mallorca', label: 'Precios de Pladur en Mallorca', descripcion: 'Consulta nuestras tarifas y precios orientativos por m².', iconPath: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z' },
  { href: '/pladur-palma', label: 'Pladur en Palma de Mallorca', descripcion: 'Instalación de pladur en todos los barrios de Palma.', iconPath: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z', iconPath2: 'M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Calvià"
      description="Servicio profesional de instalación de pladur en Calvià: especialistas en chalets de lujo, villas, apartamentos turísticos y hostelería en toda la costa oeste de Mallorca."
      serviceType="Instalación de Pladur"
      url="/pladur-calvia"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Calvià. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Calvià"
    zonas={zonas}
    faqKey="calvia"
    heroBadge="Calvià · Costa oeste de Mallorca"
    heroTitle="Pladur en Calvià — Especialistas en Chalets, Villas y Apartamentos Turísticos"
    heroDescription="Instalamos pladur en todo el municipio de Calvià: Santa Ponça, Palmanova, Portals Nous, Peguera, Magaluf, Illetes y Bendinat. Especializados en reformas de alta gama y proyectos en plazos ajustados entre temporadas."
    introLabel="Conocemos Calvià"
    introTitle="Los retos únicos del pladur en Calvià"
    serviciosBadge="Soluciones para Calvià"
    serviciosTitulo="Servicios de pladur específicos para Calvià"
    serviciosSubtitulo="Desde apartamentos turísticos que necesitan mejor aislamiento acústico hasta villas de lujo que requieren techos de diseño. Estas son las soluciones más demandadas en Calvià."
    proyectoTitulo="Apartamento turístico 85 m² en Santa Ponça"
    proyectoFicha={proyectoFicha}
    faqTitulo="Preguntas frecuentes sobre pladur en Calvià"
    faqSubtitulo="Resolvemos las dudas más habituales de propietarios y gestores de apartamentos en Calvià."
    ctaTitulo="¿Tu proyecto está en Calvià?"
    ctaSubtitulo="Especializados en chalets, villas y apartamentos turísticos. Presupuesto gratuito en 24h."
  >
    <!-- Custom servicios grid -->
    <div slot="servicios" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {serviciosCalvia.map((servicio) => (
        <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 group h-full relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500" />
          <div class="size-12 bg-surface border border-nav-border rounded-2xl group-hover:bg-foreground-dark group-hover:border-foreground-dark flex items-center justify-center mb-6 transition-[transform,box-shadow,background-color,border-color] duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={servicio.iconPath} />
            </svg>
          </div>
          <h3 class="font-bold text-foreground text-lg mb-3">{servicio.titulo}</h3>
          <div class="text-muted text-sm leading-relaxed">
            <p>{servicio.descripcion}</p>
          </div>
          {servicio.link && (
            <a
              href={servicio.link.href}
              class="mt-5 inline-flex items-center gap-2 text-foreground font-semibold text-sm hover:text-foreground-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2 rounded-lg"
            >
              {servicio.link.texto}
              <svg class="size-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Un apartamento turístico de 85 m² en un bloque de Santa Ponça con problemas severos de ruido entre unidades: los huéspedes escuchaban las conversaciones y la televisión del apartamento contiguo, y las valoraciones en Airbnb habían bajado a 3,8 estrellas de media, con varios comentarios negativos específicamente sobre el ruido.
      </p>
      <p>
        El proyecto consistió en la instalación de tabiques de pladur con sistema desacoplado (doble placa + lana mineral de alta densidad 40 kg/m³ + bandas antivibratorias) en las dos paredes medianeras con apartamentos vecinos (28 m² lineales). Adicionalmente, se instaló un falso techo con suspensión antivibratoria en el dormitorio principal para reducir el ruido de impacto procedente del piso superior.
      </p>
      <p>
        El trabajo se ejecutó en 5 días hábiles, durante la temporada baja de noviembre. La reducción acústica medida fue de 51 dB en las paredes tratadas. En la siguiente temporada, las valoraciones sobre ruido mejoraron radicalmente y la puntuación global subió a 4,6 estrellas, con un incremento del 22% en los ingresos anuales gracias a la mejora de la tasa de ocupación.
      </p>
    </div>

    <!-- Custom texto SEO with sidebar layout -->
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
          <div class="lg:col-span-8">
            <div class="max-w-none text-muted space-y-5">
              <p>
                Calvià es el municipio más turístico de las Islas Baleares y uno de los más ricos de España por renta per cápita. Este perfil socioeconómico particular se traduce en un mercado inmobiliario muy específico: chalets de lujo en Portals Nous, Illetes y Bendinat; villas con vistas al mar en Santa Ponça y Peguera; y una densa concentración de apartamentos turísticos en Palmanova, Magaluf y Torrenova.
              </p>
              <p>
                Esta diversidad de tipologías genera demandas muy concretas para los instaladores de pladur. En las zonas residenciales de alto nivel, la exigencia se centra en la calidad del acabado, la capacidad de ejecutar diseños arquitectónicos complejos y la coordinación con otros especialistas de lujo (interioristas, arquitectos de interiores, fabricantes de cocinas a medida). En las zonas turísticas, el reto principal es el plazo: las reformas deben completarse en las escasas semanas entre el cierre de temporada y la reapertura, habitualmente entre noviembre y marzo.
              </p>
              <p>
                El aislamiento acústico es una demanda especialmente relevante en Calvià. La alta densidad de alojamientos turísticos en zonas como Palmanova, Magaluf o Santa Ponça genera un nivel de ruido ambiental elevado, y los propietarios de apartamentos turísticos saben que las valoraciones en Booking.com y Airbnb dependen en gran medida del silencio nocturno. Invertir en aislamiento acústico con pladur es, en Calvià, una decisión económica racional: una mejora en las valoraciones puede traducirse en un incremento del 15-30% en los ingresos anuales por alquiler.
              </p>
              <p>
                En las zonas de alta densidad turística, Calvià tiene también normativas específicas sobre ruido entre alojamientos que las comunidades de propietarios deben cumplir. Las reformas con sistemas de pladur de alta aislamiento son la solución más eficiente para alcanzar los niveles exigidos sin obras invasivas que afecten a la estructura del edificio.
              </p>
            </div>
          </div>
          <div class="lg:col-span-4">
            <div class="bg-white/70 border border-warm-border/50 rounded-3xl shadow-soft p-6 sm:p-8 sticky top-28">
              <p class="font-bold text-lg mb-2 text-foreground">Reformas entre temporadas</p>
              <p class="text-muted text-sm leading-relaxed">
                Entendemos que en Calvià el plazo es crítico. Planificamos cada proyecto para que la reforma esté lista antes del inicio de temporada. Trabajamos con equipos amplios cuando el plazo lo requiere.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Custom enlaces internos -->
    <section slot="enlaces-internos" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            También te puede interesar
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight">
            Servicios relacionados
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {enlacesCalvia.map((link) => (
            <a
              href={link.href}
              class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 relative overflow-hidden h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500" />
              <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-4 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-[transform,box-shadow,background-color,border-color] duration-300">
                <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={link.iconPath} />
                  {link.iconPath2 && <path stroke-linecap="round" stroke-linejoin="round" d={link.iconPath2} />}
                </svg>
              </div>
              <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
              <p class="text-muted text-sm">{link.descripcion}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </PaginaGeografica>

  <ArticulosRelacionados articulos={[
    { slug: 'reformas-pladur-calvia', titulo: 'Reformas con pladur en Calvià', descripcion: 'Proyectos reales de reformas con pladur en Calvià. Villas, chalets y apartamentos turísticos.' },
    { slug: 'aislamiento-termico-chalets-calvia', titulo: 'Aislamiento térmico en chalets de Calvià', descripcion: 'Cómo mejorar el aislamiento térmico en chalets y villas de lujo en la zona de Calvià.' },
  ]} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
