    titulo: 'Aislamiento acústico en pisos de Palma',
    descripcion: 'Los pisos de la Palma urbana, especialmente en Santa Catalina, El Terreno y el Coll d\'en Rabassa, sufren problemas de ruido entre vecinos que se agravan por el bajo estándar acústico de la construcción de los años 60-80. La música, las conversaciones y especialmente el ruido de los locales de hostelería son quejas habituales.',
    descripcion2: 'Nuestros sistemas de tabique desacoplado con lana mineral de alta densidad alcanzan reducciones acústicas de 45-55 dB, superando holgadamente la normativa CTE-HR. Trabajamos tanto en la separación entre viviendas como en el aislamiento respecto a locales en planta baja.',
    iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z',
  },
  {
    titulo: 'Proyectos de alta gama en Son Vida y Génova',
    descripcion: 'En las zonas residenciales de mayor nivel de Palma —Son Vida, Génova, Son Armadams— trabajamos con los estándares más exigentes. Falsos techos con cofres y escalones para iluminación indirecta, sistemas de placa doble para máximo aislamiento acústico, acabados meticulosos y coordinación con otros gremios (electricistas, climatizadores, carpinteros).',
    descripcion2: 'Utilizamos materiales de primera calidad (Placo, Knauf) y aplicamos los sistemas de montaje más rigurosos para garantizar resultados que cumplan las expectativas de los proyectos de alta gama.',
    iconPath: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
  },
]

const proyectoFicha = [
  { label: 'Superficie', valor: '110 m²' },
  { label: 'Ubicación', valor: 'Santa Catalina, Palma' },
  { label: 'Trabajos', valor: 'Techo + Tabiques + Trasdosado' },
  { label: 'Duración', valor: '10 días hábiles' },
  { label: 'Resultado', valor: 'Distribución completamente nueva' },
]

const enlacesPalma = [
  { href: '/instalacion-pladur-mallorca', label: 'Instalación de Pladur en Mallorca', descripcion: 'Todo sobre nuestros servicios de instalación de pladur en la isla.', iconPath: 'M11.42 15.17l-5.384-3.065A1.5 1.5 0 005.25 13.5v5.25a1.5 1.5 0 001.786 1.47l5.384-1.436a1.5 1.5 0 001.08-1.442V15.17zm0 0l5.384-3.065A1.5 1.5 0 0018.75 10.5V5.25a1.5 1.5 0 00-1.786-1.47l-5.384 1.436a1.5 1.5 0 00-1.08 1.442v8.512z' },
  { href: '/falsos-techos-pladur-mallorca', label: 'Falsos Techos de Pladur', descripcion: 'Techos lisos, decorativos y con aislamiento para todo tipo de espacios.', iconPath: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25' },
  { href: '/tabiques-pladur-mallorca', label: 'Tabiques de Pladur', descripcion: 'Redistribuye tu vivienda o local con tabiques de pladur rápidos y limpios.', iconPath: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z' },
  { href: '/precios-pladur-mallorca', label: 'Precios de Pladur en Mallorca', descripcion: 'Consulta nuestras tarifas y precios orientativos por m².', iconPath: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z' },
  { href: '/pladur-calvia', label: 'Pladur en Calvià', descripcion: 'Especialistas en chalets, villas y apartamentos turísticos en Calvià.', iconPath: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z', iconPath2: 'M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Palma de Mallorca"
      description="Servicio profesional de instalación de pladur en Palma de Mallorca: falsos techos, tabiques de distribución, aislamiento acústico y térmico en todos los barrios."
      serviceType="Instalación de Pladur"
      url="/pladur-palma"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Palma de Mallorca. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Palma de Mallorca"
    zonas={zonas}
    faqKey="palma"
    heroBadge="Palma de Mallorca · Sin desplazamiento"
    heroTitle="Pladur en Palma de Mallorca — Empresa de Pladur y Escayola"
    heroDescription="Instalamos pladur y escayola en todos los barrios de Palma de Mallorca: falsos techos, tabiques de distribución, aislamiento acústico y térmico, molduras y restauración de edificios históricos. Presupuesto gratuito en 24 horas."
    introLabel="Conocemos Palma"
    introTitle="Especialistas en los retos de las viviendas de Palma"
    serviciosBadge="Nuestras soluciones en Palma"
    serviciosTitulo="Qué hacemos específicamente en Palma"
    serviciosSubtitulo="Cada barrio de Palma tiene sus propias características constructivas. Estas son las soluciones que más aplicamos según el tipo de vivienda."
    proyectoTitulo="Reforma integral en Santa Catalina, Palma"
    proyectoFicha={proyectoFicha}
    faqTitulo="Preguntas frecuentes sobre pladur en Palma"
    faqSubtitulo="Resolvemos las dudas más habituales de nuestros clientes en Palma de Mallorca."
    ctaTitulo="¿Tu proyecto está en Palma?"
    ctaSubtitulo="Contacta ahora y recibe tu presupuesto gratuito en menos de 24 horas."
  >
    <!-- Custom servicios grid -->
    <div slot="servicios" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {serviciosPalma.map((servicio) => (
        <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 group h-full relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500" />
          <div class="size-12 bg-surface border border-nav-border rounded-2xl group-hover:bg-foreground-dark group-hover:border-foreground-dark flex items-center justify-center mb-6 transition-[transform,box-shadow,background-color,border-color] duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={servicio.iconPath} />
            </svg>
          </div>
          <h3 class="font-bold text-foreground text-lg mb-3">{servicio.titulo}</h3>
          <div class="text-muted text-sm leading-relaxed">
            <p>{servicio.descripcion}</p>
            {servicio.descripcion2 && <p class="mt-3">{servicio.descripcion2}</p>}
          </div>
          {servicio.link && (
            <a
              href={servicio.link.href}
              class="mt-5 inline-flex items-center gap-2 text-foreground font-semibold text-sm hover:text-foreground-dark transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2 rounded-lg"
            >
              {servicio.link.texto}
              <svg class="size-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Un piso de 110 m² en el barrio de Santa Catalina, construido en 1972, con una distribución original de cuatro dormitorios pequeños y un salón-comedor único. Los propietarios querían convertirlo en un piso moderno con tres habitaciones, sala de estar amplia, vestidor y zona de trabajo independiente.
      </p>
      <p>
        El proyecto incluyó la instalación de falso techo continuo en todas las estancias (85 m² de techo, bajada de 35 cm para integrar la instalación eléctrica nueva y los conductos del aire acondicionado), tres tabiques de redistribución (28 ml lineales), un trasdosado en fachada norte para mejorar el aislamiento térmico, y aislamiento acústico en los tabiques medianeros con la vivienda contigua.
      </p>
      <p>
        El trabajo se completó en 10 días hábiles, con los propietarios pudiendo habitar el piso durante toda la reforma gracias a la metodología de trabajo por zonas. El resultado fue un piso completamente transformado, con distribución moderna, calidad de acabado excepcional y una mejora significativa en el confort térmico y acústico.
      </p>
    </div>

    <!-- Custom texto SEO -->
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-none text-muted space-y-5">
          <p>
            Palma de Mallorca tiene un parque inmobiliario muy diverso: desde los pisos centenarios del Centro Histórico y la Ciudad Antiga hasta los apartamentos modernos de Portixol, pasando por las villas de Son Vida y los locales comerciales del Eixample. Cada tipo de edificio presenta retos específicos que conocemos bien después de más de 20 años trabajando en la ciudad.
          </p>
          <p>
            Los pisos céntricos de Palma —especialmente los de los barrios de Sant Pere, La Calatrava y el Puig de Sant Pere— suelen tener techos de entre 3 y 4,5 metros de altura, lo que los convierte en candidatos ideales para instalar falsos techos modernos con iluminación integrada. Esos mismos edificios históricos tienen distribuciones de otra época: dormitorios pequeños, pasillos largos que no aportan nada, salones dimensionados para recibir visitas pero poco funcionales para el uso cotidiano actual.
          </p>
          <p>
            Otro reto habitual en el centro de Palma es la humedad. Los edificios del casco antiguo, con sus muros de marès —la piedra arenisca local— tienen problemas de capilaridad y condensación que se manifiestan en manchas y desperfectos en paredes interiores. Para estos casos utilizamos la placa hidrófuga (placa H), que resiste la humedad y el vapor de agua, combinada con cámaras de ventilación que cortan la capilaridad.
          </p>
          <p>
            En los barrios residenciales modernos de Palma —Son Vida, Son Armadams, el Molinar Premium— la demanda es diferente: proyectos de alta gama con falsos techos de diseño con cofres y escalones, aislamiento acústico de calidad para pisos de lujo, y trasdosados térmicos que mejoran la eficiencia energética de viviendas con certificado energético bajo.
          </p>
          <p>
            Trabajamos en <strong>todos los barrios de Palma</strong> sin coste adicional de desplazamiento: Centro Histórico, Santa Catalina, El Terreno, Portixol, Son Vida, El Molinar, Génova, Coll d'en Rabassa, Son Armadams, La Bonanova, Cala Major, Sant Agustí, Indioteria, La Soledat, Pere Garau, Son Espanyolet, y todos los demás.
          </p>
        </div>
      </div>
    </section>

    <!-- Custom enlaces internos -->
    <section slot="enlaces-internos" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            También te puede interesar
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight">
            Servicios relacionados
          </h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {enlacesPalma.map((link) => (
            <a
              href={link.href}
              class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 relative overflow-hidden h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
            >
              <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500" />
              <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-4 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-[transform,box-shadow,background-color,border-color] duration-300">
                <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={link.iconPath} />
                  {link.iconPath2 && <path stroke-linecap="round" stroke-linejoin="round" d={link.iconPath2} />}
                </svg>
              </div>
              <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
              <p class="text-muted text-sm">{link.descripcion}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </PaginaGeografica>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
