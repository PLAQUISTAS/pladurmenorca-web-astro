]

const pageFaqs = faqs['palma'] ?? []

/* Custom servicios for Palma */
const serviciosPalma = [
  {
    titulo: 'Falsos techos en pisos con techos altos',
    descripcion: 'Los pisos históricos del centro de Palma tienen techos de 3,5 a 4,5 metros. Un falso techo de pladur permite bajar la altura a 2,7-2,8 metros, creando un ambiente más acogedor, mejorando la eficiencia del aire acondicionado e integrando iluminación LED empotrada que moderniza completamente el espacio.',
    descripcion2: 'En el interior del falso techo aprovechamos para pasar el cableado eléctrico, los tubos del aire acondicionado y la instalación de altavoces o domótica, de forma completamente oculta.',
