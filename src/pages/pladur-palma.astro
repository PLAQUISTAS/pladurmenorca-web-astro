  description: 'Instaladores de pladur en Palma de Mallorca. Falsos techos, tabiques, aislamiento y escayola en todos los barrios. +6.000 proyectos, +20 años. Presupuesto gratis ☎ 627 829 723',
  canonical: '/pladur-palma',
}

const zonas = [
  {
    nombre: 'Centro Histórico',
    descripcion: 'Edificios del siglo XIX y principios del XX. Escaleras estrechas, techos altos de 3-4 m, forjados centenarios. Especialidad: falsos techos para ocultar instalaciones y placa H para humedad.',
  },
  {
    nombre: 'Santa Catalina',
    descripcion: 'Barrio en constante renovación. Pisos reformados y lofts modernos. Alta demanda de redistribución y aislamiento acústico entre vecinos.',
  },
  {
    nombre: 'El Terreno',
    descripcion: 'Mezcla de pisos antiguos y villas de los años 50-70. Proyectos de redistribución y modernización con falsos techos decorativos.',
  },
  {
    nombre: 'Portixol',
    descripcion: 'Zona de alta demanda turística y residencial premium. Reformas de alta gama con falsos techos de diseño y aislamiento acústico.',
  },
  {
    nombre: 'Son Vida',
    descripcion: 'Villas y chalets de lujo. Proyectos de gran envergadura con sistemas de pladur de alta gama, techos con cofres y acabados premium.',
  },
  {
    nombre: 'El Molinar',
    descripcion: 'Barrio marinero en transformación. Pisos con vistas al mar que se reforman con pladur para modernizar sin perder el carácter del edificio.',
  },
  {
    nombre: 'Génova',
    descripcion: 'Zona residencial tranquila con casas unifamiliares y pisos. Proyectos de aislamiento térmico y redistribución de espacios.',
  },
  {
    nombre: 'Coll d\'en Rabassa',
    descripcion: 'Zona muy demandada por la proximidad al aeropuerto y la playa. Reformas de pisos y chalets con aislamiento acústico por el tráfico aéreo.',
  },
  {
    nombre: 'Son Armadams',
    descripcion: 'Barrio residencial de clase alta. Villas y pisos amplios donde destacan los proyectos de techos decorativos con iluminación indirecta.',
