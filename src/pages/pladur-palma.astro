    descripcion: 'Barrio costero con mezcla de viviendas antiguas y nuevas promociones. Alta demanda de aislamiento por la humedad marina y el ruido del paseo marítimo.',
  },
  {
    nombre: 'Sant Agustí',
    descripcion: 'Zona tranquila junto al mar. Reformas en chalets y adosados con falsos techos y redistribuciones que maximizan las vistas.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
