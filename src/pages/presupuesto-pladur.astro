---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import TestimonioCard from '@/components/ui/TestimonioCard.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import FormPresupuesto from '@/components/forms/FormPresupuesto'
import { testimonios } from '@/data/testimonios'
import { siteConfig } from '@/data/site'
import { presupuestoFaqs } from '@/data/faqs/presupuesto'

const meta = {
  title: 'Presupuesto de Pladur en Mallorca Gratis | Respuesta en 24h',
  description: 'Solicita tu presupuesto gratuito de pladur en Mallorca. Visita técnica incluida. Sin compromiso. Respuesta garantizada en menos de 24h. Tel: 627 829 723.',
  canonical: '/presupuesto-pladur',
}

const miniTestimonios = [testimonios[0], testimonios[3], testimonios[4]]
const faqsPresupuesto = presupuestoFaqs

const badges = [
  { label: '20 años de experiencia', icon: 'calendar' },
  { label: '+6.000 proyectos realizados', icon: 'check' },
  { label: `${siteConfig.aggregateRating.ratingValue}/5 en Google`, icon: 'star' },
  { label: 'Precio cerrado garantizado', icon: 'lock' },
  { label: 'Garantía 2 años', icon: 'shield' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Presupuesto Pladur', href: '/presupuesto-pladur' }]} />
    {faqsPresupuesto.length > 0 && <SchemaFAQ faqs={faqsPresupuesto} />}
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — presupuesto gratuito de pladur en Mallorca en menos de 24 horas. Precio cerrado sin sorpresas. Visita técnica incluida en toda la isla. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-3xl text-center mx-auto">
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            {['Sin compromiso', 'Respuesta en 24h', 'Visita gratuita'].map((tag) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-surface text-foreground border border-warm-border/60">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            Solicita tu Presupuesto de Pladur Gratis
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto">
            Rellena el formulario y recibirás un presupuesto detallado con visita técnica incluida, sin coste ni compromiso.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main grid: Form + Social Proof -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- LEFT: Form -->
        <div class="lg:col-span-7">
          <div class="bg-white rounded-2xl border border-warm-border p-8 lg:p-10 shadow-soft-lg">
            <h2 class="text-2xl font-bold text-foreground mb-2">
              Cuéntanos tu proyecto
            </h2>
            <p class="text-muted text-sm mb-8">
              Rellena el formulario y un técnico se pondrá en contacto para coordinar la visita gratuita. Recibirás el presupuesto detallado en 24-48 horas.
            </p>
            <FormPresupuesto client:load />
          </div>
        </div>

        <!-- RIGHT: Social proof -->
        <div class="lg:col-span-5 space-y-6">

          <!-- Teléfono directo -->
          <div class="bg-foreground rounded-2xl p-8 text-white">
            <p class="text-xs font-bold uppercase tracking-widest text-white/50 mb-3">
              Contacto directo
            </p>
            <p class="font-bold text-3xl text-white mb-1 tracking-tight">{siteConfig.phone}</p>
            <p class="text-white/60 text-sm mb-6">
              Lunes–Viernes: 8:00–18:00 · Sábados: 8:00–14:00
            </p>
            <div class="flex flex-col gap-3">
              <a
                href={`tel:${siteConfig.phoneRaw}`}
                class="inline-flex items-center justify-center gap-3 px-6 py-3.5 rounded-xl border-2 border-white/30 text-white font-bold text-sm hover:bg-white hover:text-foreground hover:border-white transition-colors duration-200"
              >
                <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                Llamar ahora
              </a>
              <a
                href={`https://wa.me/${siteConfig.whatsapp}?text=${siteConfig.whatsappText}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-3 px-6 py-3.5 rounded-xl bg-white hover:bg-white/90 text-foreground font-bold text-sm shadow-lg shadow-black/10 hover:shadow-xl hover:shadow-black/15 transition-[background-color,box-shadow] duration-200"
              >
                <svg class="size-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
                Escribir por WhatsApp
              </a>
            </div>
          </div>

          <!-- Badges de confianza -->
          <div class="bg-white rounded-2xl border border-warm-border p-6 shadow-soft">
            <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-5">
              Por qué confiar en nosotros
            </p>
            <div class="space-y-3.5">
              {badges.map((badge) => (
                <div class="flex items-center gap-3">
                  <div class="shrink-0 w-9 h-9 bg-surface border border-nav-border rounded-xl flex items-center justify-center">
                    {badge.icon === 'star' && (
                      <svg class="size-4 text-foreground" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    )}
                    {badge.icon === 'check' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    )}
                    {badge.icon === 'calendar' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                    )}
                    {badge.icon === 'lock' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                    )}
                    {badge.icon === 'shield' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                    )}
                  </div>
                  <span class="text-sm font-semibold text-foreground">{badge.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Mini FAQ -->
          <div class="bg-white rounded-2xl border border-warm-border p-6 shadow-soft">
            <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-5">
              Dudas rápidas
            </p>
            <div class="space-y-4">
              {faqsPresupuesto.map((faq) => (
                <div class="border-b border-warm-border/60 pb-4 last:border-0 last:pb-0">
                  <p class="font-semibold text-foreground text-sm mb-1.5">{faq.pregunta}</p>
                  <p class="text-muted text-xs leading-relaxed">{faq.respuesta}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Por qué pedirnos presupuesto -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Nuestro compromiso
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          ¿Por qué pedirnos presupuesto a nosotros?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-[background-color,border-color] duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Gratis y sin compromiso</h3>
          <p class="text-muted text-sm leading-relaxed">El presupuesto es completamente gratuito. Incluye una visita técnica a tu domicilio o local donde un especialista toma medidas, evalúa las condiciones del espacio y resuelve todas tus dudas. No pagas nada y no te comprometes a nada si finalmente no contratas.</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-[background-color,border-color] duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Visita técnica incluida</h3>
          <p class="text-muted text-sm leading-relaxed">No hacemos presupuestos por teléfono o por fotos. Creemos que el único presupuesto fiable es el que se hace tras ver el espacio en persona. Un técnico experimentado de nuestro equipo visita tu vivienda o local, mide y evalúa todas las variables que afectan al precio final.</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-[background-color,border-color] duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Precio cerrado, sin sorpresas</h3>
          <p class="text-muted text-sm leading-relaxed">Una vez aceptado el presupuesto, el precio es el precio. No añadimos extras ni costes ocultos al final de la obra. Si durante la ejecución aparece algún imprevisto relevante, lo comunicamos de inmediato y acordamos por escrito cualquier modificación antes de proceder.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonios mini -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Lo que dicen nuestros clientes
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          Reseñas verificadas en Google
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {miniTestimonios.map((testimonio) => (
          <TestimonioCard testimonio={testimonio} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href={siteConfig.googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-white border-2 border-warm-border hover:border-google hover:shadow-google text-foreground font-bold text-sm tracking-wide transition-[border-color,box-shadow,transform] duration-300 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-google focus-visible:ring-offset-2"
        >
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Déjanos tu reseña en Google
          <svg class="size-4 text-muted group-hover:text-google group-hover:translate-x-0.5 transition-[color,transform]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Cómo funciona + qué incluye -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto space-y-12">

        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">El proceso</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">¿Cómo funciona nuestro presupuesto de pladur?</h2>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>Solicitar presupuesto de pladur en Mallorca es gratuito y sin compromiso. Nuestro proceso incluye una visita técnica donde medimos, evaluamos las condiciones del espacio y presentamos un presupuesto cerrado en menos de 24 horas. El 92% de nuestros presupuestos se entregan el mismo día de la visita.</p>
          </div>
        </div>

        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">¿Qué incluye nuestro presupuesto?</h2>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>Cada presupuesto de Pladur Mallorca detalla: materiales (marca y modelo de placa, tipo de perfilería CW/UW, aislante), mano de obra desglosada por partida, tiempo estimado de ejecución, y garantía de 2 años. No hay sorpresas: el precio que presupuestamos es el precio final.</p>
            <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
              <p>"Según el Colegio de Aparejadores de Baleares, un presupuesto detallado debe incluir descripción de unidades de obra, mediciones, precios unitarios y plazo de ejecución"</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">— Col·legi d'Aparelladors de les Illes Balears</cite>
            </blockquote>
          </div>
        </div>

        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">Preguntas frecuentes sobre presupuestos</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">¿El presupuesto es realmente gratis?</h3>
