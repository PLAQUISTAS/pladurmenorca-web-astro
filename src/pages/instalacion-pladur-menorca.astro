      desc: 'El equipo protege suelos, muebles y zonas adyacentes con lonas y plásticos. No hay obra húmeda, los escombros se reducen al mínimo y el polvo se aspira durante el corte de placas.',
      detalle: 'Protección completa del espacio de trabajo',
      iconPath: 'M11.42 15.17l-5.384 3.079A2.25 2.25 0 013 16.19V7.81a2.25 2.25 0 013.036-2.059l5.384 3.079m0 0L17.25 12m-5.83-3.17L17.25 12m0 0l-5.83 3.17M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    },
    {
      num: '04',
      titulo: 'Entrega con acabado perfecto',
      desc: 'Entrega lista para pintar: juntas tratadas con pasta y cinta de fibra, superficies lijadas a grano 120 y esquinas reforzadas con guardavivos metálicos. Limpieza final incluida.',
      detalle: 'Listo para pintar o revestir',
      iconPath: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    },
  ],
  garantia: 'Garantía de 1 año.',
  garantiaDesc: 'Todos los trabajos incluyen 1 año de garantía en mano de obra: incidencias resueltas sin coste adicional durante ese período. Los materiales mantienen la garantía de fábrica de Placo, Knauf o Lafarge (normalmente 10 años en placa).',
  hotelTexto: '¿Gestionas un hotel en Menorca? Descubre cómo aplicamos pladur ignífugo y aislamiento acústico en',
  hotelTextoBold: 'reformas hoteleras con plazos garantizados',
  hotelCta: 'Pladur para hoteles',
  hotelHref: '/pladur-hoteles-menorca',
  galeriaAlts: [
    'Reforma integral con instalación de pladur en casco histórico de Baleares',
    'Acabados de pladur e instalación en cocina de Baleares',
    'Instalación de pladur en salón de villa en Baleares',
    'Instalación de pladur en oficina open space en Baleares',
  ],
  faqTitulo: 'Preguntas frecuentes sobre instalación de pladur',
  faqSubtitulo: 'Todo lo que necesitas saber antes de comenzar tu proyecto de pladur en Menorca.',
  ctaTitulo: '¿Listo para tu proyecto de pladur en Menorca?',
  ctaSubtitulo: 'Presupuesto gratuito en 24 horas. Precio cerrado. Sin sorpresas.',
}

const schemaOffersPrices = ['29', '45', '29', '45']
const schemaOffers = t.schemaOffers.map((o, i) => ({ ...o, price: schemaOffersPrices[i] }))

const pageBase = lang === 'en' ? '/en/instalacion-pladur-menorca' : '/instalacion-pladur-menorca'
const homeHref = lang === 'en' ? '/en/' : '/'
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: homeHref }, { label: t.breadcrumbCurrent, href: pageBase }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService
      name={servicio.schema.name}
      description={servicio.schema.description}
      serviceType={servicio.schema.serviceType}
      url={`https://www.pladurmenorca.com${pageBase}`}
      image="https://www.pladurmenorca.com/images/proyectos/villa-obra-nueva-pladur-integral.webp"

    />
    <SchemaHowTo
      name={t.schemaHowToName}
      description={t.schemaHowToDescription}
      totalTime="PT72H"
      steps={t.schemaSteps}
    />
    <SchemaOffers offers={schemaOffers} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">
    {t.srOnly}
  </p>

  <!-- 1. Hero -->
  <Hero
    title={servicio.h1}
    subtitle={t.heroSubtitle}
    description={t.heroDescription}
    dark={true}
    badges={t.heroBadges}
    ctaPrimario={{ texto: t.ctaPrimario, href: p('/presupuesto-pladur') }}
    ctaSecundario={{ texto: `${t.ctaCallPrefix} ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- 3. ¿Qué es el pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              {t.sectionIntroEyebrow}
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              {t.sectionIntroTitle}
            </h2>
          </div>
          <div class="space-y-8 text-muted leading-relaxed">
            {/* Intro — paragraphs tightened */}
            <p class="text-lg">{t.intro1}</p>

            {/* Key specs strip — replaces intro2 + intro3 walls */}
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-warm-border/50 rounded-3xl overflow-hidden border border-warm-border/50">
              {[
                { k: lang === 'en' ? 'Core' : 'Núcleo', v: lang === 'en' ? 'High-purity gypsum' : 'Yeso alta pureza' },
                { k: lang === 'en' ? 'Thickness' : 'Espesor', v: '10 · 12,5 · 15 mm' },
                { k: lang === 'en' ? 'Weight' : 'Peso', v: '8–12 kg/m²' },
                { k: lang === 'en' ? 'Execution' : 'Ejecución', v: lang === 'en' ? '5–10 days / 50 m²' : '5–10 días / 50 m²' },
              ].map((s) => (
                <div class="bg-white/80 px-4 py-5 text-center">
                  <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted/80 mb-1">{s.k}</p>
                  <p class="text-sm font-bold text-foreground">{s.v}</p>
                </div>
              ))}
            </div>

            <p>{t.intro2}</p>
            <p>{t.intro3}</p>

            {/* Marcas — chip row clean */}
            <div class="pt-6 border-t border-warm-border/50">
              <h3 class="text-xl font-bold text-foreground mb-2">{t.marcasTitulo}</h3>
              <p class="mb-5">{t.marcasIntro}</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {[
                  { name: t.marcaPlaco, desc: t.marcaPlacoDesc },
                  { name: t.marcaKnauf, desc: t.marcaKnaufDesc },
                  { name: t.marcaLafarge, desc: t.marcaLafargeDesc },
                ].map((brand) => (
                  <div class="bg-white/70 border border-warm-border/50 rounded-2xl p-5">
                    <p class="font-bold text-foreground text-sm mb-2">{brand.name.replace(/:$/, '')}</p>
                    <p class="text-xs text-muted leading-relaxed">{brand.desc}</p>
                  </div>
                ))}
              </div>
            </div>

            {/* Tipos de placa — preserved as it was visual */}
            <div class="pt-6 border-t border-warm-border/50">
              <h3 class="text-xl font-bold text-foreground mb-2">{t.tiposTitulo}</h3>
              <p class="mb-5">{t.tiposIntro}</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {t.placaTipos.map((p) => (
                  <div class="bg-white/70 rounded-3xl border border-warm-border/50 p-5">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <p class="font-bold text-foreground text-sm">{p.tipo}</p>
                      <span class="text-[10px] font-semibold uppercase tracking-wide text-foreground bg-surface px-2 py-0.5 rounded-md shrink-0">
                        {p.tag}
                      </span>
                    </div>
                    <p class="text-sm text-muted leading-relaxed">{p.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <ContactoRapidoCard lang={lang} />

            <div class="p-6 bg-white/70 border border-warm-border/50 rounded-3xl">
              <p class="font-bold text-foreground text-sm mb-4 uppercase tracking-wider">
                {t.sidebarRelatedTitle}
              </p>
              <ul class="space-y-2">
                {t.serviciosRelacionados.map((s) => (
                  <li>
                    <a
                      href={s.href}
                      class="flex items-center gap-2 text-sm text-muted hover:text-foreground transition-colors py-1"
                    >
                      <svg aria-hidden="true" class="size-3.5 text-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- 4. ServiciosGrid -->
  <ServiciosGrid lang={lang} />

  <!-- 5. ¿Por qué elegir pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          {t.ventajasEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6 max-w-3xl">
          {t.ventajasTitle}
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="space-y-5 text-muted leading-relaxed">
          <p>{t.ventajas1}</p>
          <p>{t.ventajas2}</p>
          <p>{t.ventajas3}</p>
          <p>{t.ventajas4}</p>
        </div>

        <!-- Tabla comparativa — desktop -->
        <div class="hidden sm:block">
          <div class="rounded-3xl overflow-hidden border border-warm-border shadow-card">
            <table class="min-w-full">
              <thead>
                <tr class="bg-foreground">
                  <th class="px-5 py-4 text-left text-xs font-bold text-white/70 uppercase tracking-wider w-[35%]">{t.tablaCriterio}</th>
                  <th class="px-5 py-4 text-left text-xs font-bold text-white uppercase tracking-wider w-[35%]">
                    <span class="flex items-center gap-1.5">
                      <svg aria-hidden="true" class="size-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                      {t.tablaPladur}
                    </span>
                  </th>
                  <th class="px-5 py-4 text-left text-xs font-bold text-white/50 uppercase tracking-wider w-[30%]">{t.tablaLadrillo}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-warm-border/50">
                {t.tablaComparativa.map(([criterio, pladur, ladrillo], i) => (
                  <tr class={`${i % 2 === 0 ? 'bg-white/70' : 'bg-white/40'} hover:bg-surface/60 transition-colors duration-200`}>
                    <td class="px-5 py-3.5 text-sm font-semibold text-foreground">{criterio}</td>
                    <td class="px-5 py-3.5 text-sm text-foreground font-bold">
                      <span class="flex items-center gap-1.5">
                        <svg aria-hidden="true" class="size-3.5 text-foreground shrink-0" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        {pladur}
                      </span>
                    </td>
                    <td class="px-5 py-3.5 text-sm text-muted/70">{ladrillo}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Tabla comparativa — mobile (card layout) -->
        <div class="sm:hidden space-y-3 -mx-4 px-4">
          {t.tablaComparativa.map(([criterio, pladur, ladrillo]) => (
            <div class="bg-white/70 rounded-2xl border border-warm-border/50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-muted mb-3">{criterio}</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-wide text-foreground mb-1">{t.tablaPladur}</p>
                  <p class="text-sm font-bold text-foreground flex items-center gap-1.5">
                    <svg aria-hidden="true" class="size-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {pladur}
                  </p>
                </div>
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-wide text-muted mb-1">{t.tablaLadrillo}</p>
                  <p class="text-sm text-muted/70">{ladrillo}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Cita normativa -->
  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <blockquote class="border-l-4 border-foreground-dark/20 pl-6 my-8 italic text-muted">
        <p>{t.citaTexto}</p>
        <cite class="block mt-2 not-italic text-sm font-medium text-foreground-dark">{t.citaFuente}</cite>
      </blockquote>
    </div>
  </section>

  <!-- 6. Proceso de trabajo -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          {t.procesoEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-2xl">
          {t.procesoTitle}
        </h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-2xl">
          {t.procesoIntro}
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-5 sm:left-7 top-0 bottom-0 w-px bg-warm-border" aria-hidden="true"></div>

        <div class="space-y-0">
          {t.pasos.map((paso, i) => (
            <div class="relative flex gap-6 sm:gap-8">
              <!-- Node -->
              <div class="relative z-10 flex flex-col items-center shrink-0">
                <div class="size-10 sm:w-14 sm:h-14 rounded-full bg-foreground flex items-center justify-center text-white text-xs sm:text-sm font-bold shadow-lg shadow-foreground/20">
                  {paso.num}
                </div>
                {i < t.pasos.length - 1 && (
                  <div class="flex-1"></div>
                )}
              </div>

              <!-- Content -->
              <div class={`flex-1 ${i < t.pasos.length - 1 ? 'pb-10 sm:pb-12' : 'pb-0'}`}>
                <div class="bg-white/70 rounded-3xl border border-warm-border/50 p-6 sm:p-7 shadow-card hover:shadow-card-hover transition-shadow duration-300">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <h3 class="font-bold text-foreground text-base sm:text-lg">{paso.titulo}</h3>
                    <div class="w-9 h-9 bg-surface border border-nav-border rounded-xl flex items-center justify-center shrink-0">
                      <svg aria-hidden="true" class="w-4.5 h-4.5 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d={paso.iconPath} />
                      </svg>
                    </div>
                  </div>
                  <p class="text-sm text-muted leading-relaxed mb-4">{paso.desc}</p>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-foreground bg-surface px-3 py-1 rounded-lg">
                    <svg aria-hidden="true" class="size-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {paso.detalle}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10 p-6 bg-white/70 border border-warm-border/50 rounded-3xl">
        <p class="text-sm text-muted leading-relaxed">
          <strong class="text-foreground">{t.garantia}</strong> {t.garantiaDesc}
        </p>
      </div>
    </Container>
  </section>

  <!-- 7. NuestrosDatos — benchmarks generales de instalación -->
  <NuestrosDatos lang={lang} />

  <!-- 8. PreciosTable -->
  <PreciosTable variant="resumen" lang={lang} />

  <!-- 8. ZonasServicio -->
  <ZonasServicio lang={lang} />

  <!-- 9. GaleriaTrabajos -->
  <GaleriaTrabajos imagenes={[
    { src: '/images/proyectos/reforma-integral-piso.webp', alt: t.galeriaAlts[0] },
    { src: '/images/proyectos/acabados-pladur-madera-cocina.webp', alt: t.galeriaAlts[1] },
    { src: '/images/proyectos/salon-falso-techo-villa.webp', alt: t.galeriaAlts[2] },
    { src: '/images/proyectos/oficina-open-space-tabiques.webp', alt: t.galeriaAlts[3] },
  ]} />

  <!-- 10. FaqAccordion -->
  <FaqAccordion
    client:visible
    faqs={pageFaqs}
    lang={lang}
    titulo={t.faqTitulo}
    subtitulo={t.faqSubtitulo}
  />

  <!-- Enlace a hoteles -->
  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-foreground rounded-3xl p-7 sm:p-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-white/80 text-sm leading-relaxed">{t.hotelTexto} <strong class="text-white">{t.hotelTextoBold}</strong>.</p>
        <a href={t.hotelHref} class="inline-flex items-center gap-2 text-white font-semibold underline underline-offset-2 text-sm shrink-0">
          {t.hotelCta}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 11. CtaBanner -->
  <CtaBanner
    lang={lang}
    titulo={t.ctaTitulo}
    subtitulo={t.ctaSubtitulo}
    showForm={true}
  />

  <ServiciosRelacionados currentPath="/instalacion-pladur-menorca" />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
