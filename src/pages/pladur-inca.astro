---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import PaginaGeografica from '@/components/templates/PaginaGeografica.astro'
import { faqs } from '@/data/faqs'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur en Inca | Instaladores | Reformas y Presupuesto Gratis',
  description: 'Instalación de pladur en Inca y Raiguer de Mallorca. Falsos techos, tabiques y aislamiento. Binissalem, Lloseta, Selva. Presupuesto gratis. ☎ 627 829 723',
  canonical: '/pladur-inca',
}

const zonas = [
  {
    nombre: 'Inca centro',
    descripcion: 'Casas de pueblo señoriales y pisos del ensanche. Rehabilitación de viviendas antiguas con techos altos, redistribución de espacios y modernización de locales comerciales del centro histórico.',
  },
  {
    nombre: 'Binissalem',
    descripcion: 'Pueblo vinícola con casas tradicionales de piedra. Proyectos de reforma conservando el carácter: falsos techos, trasdosados térmicos y aislamiento acústico en viviendas adosadas.',
  },
  {
    nombre: 'Lloseta',
    descripcion: 'Antiguo pueblo industrial del calzado. Reconversión de naves y talleres en viviendas y espacios de trabajo. Pladur ideal para dividir grandes espacios y crear oficinas modernas.',
  },
  {
    nombre: 'Selva',
    descripcion: 'Pueblo de montaña con casas de piedra y fincas rústicas. Trasdosados térmicos para combatir el frío invernal y falsos techos para modernizar estancias con vigas deterioradas.',
  },
  {
    nombre: 'Alaró',
    descripcion: 'Pueblo a los pies de la sierra de Tramuntana. Casas de pueblo reformadas como residencia habitual o segunda vivienda. Alta demanda de aislamiento térmico y redistribución de espacios.',
  },
  {
    nombre: 'Santa Maria del Camí',
    descripcion: 'Conexión entre Palma y el Raiguer. Crecimiento residencial con viviendas nuevas y rehabilitación de casas antiguas. Tabiques de distribución y falsos techos en reformas integrales.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Pladur en Inca', href: '/pladur-inca' },
]

const pageFaqs = faqs['inca'] ?? []

const proyectoFicha = [
  { label: 'Superficie', valor: '180 m²' },
  { label: 'Ubicación', valor: 'Zona industrial, Inca' },
  { label: 'Trabajos', valor: 'Tabiques + Techo registrable + Aislamiento' },
  { label: 'Duración', valor: '12 días hábiles' },
  { label: 'Resultado', valor: 'Nave convertida en 3 oficinas + sala reuniones' },
]

const serviciosLinks = [
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Precios', href: '/precios-pladur-mallorca' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Inca"
      description="Servicio profesional de instalación de pladur en Inca y el Raiguer de Mallorca: falsos techos, tabiques, aislamiento acústico y térmico en Binissalem, Lloseta, Selva, Alaró y Santa Maria del Camí."
      serviceType="Instalación de Pladur"
      url="/pladur-inca"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Inca. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Inca"
    zonas={zonas}
    faqKey="inca"
    heroTitle="Pladur en Inca — Instalación y Reformas en el Raiguer de Mallorca"
    heroBadge="Inca · Raiguer de Mallorca"
    heroDescription="Instalamos pladur en Inca y toda la comarca del Raiguer: Binissalem, Lloseta, Selva, Alaró y Santa Maria del Camí. Rehabilitación de casas antiguas, reforma de locales y aislamiento térmico. Presupuesto gratuito en 24 horas."
    faqTitulo="Preguntas frecuentes sobre pladur en Inca"
    faqSubtitulo="Respuestas a las dudas más habituales de nuestros clientes en Inca y el Raiguer."
    proyectoTitulo="Reconversión de nave industrial en oficinas en Inca"
    proyectoFicha={proyectoFicha}
    ctaTitulo="¿Tu proyecto está en Inca o el Raiguer?"
    ctaSubtitulo="Contacta ahora y recibe tu presupuesto gratuito en menos de 24 horas. Sin desplazamiento en toda la comarca."
  >
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-10">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Especialistas en el Raiguer
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            Reformas con pladur en Inca: rehabilitación y modernización en el corazón de Mallorca
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-5 text-muted leading-relaxed mb-12">
          <div class="space-y-5">
            <p>
              Inca es la tercera ciudad de Mallorca y la capital comercial del Raiguer, la comarca que se extiende entre la llanura central y las estribaciones de la Sierra de Tramuntana. Con un patrimonio arquitectónico rico en casas señoriales, una herencia industrial del calzado y un crecimiento residencial sostenido, Inca presenta oportunidades únicas para las reformas con pladur.
            </p>
            <p>
              El centro histórico de Inca alberga casas de pueblo de los siglos XVIII y XIX con muros de piedra de marès, techos de vigas de madera y distribuciones pensadas para familias numerosas de otra época. Estas viviendas, que hoy se rehabilitan como residencia habitual o se adquieren como inversión, se benefician enormemente del pladur: los trasdosados mejoran el <a href="/aislamiento-termico-mallorca">aislamiento térmico</a> de los gruesos muros de piedra —que en invierno son fríos y propensos a la condensación—, los <a href="/falsos-techos-pladur-mallorca">falsos techos</a> ocultan vigas deterioradas e integran iluminación moderna, y los tabiques permiten crear distribuciones funcionales sin alterar la estructura portante original.
            </p>
            <p>
              La herencia industrial de Inca ha dejado un legado de naves, talleres y fábricas de calzado que se están reconvirtiendo en lofts, espacios de coworking, estudios creativos y viviendas tipo loft. El pladur es la herramienta perfecta para estas reconversiones: permite dividir grandes diáfanos en estancias funcionales con <a href="/tabiques-pladur-mallorca">tabiques de distribución</a>, crear oficinas con aislamiento acústico entre ellas, instalar falsos techos registrables para ocultar instalaciones industriales y mejorar la eficiencia energética de espacios con grandes cubiertas sin aislamiento.
            </p>
          </div>
          <div class="space-y-5">
            <p>
              Inca es además un centro de servicios con una importante actividad comercial. Los locales del centro —tiendas, oficinas, consultas, restaurantes— necesitan reformas periódicas para adaptarse a nuevos usos o modernizar su imagen. El pladur permite realizar estas reformas en plazos muy cortos, minimizando el tiempo de cierre del negocio: un local comercial de 100 m² puede tener falso techo nuevo, tabiques de distribución y aislamiento acústico en menos de una semana.
            </p>
            <p>
              Los pueblos del Raiguer —Binissalem, Lloseta, Selva, Alaró, Santa Maria del Camí— comparten características constructivas similares: casas de pueblo con muros de piedra, techos altos y distribuciones heredadas. En todos ellos, el pladur ofrece la misma solución eficiente: reformas rápidas, limpias y económicas que modernizan la vivienda sin alterar su estructura ni su carácter.
            </p>
            <p>
              Trabajamos en toda la comarca del Raiguer sin coste adicional de desplazamiento. Nuestro equipo conoce los materiales locales, las particularidades de la construcción tradicional mallorquina y las normativas urbanísticas de cada municipio.
            </p>
          </div>
        </div>
        <div class="bg-foreground rounded-3xl p-7 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-bold text-lg text-white mb-2">Experiencia en el Raiguer</p>
              <p class="text-white/60 text-sm leading-relaxed mb-4">Más de 20 años trabajando en Inca y toda la comarca del Raiguer. Conocemos las casas de pueblo, las naves industriales reconvertidas y los retos de la construcción tradicional mallorquina.</p>
              <div class="flex items-center gap-2">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-white/60 text-xs">4.7/5 en Google</span>
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-3">Servicios en Inca</p>
              <div class="grid grid-cols-2 gap-2">
                {serviciosLinks.map((s) => (
                  <a href={s.href} class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors">
                    <svg aria-hidden="true" class="size-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Una antigua nave de fabricacion de calzado de 180 m² en la zona industrial de Inca iba a reconvertirse en un espacio de oficinas para una empresa de servicios digitales. El local conservaba la estructura diáfana original con cubierta de uralita ya sustituida por panel sándwich, suelo de hormigón pulido y una altura libre de 4,5 metros. El propietario necesitaba crear tres despachos independientes, una sala de reuniones acristalada y una zona común de trabajo abierto.
      </p>
      <p>
        Se instalaron 52 metros lineales de tabiques de pladur con doble placa y lana mineral de 48 mm para garantizar privacidad acústica entre despachos (reducción de 47 dB). La sala de reuniones se ejecutó con tabiques de pladur hasta 2,70 m de altura y cerramiento de vidrio en la parte superior. Se montó un falso techo registrable de 60x60 cm en toda la superficie para integrar luminarias, conductos de climatización y cableado de red, bajando la altura útil a 2,80 m para mejorar la eficiencia del aire acondicionado.
      </p>
      <p>
        El proyecto se completó en 12 días hábiles con un coste aproximado de 14.200 euros. La empresa pudo trasladarse a las nuevas oficinas solo tres semanas después de la visita técnica inicial, evitando meses de obra convencional. El resultado fue un espacio profesional y moderno que conserva el carácter industrial de la nave original, con un ahorro energético del 30% gracias al falso techo que redujo el volumen de aire a climatizar.
      </p>
    </div>
  </PaginaGeografica>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
