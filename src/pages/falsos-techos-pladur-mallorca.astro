---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import Hero from '@/components/sections/Hero'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import GaleriaTrabajos from '@/components/sections/GaleriaTrabajos.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import ArticulosRelacionados from '@/components/sections/ArticulosRelacionados.astro'
import Container from '@/components/ui/Container.astro'
import { falsosTechosFaqs } from '@/data/faqs/falsos-techos'
import { getServicioBySlug } from '@/data/servicios'
import { siteConfig } from '@/data/site'

const servicio = getServicioBySlug('falsos-techos-pladur-mallorca')!
const pageFaqs = falsosTechosFaqs

const meta = {
  title: 'Falsos Techos de Pladur en Mallorca | Desde 29€/m²',
  description: 'Instalación de falsos techos de pladur en Mallorca. Techos continuos, decorativos, registrables y acústicos desde 29€/m². Presupuesto gratis. ☎ 627 829 723',
  canonical: '/falsos-techos-pladur-mallorca',
}

const tiposTecho = [
  {
    num: '01',
    titulo: 'Falso techo continuo básico',
    desc: 'Es la solución más económica y la más instalada en viviendas y oficinas. Se compone de una estructura de perfiles de acero galvanizado (maestras y omegas) anclada al forjado y una placa de yeso laminado estándar BA13 atornillada a la estructura. El resultado es un techo perfectamente liso, sin juntas visibles, listo para pintar. Permite integrar iluminación empotrada de forma sencilla.',
    bajada: '10-15 cm',
    precio: 'Desde 29€/m²',
    ideal: 'Viviendas, oficinas, locales',
    ventajas: ['Acabado limpio y homogéneo', 'Posibilidad de iluminación empotrada', 'Rápida instalación', 'Económico'],
  },
  {
    num: '02',
    titulo: 'Falso techo continuo registrable',
    desc: 'Variante del continuo básico que incorpora una o varias trampillas de registro. Estas trampillas permiten acceder al espacio interior del techo para revisar o reparar instalaciones sin necesidad de demoler el techo. Es la solución recomendada cuando hay tuberías de fontanería, cabezales de sprinklers, conexiones de climatización o cualquier otro elemento que pueda requerir mantenimiento futuro.',
    bajada: '10-20 cm',
    precio: 'Desde 29€/m²',
    ideal: 'Pisos con instalaciones que mantener',
    ventajas: ['Acceso a instalaciones ocultas', 'Sin obra para revisiones', 'Mismo acabado que continuo', 'Mayor seguridad de mantenimiento'],
  },
  {
    num: '03',
    titulo: 'Falso techo decorativo con molduras',
    desc: 'Para los proyectos que buscan un resultado diferencial, el techo decorativo permite incorporar molduras perimetrales, cornisas, artesonados, casetones y formas geométricas o curvas. Este tipo de techo requiere un nivel de planificación y ejecución más alto y es el que mayor impacto visual produce en el espacio. Es muy demandado en viviendas de lujo en zonas como Son Vida, Portals Nous o Génova.',
    bajada: '15-25 cm',
    precio: 'Desde 45€/m²',
    ideal: 'Viviendas de lujo, restaurantes, hoteles',
    ventajas: ['Alto impacto visual', 'Personalización total', 'Revalorización del inmueble', 'Acabados premium'],
  },
  {
    num: '04',
    titulo: 'Falso techo acústico',
    desc: 'Diseñado para reducir la transmisión de ruido entre plantas. Utiliza una suspensión antivibratoria que desvincula mecánicamente el techo nuevo del forjado, combinada con lana mineral de alta densidad en la cámara de aire y doble placa de yeso laminado. El resultado es una reducción de entre 8 y 15 dB adicionales respecto a un techo convencional, contribuyendo a cumplir con los requisitos del CTE-HR para separación entre viviendas.',
    bajada: '15-25 cm',
    precio: 'Desde 35€/m²',
    ideal: 'Pisos con vecinos ruidosos, hoteles, estudios',
    ventajas: ['Reducción 8-15 dB adicionales', 'Cumple CTE-HR', 'Ideal para turísticos y hostales', 'Suspensión antivibratoria'],
  },
  {
    num: '05',
    titulo: 'Falso techo técnico con integración LED',
    desc: 'La solución más completa para proyectos de interiorismo avanzado. Integra en el mismo techo la estructura de pladur, los cajetines para iluminación LED empotrada, el cableado eléctrico, los dimmers o sistemas de control inteligente y, opcionalmente, las salidas de climatización o difusores de ventilación. El resultado es un espacio donde todo el techo funciona como un sistema unificado de iluminación y ambiente.',
    bajada: '20-30 cm',
    precio: 'Desde 47€/m²',
    ideal: 'Locales, restaurantes, viviendas premium',
    ventajas: ['Iluminación integrada', 'Cableado oculto', 'Gestión inteligente opcional', 'Diseño de interiores avanzado'],
  },
]

const tablaResumen = [
  ['Continuo básico', '10 cm', '29€/m²', 'Viviendas y oficinas'],
  ['Continuo registrable', '10 cm', '29€/m²', 'Espacios con instalaciones'],
  ['Decorativo con molduras', '15 cm', '45€/m²', 'Residencias de lujo'],
  ['Acústico', '15 cm', '35€/m²', 'Hoteles y viviendas ruidosas'],
  ['Técnico con LED', '20 cm', '47€/m²', 'Locales y espacios premium'],
]

const ventajas = [
  {
    titulo: 'Oculta instalaciones',
    desc: 'Esconde cables eléctricos, tuberías de fontanería, conductos de climatización y sistemas de ventilación. El espacio queda limpio y ordenado sin intervención en la estructura.',
    iconPath: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
  },
  {
    titulo: 'Mejora el aislamiento acústico',
    desc: 'Un falso techo bien diseñado mejora el aislamiento frente al ruido de impacto y aéreo entre plantas entre 8 y 15 dB. Esencial en edificios con varios pisos y en zonas turísticas ruidosas.',
    iconPath: 'M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z',
  },
  {
    titulo: 'Reducción térmica',
    desc: 'Al crear una cámara de aire con lana mineral, reduce la transmisión de calor en hasta un 30%. En Mallorca, donde el calor en verano es intenso, esto se traduce en menor consumo de aire acondicionado.',
    iconPath: 'M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1.001A3.75 3.75 0 0012 18z',
  },
  {
    titulo: 'Acabado premium listo para pintar',
    desc: 'La superficie de las placas de pladur, correctamente tratadas, es perfectamente plana y homogénea. Acepta cualquier tipo de pintura, textura o revestimiento sin preparaciones adicionales.',
    iconPath: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  },
  {
    titulo: 'Sin obras ni demoliciones',
    desc: 'No es necesario picar el techo original, no se generan toneladas de escombros y el polvo es mínimo. Los vecinos apenas se enteran de que se está reformando el piso.',
    iconPath: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    titulo: 'Plazo rápido de ejecución',
    desc: 'Un falso techo de 50 m² se instala en 1-2 jornadas. Una reforma completa de techo en un piso de 90 m² se termina en 3-5 días. El tiempo es un bien escaso en Mallorca, especialmente en zonas turísticas.',
    iconPath: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
  },
]

const plazos = [
  { superficie: 'Hasta 30 m²', tipo: 'Techo básico', tiempo: '4-6 horas', incluye: 'Solo estructura y placa' },
  { superficie: '30-80 m²', tipo: 'Techo básico + electricidad', tiempo: '1-2 días', incluye: 'Estructura, placa y cableado' },
  { superficie: '50-100 m²', tipo: 'Techo acústico', tiempo: '2-3 días', incluye: 'Suspensión, lana mineral, doble placa' },
  { superficie: 'Cualquier m²', tipo: 'Techo decorativo', tiempo: '3-7 días', incluye: 'Molduras, formas y acabados premium' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService
      name={servicio.schema.name}
      description={servicio.schema.description}
      serviceType={servicio.schema.serviceType}
      url="https://www.pladurmallorca.com/falsos-techos-pladur-mallorca"
      image="https://www.pladurmallorca.com/images/proyectos/salon-falso-techo-pladur-villa-mallorca.webp"
     
    />
    <SchemaHowTo
      name="Cómo instalar un falso techo de pladur"
      description="Proceso completo de instalación de falso techo de pladur en 7 pasos: desde la medición inicial hasta el acabado final listo para pintar."
      totalTime="PT2D"
      steps={[
        { name: 'Medición y planificación', text: 'Se toman medidas exactas de la estancia y se planifica la altura del falso techo, ubicación de luminarias y posibles registros para instalaciones.' },
        { name: 'Marcado de niveles', text: 'Se marca el nivel del falso techo en todas las paredes con láser rotativo para garantizar una superficie perfectamente horizontal.' },
        { name: 'Instalación de perfiles perimetrales', text: 'Se fijan los perfiles en L o en U en todo el perímetro de la estancia, con banda acústica para evitar transmisión de ruido.' },
        { name: 'Colocación de varillas y perfilería', text: 'Se instalan las varillas roscadas de suspensión ancladas al forjado y los perfiles primarios y secundarios formando la estructura portante.' },
        { name: 'Paso de instalaciones', text: 'Se distribuyen las instalaciones eléctricas, conductos de aire acondicionado y cualquier otro servicio que deba quedar oculto sobre el falso techo.' },
        { name: 'Atornillado de placas', text: 'Se atornillan las placas de yeso laminado a la estructura metálica con tornillos autoroscantes cada 20-25 cm, dejando juntas de dilatación.' },
        { name: 'Tratamiento de juntas y acabado', text: 'Se tratan las juntas con cinta y pasta, se lijan y se deja la superficie completamente lisa y lista para pintar.' },
      ]}
    />
    <SchemaOffers
      offers={[
        { name: 'Falso techo continuo liso', price: '29', description: 'Falso techo de pladur continuo liso con estructura metálica y acabado listo para pintar. Precio por m².' },
        { name: 'Falso techo con aislamiento acústico', price: '35', description: 'Falso techo de pladur con lana mineral para aislamiento acústico incluido. Precio por m².' },
        { name: 'Falso techo decorativo con molduras', price: '45', description: 'Falso techo decorativo con molduras de pladur, diseño personalizado. Precio por m².' },
        { name: 'Falso techo registrable', price: '29', description: 'Falso techo registrable con placas desmontables para fácil acceso a instalaciones. Precio por m².' },
        { name: 'Falso techo con iluminación LED integrada', price: '47', description: 'Falso techo con foseado perimetral e iluminación LED integrada. Precio por m².' },
      ]}
    />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — falsos techos de pladur en toda Mallorca. Techos lisos, registrables, decorativos y acústicos. Precios desde 29€/m². Más de 6.000 proyectos. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <Hero
    client:visible
    title="Falsos Techos de Pladur en Mallorca — Continuos, Decorativos y Acústicos"
    subtitle="Instalación profesional en toda la isla desde 29€/m²"
    description="Especialistas en falsos techos de pladur en Mallorca. Transformamos techos con obra mínima: techos continuos, registrables, decorativos, acústicos e integración LED. +20 años de experiencia. Presupuesto gratis."
    dark={true}
    badges={['Desde 29€/m²', '+20 años', 'Toda Mallorca']}
    ctaPrimario={{ texto: 'Pedir presupuesto gratis', href: '/presupuesto-pladur' }}
    ctaSecundario={{ texto: `Llamar: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- ¿Qué es un falso techo de pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              Introducción
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              ¿Qué es un falso techo de pladur?
            </h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>
              Un falso techo de pladur es una estructura horizontal suspendida del forjado original mediante
              perfiles metálicos, sobre la que se instalan placas de yeso laminado para crear un nuevo plano de
              techo a la altura deseada. Esta solución permite ocultar el forjado existente —con todas sus
              instalaciones, cables, tuberías y posibles irregularidades— y obtener una superficie completamente
              plana, lisa y lista para pintar.
            </p>
            <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
              <p>"El Código Técnico de la Edificación establece que los elementos constructivos horizontales deben cumplir la exigencia básica SI 1 de propagación interior, garantizando la seguridad en caso de incendio"</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">— CTE-DB-SI, Documento Básico de Seguridad en caso de Incendio, Art. 4</cite>
            </blockquote>
            <p>
              Según las fichas técnicas de Knauf, los sistemas de falso techo D112 alcanzan una resistencia al fuego de hasta EI 120 con doble placa cortafuegos, superando con creces los requisitos normativos de Baleares.
            </p>
            <p>
              En Mallorca, los falsos techos de pladur son especialmente populares en varios contextos. Los
              edificios históricos del centro de Palma, con sus techos de viga vista o forjados unidireccionales
              irregulares, son candidatos ideales para esta solución. Los apartamentos turísticos de Calvià,
              Alcúdia o Magaluf los utilizan para modernizar sus interiores entre temporadas sin afectar la
              estructura. Y las oficinas y locales comerciales de toda la isla recurren a ellos para integrar
              sistemas de climatización, iluminación y telecomunicaciones de forma ordenada y estética.
            </p>
            <p>
              La instalación de un falso techo de pladur no requiere obra húmeda: no se utilizan cementos ni
              morteros, no se generan escombros de envergadura y el espacio puede utilizarse de nuevo al día
              siguiente de finalizar el trabajo. El tiempo de instalación de un techo de 50 m² oscila entre
              1 y 2 jornadas de trabajo.
            </p>

            <!-- Enlace interno -->
            <p class="text-sm text-muted">
              ¿Quieres saber cuánto cuesta?
              <a href="/precios-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">
                Consulta nuestra guía de precios de pladur en Mallorca
              </a>
              o
              <a href="/instalacion-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">
                conoce todos nuestros servicios de instalación
              </a>
              .
            </p>
          </div>
        </div>

        <!-- Sidebar CTA -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <div class="p-6 bg-foreground text-white rounded-3xl">
              <p class="text-xs font-bold uppercase tracking-widest text-nav-border/60 mb-3">
                Presupuesto gratis
              </p>
              <p class="font-bold text-lg mb-2">Falso techo en tu hogar o negocio</p>
              <p class="text-gray-300 text-sm mb-5 leading-relaxed">
                Visitamos tu espacio, tomamos medidas y te enviamos presupuesto en 24h.
              </p>
              <a
                href="/presupuesto-pladur"
                class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide transition-colors"
              >
                Pedir presupuesto online
              </a>
              <a
                href={`tel:${siteConfig.phoneRaw}`}
                class="flex items-center justify-center gap-2 w-full py-3 mt-3 rounded-xl border border-white/30 hover:border-white text-white font-bold text-sm tracking-wide transition-colors"
              >
                <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                {siteConfig.phone}
              </a>
            </div>
            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl">
              <p class="font-semibold text-foreground text-sm mb-3">Ver también:</p>
              <ul class="space-y-2">
                {[
                  { label: 'Instalación de Pladur', href: '/instalacion-pladur-mallorca' },
                  { label: 'Precios del Pladur', href: '/precios-pladur-mallorca' },
                  { label: 'Pladur en Palma', href: '/pladur-palma' },
                  { label: 'Tabiques de Pladur', href: '/tabiques-pladur-mallorca' },
                ].map((s) => (
                  <li>
                    <a
                      href={s.href}
                      class="flex items-center gap-2 text-sm text-muted hover:text-foreground transition-colors py-0.5"
                    >
                      <svg class="size-3.5 text-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tipos de falsos techos -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          Catálogo de soluciones
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">
          Tipos de falsos techos que instalamos en Mallorca
        </h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">
          Cada proyecto es diferente. Por eso ofrecemos cinco soluciones de falso techo adaptadas a las necesidades
          concretas de cada espacio, presupuesto y objetivo estético.
        </p>
      </div>

      <div class="space-y-6">
        {tiposTecho.map((tipo) => (
          <div class="bg-white/70 border border-warm-border/50 rounded-3xl overflow-hidden shadow-card hover:shadow-card-hover transition-shadow duration-300">
            <div class="grid grid-cols-1 lg:grid-cols-12">
              <div class="lg:col-span-8 p-8 lg:p-10">
                <div class="flex items-center gap-3 mb-4">
                  <span class="size-10 rounded-xl bg-foreground text-white text-xs font-bold flex items-center justify-center shrink-0">{tipo.num}</span>
                  <h3 class="text-xl font-bold text-foreground">{tipo.titulo}</h3>
                </div>
                <p class="text-sm text-muted leading-relaxed mb-5">{tipo.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {tipo.ventajas.map((v) => (
                    <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 bg-surface text-foreground font-medium rounded-lg">
                      <svg aria-hidden="true" class="size-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {v}
                    </span>
                  ))}
                </div>
              </div>
              <div class="lg:col-span-4 bg-foreground p-8 flex flex-col justify-center gap-5 lg:rounded-r-3xl">
                {[
                  { label: 'Bajada mínima', value: tipo.bajada },
                  { label: 'Precio desde', value: tipo.precio },
                  { label: 'Ideal para', value: tipo.ideal },
                ].map((d) => (
                  <div>
                    <p class="text-[10px] font-semibold text-white/50 uppercase tracking-wide mb-1">{d.label}</p>
