  factorSec3: 'Un techo rectangular de superficies lisas es el escenario más económico (29-35€/m²). Las formas curvas, los techos con desniveles, las columnas que hay que esquivar, los artesonados decorativos o las geometrías con muchos ángulos aumentan el tiempo de instalación entre un 20 y un 50%, elevando el precio de mano de obra hasta 45-80€/m².',
  factorSec4Title: '4. Accesibilidad y condiciones de obra',
  factorSec4: 'Trabajar en el centro histórico de Maó, Ciutadella o villas de la costa norte puede implicar escaleras estrechas, falta de ascensor y material subido a mano, añadiendo un 5-15% por horas adicionales. Techos muy irregulares o paredes fuera de plomo (típicos de casas menorquinas de piedra) requieren más trabajo de nivelación con perfiles Placo Maestra.',
  factorSec5Title: '5. Instalaciones a integrar',
  factorSec5: 'Integrar instalaciones eléctricas (focos LED empotrados, dimmers, interruptores), climatización (difusores, rejillas, conductos de aire) o telecomunicaciones (puntos de datos, antenas) añade un sobrecoste proporcional. Tarifas unitarias típicas 2026: foco LED empotrado 45-80€; difusor de climatización 120-180€; rejilla de retorno 60-90€. Todo instalado y en funcionamiento.',
  compH2: 'Pladur vs obra tradicional: comparativa de coste total',
  compLead: 'Comparando coste total de un proyecto de pladur frente a la misma solución con ladrillo, el pladur resulta 25-40% más económico al computar todos los costes reales. El tiempo de ejecución (1-5 días vs 1-4 semanas) es el ahorro más visible:',
  compHeaders: { coste: 'Coste', pladur: 'Pladur', ladrillo: 'Ladrillo' },
  tablaComparativaCostes: [
    ['Materiales', 'Medio', 'Bajo-Medio'],
    ['Mano de obra', 'Bajo (3-4x más rápido)', 'Alto'],
    ['Retirada escombros', 'Mínima', 'Alta (contenedor)'],
    ['Protección espacio', 'Básica', 'Extensiva'],
    ['Tiempo de obra', '1-5 días', '1-4 semanas'],
    ['Total aproximado/m²', '25-60€', '40-80€'],
  ],
  compFootnote: 'El ahorro total con pladur puede ser del 25-40% respecto a la obra tradicional cuando se calcula el coste completo del proyecto.',
  ejBadge: 'Casos reales',
  ejH2: 'Ejemplos prácticos: ¿cuánto cuesta mi proyecto?',
  ejLead: 'Tres escenarios habituales en Menorca con rangos de precio estimados para 2026. Todos incluyen materiales Placo/Knauf, mano de obra, tratamiento de juntas y retirada de escombros. IVA no incluido.',
  ejTotal: 'TOTAL ESTIMADO',
  ejPlazo: 'Plazo:',
  ejNoEncaja: '¿Tu proyecto no encaja en estos ejemplos?',
  ejNoEncajaText: 'Cada proyecto es único. La única manera de obtener el precio exacto es mediante una visita técnica donde medimos, evaluamos y elaboramos un presupuesto cerrado y desglosado. ',
  ejNoEncajaLink: 'Solicita tu visita ahora.',
  ejemplos: [
    {
      titulo: 'Piso de 80 m² con falso techo en toda la vivienda',
      desc: 'Piso en Maó de 80 m² sin falso techo previo. Instalamos falso techo continuo básico BA13 en toda la vivienda (salón, dormitorios, baños, cocina) e integramos 8 focos LED empotrados en salón y dormitorios. Obra seca, sin escombros, en 3-5 días trabajables.',
      desglose: [
        { concepto: 'Falso techo 80 m² (básico)', precio: '2.320-2.800€' },
        { concepto: '8 focos LED empotrados', precio: '400-640€' },
        { concepto: 'Tratamiento de juntas y acabado', precio: 'incluido' },
      ],
      total: '2.720-3.440€',
      plazo: '3-5 días',
      iva: 'Sin IVA',
    },
    {
      titulo: 'Habitación nueva con tabique acústico (15 m² de tabique)',
      desc: 'División de un dormitorio grande en dos habitaciones mediante tabique acústico de pladur de 15 m²: doble placa BA13 y lana mineral de 45 mm. Incluye puerta interior con marco y paso de instalación eléctrica. La habitación resultante de 12 m² queda lista para pintar en 1-2 días.',
      desglose: [
        { concepto: 'Tabique acústico 15 m²', precio: '780-870€' },
        { concepto: 'Puerta interior + marco', precio: '200-400€' },
        { concepto: 'Paso instalación eléctrica', precio: '80-150€' },
      ],
      total: '1.060-1.420€',
      plazo: '1-2 días',
      iva: 'Sin IVA',
    },
    {
      titulo: 'Salón insonorizado (techo + paredes)',
      desc: 'Mejora acústica integral de un salón de 25 m² con vecino ruidoso arriba y al lado. Instalamos falso techo antivibración con suspensión elástica, lana mineral de 80 mm y doble placa BA15, más trasdosado desvinculado en dos medianeras. Reducción acústica superior a 50 dB DnT,A.',
      desglose: [
        { concepto: 'Falso techo acústico 25 m²', precio: '875-1.250€' },
        { concepto: 'Trasdosado 2 paredes 30 m²', precio: '870-1.440€' },
        { concepto: 'Materiales antivibratorios', precio: 'incluido' },
      ],
      total: '1.745-2.690€',
      plazo: '4-7 días',
      iva: 'Sin IVA',
    },
  ],
  ctaBanner3Titulo: 'Tu presupuesto exacto, gratis y en 24 horas',
  ctaBanner3Subtitulo: 'Precio cerrado. Sin sorpresas. Garantía de 1 año. Cobertura en toda Menorca.',
  articulos: [
    { slug: 'precio-pladur-menorca-2026', titulo: 'Precio del pladur en Menorca 2026', descripcion: 'Guía completa de precios del pladur en Menorca actualizada a 2026. Tarifas por tipo de trabajo.' },
    { slug: 'precio-insonorizar-piso-menorca', titulo: 'Precio de insonorizar un piso', descripcion: 'Cuánto cuesta insonorizar un piso en Menorca. Precios detallados por tipo de solución acústica.' },
    { slug: 'subvenciones-aislamiento-baleares-2026', titulo: 'Subvenciones para aislamiento en Baleares', descripcion: 'Ayudas y subvenciones disponibles en 2026 para mejorar el aislamiento de tu vivienda en Baleares.' },
  ],
  faqTitle: 'Preguntas frecuentes sobre precios del pladur',
  faqSubtitle: 'Todo lo que necesitas saber sobre cómo se calculan y qué incluyen nuestros precios.',
}

const pagePathBase = lang === 'en' ? '/en/precios-pladur-menorca' : '/precios-pladur-menorca'
const urlBase = `https://www.pladurmenorca.com${pagePathBase}`
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en/' : '/' }, { label: t.breadcrumbCurrent, href: pagePathBase }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService name={servicio.schema.name} description={servicio.schema.description} serviceType={servicio.schema.serviceType} url={urlBase} image="https://www.pladurmenorca.com/images/proyectos/reforma-integral-piso.webp" />
    <SchemaAggregateOffer
      name={t.aggName}
      description={t.aggDesc}
      lowPrice="6"
      highPrice="300"
      offerCount={14}
    />
    <SchemaOffers offers={t.offers} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={alternateHref} />

  <p class="sr-only" aria-hidden="false">{t.srOnly}</p>

  <!-- Hero -->
  <Hero
    title={t.heroTitle}
    subtitle={t.heroSubtitle}
    description={t.heroDescription}
    dark={true}
    badges={t.heroBadges}
    ctaPrimario={{ texto: t.ctaPrimario, href: p('/presupuesto-pladur') }}
    ctaSecundario={{ texto: `${t.ctaLlamar}: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- Introducción -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.introBadge}</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">{t.introH2}</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>{t.introP1}</p>
            <p>{t.introP2}</p>

            <h3 class="text-xl font-bold text-foreground mt-8 mb-3">{t.introFactoresTitle}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
              {t.factores.map((f) => (
                <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card">
                  <p class="font-bold text-foreground text-sm mb-1">{f.factor}</p>
                  <p class="text-xs text-muted leading-relaxed">{f.desc}</p>
                </div>
              ))}
            </div>

            <div class="mt-6 p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-1">{t.importantTitle}</p>
              <p class="text-sm text-muted leading-relaxed">
                {t.importantText1}
                <a href={p('/presupuesto-pladur')} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark">{t.importantLink}</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <ContactoRapidoCard lang={lang} />

            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-4 uppercase tracking-wider">{t.sidebarPreciosTitle}</p>
              {t.sidebarPrecios.map((p) => (
                <div class="flex justify-between items-center py-2 border-b border-warm-border/50 last:border-0">
                  <span class="text-xs text-muted">{p.servicio}</span>
                  <span class="text-sm font-bold text-foreground-dark">{p.precio}</span>
                </div>
              ))}
            </div>

            <div class="p-4 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default text-sm text-muted">
              <p class="font-semibold text-foreground mb-1">{t.sidebarLinksTitle}</p>
              <ul class="space-y-1.5">
                {t.sidebarLinks.map((s) => (
                  <li>
                    <a href={s.href} class="flex items-center gap-2 text-muted hover:text-foreground transition-colors">
                      <svg aria-hidden="true" class="size-3 text-muted shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- NuestrosDatos — cifras reales que respaldan nuestras tarifas -->
  <NuestrosDatos
    lang={lang}
    eyebrow={lang === 'en' ? 'Why our prices are believable' : 'Por qué nuestras tarifas son creíbles'}
    title={lang === 'en' ? 'Real figures behind the rates' : 'Cifras reales detrás de las tarifas'}
    intro={lang === 'en'
      ? 'Prices on the web are not marketing bait — they reflect the real volumes at which the Mallorca parent company purchases and builds. Concrete 2025 numbers below.'
      : 'Las tarifas que ves no son un reclamo — reflejan los volúmenes reales a los que compra y ejecuta la SL matriz. Cifras concretas de 2025 abajo.'}
    metrics={lang === 'en' ? [
      { value: '508', label: 'projects closed in 2025', context: 'Each one at a fixed price, no surprises' },
      { value: '<24h', label: 'to deliver the itemised quote', context: 'After the on-site visit' },
      { value: 'Placo · Knauf · Lafarge', label: 'brands we buy at volume', context: 'Volume pricing reflected in our rates' },
      { value: '1 year', label: 'workmanship warranty', context: 'LOE Art. 17 — plus manufacturer warranty' },
    ] : [
      { value: '508', label: 'proyectos cerrados en 2025', context: 'Cada uno a precio cerrado, sin sorpresas' },
      { value: '<24h', label: 'para entregar el presupuesto', context: 'Después de la visita técnica' },
      { value: 'Placo · Knauf · Lafarge', label: 'marcas que compramos en volumen', context: 'El volumen se refleja en nuestras tarifas' },
      { value: '1 año', label: 'garantía de mano de obra', context: 'LOE Art. 17 — más garantía de fabricante' },
    ]}
  />

  <!-- Tabla resumen general -->
  <PreciosTable lang={lang} variant="resumen" />

  <!-- CtaBanner 1 -->
  <CtaBanner lang={lang} titulo={t.ctaBanner1Titulo} subtitulo={t.ctaBanner1Subtitulo} showForm={false} />

  <!-- Falsos Techos -->
  <section class="py-20 lg:py-28" id="falsos-techos">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">{t.falsosBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">{t.falsosH2}</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">{t.falsosLead}</p>
        <a href={lang === 'en' ? '/en/falsos-techos-pladur-menorca' : '/falsos-techos-pladur-menorca'} class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          {t.falsosLink}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable lang={lang} variant="Falsos Techos" hideHeader />
  </section>

  <!-- Tabiques -->
  <section class="py-20 lg:py-28" id="tabiques">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">{t.tabiquesBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">{t.tabiquesH2}</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">{t.tabiquesLead}</p>
        <a href={lang === 'en' ? '/en/tabiques-pladur-menorca' : '/tabiques-pladur-menorca'} class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          {t.tabiquesLink}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable lang={lang} variant="Tabiques y Particiones" hideHeader />
    <Container size="xl">
      <p class="mt-6 text-sm text-muted leading-relaxed">{t.tabiquesNote1}<a href={t.tabiquesNoteHref} class="text-foreground font-semibold underline underline-offset-2">{t.tabiquesNote2}</a>{t.tabiquesNote3}</p>
    </Container>
  </section>

  <!-- Aislamiento -->
  <section class="py-20 lg:py-28" id="aislamiento">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">{t.aislamientoBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">{t.aislamientoH2}</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">{t.aislamientoLead}</p>
        <a href={lang === 'en' ? '/en/aislamiento-acustico-menorca' : '/aislamiento-acustico-menorca'} class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          {t.aislamientoLink}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable lang={lang} variant="Aislamiento Acústico" hideHeader />
  </section>

  <!-- CtaBanner 2 -->
  <CtaBanner lang={lang} titulo={t.ctaBanner2Titulo} subtitulo={t.ctaBanner2Subtitulo} showForm={false} />

  <!-- Factores -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.factoresBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6 max-w-2xl">{t.factoresH2}</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="space-y-6 text-muted leading-relaxed">
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">{t.factorSec1Title}</h3>
            <p>{t.factorSec1}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">{t.factorSec2Title}</h3>
            <p>{t.factorSec2}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">{t.factorSec3Title}</h3>
            <p>{t.factorSec3}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">{t.factorSec4Title}</h3>
            <p>{t.factorSec4}</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">{t.factorSec5Title}</h3>
            <p>{t.factorSec5}</p>
          </div>
        </div>

        <div class="space-y-6 text-muted leading-relaxed">
          <h2 class="text-2xl font-bold text-foreground leading-tight text-balance mb-6">{t.compH2}</h2>
          <p>{t.compLead}</p>
          <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
            <div class="rounded-3xl overflow-hidden border border-warm-border shadow-card min-w-[420px]">
              <table class="min-w-full">
                <thead>
                  <tr class="bg-foreground">
                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider">{t.compHeaders.coste}</th>
                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider">{t.compHeaders.pladur}</th>
                    <th class="px-4 py-3 text-left text-xs font-bold text-white/70 uppercase tracking-wider">{t.compHeaders.ladrillo}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-warm-border">
                  {t.tablaComparativaCostes.map(([coste, pladur, ladrillo], i) => (
                    <tr class={`${i % 2 === 0 ? 'bg-white/70' : 'bg-white/40'} hover:bg-surface/50 transition-colors`}>
                      <td class="px-4 py-3.5 text-sm font-semibold text-foreground">{coste}</td>
                      <td class="px-4 py-3.5 text-sm text-foreground font-bold">{pladur}</td>
                      <td class="px-4 py-3.5 text-sm text-muted">{ladrillo}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          <p class="text-sm text-muted">{t.compFootnote}</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Ejemplos -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.ejBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-2xl">{t.ejH2}</h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">{t.ejLead}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
        {t.ejemplos.map((ejemplo) => (
          <div class="bg-white/70 border border-warm-border/50 overflow-hidden rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
            <div class="bg-foreground p-5">
              <h3 class="font-bold text-white text-base leading-snug">{ejemplo.titulo}</h3>
            </div>
            <div class="p-6">
              <p class="text-sm text-muted leading-relaxed mb-5">{ejemplo.desc}</p>
              <div class="space-y-2 mb-5">
                {ejemplo.desglose.map((d) => (
                  <div class="flex justify-between items-center text-sm py-1.5 border-b border-warm-border/50 last:border-0">
                    <span class="text-muted">{d.concepto}</span>
                    <span class="font-semibold text-foreground">{d.precio}</span>
                  </div>
                ))}
              </div>
              <div class="p-4 bg-white/70 border border-warm-border/50 rounded-3xl">
                <div class="flex justify-between items-center mb-2">
                  <span class="font-bold text-foreground text-sm">{t.ejTotal}</span>
                  <span class="font-bold text-foreground-dark text-lg">{ejemplo.total}</span>
                </div>
                <div class="flex justify-between items-center text-xs text-muted">
                  <span>{t.ejPlazo} {ejemplo.plazo}</span>
                  <span>{ejemplo.iva}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 p-6 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card">
        <p class="font-bold text-foreground mb-1">{t.ejNoEncaja}</p>
        <p class="text-sm text-muted leading-relaxed">
          {t.ejNoEncajaText}
          <a href={p('/presupuesto-pladur')} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark">{t.ejNoEncajaLink}</a>
        </p>
      </div>
    </Container>
  </section>

  <!-- ZonasServicio -->
  <ZonasServicio lang={lang} />

  <!-- CtaBanner 3 -->
  <CtaBanner lang={lang} titulo={t.ctaBanner3Titulo} subtitulo={t.ctaBanner3Subtitulo} showForm={true} />

  <!-- Artículos relacionados -->
  <ArticulosRelacionados articulos={t.articulos} />

  <!-- FaqAccordion -->
  <FaqAccordion client:visible lang={lang} faqs={pageFaqs} titulo={t.faqTitle} subtitulo={t.faqSubtitle} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
