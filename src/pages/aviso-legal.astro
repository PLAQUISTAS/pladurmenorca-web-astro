---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import Hero from '@/components/sections/Hero.astro'
import CookieSettingsButton from '@/components/ui/CookieSettingsButton.astro'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Aviso Legal y Política de Cookies | Pladur Menorca',
  description: 'Aviso legal, condiciones de uso y política de cookies de Pladur Menorca (PLAQUISTAS Y ACABADOS SL). Información conforme a la LSSI-CE y normativa de la AEPD.',
  canonical: '/aviso-legal',
}

const checkSvg = `<svg class="size-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>`
