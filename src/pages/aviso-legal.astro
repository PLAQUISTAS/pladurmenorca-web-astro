  <!-- ═══════════════════════════════════════════════════════════════
      PARTE 2 — POLÍTICA DE COOKIES
  ═══════════════════════════════════════════════════════════════ -->

  <!-- 2.1 ¿Qué son las cookies? -->
  <section class="w-full py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
