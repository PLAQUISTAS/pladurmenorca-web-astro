---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import Hero from '@/components/sections/Hero'
import ServiciosGrid from '@/components/sections/ServiciosGrid.astro'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import GaleriaTrabajos from '@/components/sections/GaleriaTrabajos.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import Container from '@/components/ui/Container.astro'
import { instalacionFaqs } from '@/data/faqs/instalacion'
import { getServicioBySlug } from '@/data/servicios'
import { siteConfig } from '@/data/site'

const servicio = getServicioBySlug('instalacion-pladur-mallorca')!
const pageFaqs = instalacionFaqs

const meta = {
  title: 'Instalación de Pladur en Mallorca | +20 Años Experiencia',
  description: 'Contrata instaladores de pladur en Mallorca con más de 20 años de experiencia. Falsos techos, tabiques y aislamiento. Materiales Placo, Knauf y Lafarge.',
  canonical: '/instalacion-pladur-mallorca',
}

const placaTipos = [
  {
    tipo: 'Placa Estándar (A / BA)',
    tag: 'Uso general',
    desc: 'Uso general en tabiques y techos interiores en zonas secas. Es la más económica y la más utilizada. Disponible en espesores de 10, 12,5 y 15 mm.',
  },
  {
    tipo: 'Placa Hidrófuga (H / Verde)',
    tag: 'Zonas húmedas',
    desc: 'Tratada con aditivos hidrófugos para resistir la humedad y el vapor de agua. Obligatoria en baños, cocinas y cualquier zona húmeda. Distinguible por su color verde.',
  },
  {
    tipo: 'Placa Cortafuego (F / DF / Rosa)',
    tag: 'Resistencia al fuego',
    desc: 'Con fibras de vidrio en el núcleo de yeso para resistir el fuego. Permite construir tabiques con clasificación EI-30, EI-60, EI-90 o EI-120 según el número de capas y el espesor.',
  },
  {
    tipo: 'Placa Acústica (AC)',
    tag: 'Aislamiento acústico',
    desc: 'Mayor densidad para mejorar el aislamiento a ruido aéreo. Se usa en combinación con lana mineral para conseguir índices de reducción acústica superiores a 50 dB.',
  },
]

const serviciosRelacionados = [
  { label: 'Falsos Techos de Pladur', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques de Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Precios del Pladur', href: '/precios-pladur-mallorca' },
]

const pasos = [
  {
    num: '01',
    titulo: 'Visita técnica gratuita',
    desc: 'Un técnico de nuestro equipo acude a tu domicilio o local en Mallorca para evaluar el proyecto, tomar medidas y resolver cualquier duda técnica. Sin coste y sin compromiso.',
    detalle: 'Disponible de lunes a viernes en toda la isla',
    iconPath: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
  {
    num: '02',
    titulo: 'Presupuesto detallado en 24h',
    desc: 'Elaboramos un presupuesto cerrado con desglose de materiales, mano de obra y plazo de ejecución. Sin letra pequeña ni sorpresas. El precio final no cambia.',
    detalle: 'Precio cerrado desde el primer día',
    iconPath: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  },
  {
    num: '03',
    titulo: 'Instalación limpia y profesional',
    desc: 'Nuestro equipo trabaja con total respeto al espacio: protegemos suelos, muebles y zonas adyacentes. No generamos escombros voluminosos ni polvo excesivo.',
    detalle: 'Protección completa del espacio de trabajo',
    iconPath: 'M11.42 15.17l-5.384 3.079A2.25 2.25 0 013 16.19V7.81a2.25 2.25 0 013.036-2.059l5.384 3.079m0 0L17.25 12m-5.83-3.17L17.25 12m0 0l-5.83 3.17M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    num: '04',
    titulo: 'Entrega con acabado perfecto',
    desc: 'Dejamos el trabajo listo para pintar: juntas tratadas con pasta y cinta, superficies lijadas y rincones perfectamente terminados. Limpieza final incluida.',
    detalle: 'Listo para pintar o revestir',
    iconPath: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
]

const tablaComparativa = [
  ['Velocidad', '3-5 días/50m²', '3-6 semanas/50m²'],
  ['Escombros', 'Mínimos', 'Toneladas'],
  ['Peso', '25-40 kg/m²', '120-180 kg/m²'],
  ['Limpieza de obra', 'Muy limpia', 'Polvo y barro'],
  ['Acabado', 'Perfectamente plano', 'Requiere más capas'],
  ['Modificaciones futuras', 'Muy sencillas', 'Obra nueva'],
  ['Coste total', 'Inferior', 'Superior'],
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Instalación de Pladur', href: '/instalacion-pladur-mallorca' }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService
      name={servicio.schema.name}
      description={servicio.schema.description}
      serviceType={servicio.schema.serviceType}
      url="https://www.pladurmallorca.com/instalacion-pladur-mallorca"
      image="https://www.pladurmallorca.com/images/proyectos/villa-obra-nueva-pladur-integral-mallorca.webp"
     
    />
    <SchemaHowTo
      name="Cómo instalar pladur en Mallorca"
      description="Proceso completo de instalación de pladur: desde la visita técnica gratuita hasta la entrega con acabado perfecto listo para pintar."
      totalTime="PT72H"
      steps={[
        { name: 'Visita técnica gratuita', text: 'Un técnico evalúa el proyecto, toma medidas y resuelve dudas técnicas. Disponible de lunes a viernes en toda la isla de Mallorca.' },
        { name: 'Presupuesto detallado en 24h', text: 'Presupuesto cerrado con desglose de materiales, mano de obra y plazo de ejecución. Sin compromiso.' },
        { name: 'Instalación limpia y profesional', text: 'El equipo trabaja con respeto al espacio, protegiendo suelos, muebles y zonas adyacentes durante toda la instalación.' },
        { name: 'Entrega con acabado perfecto', text: 'Trabajo listo para pintar con juntas tratadas, superficies lijadas y limpieza final incluida.' },
      ]}
    />
    <SchemaOffers
      offers={[
        { name: 'Instalación de falso techo', price: '29', description: 'Instalación de falso techo de pladur continuo con estructura metálica. Precio por m².' },
        { name: 'Instalación de tabiques', price: '45', description: 'Instalación de tabiques divisorios de pladur con aislante interior. Precio por m².' },
        { name: 'Instalación de trasdosados', price: '29', description: 'Trasdosado autoportante con aislamiento térmico y acústico incluido. Precio por m².' },
        { name: 'Instalación de pladur hidrófugo', price: '45', description: 'Instalación de sistemas de pladur hidrófugo para baños, cocinas y zonas húmedas. Precio por m².' },
      ]}
    />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instalación profesional de pladur en Mallorca. Más de 20 años de experiencia, +6.000 proyectos realizados. Materiales Placo, Knauf y Lafarge. Presupuesto gratuito en 24h. Tel: 627 829 723.
  </p>

  <!-- 1. Hero -->
  <Hero
    client:visible
    title="Instalación de Pladur en Mallorca — Especialistas con +20 Años"
    subtitle="Instaladores profesionales de yeso laminado en toda la isla"
    description="Empresa líder en instalación de pladur en Mallorca desde 2004. Falsos techos, tabiques de distribución, aislamiento acústico y térmico. Materiales premium de Placo, Knauf y Lafarge. Presupuesto gratis en 24h."
    dark={true}
    badges={['+20 años', 'Toda Mallorca', 'Presupuesto gratis']}
    ctaPrimario={{ texto: 'Pedir presupuesto gratis', href: '/presupuesto-pladur' }}
    ctaSecundario={{ texto: `Llamar: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- 3. ¿Qué es el pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              Introducción
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              ¿Qué es el pladur y cómo funciona?
            </h2>
          </div>
          <div class="prose prose-gray max-w-none space-y-5 text-muted leading-relaxed">
            <p>
              El pladur —también llamado placa de yeso laminado, cartón-yeso o simplemente yeso laminado— es el
              sistema constructivo en seco más utilizado en España para la construcción de interiores. El término
              «pladur» es en realidad una marca registrada de Saint-Gobain Placo que con el tiempo se ha convertido
              en el nombre genérico con el que la mayoría de profesionales y usuarios designan este tipo de placa.
            </p>
            <p>
              Structuralmente, una placa de yeso laminado consiste en un núcleo de yeso de alta pureza encapsulado
              entre dos láminas de cartón especial tratado. El núcleo de yeso aporta rigidez, aislamiento y
              resistencia al fuego, mientras que las láminas de cartón ofrecen resistencia a la tracción y sirven
              de soporte para el acabado final. El resultado es un panel ligero, versátil y muy fácil de trabajar
              que se adapta a cualquier tipo de espacio interior.
            </p>
            <p>
              El sistema de instalación consiste en fijar una estructura metálica —formada por perfiles guía y
              montantes de acero galvanizado— al suelo, techo y paredes existentes. Sobre esta estructura se
              atornillan las placas de yeso, se tratan las juntas con pasta y cinta especial, y se lija hasta
              obtener una superficie perfectamente plana lista para pintar o alicatar. Sin demoliciones, sin
              escombros, sin semanas de espera.
            </p>

            <h3 class="text-xl font-bold text-foreground mt-8 mb-3">
              Marcas de referencia: Placo, Knauf y Lafarge
            </h3>
            <p>
              En el mercado español existen tres grandes fabricantes de sistemas de yeso laminado:
            </p>
            <ul class="list-none space-y-3 pl-0">
              <li class="flex items-start gap-3">
                <span class="mt-1 shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                  <svg aria-hidden="true" class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span>
                  <strong class="text-foreground">Saint-Gobain Placo (Pladur®):</strong> líder del mercado en
                  España, con la gama más amplia de productos técnicos. Sus placas estándar BA13 y BA15 son las más
                  utilizadas en falsos techos y tabiques residenciales.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                  <svg aria-hidden="true" class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span>
                  <strong class="text-foreground">Knauf:</strong> empresa alemana con presencia global y gran
                  tradición en sistemas de construcción en seco. Especialmente reconocida por sus sistemas de
                  aislamiento acústico de alta prestación.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                  <svg aria-hidden="true" class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span>
                  <strong class="text-foreground">Lafarge:</strong> perteneciente al grupo Holcim, es otra
                  referencia de calidad muy utilizada en proyectos de obra nueva y rehabilitación en España.
                </span>
              </li>
            </ul>

            <h3 class="text-xl font-bold text-foreground mt-8 mb-3">
              Tipos de placa según la aplicación
            </h3>
            <p>
              La versatilidad del sistema pladur se debe en gran parte a la variedad de placas disponibles. Cada
              tipo tiene aditivos específicos que le confieren propiedades diferenciadas:
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 not-prose mt-4">
              {placaTipos.map((p) => (
                <div class="bg-white/70 rounded-3xl border border-warm-border/50 p-5">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <p class="font-bold text-foreground text-sm">{p.tipo}</p>
                    <span class="text-[10px] font-semibold uppercase tracking-wide text-foreground bg-surface px-2 py-0.5 rounded-md shrink-0">
                      {p.tag}
                    </span>
                  </div>
                  <p class="text-sm text-muted leading-relaxed">{p.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <div class="p-6 bg-foreground text-white rounded-3xl">
              <p class="text-xs font-bold uppercase tracking-widest text-nav-border/60 mb-3">
                Contacto rápido
              </p>
              <p class="font-bold text-lg mb-2">¿Necesitas instaladores de pladur en Mallorca?</p>
              <p class="text-gray-300 text-sm mb-5 leading-relaxed">
                Presupuesto gratuito. Visita técnica sin coste. Respuesta en menos de 24 horas.
              </p>
              <a
                href={`tel:${siteConfig.phoneRaw}`}
                class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide transition-colors"
              >
                <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                {siteConfig.phone}
              </a>
              <a
                href="/presupuesto-pladur"
                class="flex items-center justify-center gap-2 w-full py-3 mt-3 rounded-xl border border-white/30 hover:border-white text-white font-bold text-sm tracking-wide transition-colors"
              >
                Pedir presupuesto online
              </a>
            </div>

            <div class="p-6 bg-white/70 border border-warm-border/50 rounded-3xl">
              <p class="font-bold text-foreground text-sm mb-4 uppercase tracking-wider">
                Servicios relacionados
              </p>
              <ul class="space-y-2">
                {serviciosRelacionados.map((s) => (
                  <li>
                    <a
                      href={s.href}
                      class="flex items-center gap-2 text-sm text-muted hover:text-foreground transition-colors py-1"
                    >
                      <svg aria-hidden="true" class="size-3.5 text-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- 4. ServiciosGrid -->
  <ServiciosGrid />

  <!-- 5. ¿Por qué elegir pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          Ventajas
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6 max-w-3xl">
          ¿Por qué elegir pladur frente a la obra tradicional?
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="space-y-5 text-muted leading-relaxed">
          <p>
            La comparación entre pladur y obra tradicional de ladrillo o bloque de hormigón siempre arroja el mismo
            resultado cuando se evalúan de forma objetiva todos los factores implicados: tiempo de ejecución,
            generación de residuos, impacto en la vida cotidiana y coste total de la intervención.
          </p>
          <p>
            En Mallorca, donde la mayoría de las intervenciones se realizan en pisos habitados, edificios de
            apartamentos turísticos con plazos de entrega muy ajustados o locales comerciales que no pueden
            cerrar durante semanas, la ventaja del pladur es todavía más evidente. Una reforma con obra
            tradicional puede durar entre 3 y 6 semanas. La misma reforma con pladur se ejecuta en 5-10 días.
          </p>
          <p>
            El peso es otro factor crítico en la isla. Los forjados de los edificios más antiguos del centro de
            Palma y de otras localidades no están dimensionados para soportar nuevas cargas de albañilería. Un
            tabique de ladrillo sencillo pesa entre 120 y 180 kg/m², mientras que un tabique de pladur equivalente
            pesa solo 25-40 kg/m². Esta diferencia permite realizar redistribuciones de espacios en edificios
            donde la albañilería estaría directamente contraindicada.
          </p>
          <p>
            Finalmente, el acabado del pladur supera al del enfoscado y yesado tradicional en términos de
            planimetría. La superficie de una placa de yeso laminado bien instalada y tratada es perfectamente
            plana, sin ondulaciones, y acepta cualquier tipo de pintura, papel pintado o revestimiento sin
            necesidad de preparación adicional.
          </p>
        </div>

        <!-- Tabla comparativa — desktop -->
        <div class="hidden sm:block">
          <div class="rounded-3xl overflow-hidden border border-warm-border shadow-card">
            <table class="min-w-full">
              <thead>
                <tr class="bg-foreground">
                  <th class="px-5 py-4 text-left text-xs font-bold text-white/70 uppercase tracking-wider w-[35%]">Criterio</th>
                  <th class="px-5 py-4 text-left text-xs font-bold text-white uppercase tracking-wider w-[35%]">
                    <span class="flex items-center gap-1.5">
                      <svg aria-hidden="true" class="size-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                      Pladur
                    </span>
                  </th>
                  <th class="px-5 py-4 text-left text-xs font-bold text-white/50 uppercase tracking-wider w-[30%]">Ladrillo</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-warm-border/50">
                {tablaComparativa.map(([criterio, pladur, ladrillo], i) => (
                  <tr class={`${i % 2 === 0 ? 'bg-white/70' : 'bg-white/40'} hover:bg-surface/60 transition-colors duration-200`}>
                    <td class="px-5 py-3.5 text-sm font-semibold text-foreground">{criterio}</td>
                    <td class="px-5 py-3.5 text-sm text-foreground font-bold">
                      <span class="flex items-center gap-1.5">
                        <svg aria-hidden="true" class="size-3.5 text-foreground shrink-0" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        {pladur}
                      </span>
                    </td>
                    <td class="px-5 py-3.5 text-sm text-muted/70">{ladrillo}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Tabla comparativa — mobile (card layout) -->
        <div class="sm:hidden space-y-3 -mx-4 px-4">
          {tablaComparativa.map(([criterio, pladur, ladrillo]) => (
            <div class="bg-white/70 rounded-2xl border border-warm-border/50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-muted mb-3">{criterio}</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-wide text-foreground mb-1">Pladur</p>
                  <p class="text-sm font-bold text-foreground flex items-center gap-1.5">
                    <svg aria-hidden="true" class="size-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {pladur}
                  </p>
                </div>
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-wide text-muted mb-1">Ladrillo</p>
                  <p class="text-sm text-muted/70">{ladrillo}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Cita normativa -->
  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <blockquote class="border-l-4 border-foreground-dark/20 pl-6 my-8 italic text-muted">
        <p>"Las placas de yeso laminado deben cumplir la norma UNE-EN 520, que establece los requisitos de resistencia mecánica, comportamiento frente al fuego y tolerancias dimensionales. Los sistemas completos de tabiquería y trasdosados deben ensayarse según las normas UNE-EN correspondientes para acreditar sus prestaciones acústicas, térmicas y de resistencia al fuego."</p>
        <cite class="block mt-2 not-italic text-sm font-medium text-foreground-dark">— Norma UNE-EN 520:2005+A1:2010, Placas de yeso laminado. Definiciones, especificaciones y métodos de ensayo</cite>
      </blockquote>
    </div>
  </section>

  <!-- 6. Proceso de trabajo -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          Metodología
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-2xl">
          Nuestro proceso de trabajo paso a paso
        </h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-2xl">
          Desde la visita técnica hasta la entrega final, un proceso claro y sin sorpresas.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-5 sm:left-7 top-0 bottom-0 w-px bg-warm-border" aria-hidden="true"></div>

        <div class="space-y-0">
          {pasos.map((paso, i) => (
            <div class="relative flex gap-6 sm:gap-8">
              <!-- Node -->
              <div class="relative z-10 flex flex-col items-center shrink-0">
                <div class="size-10 sm:w-14 sm:h-14 rounded-full bg-foreground flex items-center justify-center text-white text-xs sm:text-sm font-bold shadow-lg shadow-foreground/20">
                  {paso.num}
                </div>
                {i < pasos.length - 1 && (
                  <div class="flex-1"></div>
                )}
              </div>

              <!-- Content -->
              <div class={`flex-1 ${i < pasos.length - 1 ? 'pb-10 sm:pb-12' : 'pb-0'}`}>
                <div class="bg-white/70 rounded-3xl border border-warm-border/50 p-6 sm:p-7 shadow-card hover:shadow-card-hover transition-shadow duration-300">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <h3 class="font-bold text-foreground text-base sm:text-lg">{paso.titulo}</h3>
                    <div class="w-9 h-9 bg-surface border border-nav-border rounded-xl flex items-center justify-center shrink-0">
                      <svg aria-hidden="true" class="w-4.5 h-4.5 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d={paso.iconPath} />
                      </svg>
                    </div>
                  </div>
                  <p class="text-sm text-muted leading-relaxed mb-4">{paso.desc}</p>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-foreground bg-surface px-3 py-1 rounded-lg">
                    <svg aria-hidden="true" class="size-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {paso.detalle}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10 p-6 bg-white/70 border border-warm-border/50 rounded-3xl">
        <p class="text-sm text-muted leading-relaxed">
          <strong class="text-foreground">Garantía de 2 años.</strong> Todos nuestros trabajos incluyen garantía
          de 2 años en mano de obra. Si surge cualquier incidencia durante ese período, la resolvemos sin coste
          adicional. Los materiales tienen la garantía de fábrica de Placo, Knauf o Lafarge según corresponda.
        </p>
      </div>
    </Container>
  </section>

  <!-- 7. PreciosTable -->
  <PreciosTable variant="resumen" />

  <!-- 8. ZonasServicio -->
  <ZonasServicio />

  <!-- 9. GaleriaTrabajos -->
  <GaleriaTrabajos imagenes={[
    { src: '/images/proyectos/reforma-integral-piso-santa-catalina-pladur-mallorca.webp', alt: 'Reforma integral con instalación de pladur en Santa Catalina' },
    { src: '/images/proyectos/acabados-pladur-madera-cocina-mallorca.webp', alt: 'Acabados de pladur e instalación en cocina de Mallorca' },
    { src: '/images/proyectos/salon-falso-techo-pladur-villa-mallorca.webp', alt: 'Instalación de pladur en salón de villa en Mallorca' },
    { src: '/images/proyectos/oficina-open-space-tabiques-pladur-mallorca.webp', alt: 'Instalación de pladur en oficina open space en Mallorca' },
  ]} />

  <!-- 10. FaqAccordion -->
  <FaqAccordion
    client:visible
    faqs={pageFaqs}
    titulo="Preguntas frecuentes sobre instalación de pladur"
    subtitulo="Todo lo que necesitas saber antes de comenzar tu proyecto de pladur en Mallorca."
  />

  <!-- Enlace a hoteles -->
  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-foreground rounded-3xl p-7 sm:p-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-white/80 text-sm leading-relaxed">¿Gestionas un hotel en Mallorca? Descubre cómo aplicamos pladur ignífugo y aislamiento acústico en <strong class="text-white">reformas hoteleras con plazos garantizados</strong>.</p>
        <a href="/pladur-hoteles-mallorca" class="inline-flex items-center gap-2 text-white font-semibold underline underline-offset-2 text-sm shrink-0">
          Pladur para hoteles
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 11. CtaBanner -->
  <CtaBanner
    titulo="¿Listo para tu proyecto de pladur en Mallorca?"
    subtitulo="Presupuesto gratuito en 24 horas. Precio cerrado. Sin sorpresas."
    showForm={true}
  />

  <ServiciosRelacionados currentPath="/instalacion-pladur-mallorca" />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
