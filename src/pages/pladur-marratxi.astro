---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import PaginaGeografica from '@/components/templates/PaginaGeografica.astro'
import { faqs } from '@/data/faqs'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur en Marratxí | Reformas y Presupuesto Gratis',
  description: "Instala pladur en Marratxí: Pont d'Inca, Sa Cabaneta y Pòrtol. Reformas en pisos y casas de pueblo. Techos, tabiques y aislamiento. Presupuesto gratis en 24h.",
  canonical: '/pladur-marratxi',
}

const zonas = [
  {
    nombre: "Pont d'Inca",
    descripcion: 'Principal núcleo urbano de Marratxí, limítrofe con Palma. Alta densidad de pisos y adosados de construcción reciente. Proyectos habituales: personalización de viviendas nuevas, vestidores, despachos y aislamiento acústico entre vecinos.',
  },
  {
    nombre: 'Sa Cabaneta',
    descripcion: 'Núcleo tradicional en la zona alta del municipio. Mix de casas de pueblo antiguas y promociones nuevas. Reformas para modernizar viviendas heredadas y personalizar obra nueva: falsos techos, tabiques y trasdosados.',
  },
  {
    nombre: 'Pòrtol',
    descripcion: 'Pueblo conocido por su tradición alfarera. Casas de pueblo con carácter que necesitan actualizaciones: trasdosados térmicos en muros de piedra, falsos techos para ocultar instalaciones y redistribución funcional.',
  },
  {
    nombre: 'Marratxinet',
    descripcion: 'Pequeño núcleo residencial tranquilo. Casas unifamiliares y adosados que se benefician del pladur para crear nuevas estancias, mejorar el aislamiento y modernizar acabados.',
  },
  {
    nombre: "Es Pont d'Inca Nou",
    descripcion: 'Urbanización de desarrollo reciente con pisos y dúplex de nueva construcción. Reformas de personalización: vestidores, zonas de estudio, armarios empotrados con estructura de pladur y mejoras acústicas.',
  },
  {
    nombre: 'Es Caülls / Son Ramonell',
    descripcion: 'Zonas residenciales en expansión con chalets y adosados. Proyectos de ampliación interior, creación de despachos en casa, mejora del aislamiento térmico y falsos techos con iluminación LED.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Pladur en Marratxí', href: '/pladur-marratxi' },
]

const pageFaqs = faqs['marratxi'] ?? []

const proyectoFicha = [
  { label: 'Superficie', valor: '92 m²' },
  { label: 'Ubicación', valor: "Pont d'Inca, Marratxí" },
  { label: 'Trabajos', valor: 'Tabiques + Techo + Aislamiento acústico' },
  { label: 'Duración', valor: '7 días hábiles' },
  { label: 'Resultado', valor: 'Vestidor + despacho + mejora acústica' },
]

const serviciosLinks = [
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Precios', href: '/precios-pladur-mallorca' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Marratxí"
      description="Servicio profesional de instalación de pladur en Marratxí: falsos techos, tabiques, aislamiento acústico y térmico en Pont d'Inca, Sa Cabaneta, Pòrtol y Marratxinet."
      serviceType="Instalación de Pladur"
      url="/pladur-marratxi"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Marratxí. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Marratxí"
    zonas={zonas}
    faqKey="marratxi"
    heroTitle="Pladur en Marratxí — Reformas y Nuevas Instalaciones"
    heroBadge="Marratxí · Área Metropolitana de Palma"
    heroDescription="Instalamos pladur en Marratxí y todos sus núcleos: Pont d'Inca, Sa Cabaneta, Pòrtol, Marratxinet y Es Pont d'Inca Nou. Reformas en pisos nuevos y casas de pueblo. Presupuesto gratuito en 24 horas."
    faqTitulo="Preguntas frecuentes sobre pladur en Marratxí"
    faqSubtitulo="Respuestas a las dudas más habituales de nuestros clientes en Marratxí."
    proyectoTitulo="Personalización de piso nuevo en Pont d'Inca"
    proyectoFicha={proyectoFicha}
    ctaTitulo="¿Tu proyecto está en Marratxí?"
    ctaSubtitulo="Contacta ahora y recibe tu presupuesto gratuito en menos de 24 horas. Sin desplazamiento — estamos al lado."
  >
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-10">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Especialistas en Marratxí
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            Pladur en Marratxí: reformas en el municipio que más crece
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-5 text-muted leading-relaxed mb-12">
          <div class="space-y-5">
            <p>
              Marratxí es el municipio con mayor crecimiento demográfico del área metropolitana de Palma. Con más de 40.000 habitantes repartidos en seis núcleos urbanos —Pont d'Inca, Sa Cabaneta, Pòrtol, Marratxinet, Es Pont d'Inca Nou y Es Caülls—, combina la tranquilidad residencial con la proximidad a Palma y sus servicios. Esta dualidad se refleja en su parque inmobiliario: desde casas de pueblo centenarias en Pòrtol y Sa Cabaneta hasta pisos y adosados de nueva promoción en Pont d'Inca y Es Pont d'Inca Nou.
            </p>
            <p>
              Las promociones de obra nueva que proliferan en Marratxí se entregan con distribuciones estándar que no siempre se adaptan a las necesidades de cada familia. El pladur permite personalizar estos espacios de forma rápida y limpia: crear un vestidor en el dormitorio principal con <a href="/tabiques-pladur-mallorca">tabiques de distribución</a>, dividir una habitación grande para los hijos, montar un despacho aprovechando un rincón del salón, o instalar un <a href="/falsos-techos-pladur-mallorca">falso techo con iluminación LED</a> empotrada que transforma completamente el ambiente del hogar.
            </p>
            <p>
              El <a href="/aislamiento-acustico-mallorca">aislamiento acústico</a> es una necesidad creciente en las nuevas promociones de Marratxí. Aunque los edificios cumplen la normativa CTE-HR, muchos propietarios desean una mejora adicional de la insonorización entre viviendas, especialmente en tabiques medianeros y forjados. Nuestros sistemas de pladur con doble placa y lana mineral de alta densidad aportan entre 10 y 15 dB adicionales de aislamiento, una diferencia muy perceptible en el día a día.
            </p>
          </div>
          <div class="space-y-5">
            <p>
              Los núcleos tradicionales de Pòrtol y Sa Cabaneta conservan un tejido de casas de pueblo con muros de piedra, techos de vigas de madera y distribuciones de otra época. Muchas de estas viviendas están siendo adquiridas por familias jóvenes que buscan más espacio que un piso en Palma. El pladur es la herramienta clave para la rehabilitación: trasdosados que aíslan del frío invernal y del calor del verano, falsos techos que ocultan instalaciones antiguas y permiten integrar climatización moderna, y tabiques que crean dormitorios, baños y zonas funcionales.
            </p>
            <p>
              La proximidad de Marratxí a nuestro centro de operaciones en Palma se traduce en ventajas logísticas para nuestros clientes: tiempos de respuesta mínimos, facilidad para gestionar visitas técnicas y entrega de materiales sin complicaciones. No hay coste de desplazamiento y podemos iniciar obras con plazos muy ajustados cuando el cliente lo necesita.
            </p>
            <p>
              Trabajamos en todos los núcleos de Marratxí y adaptamos nuestras soluciones a cada tipo de vivienda: desde la personalización de un piso nuevo en Es Pont d'Inca Nou hasta la rehabilitación completa de una casa de pueblo en Pòrtol. Presupuesto gratuito y cerrado en 24-48 horas tras visita técnica.
            </p>
          </div>
        </div>
        <div class="bg-foreground rounded-3xl p-7 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-bold text-lg text-white mb-2">Marratxí confía en nosotros</p>
              <p class="text-white/60 text-sm leading-relaxed mb-4">Más de 20 años trabajando en Marratxí y toda el área metropolitana de Palma. Conocemos cada núcleo del municipio y sus particularidades constructivas.</p>
              <div class="flex items-center gap-2">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-white/60 text-xs">4.7/5 en Google</span>
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-3">Servicios en Marratxí</p>
              <div class="grid grid-cols-2 gap-2">
                {serviciosLinks.map((s) => (
                  <a href={s.href} class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors">
                    <svg aria-hidden="true" class="size-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Una familia con dos hijos adquirió un piso de obra nueva de 92 m² en una promoción reciente de Pont d'Inca. La distribución de entrega incluía tres dormitorios, un baño y un aseo, salón-comedor y cocina. Sin embargo, necesitaban un vestidor en el dormitorio principal, un despacho para teletrabajo y mejorar el aislamiento acústico del tabique medianero con el vecino, que resultaba insuficiente para su día a día.
      </p>
      <p>
        El proyecto consistió en la instalación de un tabique de pladur para dividir el dormitorio principal (14 m²) y crear un vestidor de 4 m² con puerta corredera. Se creó un despacho de 6 m² aprovechando una zona del salón mediante un tabique con placa doble para garantizar privacidad acústica durante las videollamadas. Sobre el tabique medianero existente se montó un trasdosado de refuerzo acústico con placa de 15 mm y lana mineral de alta densidad (12 m² de superficie). Además, se instaló un falso techo continuo en el salón-comedor (28 m²) con focos LED empotrados que sustituyeron las lámparas de techo originales.
      </p>
      <p>
        Todo el trabajo se realizó en 7 días hábiles, con la familia pudiendo dormir en la vivienda durante la reforma gracias al trabajo secuencial por estancias. El presupuesto total fue de 5.900 euros. El resultado fue un piso completamente personalizado que se adaptó a las necesidades reales de la familia, con un aislamiento acústico notablemente mejorado y una iluminación moderna que transformó el aspecto del salón.
      </p>
    </div>
  </PaginaGeografica>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
