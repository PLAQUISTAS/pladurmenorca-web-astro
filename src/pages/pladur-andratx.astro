---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import PaginaGeografica from '@/components/templates/PaginaGeografica.astro'
import { faqs } from '@/data/faqs'
import { siteConfig } from '@/data/site'

const meta = {
  title: "Pladur en Andratx y Port d'Andratx | Reformas Premium",
  description: "Instala pladur en Andratx y Port d'Andratx. Reformas premium en villas de lujo. Falsos techos, aislamiento y acabados de alta gama. Presupuesto gratis.",
  canonical: '/pladur-andratx',
}

const zonas = [
  {
    nombre: 'Andratx pueblo',
    descripcion: 'Centro urbano tradicional con casas de pueblo y pisos del ensanche. Reformas para modernizar viviendas: falsos techos, trasdosados térmicos, redistribución de espacios y mejora del aislamiento acústico.',
  },
  {
    nombre: "Port d'Andratx",
    descripcion: 'Una de las zonas más exclusivas de Mallorca. Villas y apartamentos de lujo que demandan acabados impecables: pladur con perfilería reforzada, aislamiento de altas prestaciones y coordinación con arquitectos e interioristas.',
  },
  {
    nombre: 'Camp de Mar',
    descripcion: 'Urbanización costera residencial con chalets y algunos hoteles. Reformas de viviendas para mejorar distribución, aislamiento térmico contra el calor de poniente y modernización de acabados interiores.',
  },
  {
    nombre: 'Sant Elm',
    descripcion: 'Pequeño núcleo costero en el extremo suroeste de Mallorca. Casas y apartamentos que necesitan actualizaciones: falsos techos, aislamiento térmico en fachadas expuestas al sol y redistribución de espacios.',
  },
  {
    nombre: "S'Arracó",
    descripcion: 'Pueblo tradicional del interior con casas de piedra heredadas. Proyectos de rehabilitación que combinan pladur con elementos originales: trasdosados sobre muros de piedra, techos nuevos y redistribución funcional.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Pladur en Andratx', href: '/pladur-andratx' },
]

const pageFaqs = faqs['andratx'] ?? []

const proyectoFicha = [
  { label: 'Superficie', valor: '220 m²' },
  { label: 'Ubicación', valor: "Port d'Andratx" },
  { label: 'Trabajos', valor: 'Techos de diseño + Aislamiento + Tabiques' },
  { label: 'Duración', valor: '18 días hábiles' },
  { label: 'Nivel', valor: 'Alta gama — coordinación con interiorista' },
]

const serviciosLinks = [
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Precios', href: '/precios-pladur-mallorca' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Andratx"
      description="Servicio profesional de instalación de pladur en Andratx y el suroeste de Mallorca: falsos techos, tabiques, aislamiento acústico y térmico en Port d'Andratx, Camp de Mar y Sant Elm."
      serviceType="Instalación de Pladur"
      url="/pladur-andratx"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Andratx. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Andratx"
    zonas={zonas}
    faqKey="andratx"
    heroTitle="Pladur en Andratx — Reformas Premium en el Suroeste de Mallorca"
    heroBadge="Andratx · Suroeste de Mallorca"
    heroDescription="Instalamos pladur en Andratx y todo el suroeste: Port d'Andratx, Camp de Mar, Sant Elm y S'Arracó. Acabados de alta gama, aislamiento térmico y acústico, falsos techos y tabiques. Presupuesto gratuito en 24 horas."
    faqTitulo="Preguntas frecuentes sobre pladur en Andratx"
    faqSubtitulo="Respuestas a las dudas más habituales de nuestros clientes en Andratx y el suroeste de Mallorca."
    proyectoTitulo="Reforma premium de villa en Port d'Andratx"
    proyectoFicha={proyectoFicha}
    ctaTitulo="¿Tu proyecto está en Andratx o el suroeste?"
    ctaSubtitulo="Contacta ahora y recibe tu presupuesto gratuito en menos de 24 horas. Sin desplazamiento en toda la zona."
  >
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-10">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Especialistas en el suroeste
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            Pladur en Andratx: acabados premium para el suroeste de Mallorca
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-5 text-muted leading-relaxed mb-12">
          <div class="space-y-5">
            <p>
              Andratx es uno de los municipios más diversos de Mallorca desde el punto de vista inmobiliario. Mientras que el pueblo de Andratx y S'Arracó mantienen su carácter de poblaciones tradicionales mallorquinas con casas de pueblo y pisos modestos, Port d'Andratx y sus urbanizaciones circundantes albergan algunas de las propiedades más exclusivas del Mediterráneo occidental. Esta diversidad se traduce en una demanda de reformas con pladur igualmente variada.
            </p>
            <p>
              Port d'Andratx es sinónimo de lujo inmobiliario en Mallorca. Las villas y apartamentos de esta zona exigen un nivel de acabado acorde con su posición en el mercado: el pladur permite crear superficies perfectamente lisas para pinturas de primer nivel, integrar sistemas de iluminación de diseño en <a href="/falsos-techos-pladur-mallorca">falsos techos escalonados</a>, y conseguir un <a href="/aislamiento-acustico-mallorca">aislamiento acústico</a> que garantice la privacidad absoluta entre estancias y entre viviendas. En estos proyectos, la calidad del material y la precisión de la instalación son tan importantes como el diseño.
            </p>
            <p>
              Trabajamos habitualmente con los principales estudios de arquitectura e interiorismo que operan en Port d'Andratx. Nos coordinamos con electricistas, fontaneros y pintores especializados para ofrecer un resultado integral donde el pladur es la base invisible sobre la que se construye todo el interiorismo. Nuestros técnicos están formados en técnicas de instalación de alta precisión: juntas invisibles, ángulos perfectos y superficies que no necesitan más de una mano de masilla antes de pintar.
            </p>
          </div>
          <div class="space-y-5">
            <p>
              Camp de Mar presenta una tipología diferente: chalets y viviendas unifamiliares que necesitan actualizaciones para mejorar su eficiencia energética. La orientación de poniente de muchas de estas viviendas las expone a horas de sol directo por la tarde, lo que dispara el consumo de aire acondicionado en verano. Un trasdosado de pladur con <a href="/aislamiento-termico-mallorca">aislamiento térmico</a> de alta prestación puede reducir la temperatura interior hasta 8°C sin aire acondicionado, con un ahorro energético del 25-35% en la factura eléctrica.
            </p>
            <p>
              El pueblo de Andratx y S'Arracó conservan un tejido de casas de pueblo tradicionales, muchas heredadas y en proceso de renovación. El pladur es la herramienta perfecta para modernizar estas viviendas: falsos techos que ocultan instalaciones antiguas y permiten integrar iluminación LED, tabiques que redistribuyen espacios para adaptarlos a las necesidades de una familia actual, y trasdosados que aíslan del frío y la humedad que se filtra a través de los muros de piedra centenarios.
            </p>
            <p>
              Cubrimos todo el municipio de Andratx sin coste adicional de desplazamiento para obras a partir de 500€. Desde las villas más exclusivas de Port d'Andratx hasta las casas de pueblo de S'Arracó, adaptamos nuestro servicio al nivel de acabado que cada proyecto requiere.
            </p>
          </div>
        </div>
        <div class="bg-foreground rounded-3xl p-7 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-bold text-lg text-white mb-2">El suroeste confía en nosotros</p>
              <p class="text-white/60 text-sm leading-relaxed mb-4">Más de 20 años trabajando en Andratx y todo el suroeste de Mallorca. Experiencia en proyectos de alta gama en Port d'Andratx y reformas residenciales en todo el municipio.</p>
              <div class="flex items-center gap-2">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-white/60 text-xs">4.7/5 en Google</span>
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-3">Servicios en Andratx</p>
              <div class="grid grid-cols-2 gap-2">
                {serviciosLinks.map((s) => (
                  <a href={s.href} class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors">
                    <svg aria-hidden="true" class="size-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Una villa de 220 m² con vistas al puerto deportivo de Port d'Andratx necesitaba una reforma interior integral coordinada por un estudio de interiorismo de Palma. La vivienda, construida en 2005, tenía acabados que habían quedado desfasados y una distribución de la planta principal que los nuevos propietarios querían transformar por completo. El nivel de exigencia era máximo: superficies perfectamente planas para un acabado de pintura artesanal tipo estuco veneciano, falsos techos de diseño con geometrías complejas e insonorización total entre la zona de día y los dormitorios.
      </p>
      <p>
        El proyecto de pladur abarcó toda la planta principal y la planta de dormitorios. En el salón principal (55 m²), se ejecutó un falso techo escalonado a tres niveles con cofre perimetral para iluminación LED indirecta y nichos para integrar altavoces de sonido ambiente. En los cuatro dormitorios se instalaron techos continuos con doble placa (120 m² en total) y aislamiento acústico de lana mineral de 60 mm entre la placa y el forjado. Los tabiques entre la zona de día y los dormitorios se reforzaron con un sistema de doble estructura independiente, doble placa y lana mineral de alta densidad, alcanzando una reducción acústica de 56 dB. Se crearon además dos vestidores con estructura de pladur (16 ml de tabiques) y un office junto a la cocina.
      </p>
      <p>
        El trabajo se completó en 18 días hábiles con un equipo de tres técnicos dedicados en exclusiva. El coste de la partida de pladur fue de 19.800 euros. La coordinación con el interiorista fue constante: se realizaron tres visitas conjuntas para verificar niveles, planeidad y posiciones exactas de los elementos técnicos antes de cada fase. El resultado fue una base perfecta sobre la que el pintor pudo aplicar el estuco veneciano sin correcciones, y un aislamiento acústico que permite escuchar música en el salón sin que llegue sonido alguno a los dormitorios.
      </p>
    </div>
  </PaginaGeografica>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
