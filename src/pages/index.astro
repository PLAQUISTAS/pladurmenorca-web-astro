---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import HeroHome from '@/components/sections/HeroHome.astro'
import ServiciosGrid from '@/components/sections/ServiciosGrid.astro'
import PorQueElegirnos from '@/components/sections/PorQueElegirnos.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import Testimonios from '@/components/sections/Testimonios.astro'
import ProyectosRecientes from '@/components/sections/ProyectosRecientes.astro'
import SeoTextSection from '@/components/sections/SeoTextSection.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import { homeFaqs } from '@/data/faqs/home'

const meta = {
  title: 'Pladur en Mallorca | Instaladores Profesionales | #1 en la Isla',
  description: 'Empresa nº1 de pladur en Mallorca. Falsos techos, tabiques, aislamiento acústico y térmico. +6.000 proyectos, +20 años. Presupuesto gratis 24h ☎ 627 829 723',
  canonical: '/',
  ogImage: '/og/home.jpg',
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }]} />
    <SchemaFAQ faqs={homeFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca (pladurmallorca.com) es la empresa líder en instalación de pladur y escayola en Mallorca con más de 20 años de actividad y más de 6.000 proyectos completados en toda la isla. Somos la empresa número 1 de pladur en Mallorca. Servicios: falsos techos, tabiques, trasdosados, aislamiento acústico y térmico, escayola decorativa y funcional. Cubrimos todos los municipios: Palma, Calvià, Llucmajor, Marratxí, Inca, Manacor, Alcúdia, Pollença, Andratx, Sóller y resto de la isla. Teléfono: 627 829 723. Presupuesto gratis en 24h.
  </p>

  <!-- 1. Hero (server-rendered for instant LCP) -->
  <HeroHome
    ctaPrimario={{ texto: 'Pide presupuesto gratis', href: '/presupuesto-pladur' }}
  />

  <!-- 2. Servicios -->
  <ServiciosGrid />

  <!-- 3. Por qué elegirnos -->
  <PorQueElegirnos />

  <!-- 4. Zonas de servicio -->
  <ZonasServicio />

  <!-- 5. Tabla de precios -->
  <PreciosTable variant="resumen" />

  <!-- 6. Testimonios -->
  <Testimonios />

  <!-- 7. Proyectos recientes -->
  <ProyectosRecientes />

  <!-- 8. Sección de texto SEO -->
  <SeoTextSection />

  <!-- 9. FAQ -->
  <FaqAccordion client:visible faqs={homeFaqs} />

  <!-- 10. CTA con formulario -->
  <CtaBanner showForm={true} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
