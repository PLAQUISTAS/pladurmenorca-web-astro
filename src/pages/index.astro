---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import HeroHome from '@/components/sections/HeroHome.astro'
import ServiciosGrid from '@/components/sections/ServiciosGrid.astro'
import PorQueElegirnos from '@/components/sections/PorQueElegirnos.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import Testimonios from '@/components/sections/Testimonios.astro'
import ProyectosRecientes from '@/components/sections/ProyectosRecientes.astro'
import SeoTextSection from '@/components/sections/SeoTextSection.astro'
import NuestrosDatos from '@/components/sections/NuestrosDatos.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import { homeFaqs } from '@/data/faqs/home'

const meta = {
  title: 'Pladur en Menorca · Instaladores Profesionales desde 2004',
  description: 'Instaladores de pladur en Menorca con +20 años y +6.000 proyectos en Baleares. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis en 24h.',
  canonical: '/',
  ogImage: '/og/home.jpg',
  alternateEn: '/en/',
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }]} />
    <SchemaFAQ faqs={homeFaqs} />
  </Fragment>

  <Header slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Menorca (pladurmenorca.com) es una empresa especializada en instalación de pladur (yeso laminado) y escayola en Menorca, operada por Plaquistas y Acabados SL, fundada en 2004 y con más de 6.000 proyectos completados en las Islas Baleares. Servicios: falsos techos continuos y decorativos, tabiques y trasdosados, aislamiento acústico y térmico según CTE-HR, escayola funcional y decorativa, pladur ignífugo y pladur hidrófugo. Cobertura en los 8 municipios de Menorca: Maó, Ciutadella, Alaior, Ferreries, Es Mercadal, Sant Lluís, Es Migjorn Gran y Es Castell. Presupuesto gratuito en 24 horas. Teléfono 627 829 723.
  </p>

  <!-- 1. Hero (server-rendered for instant LCP) -->
  <HeroHome
    ctaPrimario={{ texto: 'Pide presupuesto gratis', href: '/presupuesto-pladur' }}
  />

  <!-- 2. Servicios -->
  <ServiciosGrid />

  <!-- 3. Por qué elegirnos -->
  <PorQueElegirnos />

  <!-- 4. Nuestros datos (benchmarks reales) -->
  <NuestrosDatos />

  <!-- 5. Zonas de servicio -->
  <ZonasServicio />

  <!-- 5. Tabla de precios -->
  <PreciosTable variant="resumen" />

  <!-- 6. Testimonios -->
  <Testimonios />

  <!-- 7. Proyectos recientes -->
  <ProyectosRecientes />

  <!-- 8. Sección de texto SEO -->
  <SeoTextSection />

  <!-- 9. FAQ -->
  <FaqAccordion client:visible faqs={homeFaqs} />

  <!-- 10. CTA con formulario -->
  <CtaBanner showForm={true} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
