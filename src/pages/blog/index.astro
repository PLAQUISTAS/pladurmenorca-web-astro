---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import { Image } from 'astro:assets'
import { getAllPosts, blogCategories, formatDate } from '@/lib/blog'
import { siteConfig } from '@/data/site'

const posts = await getAllPosts()
const FEATURED_SLUG = 'precio-pladur-mallorca-2026'
const featuredPost = posts.find((p) => p.slug === FEATURED_SLUG) || posts[0]
const restPosts = posts.filter((p) => p.slug !== featuredPost?.slug)

const meta = {
  title: 'Blog Pladur Mallorca | Guías, Precios y Consejos',
  description: 'Blog de Pladur Mallorca: guías de precios actualizados 2026, consejos de instalación, comparativas de materiales y todo sobre pladur en Mallorca. Gratis.',
  canonical: '/blog',
}

const collectionPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog Pladur Mallorca',
  description: 'Guías de precios, consejos de instalación, comparativas y todo lo que necesitas saber sobre el pladur en Mallorca.',
  url: `${siteConfig.url}/blog`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteConfig.url}/blog/${post.slug}`,
      name: post.title,
    })),
  },
})
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Blog', href: '/blog' }]} />
    <script type="application/ld+json" set:html={collectionPageSchema} />
  </Fragment>

  <Header client:idle slot="header" />

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-3xl text-center mx-auto">
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            {['Guías prácticas', 'Precios actualizados', 'Consejos de expertos'].map((tag) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-surface text-foreground border border-warm-border/60">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            Blog Pladur Mallorca
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto">
            Guías de precios, consejos de instalación, comparativas de materiales y proyectos reales. Todo lo que necesitas saber sobre el pladur en Mallorca.
          </p>
        </div>
      </div>
    </div>
  </section>

  {posts.length === 0 ? (
    <!-- Empty state -->
    <section class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center py-20">
          <div class="size-16 rounded-2xl bg-warm-border-light flex items-center justify-center mx-auto mb-6">
            <svg class="size-8 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <p class="text-xl font-bold text-foreground mb-2">Próximamente</p>
          <p class="text-muted text-base leading-relaxed max-w-sm mx-auto">
            Estamos preparando artículos y guías sobre pladur en Mallorca. Vuelve pronto.
          </p>
          <a
            href="/presupuesto-pladur"
            class="inline-flex items-center gap-2 mt-8 px-8 py-4 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 transition-[background-color,box-shadow] duration-200"
          >
            Pide tu presupuesto gratis
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  ) : (
    <>
      <!-- Featured Post -->
      {featuredPost && (
        <section class="py-20 lg:py-28">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-8 inline-flex items-center px-3 py-1 rounded-lg">
              Artículo destacado
            </p>
            <a href={`/blog/${featuredPost.slug}`} class="group block">
              <article class="bg-white/70 rounded-3xl border border-warm-border/50 overflow-hidden shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                  <!-- Image -->
                  <div class="relative aspect-[16/10] lg:aspect-auto overflow-hidden bg-warm-border-light">
                    <Image
                      src={featuredPost.image}
                      alt={`${featuredPost.title} — ${featuredPost.category}, Pladur Mallorca`}
                      width={800}
                      height={500}
                      class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="eager"
                    />
                    <div class="absolute top-4 left-4">
                      <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold text-white bg-foreground-dark uppercase tracking-wider">
                        {featuredPost.category}
                      </span>
                    </div>
                  </div>
                  <!-- Content -->
                  <div class="flex flex-col justify-center p-8 lg:p-12">
                    <div class="flex items-center gap-3 mb-5 text-sm text-muted">
                      <time datetime={featuredPost.date}>{formatDate(featuredPost.date)}</time>
                      <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                      <span>{featuredPost.readingTime}</span>
                    </div>
                    <h2 class="text-2xl lg:text-3xl font-bold text-foreground leading-snug mb-4 group-hover:text-muted transition-colors">
                      {featuredPost.title}
                    </h2>
                    <p class="text-muted text-base leading-relaxed mb-8 line-clamp-3">
                      {featuredPost.excerpt}
                    </p>
                    <div class="inline-flex items-center gap-2 text-foreground font-bold text-sm">
                      Leer artículo completo
                      <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            </a>
          </div>
        </section>
      )}

      <!-- Categories + Posts Grid -->
      <section class="py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-12">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">
                Todos los artículos
              </p>
              <p class="text-sm text-muted">
                <span class="font-bold text-foreground">{posts.length}</span> artículos publicados
              </p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              {blogCategories.map((cat) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium text-foreground bg-surface border border-warm-border/60">
                  {cat}
                </span>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
            {(restPosts.length > 0 ? restPosts : posts).map((post) => (
              <article class="group h-full bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 flex flex-col overflow-hidden">
                <!-- Image -->
                <div class="relative aspect-[16/9] overflow-hidden bg-warm-border-light">
                  <Image
                    src={post.image}
                    alt={`${post.title} — ${post.category}, Pladur Mallorca`}
                    width={600}
                    height={338}
                    class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold text-white bg-foreground-dark uppercase tracking-wider">
                      {post.category}
                    </span>
                  </div>
                </div>

                <!-- Content -->
                <div class="flex flex-col flex-1 p-7">
                  <div class="flex items-center gap-3 mb-4 text-sm text-muted">
                    <time datetime={post.date}>{formatDate(post.date)}</time>
                    <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                    <span>{post.readingTime}</span>
                  </div>
                  <h3 class="text-lg font-bold text-foreground leading-snug mb-4 group-hover:text-muted transition-colors">
                    <a href={`/blog/${post.slug}`}>
                      {post.title}
                    </a>
                  </h3>
                  <p class="text-muted text-sm leading-relaxed flex-1 mb-6 line-clamp-3">
                    {post.excerpt}
                  </p>
                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center gap-1.5 text-foreground font-semibold text-sm hover:text-foreground-dark transition-colors"
                  >
                    Leer más
                    <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <!-- Qué encontrarás en nuestro blog -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg mx-auto">
          Recursos para tu proyecto
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
          ¿Qué encontrarás en nuestro blog?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Guías de precios actualizadas</h3>
          <p class="text-muted text-sm leading-relaxed">Precios reales por m² de cada tipo de instalación de pladur en Mallorca. Actualizados periódicamente con costes de materiales y mano de obra vigentes.</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Comparativas y consejos</h3>
          <p class="text-muted text-sm leading-relaxed">Pladur vs ladrillo, tipos de placa, aislamiento acústico vs térmico. Información técnica explicada de forma clara para que tomes la mejor decisión.</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">Proyectos en Mallorca</h3>
          <p class="text-muted text-sm leading-relaxed">Casos reales de reformas con pladur en Palma, Calvià, Inca y otros municipios. Descubre qué resultados puedes esperar en tu zona.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl py-16 lg:py-24 px-6 sm:px-10 lg:px-16 relative overflow-hidden shadow-warm">
        <div class="text-center max-w-2xl mx-auto">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-6">
            Empieza tu proyecto
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            ¿Tienes un proyecto en mente?
          </h2>
          <p class="text-lg text-muted leading-relaxed mb-10">
            Solicita tu presupuesto gratuito. Visita técnica incluida. Respuesta en 24 horas.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/presupuesto-pladur"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 transition-[background-color,box-shadow] duration-200 active:scale-95"
            >
              Pide presupuesto gratis
              <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="inline-flex items-center gap-2 px-8 py-4 border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-[background-color,border-color,color,transform] duration-200 active:scale-95 rounded-xl"
            >
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Llamar ahora
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-8 inline-flex items-center px-3 py-1 rounded-lg">También te puede interesar</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { href: '/presupuesto-pladur', label: 'Presupuesto de Pladur', descripcion: 'Solicita un presupuesto detallado con visita técnica gratuita incluida' },
          { href: '/precios-pladur-mallorca', label: 'Precios de Pladur', descripcion: 'Consulta nuestras tarifas y precios orientativos por m²' },
          { href: '/instalacion-pladur-mallorca', label: 'Instalación de Pladur', descripcion: 'Todo sobre nuestros servicios de instalación de pladur en Mallorca' },
        ].map((link) => (
          <a
            href={link.href}
            class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300"
          >
            <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
            <p class="text-muted text-sm mb-4">{link.descripcion}</p>
            <div class="h-0.5 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-0 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
