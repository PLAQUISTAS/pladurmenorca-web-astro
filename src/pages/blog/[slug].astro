---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaArticle from '@/components/seo/SchemaArticle.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import { Image } from 'astro:assets'
import { getAllPosts, getPostBySlug, formatDate } from '@/lib/blog'
import { siteConfig } from '@/data/site'
import type { FAQ } from '@/data/faqs/types'

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map((post) => ({ params: { slug: post.slug } }))
}

const { slug } = Astro.params
const [post, allPosts] = await Promise.all([
  getPostBySlug(slug!),
  getAllPosts(),
])

if (!post) {
  return Astro.redirect('/404')
}

const relatedPosts = allPosts.filter((p) => p.slug !== post.slug).slice(0, 3)

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: post.title, href: `/blog/${post.slug}` },
]

const postFaqs = (post as unknown as { faqs?: FAQ[] }).faqs

const ogImage = post.image.startsWith('http') ? post.image : `${siteConfig.url}${post.image}`

const meta = {
  title: post.title,
  description: post.description,
  canonical: `/blog/${post.slug}`,
  ogImage,
  type: 'article' as const,
  publishedTime: post.date,
  modifiedTime: post.updated || post.date,
  articleSection: post.category,
  articleTags: post.keywords,
  preloadImage: post.image,
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaArticle
      title={post.title}
      description={post.description}
      url={`/blog/${post.slug}`}
      image={post.image}
      datePublished={post.date}
      dateModified={post.updated}
      authorName={post.author}
      articleSection={post.category}
      keywords={post.keywords}
    />
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbItems} />
    {postFaqs && postFaqs.length > 0 && <SchemaFAQ faqs={postFaqs} />}
  </Fragment>

  <Header client:idle slot="header" />

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white border border-warm-border/40 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="relative max-w-4xl mx-auto text-center">
          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb" class="mb-6">
            <ol class="flex flex-wrap items-center justify-center gap-1.5 text-sm text-muted">
              {breadcrumbItems.map((item, i) => (
                <li class="flex items-center gap-1.5">
                  {i > 0 && (
                    <svg class="size-3.5 text-warm-border" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  )}
                  {i < breadcrumbItems.length - 1 ? (
                    <a href={item.href} class="hover:text-foreground transition-colors">
                      {item.label}
                    </a>
                  ) : (
                    <span class="text-foreground font-medium truncate max-w-[200px] sm:max-w-[400px]">{item.label}</span>
                  )}
                </li>
              ))}
            </ol>
          </nav>

          <div class="flex items-center justify-center gap-3 mb-6">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-warm-200 text-foreground border border-warm-border/60">
              {post.category}
            </span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-8">
            {post.title}
          </h1>
          <!-- Article meta -->
          <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-muted">
            <div class="flex items-center gap-2">
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
              <span>{post.author}</span>
            </div>
            <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
            <div class="flex items-center gap-2">
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              <time datetime={post.date}>{formatDate(post.date)}</time>
            </div>
            {post.updated && post.updated !== post.date && (
              <>
                <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                <div class="flex items-center gap-2">
                  <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                  </svg>
                  <span>Actualizado: {formatDate(post.updated)}</span>
                </div>
              </>
            )}
            <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
            <div class="flex items-center gap-2">
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{post.readingTime}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content area -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- Main content -->
        <article class="lg:col-span-8">
          <!-- Featured image -->
          {post.image && (
            <div class="relative aspect-[16/9] mb-14 overflow-hidden rounded-2xl bg-warm-border-light border border-warm-border/40 shadow-card">
              <Image
                src={post.image}
                alt={`${post.title} — ${post.category}, Pladur Mallorca`}
                width={900}
                height={506}
                class="object-cover w-full h-full"
                loading="eager"
              />
            </div>
          )}

          <!-- MDX/Markdown content -->
          <div class="prose-pladur max-w-prose" set:html={post.content} />
        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">

            <!-- CTA presupuesto -->
            <div class="bg-foreground-dark rounded-3xl p-8 text-white relative overflow-hidden">
              <!-- Decorative accent line -->
              <div class="absolute top-0 left-0 right-0 h-1 bg-accent"></div>

              <div class="flex items-center gap-3 mb-5">
                <div class="size-10 rounded-xl bg-white/10 flex items-center justify-center">
                  <svg class="size-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25v-.008zm2.498-6h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007v-.008zm2.504-6h.006v.008h-.006v-.008zm0 2.25h.006v.008h-.006v-.008zm0 2.25h.006v.008h-.006v-.008zm0 2.25h.006v.008h-.006v-.008zm2.498-6h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z" />
                  </svg>
                </div>
                <p class="text-xs font-bold uppercase tracking-widest text-white/50">
                  Empieza tu proyecto
                </p>
              </div>

              <h3 class="font-bold text-xl text-white mb-3">
                Pide tu presupuesto gratis
              </h3>

              <!-- Trust signals -->
              <ul class="space-y-2.5 mb-7">
                {['Visita técnica gratuita', 'Respuesta en 24-48 horas', 'Precio cerrado sin sorpresas'].map((item) => (
                  <li class="flex items-center gap-2.5 text-white/70 text-sm">
                    <div class="shrink-0 size-5 bg-white/15 rounded-full flex items-center justify-center">
                      <svg class="size-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>

              <div class="flex flex-col gap-3">
                <a
                  href="/presupuesto-pladur"
                  class="flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide shadow-lg shadow-accent/30 transition-[background-color,box-shadow] duration-200"
                >
                  Solicitar presupuesto
                  <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </a>
                <a
                  href={`tel:${siteConfig.phoneRaw}`}
                  class="flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl border-2 border-white/20 text-white font-bold text-sm hover:bg-white hover:text-foreground hover:border-white transition-colors duration-200"
                >
                  <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  {siteConfig.phone}
                </a>
              </div>

              <div class="mt-6 flex items-center gap-2 pt-5 border-t border-white/10">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" aria-hidden="true" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-white/70 text-sm">{siteConfig.aggregateRating.ratingValue}/5 en Google</span>
              </div>
            </div>

            <!-- Article info card -->
            <div class="bg-white rounded-3xl border border-warm-border/40 p-7 shadow-card">
              <p class="text-xs font-semibold uppercase tracking-wide text-foreground mb-6">
                Sobre este artículo
              </p>
              <div class="space-y-5">
                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center">
                    <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-xs text-muted">Categoría</p>
                    <p class="text-sm font-semibold text-foreground truncate">{post.category}</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center">
                    <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-xs text-muted">Autor</p>
                    <p class="text-sm font-semibold text-foreground truncate">{post.author}</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center">
                    <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-xs text-muted">Publicado</p>
                    <p class="text-sm font-semibold text-foreground">{formatDate(post.date)}</p>
                  </div>
                </div>

                {post.updated && post.updated !== post.date && (
                  <div class="flex items-center gap-3">
                    <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center">
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs text-muted">Actualizado</p>
                      <p class="text-sm font-semibold text-foreground">{formatDate(post.updated)}</p>
                    </div>
                  </div>
                )}

                <div class="flex items-center gap-3">
                  <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center">
                    <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-xs text-muted">Lectura</p>
                    <p class="text-sm font-semibold text-foreground">{post.readingTime}</p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </aside>

      </div>
    </div>
  </section>

  <CtaBanner
    titulo="¿Tienes un proyecto en mente?"
    subtitulo="Presupuesto gratuito en 24 horas. Visita técnica incluida. Sin compromiso."
  />

  <!-- Posts relacionados -->
  {relatedPosts.length > 0 && (
    <section class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-14 animate-fade-up">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Continúa leyendo
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
            Artículos relacionados
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 stagger-children">
          {relatedPosts.map((relPost) => (
            <a href={`/blog/${relPost.slug}`} class="group block h-full">
              <article class="h-full bg-white rounded-3xl border border-warm-border/40 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 flex flex-col overflow-hidden"
                style="transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;">
                <!-- Image -->
                <div class="relative aspect-[16/9] overflow-hidden bg-warm-border-light">
                  <Image
                    src={relPost.image}
                    alt={`${relPost.title} — ${relPost.category}, Pladur Mallorca`}
                    width={600}
                    height={338}
                    class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold text-white bg-foreground/80 backdrop-blur-sm uppercase tracking-wider">
                      {relPost.category}
                    </span>
                  </div>
                </div>

                <!-- Content -->
                <div class="flex flex-col flex-1 p-7">
                  <div class="flex items-center gap-2 mb-4 text-xs text-muted">
                    <time datetime={relPost.date}>{formatDate(relPost.date)}</time>
                    <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                    <span>{relPost.readingTime}</span>
                  </div>

                  <h3 class="text-lg font-bold text-foreground leading-snug mb-5 group-hover:text-muted transition-colors flex-1">
                    {relPost.title}
                  </h3>

                  <div class="flex items-center gap-1.5 text-foreground font-semibold text-sm">
                    Leer artículo
                    <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>

        <div class="mt-14 text-center">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-all duration-200 active:scale-95"
          >
            Ver todos los artículos
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          Explora más
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-foreground leading-tight text-balance">
          También te puede interesar
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 stagger-children">
        {[
          { href: '/presupuesto-pladur', label: 'Presupuesto Gratuito', descripcion: 'Visita técnica incluida. Precio cerrado en 24-48h sin compromiso.' },
          { href: '/precios-pladur-mallorca', label: 'Precios por m²', descripcion: 'Tarifas actualizadas 2026 para todos los sistemas de pladur.' },
          { href: '/instalacion-pladur-mallorca', label: 'Servicios de Instalación', descripcion: 'Falsos techos, tabiques, trasdosados y reformas integrales.' },
        ].map((link) => (
          <a
            href={link.href}
            class="group flex flex-col items-center text-center bg-white rounded-3xl border border-warm-border/40 p-8 shadow-card hover:shadow-card-hover hover:-translate-y-0.5"
            style="transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;"
          >
            <h3 class="font-bold text-foreground text-lg mb-2">{link.label}</h3>
            <p class="text-muted text-sm leading-relaxed mb-5">{link.descripcion}</p>
            <span class="inline-flex items-center gap-1.5 text-foreground font-semibold text-sm mt-auto">
              Ver más
              <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
