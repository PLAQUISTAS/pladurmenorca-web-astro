---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import ArticulosRelacionados from '@/components/sections/ArticulosRelacionados.astro'
import { reformasFaqs } from '@/data/faqs/reformas'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Reformas Interiores con Pladur en Mallorca | Desde 45€/m²',
  description: 'Transforma tu espacio con reformas de pladur en Mallorca. Redistribución, falsos techos y aislamiento sin obra pesada. Desde 45€/m². Listo en 1-2 semanas.',
  canonical: '/reformas-interiores-pladur-mallorca',
}

const comparativa = [
  { criterio: 'Tiempo de ejecución', pladur: '1–2 semanas para un piso completo', obraTradicional: '4–8 semanas con curado y secado' },
  { criterio: 'Generación de escombros', pladur: 'Mínima — sin picar paredes ni demoler', obraTradicional: 'Alta — sacos de escombros, polvo, ruido' },
  { criterio: 'Precio orientativo', pladur: 'Desde 45€/m² (tabique completo)', obraTradicional: 'Desde 55€/m² (ladrillo hueco + enlucido)' },
  { criterio: 'Resultado final', pladur: 'Superficie perfectamente lisa, lista para pintar', obraTradicional: 'Requiere enlucido adicional y más tiempo' },
  { criterio: 'Instalaciones integradas', pladur: 'Electricidad, fontanería y climatización por el interior', obraTradicional: 'Requiere regatas y rozas en la pared' },
  { criterio: 'Peso estructural', pladur: 'Muy ligero — sin sobrecarga para el forjado', obraTradicional: 'Añade carga significativa al edificio' },
  { criterio: 'Impacto en la vivienda habitada', pladur: 'Se puede vivir durante la reforma', obraTradicional: 'Normalmente requiere desalojar la vivienda' },
]

const ventajasClave = [
  'Sin obra pesada ni demolición',
  'Mínima generación de escombros y polvo',
  'Instalación 3-4× más rápida que ladrillo',
  'Instalaciones integradas en el interior',
  'Aislamiento acústico y térmico incorporado',
  'Compatible con edificios históricos',
  'Superficie perfectamente lisa para pintar',
  'Garantía de 2 años en mano de obra',
]

const tiposReformas = [
  {
    num: '01',
    titulo: 'Redistribución de espacios con tabiques de pladur',
    parrafos: [
      'La redistribución de espacios es la reforma más habitual en Mallorca. Muchas viviendas —especialmente pisos del centro de Palma construidos antes de 1980— tienen distribuciones que no se adaptan a las necesidades actuales: salones demasiado grandes, dormitorios sin ventilación directa, pasillos que roban metros útiles o estudios que necesitan convertirse en dos habitaciones.',
      'Con tabiques de pladur podemos diseñar y ejecutar cualquier redistribución de planta en un tiempo récord. La estructura metálica se ancla al suelo y al techo sin necesidad de obra de albañilería, y las placas de yeso laminado se atornillan sobre ella dejando un acabado perfectamente liso listo para pintar. El interior del tabique se aprovecha para pasar cables, tuberías y conductos de climatización.',
      'Un tabique de distribución estándar tiene un espesor de tan solo 10 cm (con un ancho de placa de 12.5 mm a cada lado y un montante de 70 mm), lo que maximiza el espacio útil de la estancia. Si se necesita aislamiento acústico entre habitaciones, el interior se rellena con lana mineral de alta densidad sin aumentar significativamente el espesor total.',
      'Los tabiques de pladur son ideales también para crear espacios funcionales: vestidores integrados, cuartos de baño secos, zonas de trabajo independientes o habitaciones infantiles. La versatilidad del sistema permite curvas, ángulos y formas que serían muy costosas con ladrillo.',
    ],
    linkTexto: 'Ver todos los tipos de tabiques de pladur',
    linkHref: '/tabiques-pladur-mallorca',
  },
  {
    num: '02',
    titulo: 'Falsos techos de pladur para modernizar cualquier espacio',
    parrafos: [
      'Los falsos techos de pladur son una de las transformaciones más impactantes que puede experimentar una vivienda. En Mallorca, donde abundan los pisos del siglo pasado con techos de 3 a 4 metros de altura, el falso techo permite crear ambientes más cálidos y modernos, integrar la iluminación de forma elegante y ocultar instalaciones antiguas —tuberías de calefacción, cableado visto, vigas deterioradas— sin necesidad de picar ni demoler.',
      'Existen múltiples opciones de falso techo según el uso y el estilo deseado. El techo continuo liso es el más habitual en viviendas: una superficie perfectamente plana que baja entre 10 y 20 cm del techo original, en la que se integran focos de LED empotrados, difusores de climatización y altavoces. El techo con cofres y escalones permite crear efectos de volumen y profundidad muy cotizados en reformas de diseño.',
      'En locales comerciales y hostelería, el falso techo es la herramienta habitual para segmentar ambientes, crear zonas diferenciadas y mejorar la acústica del espacio. La placa de pladur acepta pinturas, revestimientos decorativos y acabados de todo tipo, por lo que el diseño final está limitado únicamente por la creatividad. Para locales que requieren cumplir normativa de protección contra incendios (CTE DB-SI), ofrecemos soluciones con <a href="/pladur-ignifugo-mallorca" class="text-foreground font-semibold underline underline-offset-2">pladur ignífugo certificado EI-60 y EI-120</a>.',
      'Un aspecto especialmente relevante en Mallorca es la integración del falso techo con los sistemas de aire acondicionado en casete o conducto. Instalamos el techo coordinando la posición de las rejillas de climatización para un resultado estético impecable, evitando las típicas "verrugas" que generan los instaladores que no coordinan con el yesero.',
    ],
    linkTexto: 'Ver todos los tipos de falsos techos de pladur',
    linkHref: '/falsos-techos-pladur-mallorca',
  },
  {
    num: '03',
    titulo: 'Aislamiento acústico entre vecinos con sistemas de pladur',
    parrafos: [
      'El ruido es uno de los principales problemas en la convivencia en pisos, especialmente en el tejido urbano denso de Mallorca. Palma, Calvià y otros municipios turísticos concentran una densidad de viviendas muy alta, y los estándares de aislamiento acústico de la construcción de las décadas de 1960 a 1990 son muy inferiores a los que exige hoy la normativa CTE-HR.',
      'Los sistemas de pladur para aislamiento acústico utilizan una combinación de técnicas para cortar la transmisión del sonido: doble placa en una o ambas caras del tabique, lana mineral de alta densidad en el interior de la cámara y —la técnica más eficaz— estructura desacoplada mediante bandas antivibratorias que impiden que el sonido se transmita a través de la estructura del edificio.',
      'Un tabique estándar de pladur con lana mineral puede alcanzar un índice de reducción acústica de 45 dB, por encima del mínimo de 47 dBRA exigido por el CTE. Las soluciones de alta gama, con doble placa y estructura desacoplada, pueden superar los 55 dB, lo que convierte una habitación en un espacio prácticamente insonorizado.',
      'Esta solución es especialmente demandada en Mallorca por propietarios de apartamentos turísticos que quieren mejorar sus valoraciones en plataformas como Airbnb o Booking, y por viviendas colindantes con locales de hostelería que sufren ruido nocturno.',
    ],
    linkTexto: 'Ver soluciones de aislamiento acústico en Mallorca',
    linkHref: '/aislamiento-acustico-mallorca',
  },
  {
    num: '04',
    titulo: 'Mejora térmica con trasdosados de pladur',
    parrafos: [
      'El trasdosado es la solución de pladur específica para mejorar el comportamiento térmico de fachadas, medianeras y paredes en contacto con el exterior. Consiste en adosar una segunda pared de pladur a la pared existente, creando una cámara que se rellena con aislante térmico —habitualmente lana mineral, poliestireno extruido o espuma de poliuretano proyectado, según las especificaciones técnicas del proyecto.',
      'En Mallorca, donde el clima mediterráneo combina veranos calurosos con inviernos suaves pero húmedos, la mejora del aislamiento térmico tiene un impacto directo y mesurable en la factura eléctrica. El consumo de aire acondicionado en verano puede reducirse entre un 20 y un 35% tras instalar un trasdosado adecuado. La amortización de la inversión suele producirse entre los 5 y los 10 años, dependiendo del consumo previo.',
      'El trasdosado de pladur mejora además la calificación energética del inmueble, un factor cada vez más relevante en Mallorca para la venta y el alquiler de viviendas. Una mejora de calificación de E a C puede incrementar el valor de la propiedad entre un 5 y un 15%, según estudios del mercado inmobiliario balear.',
    ],
    linkTexto: 'Ver soluciones de aislamiento térmico con pladur',
    linkHref: '/aislamiento-termico-mallorca',
  },
]

const preciosCards = [
  { servicio: 'Tabique básico', desde: 45, unidad: '€/m²' },
  { servicio: 'Tabique acústico', desde: 52, unidad: '€/m²' },
  { servicio: 'Falso techo continuo', desde: 29, unidad: '€/m²' },
  { servicio: 'Falso techo con iluminación', desde: 35, unidad: '€/m²' },
  { servicio: 'Trasdosado térmico', desde: 35, unidad: '€/m²' },
  { servicio: 'Reforma piso completo', desde: 10000, unidad: '€ aprox.' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Reformas Interiores', href: '/reformas-interiores-pladur-mallorca' }]} />
    <SchemaFAQ faqs={reformasFaqs} />
    <SchemaService name="Reformas Interiores con Pladur en Mallorca" description="Servicio de reformas interiores con sistemas de pladur en Mallorca: redistribución de espacios, falsos techos, aislamiento acústico y térmico sin obra pesada." serviceType="Reformas Interiores con Pladur" url="/reformas-interiores-pladur-mallorca" />
    <SchemaOffers offers={[
      { name: 'Tabique divisorio estándar', price: '45', description: 'Tabique de pladur para redistribución de espacios con aislante incluido. Precio por m².' },
      { name: 'Reforma integral con pladur', price: '45', description: 'Reforma completa de estancia incluyendo tabiques, falso techo y trasdosados. Precio por m².' },
      { name: 'Falso techo continuo', price: '29', description: 'Falso techo de pladur liso para ocultar instalaciones y mejorar la estética. Precio por m².' },
      { name: 'Trasdosado de paredes', price: '29', description: 'Trasdosado para regularizar paredes, mejorar aislamiento térmico y acústico. Precio por m².' },
      { name: 'Muebles y estanterías de pladur', price: '40', description: 'Estanterías, hornacinas y muebles empotrados de pladur a medida. Precio por metro lineal.' },
    ]} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — reformas interiores con pladur en Mallorca. Redistribución de espacios, falsos techos, aislamiento y acabados. +6.000 proyectos completados. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <section class="pt-24 pb-20 lg:pt-32 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-4">
            Reformas con pladur &middot; Mallorca
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            Reformas Interiores con Pladur en Mallorca — Rápido, Limpio y Económico
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto mb-8">
            Transforma tu vivienda, local u oficina sin obra pesada ni semanas de polvo. El pladur permite redistribuir espacios, modernizar techos y mejorar el aislamiento con un impacto mínimo en tu día a día.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/presupuesto-pladur"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-base tracking-wide shadow-lg shadow-accent/20 hover:shadow-xl hover:shadow-accent/30 transition-[background-color,box-shadow] duration-200"
            >
              Pide presupuesto gratis
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border-2 border-warm-border hover:bg-foreground-dark hover:border-foreground-dark hover:text-white text-foreground font-bold text-base tracking-wide transition-[background-color,border-color,color,transform] duration-200 active:scale-95"
            >
              <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {siteConfig.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección 1: Por qué el pladur es ideal para reformas -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <div class="animate-fade-up">
            <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Por qué elegir pladur</span>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">¿Por qué el pladur es ideal para reformas interiores?</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>Cuando te planteas una reforma interior en tu vivienda o local en Mallorca, la primera pregunta es siempre la misma: ¿cuánto tiempo va a durar, cuánto polvo y ruido va a generar y cuánto me va a costar? El sistema de pladur —también llamado yeso laminado o sistema de tabiquería en seco— resuelve las tres preguntas de forma mucho más favorable que la obra tradicional.</p>
            <p>El pladur consiste en una estructura metálica ligera (montantes y canales de acero galvanizado) sobre la que se atornillan placas de yeso laminado. La instalación no requiere agua, no genera escombros y no necesita tiempo de secado. Esto significa que un tabique de distribución que con ladrillo tardaría tres días en instalarse y otros dos en secar, con pladur puede estar listo en una sola jornada.</p>
            <p>En Mallorca, donde muchas viviendas son pisos heredados de los años 60 y 70 con distribuciones anacrónicas, o apartamentos turísticos que necesitan reformas rápidas entre temporadas, el pladur se convierte en la herramienta perfecta. La isla tiene además una climatología especial —veranos muy cálidos y humedad mediterránea— que hace que las soluciones de aislamiento integradas en el sistema sean especialmente valoradas.</p>
            <p>Otra ventaja clave para las reformas en Mallorca es que el pladur es un sistema de muy bajo peso estructural. En edificios históricos del centro de Palma o en pisos con forjados antiguos, añadir tabiques de ladrillo puede suponer un problema estructural. El pladur, al pesar apenas 25 kg/m² frente a los 120 kg/m² de un tabique de ladrillo, es compatible con cualquier estructura existente sin necesidad de refuerzo.</p>
            <p>Por último, el pladur permite integrar en su interior todo tipo de instalaciones: cableado eléctrico, tuberías de climatización, sistemas de audio y domótica. No hay que hacer rozas ni picar paredes. Las instalaciones quedan ocultas y protegidas, con acceso sencillo a través de registros si es necesario.</p>
            <p>Para conocer todos los detalles técnicos de la instalación de pladur, visita nuestra <a href="/instalacion-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 transition-colors">página de instalación de pladur en Mallorca</a>, donde explicamos paso a paso el proceso y los tipos de placa disponibles.</p>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="sticky top-28 space-y-5">
            <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card p-7">
              <p class="text-[10px] font-bold uppercase tracking-wider text-muted mb-4">Ventajas clave</p>
              <ul class="space-y-2.5">
                {ventajasClave.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-muted">
                    <div class="shrink-0 w-4 h-4 bg-foreground-dark rounded-full flex items-center justify-center mt-0.5">
                      <svg aria-hidden="true" class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="bg-foreground rounded-3xl p-7">
              <p class="font-bold text-white text-base mb-2">20 años reformando en Mallorca</p>
              <p class="text-white/60 text-sm leading-relaxed mb-4">Desde 2004 hemos completado más de 6.000 proyectos de reforma con pladur en toda la isla. Conocemos los edificios, las normativas locales y los retos específicos de la construcción mallorquina.</p>
              <div class="flex items-center gap-2">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  ))}
                </div>
                <span class="text-white/50 text-xs">4.7/5 en Google</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección 2: Tipos de reformas con pladur -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14 max-w-3xl animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Soluciones completas</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">Tipos de reformas interiores con pladur</h2>
        <p class="text-lg text-muted leading-relaxed">Cada proyecto es diferente. Estas son las cuatro soluciones con pladur que más demandan nuestros clientes en Mallorca y cómo pueden transformar tu espacio.</p>
      </div>
      <div class="space-y-4 stagger-children">
        {tiposReformas.map((reforma) => (
          <div class="group bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 p-7 cursor-default">
            <div class="flex items-start gap-5">
              <div class="shrink-0 size-11 bg-surface border border-nav-border rounded-xl flex items-center justify-center group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-all duration-300">
                <span class="text-sm font-bold text-foreground group-hover:text-white transition-colors duration-300">{reforma.num}</span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-foreground mb-4">{reforma.titulo}</h3>
                <div class="space-y-4 text-sm text-muted leading-relaxed">
                  {reforma.parrafos.map((p) => (<p>{p}</p>))}
                </div>
                <div class="mt-5">
                  <a href={reforma.linkHref} class="inline-flex items-center gap-2 text-foreground font-semibold underline underline-offset-2 text-sm transition-colors">
                    {reforma.linkTexto}
                    <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tabla comparativa -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-2xl animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Comparativa técnica</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">Pladur vs obra tradicional en reformas interiores</h2>
        <p class="text-lg text-muted leading-relaxed">Una comparativa objetiva entre los dos sistemas para ayudarte a tomar la decisión correcta para tu proyecto.</p>
      </div>
      <div class="space-y-3">
        {comparativa.map((fila) => (
          <div class="bg-white/70 rounded-2xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 p-5 cursor-default">
            <p class="text-[10px] font-bold uppercase tracking-wider text-muted mb-3">{fila.criterio}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div class="flex items-start gap-2.5 bg-surface rounded-xl p-3 border border-nav-border">
