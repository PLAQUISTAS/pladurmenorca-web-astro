---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import Hero from '@/components/sections/Hero'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import GaleriaTrabajos from '@/components/sections/GaleriaTrabajos.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import ArticulosRelacionados from '@/components/sections/ArticulosRelacionados.astro'
import Container from '@/components/ui/Container.astro'
import { aislamientoAcusticoFaqs } from '@/data/faqs/aislamiento-acustico'
import { getServicioBySlug } from '@/data/servicios'
import { siteConfig } from '@/data/site'

const servicio = getServicioBySlug('aislamiento-acustico-mallorca')!
const pageFaqs = aislamientoAcusticoFaqs

const meta = {
  title: 'Aislamiento Acústico en Mallorca | Pladur | Desde 45€/m²',
  description: 'Instala aislamiento acústico con pladur en Mallorca. Reducción de 40-55 dB garantizada. Cumplimiento CTE-HR en viviendas, hoteles y locales desde 35€/m².',
  canonical: '/aislamiento-acustico-mallorca',
}

const sidebarReduccion = [
  { label: 'Tabique básico con lana', valor: '40-45 dB' },
  { label: 'Tabique doble placa', valor: '50-55 dB' },
  { label: 'Techo antivibración', valor: '+8-15 dB' },
  { label: 'Sistema box-in-box', valor: '55-65 dB' },
]

const soluciones = [
  {
    titulo: 'Tabiques desvinculados para ruido aéreo entre espacios',
    desc: 'El sistema más efectivo para reducir el ruido entre habitaciones, pisos o locales colindantes en horizontal. Consiste en construir un tabique de pladur desvinculado mecánicamente de la estructura del edificio mediante bandas resilientes en el perímetro (suelo, techo y paredes laterales). La cámara de aire interior se rellena con lana mineral de alta densidad (mínimo 40 kg/m³), y se instalan dos placas de yeso en cada cara —a veces de distinto espesor para romper la coincidencia de masa. El resultado es un tabique con un índice de reducción acústica Rw de entre 50 y 55 dB, muy por encima del mínimo exigido por el CTE-HR (47 dB para separación entre viviendas).',
    reduccion: '50-55 dB',
    precio: 'Desde 52€/m²',
    ideal: 'Separación entre viviendas, hoteles, oficinas',
    materiales: ['Montantes con banda resiliente', 'Lana mineral 60-80mm', 'Doble placa BA13/BA15', 'Sellado perimetral total'],
  },
  {
    titulo: 'Falsos techos suspendidos con sistema antivibración',
    desc: 'Para el ruido de impacto proveniente del piso superior (pasos, caídas, arrastre de muebles) y también para el ruido aéreo que viaja a través del forjado. El sistema utiliza suspensores antivibratorios especiales (percha antivibratoria o Isomax) que desvinculan mecánicamente el nuevo techo del forjado original. Esta separación mecánica impide que las vibraciones del forjado se transmitan directamente al nuevo techo. Combinado con lana mineral en la cámara de aire y doble placa de yeso, este sistema puede reducir el ruido de impacto entre 8 y 15 dB y el ruido aéreo en 10-18 dB adicionales respecto al forjado desnudo. Es la solución habitual en la rehabilitación de hoteles y apartamentos turísticos en Mallorca.',
    reduccion: '+8-15 dB impacto / +10-18 dB aéreo',
    precio: 'Desde 35€/m²',
    ideal: 'Pisos con vecinos de arriba ruidosos, hoteles',
    materiales: ['Suspensores antivibratorios', 'Lana mineral 60mm', 'Doble placa BA15', 'Perfil cuelgue antivibración'],
  },
  {
    titulo: 'Suelos flotantes para ruido de impacto',
    desc: 'La solución más efectiva para el ruido de impacto, aunque la más invasiva en términos de reducción de altura libre. Consiste en instalar sobre el forjado original una capa de material amortiguador de impactos (lana de roca compacta, polietileno expandido de alta densidad o sistemas especializados como Regupol o Sylomer) sobre la que se construye el suelo acabado. Al estar el suelo «flotando» sobre el aislante, los impactos no se transmiten directamente al forjado. Es habitual combinar este sistema con un falso techo antivibración en el piso inferior para conseguir los mejores resultados. La bajada de cota es de 4-8 cm dependiendo del sistema elegido.',
    reduccion: '15-25 dB impacto',
    precio: 'Desde 10€/m²',
    ideal: 'Cuando se renueva el suelo, piso nuevo',
    materiales: ['Lana de roca compacta', 'Lámina amortiguadora', 'Capa separadora', 'Suelo a medida'],
  },
]

const guiaRapida = [
  { problema: 'Voces de vecinos a través de la pared', solucion: 'Tabique desvinculado doble placa', reduccion: '50-55 dB', precio: '52€/m²' },
  { problema: 'Ruido de pasos del piso de arriba', solucion: 'Falso techo antivibración', reduccion: '+8-15 dB', precio: '35€/m²' },
  { problema: 'Ruido de música/fiesta de arriba', solucion: 'Techo antivibración + lana mineral', reduccion: '+10-18 dB', precio: '35€/m²' },
  { problema: 'Ruido de calle en habitación', solucion: 'Trasdosado fachada + doble placa', reduccion: '40-50 dB', precio: '6€/m²' },
  { problema: 'Sala de ensayos / estudio', solucion: 'Sistema box-in-box completo', reduccion: '55-65 dB', precio: '150-300€/m²' },
  { problema: 'Hotel junto a zona de ocio', solucion: 'Tabique + techo combinados', reduccion: '55-60 dB', precio: 'Proyecto a medida' },
]

const requisitosLey = [
  'Paredes entre viviendas: DnT,A \u2265 47 dB (ruido aéreo)',
  'Paredes entre viviendas y zonas comunes: DnT,A \u2265 50 dB',
  "Ruido de impacto entre plantas: L'nT,w \u2264 65 dB",
  'Paredes entre habitaciones de hotel: DnT,A \u2265 50 dB',
  'Locales comerciales bajo viviendas: DnT,A \u2265 55 dB',
]

const materiales = [
  {
    nombre: 'Lana mineral (lana de vidrio)',
    desc: 'Material de referencia para el aislamiento acústico. Excelente absorción del sonido en un amplio rango de frecuencias. Densidad entre 26 y 70 kg/m³ según la aplicación. Además del aislamiento acústico, aporta mejora en el aislamiento térmico.',
    propiedades: ['Absorción multi-frecuencia', 'No combustible', 'Alta densidad disponible'],
  },
  {
    nombre: 'Lana de roca (Rockwool)',
    desc: 'Mayor densidad que la lana de vidrio, lo que la hace especialmente eficiente contra las bajas frecuencias (graves de música, maquinaria). Densidad de 45-100 kg/m³. Excelente comportamiento ante el fuego, con clasificación A1.',
    propiedades: ['Óptima en bajas frecuencias', 'Comportamiento ante fuego A1', 'Alta densidad'],
  },
  {
    nombre: 'Bandas y perfiles resilientes',
    desc: 'Elementos de caucho o polietileno expandido que desvinculan mecánicamente la estructura del tabique o techo del forjado. Son el elemento clave para romper el puente acústico estructural entre el sistema de pladur y el edificio existente.',
    propiedades: ['Desvinculación estructural', 'Caucho EPDM de alta densidad', 'Imprescindibles en sistemas acústicos'],
  },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService
      name={servicio.schema.name}
      description={servicio.schema.description}
      serviceType={servicio.schema.serviceType}
      url="https://www.pladurmallorca.com/aislamiento-acustico-mallorca"
      image="https://www.pladurmallorca.com/images/proyectos/aislamiento-acustico-apartamento-turistico-pladur-mallorca.webp"
     
    />
    <SchemaHowTo
      name="Cómo insonorizar una pared con pladur"
      description="Proceso de insonorización de paredes con trasdosado de pladur en 6 pasos: desde el diagnóstico acústico hasta la verificación final del aislamiento."
      totalTime="PT3D"
      steps={[
        { name: 'Diagnóstico acústico', text: 'Se evalúa el origen del ruido, tipo de transmisión (aérea o por impacto) y se mide el nivel sonoro para determinar la solución óptima.' },
        { name: 'Diseño de la solución', text: 'Se selecciona el sistema de trasdosado adecuado: tipo de placa (estándar, alta densidad o doble), aislante (lana mineral, lana de roca) y espesor necesario.' },
        { name: 'Instalación de estructura independiente', text: 'Se monta la perfilería metálica con bandas resilientes y amortiguadores acústicos, desacoplada de la pared existente para cortar la transmisión.' },
        { name: 'Colocación de material absorbente', text: 'Se instala la lana mineral o de roca en las cavidades, asegurando cobertura total sin huecos que comprometan el aislamiento.' },
        { name: 'Montaje de placas acústicas', text: 'Se atornillan las placas de yeso laminado de alta densidad, sellando juntas y encuentros con masilla acústica flexible.' },
        { name: 'Verificación y acabado', text: 'Se comprueba que no existen puentes acústicos, se tratan las juntas y se deja la superficie lista para pintar.' },
      ]}
    />
    <SchemaOffers
      offers={[
        { name: 'Trasdosado acústico básico', price: '6', description: 'Trasdosado acústico con placa estándar y lana mineral de 40mm. Reducción de hasta 10dB. Precio por m².' },
        { name: 'Trasdosado acústico premium', price: '10', description: 'Trasdosado con doble placa de alta densidad y lana de roca de 60mm. Reducción de hasta 20dB. Precio por m².' },
        { name: 'Aislamiento acústico de techo', price: '10', description: 'Falso techo acústico con sistema antivibratorio y lana mineral. Precio por m².' },
        { name: 'Tabique acústico completo', price: '52', description: 'Tabique divisorio con doble placa por cara y aislante interior para máxima insonorización. Precio por m².' },
      ]}
    />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — aislamiento acústico profesional en toda Mallorca. Reducción de 40 a 55 dB en paredes, techos y suelos. Más de 1.200 proyectos de insonorización completados. Precios desde 45€/m². CTE-HR certificado. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <Hero
    client:visible
    title="Aislamiento Acústico en Mallorca — Soluciones con Pladur y CTE-HR"
    subtitle="Reducimos el ruido entre 40 y 55 dB con sistemas certificados"
    description="Especialistas en aislamiento acústico con pladur en Mallorca. Hoteles, viviendas, locales y oficinas. Tabiques desvinculados, falsos techos suspendidos y suelos flotantes. Cumplimiento normativa CTE-HR. Presupuesto gratis."
    dark={true}
    badges={['40-55 dB de reducción', 'CTE-HR', 'Toda Mallorca']}
    ctaPrimario={{ texto: 'Pedir presupuesto gratis', href: '/presupuesto-pladur' }}
    ctaSecundario={{ texto: `Llamar: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- Aislamiento vs insonorización -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-bold uppercase tracking-widest bg-surface text-foreground mb-4 inline-block px-3 py-1 rounded-lg">
              Conceptos clave
            </p>
            <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">
              Aislamiento acústico vs insonorización: ¿qué diferencia hay?
            </h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>
              Estos dos términos se usan con frecuencia como sinónimos pero describen conceptos técnicamente
              distintos. El <strong class="text-foreground">aislamiento acústico</strong> es la capacidad de un
              elemento constructivo (pared, techo, suelo) de impedir el paso del sonido de un espacio a otro.
              Se mide en decibelios de reducción (dB) y es lo que persiguen los sistemas de pladur que
              instalamos: tabiques con doble placa, techos con suspensión antivibratoria y trasdosados con
              lana mineral.
            </p>
            <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
              <p>"El aislamiento acústico a ruido aéreo entre recintos protegidos (viviendas) y cualquier otro recinto del edificio no será menor que 50 dBA"</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">— CTE-HR, Tabla 2.1, Valores de aislamiento acústico a ruido aéreo</cite>
            </blockquote>
            <p>
              La <strong class="text-foreground">insonorización</strong>, en sentido estricto, implica
              conseguir que un espacio sea prácticamente impermeable al sonido hacia el exterior. Es el caso
              de los estudios de grabación profesionales, salas de pruebas de motores o cabinas de traducción.
              Este nivel de prestación requiere sistemas mucho más complejos (box-in-box, flotación total de la
              sala) y costes sustancialmente más elevados.
            </p>
            <p>
              Para la mayoría de los proyectos en Mallorca —pisos con vecinos ruidosos, hoteles junto a zonas
              de ocio, apartamentos turísticos en el Arenal o Magaluf, oficinas junto a talleres—,
              el aislamiento acústico con sistemas de pladur es la solución correcta y suficiente para alcanzar
              un nivel de confort satisfactorio y cumplir con la normativa CTE-HR.
            </p>
            <p>
              Ver también:
              <a href="/instalacion-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2">
                servicios de instalación de pladur en Mallorca
              </a>
              &middot;
              <a href="/tabiques-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2">
                tabiques de pladur acústico
              </a>
              &middot;
              <a href="/falsos-techos-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2">
                falsos techos acústicos
              </a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <div class="p-6 bg-foreground rounded-3xl text-white">
              <p class="text-xs font-bold uppercase tracking-widest text-nav-border/60 mb-3">Presupuesto gratis</p>
              <p class="font-bold text-lg mb-2">Acabemos con el ruido de tus vecinos</p>
              <p class="text-gray-300 text-sm mb-5 leading-relaxed">Evaluamos tu caso, te explicamos la solución óptima y te enviamos presupuesto en 24h.</p>
              <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide transition-colors">{siteConfig.phone}</a>
              <a href="/presupuesto-pladur" class="flex items-center justify-center gap-2 w-full py-3 mt-3 rounded-xl border border-white/30 hover:border-white text-white font-bold text-sm tracking-wide transition-colors">Pedir presupuesto online</a>
            </div>
            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl">
              <p class="font-bold text-foreground text-sm mb-2">Reducción que conseguimos:</p>
              <div class="space-y-2 mt-3">
                {sidebarReduccion.map((r) => (
                  <div class="flex items-center justify-between gap-2 py-1.5 border-b border-warm-border/50 last:border-0">
                    <span class="text-xs text-muted">{r.label}</span>
                    <span class="text-xs font-bold text-muted">{r.valor}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tipos de ruido -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-bold uppercase tracking-widest bg-surface text-foreground mb-4 inline-block px-3 py-1 rounded-lg">Análisis del problema</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6 max-w-2xl">Tipos de ruido: aéreo vs impacto</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-12 stagger-children">
        <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
          <div class="size-12 bg-surface border border-nav-border rounded-xl flex items-center justify-center mb-5">
            <svg aria-hidden="true" class="size-6 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-foreground mb-3">Ruido aéreo</h3>
          <p class="text-muted leading-relaxed mb-4">Se propaga a través del aire y se transmite a través de paredes y techos cuando estas vibran. Incluye voces, música, televisión, equipos de sonido y el ruido de zonas de ocio nocturno.</p>
          <p class="text-muted leading-relaxed">En Mallorca, el ruido aéreo es especialmente problemático en edificios de la zona de turismo masivo (Arenal, Magaluf, Punta Ballena), en el casco histórico de Palma (bares, restaurantes, música en directo) y en edificios plurifamiliares con vecinos que trabajan de noche. Los tabiques de pladur con doble placa y lana mineral son la solución más eficiente para este tipo de ruido, consiguiendo reducciones de 50-55 dB.</p>
          <div class="mt-5 p-3 bg-white/70 rounded-xl">
            <p class="text-sm font-semibold text-foreground">Solución: tabiques desvinculados + doble placa</p>
          </div>
        </div>

        <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
          <div class="size-12 bg-surface border border-nav-border rounded-xl flex items-center justify-center mb-5">
            <svg aria-hidden="true" class="size-6 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-foreground mb-3">Ruido de impacto</h3>
          <p class="text-muted leading-relaxed mb-4">Se genera cuando un objeto golpea o camina sobre el forjado, transmitiendo las vibraciones directamente a través de la estructura del edificio. Incluye pasos de personas, caída de objetos, sillas arrastrándose y vibraciones de electrodomésticos.</p>
          <p class="text-muted leading-relaxed">El ruido de impacto es el más difícil de combatir porque viaja por la propia estructura del edificio. La solución más efectiva es actuar desde abajo (suelo flotante en el piso de origen) o desde arriba (falso techo con suspensión antivibratoria en el piso receptor). En muchos casos en Mallorca, especialmente en pisos en alquiler, solo es posible actuar desde el piso receptor, lo que hace imprescindible el uso de suspensión antivibratoria en el techo.</p>
          <div class="mt-5 p-3 bg-white/70 rounded-xl">
            <p class="text-sm font-semibold text-foreground">Solución: falso techo con suspensión antivibratoria</p>
          </div>
        </div>
      </div>

      <div class="bg-white/70 p-6 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
        <p class="font-semibold text-foreground mb-2">Fuentes habituales de ruido en Mallorca</p>
        <p class="text-sm text-muted leading-relaxed">Mallorca tiene una casuística de ruido específica derivada de su actividad turística. Las zonas como El Arenal, Magaluf, Puerto Alcúdia, Cala Millor o el Puerto de Pollença concentran una actividad de ocio nocturno intensa durante los meses de temporada alta. Los hoteles y apartamentos turísticos de estas zonas son los que mayor demanda de soluciones de aislamiento acústico generan, tanto para proteger a sus huéspedes del ruido exterior como para aislar las habitaciones entre sí. El sector hotelero en Mallorca es, de hecho, uno de nuestros principales clientes en proyectos de aislamiento acústico, con reformas que se concentran en los meses de octubre a marzo.</p>
      </div>
    </Container>
  </section>

  <!-- Soluciones con pladur -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Left: sticky header -->
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28">
            <div>
              <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Nuestras soluciones</span>
              <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">Soluciones de aislamiento acústico con pladur</h2>
              <p class="text-muted leading-relaxed mb-8">Cada problema de ruido tiene una solución técnica específica. Analizamos el origen del ruido y proyectamos la solución más eficiente para tu caso.</p>
            </div>
            <div class="bg-foreground rounded-3xl p-7">
              <p class="text-xs font-bold uppercase tracking-widest text-white/50 mb-5">3 sistemas especializados</p>
              <div class="space-y-3">
                {[
                  { label: 'Tabiques desvinculados', valor: '50-55 dB' },
                  { label: 'Techos antivibración', valor: '+8-15 dB' },
                  { label: 'Suelos flotantes', valor: '15-25 dB' },
                ].map((s) => (
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="shrink-0 w-5 h-5 bg-white/20 rounded-full flex items-center justify-center">
                        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                      </div>
                      <p class="text-white/70 text-sm">{s.label}</p>
                    </div>
                    <span class="text-xs font-bold text-white bg-white/10 px-2.5 py-1 rounded-lg shrink-0">{s.valor}</span>
                  </div>
                ))}
              </div>
              <div class="mt-6 pt-5 border-t border-white/10">
                <p class="text-white/50 text-xs leading-relaxed">Todos los sistemas cumplen la normativa CTE-HR vigente para edificación en España.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Solution cards -->
        <div class="lg:col-span-7 space-y-6">
          {soluciones.map((sol) => (
            <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 overflow-hidden">
              <div class="p-7 lg:p-8">
                <h3 class="text-lg font-bold text-foreground mb-4">{sol.titulo}</h3>
                <p class="text-sm text-muted leading-relaxed mb-6">{sol.desc}</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
                  {[
                    { label: 'Reducción', value: sol.reduccion },
                    { label: 'Precio', value: sol.precio },
                    { label: 'Ideal para', value: sol.ideal },
                  ].map((stat) => (
                    <div class="bg-surface rounded-2xl p-4 border border-nav-border">
                      <p class="text-[10px] font-bold uppercase tracking-wider text-muted mb-1.5">{stat.label}</p>
                      <p class="text-sm font-semibold text-foreground leading-snug">{stat.value}</p>
                    </div>
                  ))}
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {sol.materiales.map((m) => (
                    <span class="text-xs px-2.5 py-1 bg-surface text-foreground rounded-lg font-medium">{m}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Guía rápida: problema - solución -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Guía rápida</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-4 max-w-2xl">¿Qué solución necesitas?</h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">Identifica tu problema de ruido y descubre la solución técnica más adecuada para tu caso.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {guiaRapida.map((item) => (
          <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 h-full flex flex-col">
            <div class="flex items-start gap-3 mb-5">
              <div class="shrink-0 size-9 rounded-xl bg-surface border border-nav-border flex items-center justify-center group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
                <svg class="size-4 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
              </div>
              <p class="text-sm font-semibold text-foreground leading-snug">{item.problema}</p>
            </div>
            <div class="bg-surface rounded-2xl p-4 border border-nav-border mb-5 flex-1">
              <p class="text-[10px] font-bold uppercase tracking-wider text-muted mb-1.5">Solución</p>
              <p class="text-sm font-medium text-foreground">{item.solucion}</p>
            </div>
            <div class="flex items-center justify-between gap-3 pt-4 border-t border-warm-border/50">
              <div class="flex items-center gap-2">
                <div class="shrink-0 w-4 h-4 bg-foreground-dark rounded-full flex items-center justify-center">
                  <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <span class="text-xs font-bold text-foreground">{item.reduccion}</span>
              </div>
              <span class="text-xs font-medium text-muted">{item.precio}</span>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CtaBanner intermedio -->
  <CtaBanner titulo="¿Problemas de ruido en tu vivienda o negocio en Mallorca?" subtitulo="Evaluamos tu caso gratis y te proponemos la solución más eficiente." showForm={false} />

  <!-- Normativa CTE-HR -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest bg-surface text-foreground mb-4 inline-block px-3 py-1 rounded-lg">Marco legal</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">Normativa CTE-HR: ¿qué exige la ley?</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>El Código Técnico de la Edificación, en su Documento Básico de Protección frente al Ruido (DB-HR), establece los requisitos mínimos de aislamiento acústico que deben cumplir todos los edificios de nueva construcción y las grandes rehabilitaciones en España, incluida Mallorca.</p>
            <p>Los valores clave del CTE-HR que más afectan a los proyectos de reforma en Mallorca son:</p>
            <ul class="space-y-2 pl-0">
              {requisitosLey.map((req) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 shrink-0 size-5 bg-foreground-dark rounded-full flex items-center justify-center">
                    <svg aria-hidden="true" class="size-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  </span>
                  <span class="text-sm">{req}</span>
                </li>
              ))}
            </ul>
            <p>Nuestros sistemas de pladur con doble placa y lana mineral están certificados para cumplir y superar estos valores en la mayoría de las configuraciones habituales. En los proyectos donde la normativa CTE-HR es de cumplimiento obligatorio (obra nueva, legalización de locales, cambio de uso), podemos aportar la documentación técnica de los sistemas instalados.</p>
          </div>
        </div>

        <!-- Materiales utilizados -->
        <div>
          <p class="text-xs font-bold uppercase tracking-widest bg-surface text-foreground mb-4 inline-block px-3 py-1 rounded-lg">Materiales</p>
          <h3 class="text-2xl font-bold text-foreground leading-tight text-balance mb-6">Materiales aislantes que utilizamos</h3>
          <div class="space-y-4">
            {materiales.map((mat) => (
              <div class="p-6 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
                <h4 class="font-bold text-foreground text-base mb-2">{mat.nombre}</h4>
                <p class="text-sm text-muted leading-relaxed mb-3">{mat.desc}</p>
                <div class="flex flex-wrap gap-1.5">
                  {mat.propiedades.map((p) => (
                    <span class="text-xs px-2 py-0.5 bg-surface text-foreground rounded-lg font-medium">{p}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

