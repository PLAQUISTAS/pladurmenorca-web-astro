---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import PaginaGeografica from '@/components/templates/PaginaGeografica.astro'
import { faqs } from '@/data/faqs'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Pladur en Pollença | Instaladores | Presupuesto Gratis',
  description: 'Instala pladur en Pollença y Port de Pollença. Reformas en casas históricas y apartamentos turísticos. Techos, aislamiento y tabiques. Presupuesto gratis.',
  canonical: '/pladur-pollenca',
}

const zonas = [
  {
    nombre: 'Pollença centro',
    descripcion: 'Casco histórico con casas de piedra centenarias y calles empedradas. Reformas para modernizar viviendas heredadas: trasdosados térmicos sobre muros de piedra, falsos techos decorativos y redistribución funcional.',
  },
  {
    nombre: 'Port de Pollença',
    descripcion: 'Núcleo turístico y residencial junto a la bahía. Apartamentos, hoteles y casas que necesitan reformas entre temporadas: falsos techos con LED, aislamiento acústico, tabiques y modernización general.',
  },
  {
    nombre: 'Cala Sant Vicenç',
    descripcion: 'Urbanización exclusiva entre calas. Chalets y villas expuestos al viento de tramontana que demandan aislamiento térmico de altas prestaciones, redistribución de espacios y acabados de calidad.',
  },
  {
    nombre: 'La Font / Crestatx',
    descripcion: 'Zonas rurales y residenciales del municipio. Fincas rústicas y casas de campo que se rehabilitan con pladur: aislamiento integral, falsos techos para ocultar instalaciones y tabiques para crear nuevas estancias.',
  },
  {
    nombre: 'Cala Molins / Cala Barques',
    descripcion: 'Zona costera con mezcla de vivienda residencial y turística. Apartamentos y chalets que necesitan actualizaciones periódicas: techos nuevos, mejora del aislamiento y redistribución para optimizar el alquiler vacacional.',
  },
]

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Pladur en Pollença', href: '/pladur-pollenca' },
]

const pageFaqs = faqs['pollenca'] ?? []

const proyectoFicha = [
  { label: 'Superficie', valor: '140 m²' },
  { label: 'Ubicación', valor: 'Cala Sant Vicenç, Pollença' },
  { label: 'Trabajos', valor: 'Trasdosado térmico + Techo + Tabiques' },
  { label: 'Duración', valor: '14 días hábiles' },
  { label: 'Ahorro energético', valor: '35% en calefacción' },
]

const serviciosLinks = [
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Aislamiento Térmico', href: '/aislamiento-termico-mallorca' },
  { label: 'Precios', href: '/precios-pladur-mallorca' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Instalación de Pladur en Pollença"
      description="Servicio profesional de instalación de pladur en Pollença y el norte de Mallorca: falsos techos, tabiques, aislamiento acústico y térmico en Port de Pollença y Cala Sant Vicenç."
      serviceType="Instalación de Pladur"
      url="/pladur-pollenca"
     
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — instaladores de pladur en Pollença. Falsos techos, tabiques, aislamiento acústico y térmico. Presupuesto gratis. Tel: 627 829 723.
  </p>

  <PaginaGeografica
    municipio="Pollença"
    zonas={zonas}
    faqKey="pollenca"
    heroTitle="Pladur en Pollença — Instaladores Profesionales en el Norte de Mallorca"
    heroBadge="Pollença · Norte de Mallorca"
    heroDescription="Instalamos pladur en Pollença y alrededores: Port de Pollença, Cala Sant Vicenç y La Font. Falsos techos, tabiques, aislamiento acústico y térmico. Reformas en casas históricas y apartamentos turísticos. Presupuesto gratuito en 24 horas."
    faqTitulo="Preguntas frecuentes sobre pladur en Pollença"
    faqSubtitulo="Respuestas a las dudas más habituales de nuestros clientes en Pollença y el norte de Mallorca."
    proyectoTitulo="Aislamiento térmico de chalet en Cala Sant Vicenç"
    proyectoFicha={proyectoFicha}
    ctaTitulo="¿Tu proyecto está en Pollença o el norte?"
    ctaSubtitulo="Contacta ahora y recibe tu presupuesto gratuito en menos de 24 horas. Sin desplazamiento en toda la zona norte."
  >
    <section slot="texto-seo" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-10">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            Especialistas en el norte
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            Reformas con pladur en Pollença: historia y modernidad en el norte
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-5 text-muted leading-relaxed mb-12">
          <div class="space-y-5">
            <p>
              Pollença es uno de los municipios con mayor riqueza patrimonial del norte de Mallorca. Su casco histórico, con calles empedradas que ascienden hasta el Calvari, alberga casas de piedra centenarias que representan lo mejor de la arquitectura tradicional mallorquina. Al mismo tiempo, Port de Pollença es un destino turístico consolidado con una amplia oferta de apartamentos, hoteles y viviendas residenciales.
            </p>
            <p>
              Las casas del centro de Pollença presentan características constructivas propias de la arquitectura popular mallorquina: muros de piedra de marès de 40-60 cm, techos de vigas de madera con cañizo y teja árabe, y distribuciones diseñadas para otra época. El pladur permite transformar estos espacios sin comprometer la estructura original: trasdosados que proporcionan <a href="/aislamiento-termico-mallorca">aislamiento térmico</a> contra el frío de la tramontana y el calor del verano, <a href="/falsos-techos-pladur-mallorca">falsos techos</a> que ocultan instalaciones eléctricas y de climatización modernas, y <a href="/tabiques-pladur-mallorca">tabiques</a> que crean nuevas estancias funcionales.
            </p>
            <p>
              Port de Pollença concentra la mayor parte de la oferta turística del municipio. Edificios de apartamentos construidos entre los años 60 y 90 que necesitan actualizaciones periódicas para mantener su competitividad en el mercado del alquiler vacacional. El pladur permite modernizar un apartamento completo en una o dos semanas: falsos techos con iluminación LED empotrada que transforman el aspecto del espacio, aislamiento acústico entre viviendas que elimina las quejas por ruido, y redistribución para crear distribuciones más funcionales y atractivas.
            </p>
          </div>
          <div class="space-y-5">
            <p>
              Cala Sant Vicenç, enclavada entre acantilados al norte del municipio, es una de las zonas residenciales más singulares de Mallorca. Los chalets y villas de esta zona están especialmente expuestos al viento de tramontana, que puede soplar con fuerza durante los meses de invierno. Un trasdosado de pladur con aislamiento térmico de altas prestaciones es la solución más eficiente para mejorar el confort de estas viviendas: reduce la pérdida de calor a través de las fachadas expuestas y mejora la eficiencia del sistema de calefacción.
            </p>
            <p>
              La comunidad de residentes internacionales en Pollença —británicos, alemanes, escandinavos— ha crecido significativamente en las últimas décadas. Estos propietarios buscan reformar casas antiguas combinando el encanto de la arquitectura tradicional con estándares de confort europeos: aislamiento térmico eficiente, insonorización entre estancias, distribuciones abiertas y acabados de primera calidad. El pladur es la herramienta que permite esta transformación sin sacrificar la autenticidad del edificio.
            </p>
            <p>
              Cubrimos todo el municipio de Pollença sin coste adicional de desplazamiento para obras a partir de 500€. Nuestro equipo conoce las particularidades de cada zona: desde los muros centenarios del casco histórico hasta los edificios turísticos del puerto, pasando por los chalets de Cala Sant Vicenç y las fincas rústicas de La Font.
            </p>
          </div>
        </div>
        <div class="bg-foreground rounded-3xl p-7 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-bold text-lg text-white mb-2">El norte confía en nosotros</p>
              <p class="text-white/60 text-sm leading-relaxed mb-4">Más de 20 años trabajando en Pollença y el norte de Mallorca. Experiencia en casas históricas del casco antiguo y reformas turísticas en Port de Pollença.</p>
              <div class="flex items-center gap-2">
                <div class="flex">
                  {Array.from({ length: 5 }).map(() => (
                    <svg class="size-4 text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-white/60 text-xs">4.7/5 en Google</span>
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-wider text-white/50 mb-3">Servicios en Pollença</p>
              <div class="grid grid-cols-2 gap-2">
                {serviciosLinks.map((s) => (
                  <a href={s.href} class="flex items-center gap-2 text-sm text-white/60 hover:text-white transition-colors">
                    <svg aria-hidden="true" class="size-3 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Custom proyecto contenido -->
    <div slot="proyecto-contenido" class="max-w-none text-muted space-y-4">
      <p>
        Un chalet de 140 m² en Cala Sant Vicenç, construido en los años 90 con orientación norte-noreste, sufría pérdidas térmicas severas durante los meses de invierno. La fachada principal, directamente expuesta al viento de tramontana, carecía de aislamiento y los propietarios —una familia alemana residente durante todo el año— enfrentaban facturas de calefacción de más de 400 euros mensuales entre noviembre y febrero. Además, la distribución original de cinco dormitorios pequeños ya no se ajustaba a sus necesidades.
      </p>
      <p>
        Se ejecutó un trasdosado completo con pladur y poliestireno extruido de 50 mm en las fachadas norte y este (62 m² de superficie), que son las más expuestas al viento. En las dos plantas se instaló un falso techo continuo (140 m²) con lana mineral de 80 mm sobre la placa, que además de aislar térmicamente desde la cubierta permitió integrar la nueva instalación de aerotermia por conductos y la iluminación LED de diseño. Se eliminaron dos tabiques originales y se crearon tres nuevos (24 ml) para conseguir una distribución de tres dormitorios amplios con armarios empotrados, un baño en suite en el dormitorio principal y un estudio con vistas a la cala.
      </p>
      <p>
        El proyecto se completó en 14 días hábiles repartidos en dos fases (una por planta), con un coste de pladur de 13.500 euros. El primer invierno tras la reforma, la factura de calefacción se redujo un 35%, pasando de 400 a 260 euros mensuales de media. En verano, la temperatura interior se mantuvo hasta 7 grados por debajo de la exterior sin aire acondicionado en las horas centrales del día. Los propietarios describieron el resultado como "vivir en una casa completamente diferente".
      </p>
    </div>
  </PaginaGeografica>

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
