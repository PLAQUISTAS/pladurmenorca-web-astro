    ['Acústico', '15 cm', '35€/m²', 'Hoteles y viviendas ruidosas'],
    ['Técnico con LED', '20 cm', '47€/m²', 'Locales y espacios premium'],
  ],
  tablaMobileCols: { bajada: 'Bajada', precio: 'Precio', ideal: 'Ideal' },
  tablaFootnote: '* Precios falsos techos pladur en Menorca 2026, sin IVA. El presupuesto exacto se obtiene tras la visita técnica.',
  tablaFootnoteLink: 'Ver guía completa de precios',
  ctaMidTitulo: 'Solicita tu presupuesto de falso techo',
  ctaMidSubtitulo: 'Presupuesto gratis y sin compromiso. Cubrimos todos los municipios de Menorca.',
  ventajasEyebrow: 'Por qué elegir pladur',
  ventajasTitle: 'Ventajas de los falsos techos de pladur',
  ventajas: [
    {
      titulo: 'Oculta instalaciones',
      desc: 'La cámara de 10-30 cm esconde cables, tuberías de fontanería, conductos de climatización y ventilación. Integra todas las instalaciones sin intervención en la estructura portante.',
