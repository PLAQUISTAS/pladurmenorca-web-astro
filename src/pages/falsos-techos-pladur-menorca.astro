      titulo: 'Falso techo acústico',
      desc: 'Desde 35€/m². Suspensión antivibratoria que desvincula el techo nuevo del forjado, lana mineral de densidad 40-70 kg/m³ en la cámara y doble placa atornillada. Aporta 8-15 dB adicionales frente a un techo convencional y contribuye al cumplimiento del CTE-HR para separación entre viviendas.',
      bajada: '15-25 cm',
      precio: 'Desde 35€/m²',
      ideal: 'Pisos con vecinos ruidosos, hoteles, estudios',
      ventajas: ['Reducción 8-15 dB adicionales', 'Cumple CTE-HR', 'Ideal para turísticos y hostales', 'Suspensión antivibratoria'],
    },
    {
      num: '05',
      titulo: 'Falso techo técnico con integración LED',
      desc: 'Desde 47€/m². Integra estructura de pladur, cajetines para focos LED empotrados, tiras LED en foseado perimetral, cableado eléctrico, dimmers y control KNX o Zigbee, y salidas de climatización o difusores de ventilación. Todo el techo funciona como un sistema unificado de iluminación y ambiente.',
      bajada: '20-30 cm',
      precio: 'Desde 47€/m²',
      ideal: 'Locales, restaurantes, viviendas premium',
      ventajas: ['Iluminación integrada', 'Cableado oculto', 'Gestión inteligente opcional', 'Diseño de interiores avanzado'],
    },
  ],
  tablaEyebrow: 'Resumen',
  tablaTitle: 'Comparativa de tipos de falso techo',
  tablaHeaders: ['Tipo de techo', 'Bajada mínima', 'Precio desde', 'Ideal para'],
