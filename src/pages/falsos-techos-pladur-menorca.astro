  proceso2: 'Un techo continuo de 50 m² sin instalaciones se ejecuta en una jornada. Con focos LED empotrados el plazo sube a 1,5-2 jornadas. Para sistemas acústicos con doble placa, artesonados o formas curvas, el plazo alcanza los 3-5 días.',
  proceso3: 'El tratamiento de juntas con cinta y pasta, imprimación y lijado a grano 120 se realiza al día siguiente y no impide el uso del espacio adyacente. El pintado no está incluido en la oferta estándar y puede ejecutarse 24-48h después del secado completo de la pasta.',
  plazos: [
    { superficie: 'Hasta 30 m²', tipo: 'Techo básico', tiempo: '4-6 horas', incluye: 'Solo estructura y placa' },
    { superficie: '30-80 m²', tipo: 'Techo básico + electricidad', tiempo: '1-2 días', incluye: 'Estructura, placa y cableado' },
    { superficie: '50-100 m²', tipo: 'Techo acústico', tiempo: '2-3 días', incluye: 'Suspensión, lana mineral, doble placa' },
    { superficie: 'Cualquier m²', tipo: 'Techo decorativo', tiempo: '3-7 días', incluye: 'Molduras, formas y acabados premium' },
  ],
  plazosLabelSuperficie: 'Superficie',
  plazosLabelIncluye: 'Incluye',
  galeriaAlts: [
    'Falso techo con iluminación LED en exterior de villa en Baleares',
    'Salón con falso techo de pladur en villa de Baleares',
    'Vestidor con falso techo LED y vistas al mar en Baleares',
    'Dormitorio con falso techo de pladur y vistas al mar en Baleares',
  ],
  articulos: [
    { slug: 'techos-pladur-led-menorca', titulo: 'Techos de pladur con LED en Menorca', descripcion: 'Diseños de falsos techos con iluminación LED integrada. Ideas y precios para tu reforma.' },
    { slug: 'precio-pladur-menorca-2026', titulo: 'Precio del pladur en Menorca 2026', descripcion: 'Guía completa de precios del pladur en Menorca actualizada a 2026. Desde falsos techos hasta tabiques.' },
    { slug: 'ventajas-reforma-pladur-menorca', titulo: 'Ventajas de reformar con pladur', descripcion: 'Descubre por qué el pladur es la mejor opción para reformas en Menorca frente a la obra tradicional.' },
  ],
  faqTitulo: 'Preguntas frecuentes sobre falsos techos',
  faqSubtitulo: 'Todo lo que necesitas saber sobre la instalación de falsos techos de pladur en Menorca.',
  banner: 'En baños y cocinas, instalamos falsos techos con',
  bannerBold: 'placa hidrófuga',
  bannerTail: 'que resiste la humedad ambiental sin deteriorarse. Absorción de agua inferior al 5%.',
  bannerCta: 'Ver pladur hidrófugo',
  ctaFinalTitulo: 'Transforma el techo de tu espacio',
  ctaFinalSubtitulo: 'Presupuesto cerrado en 24h. Instalando pladur en Menorca desde 2004, más de 6.000 obras ejecutadas.',
}

const schemaOffersPrices = ['29', '35', '45', '29', '47']
const schemaOffers = t.schemaOffers.map((o, i) => ({ ...o, price: schemaOffersPrices[i] }))

const pageBase = lang === 'en' ? '/en/falsos-techos-pladur-menorca' : '/falsos-techos-pladur-menorca'
const homeHref = lang === 'en' ? '/en/' : '/'
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: homeHref }, { label: t.breadcrumbCurrent, href: pageBase }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService
      name={servicio.schema.name}
      description={servicio.schema.description}
      serviceType={servicio.schema.serviceType}
      url={`https://www.pladurmenorca.com${pageBase}`}
      image="https://www.pladurmenorca.com/images/proyectos/salon-falso-techo-villa.webp"

    />
    <SchemaHowTo
      name={t.schemaHowToName}
      description={t.schemaHowToDescription}
      totalTime="PT2D"
      steps={t.schemaSteps}
    />
    <SchemaOffers offers={schemaOffers} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">
    {t.srOnly}
  </p>

  <!-- Hero -->
  <Hero
    title={servicio.h1}
    subtitle={t.heroSubtitle}
    description={t.heroDescription}
    dark={true}
    badges={t.heroBadges}
    ctaPrimario={{ texto: t.ctaPrimario, href: p('/presupuesto-pladur') }}
    ctaSecundario={{ texto: `${t.ctaCallPrefix} ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- ¿Qué es un falso techo de pladur? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              {t.sectionIntroEyebrow}
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              {t.sectionIntroTitle}
            </h2>
          </div>
          <div class="space-y-7 text-muted leading-relaxed">
            <p class="text-lg">{t.intro1}</p>

            {/* Key facts strip */}
            <div class="grid grid-cols-3 gap-px bg-warm-border/50 rounded-3xl overflow-hidden border border-warm-border/50">
              {[
                { k: lang === 'en' ? 'Drop' : 'Bajada', v: '10–30 cm' },
                { k: lang === 'en' ? 'Install time' : 'Ejecución', v: lang === 'en' ? '1–2 days / 50 m²' : '1–2 días / 50 m²' },
                { k: lang === 'en' ? 'Fire rating' : 'Resistencia fuego', v: 'EI 120' },
              ].map((s) => (
                <div class="bg-white/80 px-4 py-5 text-center">
                  <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted/80 mb-1">{s.k}</p>
                  <p class="text-sm font-bold text-foreground">{s.v}</p>
                </div>
              ))}
            </div>

            <blockquote class="border-l-4 border-foreground/20 pl-5 italic text-muted">
              <p>{t.citaTexto}</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">{t.citaFuente}</cite>
            </blockquote>

            <p>{t.intro2}</p>

            {/* intro3 as a clean typographic list */}
            <ul class="grid grid-cols-1 sm:grid-cols-3 gap-x-8 gap-y-4 pt-2 not-prose list-none pl-0">
              {[
                { title: lang === 'en' ? 'Historic centre' : 'Centros históricos', desc: lang === 'en' ? 'Maó buildings with exposed beams or irregular slabs.' : 'Edificios de Maó con vigas vistas o forjados irregulares.' },
                { title: lang === 'en' ? 'Holiday apartments' : 'Apartamentos turísticos', desc: lang === 'en' ? 'Ciutadella, Sant Lluís or Es Castell, modernised between seasons.' : 'Ciutadella, Sant Lluís o Es Castell, modernizados entre temporadas.' },
                { title: lang === 'en' ? 'Offices & premises' : 'Oficinas y locales', desc: lang === 'en' ? 'HVAC, lighting and telecoms integrated above the board.' : 'Climatización, iluminación y telecom integrados sobre la placa.' },
              ].map((c) => (
                <li class="border-l-2 border-warm-border pl-4">
                  <strong class="block font-bold text-foreground text-sm mb-1">{c.title}</strong>
                  <span class="block text-sm text-muted leading-relaxed">{c.desc}</span>
                </li>
              ))}
            </ul>

            <p>{t.intro4}</p>

            <!-- Enlace interno -->
            <p class="text-sm text-muted pt-2">
              {t.interno}
              <a href={p('/precios-pladur-menorca')} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">
                {t.internoLink1}
              </a>
              {t.internoOr}
              <a href={lang === 'en' ? '/en/instalacion-pladur-menorca' : '/instalacion-pladur-menorca'} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">
                {t.internoLink2}
              </a>
              .
            </p>
          </div>
        </div>

        <!-- Sidebar CTA -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <ContactoRapidoCard lang={lang} />
            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl">
              <p class="font-semibold text-foreground text-sm mb-3">{t.sidebarVerTambien}</p>
              <ul class="space-y-2">
                {t.sidebarLinks.map((s) => (
                  <li>
                    <a
                      href={s.href}
                      class="flex items-center gap-2 text-sm text-muted hover:text-foreground transition-colors py-0.5"
                    >
                      <svg class="size-3.5 text-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tipos de falsos techos -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          {t.tiposEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">
          {t.tiposTitle}
        </h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">
          {t.tiposIntro}
        </p>
      </div>

      <div class="space-y-6">
        {t.tiposTecho.map((tipo) => (
          <div class="bg-white/70 border border-warm-border/50 rounded-3xl overflow-hidden shadow-card hover:shadow-card-hover transition-shadow duration-300">
            <div class="grid grid-cols-1 lg:grid-cols-12">
              <div class="lg:col-span-8 p-8 lg:p-10">
                <div class="flex items-center gap-3 mb-4">
                  <span class="size-10 rounded-xl bg-foreground text-white text-xs font-bold flex items-center justify-center shrink-0">{tipo.num}</span>
                  <h3 class="text-xl font-bold text-foreground">{tipo.titulo}</h3>
                </div>
                <p class="text-sm text-muted leading-relaxed mb-5">{tipo.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {tipo.ventajas.map((v) => (
                    <span class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 bg-surface text-foreground font-medium rounded-lg">
                      <svg aria-hidden="true" class="size-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {v}
                    </span>
                  ))}
                </div>
              </div>
              <div class="lg:col-span-4 bg-foreground p-8 flex flex-col justify-center gap-5 lg:rounded-r-3xl">
                {[
                  { label: lang === 'en' ? 'Min. drop' : 'Bajada mínima', value: tipo.bajada },
                  { label: lang === 'en' ? 'From' : 'Precio desde', value: tipo.precio },
                  { label: lang === 'en' ? 'Ideal for' : 'Ideal para', value: tipo.ideal },
                ].map((d) => (
                  <div>
                    <p class="text-[10px] font-semibold text-white/50 uppercase tracking-wide mb-1">{d.label}</p>
                    <p class="text-white font-bold text-sm">{d.value}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Tabla resumen tipos -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          {t.tablaEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-10 max-w-2xl">
          {t.tablaTitle}
        </h2>
      </div>

      <!-- Desktop table -->
      <div class="hidden sm:block">
        <div class="rounded-3xl overflow-hidden border border-warm-border shadow-card">
          <table class="min-w-full">
            <thead>
              <tr class="bg-foreground">
                {t.tablaHeaders.map((h) => (
                  <th class="px-5 py-4 text-left text-xs font-bold text-white uppercase tracking-wider">
                    {h}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-warm-border/50">
              {t.tablaResumen.map(([tipo, bajada, precio, ideal], i) => (
                <tr class={`${i % 2 === 0 ? 'bg-white/70' : 'bg-white/40'} hover:bg-surface/60 transition-colors duration-200`}>
                  <td class="px-5 py-3.5 text-sm font-semibold text-foreground">{tipo}</td>
                  <td class="px-5 py-3.5 text-sm text-muted">{bajada}</td>
                  <td class="px-5 py-3.5 text-sm font-bold text-foreground">{precio}</td>
                  <td class="px-5 py-3.5 text-sm text-muted">{ideal}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile cards -->
      <div class="sm:hidden space-y-3">
        {t.tablaResumen.map(([tipo, bajada, precio, ideal]) => (
          <div class="bg-white/70 rounded-2xl border border-warm-border/50 p-4">
            <p class="font-bold text-foreground text-sm mb-3">{tipo}</p>
            <div class="grid grid-cols-3 gap-2">
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-muted mb-0.5">{t.tablaMobileCols.bajada}</p>
                <p class="text-sm text-muted">{bajada}</p>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-muted mb-0.5">{t.tablaMobileCols.precio}</p>
                <p class="text-sm font-bold text-foreground">{precio}</p>
              </div>
              <div>
                <p class="text-[10px] font-semibold uppercase tracking-wide text-muted mb-0.5">{t.tablaMobileCols.ideal}</p>
                <p class="text-sm text-muted">{ideal}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-xs text-muted mt-4">
        {t.tablaFootnote}
        <a href={p('/precios-pladur-menorca')} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">
          {t.tablaFootnoteLink}
        </a>
      </p>
    </Container>
  </section>

  <!-- CtaBanner intermedio -->
  <CtaBanner
    lang={lang}
    titulo={t.ctaMidTitulo}
    subtitulo={t.ctaMidSubtitulo}
    showForm={false}
  />

  <!-- Ventajas -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
          {t.ventajasEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-12 max-w-2xl">
          {t.ventajasTitle}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {t.ventajas.map((v) => (
          <div class="p-7 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
            <div class="size-10 bg-surface border border-nav-border rounded-xl flex items-center justify-center mb-5">
              <svg class="size-5 text-foreground" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={v.iconPath} />
              </svg>
            </div>
            <h3 class="font-bold text-foreground text-base mb-2">{v.titulo}</h3>
            <p class="text-sm text-muted leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Proceso: ¿Cuánto tarda instalar un falso techo? -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">
              {t.procesoEyebrow}
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
              {t.procesoTitle}
            </h2>
          </div>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>{t.proceso1}</p>
            <p>{t.proceso2}</p>
            <p>{t.proceso3}</p>
          </div>
        </div>

        <div class="space-y-4">
          {t.plazos.map((fila, i) => (
            <div class="bg-white/70 border border-warm-border/50 rounded-3xl p-6 shadow-card hover:shadow-card-hover transition-shadow duration-300">
              <div class="flex items-start gap-4">
                <div class="w-9 h-9 rounded-full bg-foreground text-white text-xs font-bold flex items-center justify-center shrink-0">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div class="flex-1">
                  <div class="flex items-center justify-between gap-3 mb-3">
                    <p class="text-sm font-bold text-foreground">{fila.tipo}</p>
                    <span class="text-xs font-bold text-foreground bg-surface px-2.5 py-1 rounded-lg shrink-0">{fila.tiempo}</span>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <p class="text-[10px] font-semibold text-muted uppercase tracking-wide mb-0.5">{t.plazosLabelSuperficie}</p>
                      <p class="text-sm text-muted">{fila.superficie}</p>
                    </div>
                    <div>
                      <p class="text-[10px] font-semibold text-muted uppercase tracking-wide mb-0.5">{t.plazosLabelIncluye}</p>
                      <p class="text-sm text-muted">{fila.incluye}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- NuestrosDatos — benchmarks reales de falsos techos -->
  <NuestrosDatos
    lang={lang}
    eyebrow={lang === 'en' ? 'Our numbers — false ceilings' : 'Nuestras cifras — falsos techos'}
    title={lang === 'en' ? '80% of our works include a false ceiling' : 'El 80% de nuestras obras incluye falso techo'}
    intro={lang === 'en'
      ? 'False ceilings are our most installed system. Concrete figures from the Mallorca parent company (2004-2025) that backs every Menorca project.'
      : 'El falso techo es el sistema que más instalamos. Estas son las cifras reales de la SL matriz (Mallorca, 2004-2025) que respalda cada proyecto en Menorca.'}
    metrics={lang === 'en' ? [
      { value: '~406', label: 'false ceilings in 2025', context: '80% of the 508 projects delivered' },
      { value: '1-2', label: 'working days for 50 m²', context: 'Dry build, no wet trades involved' },
      { value: 'Placo · Knauf · Lafarge', label: 'brands installed', context: 'Exclusive suppliers since 2004' },
      { value: '22', label: 'years as specialists', context: 'Exclusively drywall and plaster' },
    ] : [
      { value: '~406', label: 'falsos techos en 2025', context: '80% de los 508 proyectos ejecutados' },
      { value: '1-2', label: 'días laborables para 50 m²', context: 'Montaje en seco, sin obra húmeda' },
      { value: 'Placo · Knauf · Lafarge', label: 'marcas que instalamos', context: 'Proveedores exclusivos desde 2004' },
      { value: '22', label: 'años especialistas', context: 'Exclusivamente pladur y escayola' },
    ]}
  />

  <!-- PreciosTable -->
  <PreciosTable lang={lang} variant="Falsos Techos" />

  <!-- GaleriaTrabajos -->
  <GaleriaTrabajos imagenes={[
    { src: '/images/proyectos/falso-techo-led-exterior-villa.webp', alt: t.galeriaAlts[0] },
    { src: '/images/proyectos/salon-falso-techo-villa.webp', alt: t.galeriaAlts[1] },
    { src: '/images/proyectos/vestidor-falso-techo-led-vistas-mar.webp', alt: t.galeriaAlts[2] },
    { src: '/images/proyectos/dormitorio-vistas-mar-falso-techo.webp', alt: t.galeriaAlts[3] },
  ]} />

  <!-- ZonasServicio -->
  <ZonasServicio lang={lang} />

  <!-- Artículos relacionados -->
  <ArticulosRelacionados articulos={t.articulos} />

  <!-- FaqAccordion -->
  <FaqAccordion
    client:visible
    faqs={pageFaqs}
    lang={lang}
    titulo={t.faqTitulo}
    subtitulo={t.faqSubtitulo}
  />

  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-foreground rounded-3xl p-7 sm:p-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-white/80 text-sm leading-relaxed">{t.banner} <strong class="text-white">{t.bannerBold}</strong> {t.bannerTail}</p>
        <a href={p('/pladur-hidrofugo-menorca')} class="inline-flex items-center gap-2 text-white font-semibold underline underline-offset-2 text-sm shrink-0">
          {t.bannerCta}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CtaBanner final -->
  <CtaBanner
    lang={lang}
    titulo={t.ctaFinalTitulo}
    subtitulo={t.ctaFinalSubtitulo}
    showForm={true}
  />

  <ServiciosRelacionados currentPath="/falsos-techos-pladur-menorca" />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
