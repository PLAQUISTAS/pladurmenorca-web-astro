---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import { Image } from 'astro:assets'
import Button from '@/components/ui/Button.astro'
import { getAllPosts, blogCategories, blogCategoriesEn, formatDate } from '@/lib/blog'
import { siteConfig } from '@/data/site'
import type { Lang } from '@/i18n'

const lang = (Astro.currentLocale ?? 'es') as Lang
const posts = await getAllPosts(lang)
const FEATURED_SLUG = 'precio-pladur-menorca-2026'
const featuredPost = posts.find((p) => p.slug === FEATURED_SLUG) || posts[0]
const restPosts = posts.filter((p) => p.slug !== featuredPost?.slug)

const blogPath = lang === 'en' ? '/en/blog' : '/blog'
const postPath = (slug: string) => (lang === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`)

const t = lang === 'en' ? {
  metaTitle: 'Drywall Menorca Blog 2026 | Prices, Guides, Comparisons',
  metaDescription: 'Pladur Menorca blog: 2026 real prices per m², technical guides, installation tips, regulations and zone comparisons by Plaquistas y Acabados SL since 2004.',
  collectionName: 'Pladur Menorca Blog',
  collectionDesc: 'Technical guides and real 2026 drywall prices in Menorca: per m² rates, insulation, renovations, regulations, comparisons and coverage by zone.',
  breadcrumbHome: 'Home',
  breadcrumbBlog: 'Blog',
  heroBadges: ['Technical guides', '2026 real prices', 'Plaquistas y Acabados SL since 2004'],
  heroTitle: 'Pladur Menorca Blog — Drywall Guides and 2026 Prices',
  heroSubtitle: 'Answers to "how much does drywall cost", "which board should I use" and "how long does installation take", based on 6,000+ drywall projects delivered in Menorca since 2004. 2026 prices per m², insulation, board comparisons, regulations and project logs by zone.',
  emptyTitle: 'Coming soon',
  emptyBody: 'We are preparing 2026 articles and guides about drywall in Menorca (prices per m², insulation, comparisons and zone coverage). Please come back soon.',
  emptyCta: 'Get your free quote',
  featuredEyebrow: 'Featured article',
  readFull: 'Read full article',
  readMore: 'Read more',
  allArticlesEyebrow: 'All articles',
  articlesCountSuffix: 'articles published',
  resourcesEyebrow: 'Resources for your project',
  resourcesTitle: 'What you will find in this drywall blog',
  card1Title: '2026 prices per m² in Menorca',
  card1Body: 'Real per m² prices for every drywall service (partitions, false ceilings, acoustic and thermal insulation), updated for 2026 with current Placo, Knauf and Lafarge material rates and Balearic labour costs.',
  card2Title: 'Board comparisons and technical advice',
  card2Body: 'Drywall vs brick, standard vs moisture-resistant vs fireproof boards, mineral wool vs XPS, CW/UW profilework. Technical information focused on CTE DB-SI, HR and HE compliance, explained for homeowners and architects.',
  card3Title: 'Drywall projects across Menorca',
  card3Body: 'Real renovation logs from Maó, Calvià, Inca, Manacor, Andratx and Alcúdia: m² installed, boards and insulation used, execution time and final price, so you know what to expect in your own municipality.',
  ctaEyebrow: 'Start your project',
  ctaTitle: 'Got a drywall project in Menorca?',
  ctaSubtitle: 'Request your free quote in 24-48h. Project logistics (crew travel and materials transport) are reflected transparently inside the fixed quote — no surprise charges. Call +34 627 829 723 or email info@plaquistas.com.',
  ctaPrimary: 'Get a free quote',
  ctaCall: 'Call now',
  relatedEyebrow: 'You may also be interested in',
  categories: blogCategoriesEn,
  relatedLinks: [
    { href: '/en/presupuesto-pladur', label: 'Drywall Quote', desc: 'Free quote in 24-48h, no obligation, coverage across Menorca.' },
    { href: '/en/precios-pladur-menorca', label: 'Drywall Prices', desc: '2026 real rates per m² for partitions, false ceilings and insulation.' },
    { href: '/en/instalacion-pladur-menorca', label: 'Drywall Installation', desc: 'Installation by Plaquistas y Acabados SL specialists since 2004 in Menorca.' },
  ],
} : {
  metaTitle: 'Blog Pladur Menorca 2026 | Precios, Guías y Comparativas',
  metaDescription: 'Blog Pladur Menorca: precios reales 2026 por m², guías técnicas, normativa CTE y comparativas por zonas por Plaquistas y Acabados SL desde 2004.',
  collectionName: 'Blog Pladur Menorca',
  collectionDesc: 'Guías técnicas y precios reales 2026 de pladur en Menorca: tarifas por m², aislamiento, reformas, normativa, comparativas y cobertura por zonas.',
  breadcrumbHome: 'Inicio',
  breadcrumbBlog: 'Blog',
  heroBadges: ['Guías técnicas', 'Precios reales 2026', 'Plaquistas y Acabados SL desde 2004'],
  heroTitle: 'Blog Pladur Menorca — Guías y precios de pladur 2026',
  heroSubtitle: 'Respuestas a "cuánto cuesta el pladur", "qué placa usar" y "cuánto tarda la instalación", basadas en 6.000+ obras de pladur ejecutadas en Menorca desde 2004. Precios 2026 por m², aislamiento, comparativas de placas, normativa y casos reales por zonas.',
  emptyTitle: 'Próximamente',
  emptyBody: 'Estamos preparando artículos y guías 2026 sobre pladur en Menorca (precios por m², aislamiento, comparativas y cobertura por zonas). Vuelve pronto.',
  emptyCta: 'Pide tu presupuesto gratis',
  featuredEyebrow: 'Artículo destacado',
  readFull: 'Leer artículo completo',
  readMore: 'Leer más',
  allArticlesEyebrow: 'Todos los artículos',
  articlesCountSuffix: 'artículos publicados',
  resourcesEyebrow: 'Recursos para tu proyecto',
  resourcesTitle: 'Qué encontrarás en este blog de pladur',
  card1Title: 'Precios 2026 por m² en Menorca',
  card1Body: 'Precios reales por m² de cada servicio de pladur (tabiques, falsos techos, aislamiento acústico y térmico), actualizados a 2026 con las tarifas vigentes de Placo, Knauf y Lafarge y los costes de mano de obra en Baleares.',
  card2Title: 'Comparativas de placas y consejos técnicos',
  card2Body: 'Pladur vs ladrillo, placas estándar vs hidrófugas vs ignífugas, lana mineral vs XPS, perfilería CW/UW. Información técnica orientada al cumplimiento del CTE DB-SI, HR y HE, explicada para propietarios y arquitectos.',
  card3Title: 'Obras de pladur en toda Menorca',
  card3Body: 'Casos reales de reformas en Maó, Calvià, Inca, Manacor, Andratx y Alcúdia: m² instalados, placas y aislante empleados, tiempo de ejecución y precio final, para que sepas qué esperar en tu municipio.',
  ctaEyebrow: 'Empieza tu proyecto',
  ctaTitle: '¿Tienes un proyecto de pladur en Menorca?',
  ctaSubtitle: 'Solicita tu presupuesto gratis en 24-48h. La logística de obra (desplazamiento del equipo y transporte de materiales) va reflejada de forma transparente dentro del presupuesto cerrado, sin cargos sorpresa. Llama al 627 829 723 o escribe a info@plaquistas.com.',
  ctaPrimary: 'Pide presupuesto gratis',
  ctaCall: 'Llamar ahora',
  relatedEyebrow: 'También te puede interesar',
  categories: blogCategories,
  relatedLinks: [
    { href: '/presupuesto-pladur', label: 'Presupuesto de Pladur', desc: 'Presupuesto gratis en 24-48h, sin compromiso, en toda Menorca.' },
    { href: '/precios-pladur-menorca', label: 'Precios de Pladur', desc: 'Tarifas reales 2026 por m² para tabiques, falsos techos y aislamiento.' },
    { href: '/instalacion-pladur-menorca', label: 'Instalación de Pladur', desc: 'Instalación por técnicos de Plaquistas y Acabados SL desde 2004 en Menorca.' },
  ],
}

const meta = lang === 'en' ? {
  title: t.metaTitle,
  description: t.metaDescription,
  canonical: '/en/blog',
  alternateEs: '/blog',
} : {
  title: t.metaTitle,
  description: t.metaDescription,
  canonical: '/blog',
  alternateEn: '/en/blog',
}

const collectionPageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t.collectionName,
  description: t.collectionDesc,
  url: `${siteConfig.url}${blogPath}`,
  inLanguage: lang === 'en' ? 'en' : 'es',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteConfig.url}${postPath(post.slug)}`,
      name: post.title,
    })),
  },
})
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en' : '/' }, { label: t.breadcrumbBlog, href: blogPath }]} />
    <script type="application/ld+json" set:html={collectionPageSchema} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-3xl text-center mx-auto">
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            {t.heroBadges.map((tag) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-surface text-foreground border border-warm-border/60">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            {t.heroTitle}
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto">
            {t.heroSubtitle}
          </p>
        </div>
      </div>
    </div>
  </section>

  {posts.length === 0 ? (
    <!-- Empty state -->
    <section class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center py-20">
          <div class="size-16 rounded-2xl bg-warm-border-light flex items-center justify-center mx-auto mb-6">
            <svg class="size-8 text-muted" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <p class="text-xl font-bold text-foreground mb-2">{t.emptyTitle}</p>
          <p class="text-muted text-base leading-relaxed max-w-sm mx-auto">
            {t.emptyBody}
          </p>
          <Button href={lang === 'en' ? '/en/presupuesto-pladur' : '/presupuesto-pladur'} variant="primary" size="lg" class="mt-8" withArrow>
            {t.emptyCta}
          </Button>
        </div>
      </div>
    </section>
  ) : (
    <>
      <!-- Featured Post -->
      {featuredPost && (
        <section class="py-20 lg:py-28">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-8 inline-flex items-center px-3 py-1 rounded-lg">
              {t.featuredEyebrow}
            </p>
            <a href={postPath(featuredPost.slug)} class="group block">
              <article class="bg-white/70 rounded-3xl border border-warm-border/50 overflow-hidden shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                  <!-- Image -->
                  <div class="relative aspect-[16/10] lg:aspect-auto overflow-hidden bg-warm-border-light">
                    <Image
                      src={featuredPost.image}
                      alt={`${featuredPost.title} — ${featuredPost.category}, Pladur Menorca`}
                      width={800}
                      height={500}
                      class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="eager"
                    />
                    <div class="absolute top-4 left-4">
                      <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold text-white bg-foreground-dark uppercase tracking-wider">
                        {featuredPost.category}
                      </span>
                    </div>
                  </div>
                  <!-- Content -->
                  <div class="flex flex-col justify-center p-8 lg:p-12">
                    <div class="flex items-center gap-3 mb-5 text-sm text-muted">
                      <time datetime={featuredPost.date}>{formatDate(featuredPost.date, lang)}</time>
                      <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                      <span>{featuredPost.readingTime}</span>
                    </div>
                    <h2 class="text-2xl lg:text-3xl font-bold text-foreground leading-snug mb-4 group-hover:text-muted transition-colors">
                      {featuredPost.title}
                    </h2>
                    <p class="text-muted text-base leading-relaxed mb-8 line-clamp-3">
                      {featuredPost.excerpt}
                    </p>
                    <div class="inline-flex items-center gap-2 text-foreground font-bold text-sm">
                      {t.readFull}
                      <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </article>
            </a>
          </div>
        </section>
      )}

      <!-- Categories + Posts Grid -->
      <section class="py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-12">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">
                {t.allArticlesEyebrow}
              </p>
              <p class="text-sm text-muted">
                <span class="font-bold text-foreground">{posts.length}</span> {t.articlesCountSuffix}
              </p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
              {t.categories.map((cat) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium text-foreground bg-surface border border-warm-border/60">
                  {cat}
                </span>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 stagger-children">
            {(restPosts.length > 0 ? restPosts : posts).map((post) => (
              <article class="group h-full bg-white/70 rounded-3xl border border-warm-border/50 shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 flex flex-col overflow-hidden">
                <!-- Image -->
                <div class="relative aspect-[16/9] overflow-hidden bg-warm-border-light">
                  <Image
                    src={post.image}
                    alt={`${post.title} — ${post.category}, Pladur Menorca`}
                    width={600}
                    height={338}
                    class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-[1.02]"
                    loading="lazy"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold text-white bg-foreground-dark uppercase tracking-wider">
                      {post.category}
                    </span>
                  </div>
                </div>

                <!-- Content -->
                <div class="flex flex-col flex-1 p-7">
                  <div class="flex items-center gap-3 mb-4 text-sm text-muted">
                    <time datetime={post.date}>{formatDate(post.date, lang)}</time>
                    <span class="size-1 rounded-full bg-warm-border" aria-hidden="true"></span>
                    <span>{post.readingTime}</span>
                  </div>
                  <h3 class="text-lg font-bold text-foreground leading-snug mb-4 group-hover:text-muted transition-colors">
                    <a href={postPath(post.slug)}>
                      {post.title}
                    </a>
                  </h3>
                  <p class="text-muted text-sm leading-relaxed flex-1 mb-6 line-clamp-3">
                    {post.excerpt}
                  </p>
                  <a
                    href={postPath(post.slug)}
                    class="inline-flex items-center gap-1.5 text-foreground font-semibold text-sm hover:text-foreground-dark transition-colors"
                  >
                    {t.readMore}
                    <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <!-- Qué encontrarás en nuestro blog -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg mx-auto">
          {t.resourcesEyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance">
          {t.resourcesTitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.card1Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.card1Body}</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.card2Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.card2Body}</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.card3Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.card3Body}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl py-16 lg:py-24 px-6 sm:px-10 lg:px-16 relative overflow-hidden shadow-warm">
        <div class="text-center max-w-2xl mx-auto">
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-6">
            {t.ctaEyebrow}
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">
            {t.ctaTitle}
          </h2>
          <p class="text-lg text-muted leading-relaxed mb-10">
            {t.ctaSubtitle}
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <Button href={lang === 'en' ? '/en/presupuesto-pladur' : '/presupuesto-pladur'} variant="primary" size="lg" withArrow>
              {t.ctaPrimary}
            </Button>
            <Button href={`tel:${siteConfig.phoneRaw}`} variant="secondary" size="lg">
              <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {t.ctaCall}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-8 inline-flex items-center px-3 py-1 rounded-lg">{t.relatedEyebrow}</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {t.relatedLinks.map((link) => (
          <a
            href={link.href}
            class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
          >
            <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
            <p class="text-muted text-sm mb-4">{link.desc}</p>
            <div class="h-0.5 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-0 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
