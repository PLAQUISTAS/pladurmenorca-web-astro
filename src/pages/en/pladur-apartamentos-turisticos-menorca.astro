    </div>
  </section>

  <!-- CTA final -->
  <CtaBanner
    lang={lang}
    titulo={t.ctaTitle}
    subtitulo={t.ctaSubtitle}
  />

  <ServiciosRelacionados currentPath={breadcrumbHref} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
