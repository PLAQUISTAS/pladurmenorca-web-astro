  schemaDesc: 'Servicio de reformas interiores con sistemas de pladur en Menorca: redistribución de espacios, falsos techos, aislamiento acústico y térmico sin obra pesada.',
  schemaType: 'Reformas Interiores con Pladur',
  offers: [
    { name: 'Tabique divisorio estándar', price: '45', description: 'Tabique de pladur para redistribución de espacios con aislante incluido. Precio por m².' },
    { name: 'Reforma integral con pladur', price: '45', description: 'Reforma completa de estancia incluyendo tabiques, falso techo y trasdosados. Precio por m².' },
    { name: 'Falso techo continuo', price: '29', description: 'Falso techo de pladur liso para ocultar instalaciones y mejorar la estética. Precio por m².' },
