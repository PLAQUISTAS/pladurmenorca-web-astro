const t = lang === 'en' ? {
  srOnly: 'Pladur Menorca — interior drywall (pladur) renovations in Menorca. Space redistribution, false ceilings, insulation and finishes. 6,000+ projects completed. Tel: +34 627 829 723.',
  breadcrumbHome: 'Home',
  breadcrumbCurrent: 'Interior Renovations',
  schemaName: 'Interior Drywall Renovations in Menorca',
  schemaDesc: 'Interior renovation service using drywall (pladur) systems in Menorca: space redistribution, false ceilings, acoustic and thermal insulation without heavy works.',
  schemaType: 'Interior Drywall Renovations',
  offers: [
    { name: 'Standard dividing partition', price: '45', description: 'Drywall partition for space redistribution with insulation included. Price per m².' },
    { name: 'Full renovation with drywall', price: '45', description: 'Complete room renovation including partitions, false ceiling and wall linings. Price per m².' },
    { name: 'Continuous false ceiling', price: '29', description: 'Smooth drywall false ceiling to hide services and improve aesthetics. Price per m².' },
    { name: 'Wall linings', price: '29', description: 'Wall linings to level walls and improve thermal and acoustic insulation. Price per m².' },
    { name: 'Drywall furniture and shelving', price: '40', description: 'Bespoke built-in shelving, niches and drywall furniture. Price per linear metre.' },
  ],
  heroEyebrow: 'Drywall renovations · Menorca',
  heroH1: 'Interior Drywall Renovations in Menorca — Fast, Clean and Affordable',
  heroLead: 'We renovate flats, villas, offices and holiday apartments in Menorca with drywall: layout changes, false ceilings and insulation from €45/m², ready in 1-2 weeks. Dry build, no debris, no need to vacate the home. Fixed quote in 24-48h after an on-site visit.',
  heroCtaPrimary: 'Request a free quote',
  heroCtaCall: siteConfig.phone,
  porQueEyebrow: 'Why choose drywall',
  porQueH2: 'Why is drywall ideal for interior renovations?',
  porQueP1: 'Drywall is the fastest, cleanest and cheapest system for interior renovations in Menorca: a full renovation of an 80-100 m² flat takes 1-2 weeks from €10,000, compared with 4-8 weeks and €15,000 for traditional brick. Drywall — also called laminated plaster or dry-lining — wins on the three usual concerns (time, dust, cost) by a clear margin.',
  porQueP2: 'Drywall uses a galvanised steel frame (M48/70/100 studs and Placo/Knauf tracks) onto which 12.5 mm plasterboard is screwed. Installation needs no water and no drying time, so a layout partition that takes 3 days to build and 2 to cure with brick is ready in a single shift with drywall and accepts paint 24 hours later.',
  porQueP3: 'Menorca has thousands of 1960s-70s flats with outdated layouts and a strong holiday-let market that needs fast refurbishing between seasons. For both audiences drywall is the optimal tool: a full flat layout change with no debris, back on the market in 10-14 days. The Mediterranean climate (summers of 32-34 °C and high summer humidity) adds value to the integrated insulation Placo/Knauf systems offer.',
  porQueP4: 'Drywall weighs 25 kg/m² vs 120 kg/m² for a double-hollow brick partition: an 80% cut in structural weight. In historic buildings in Maó, Ciutadella or Alaior, or in flats with 1940s-60s timber-and-concrete slabs, brick can require structural calculations and reinforcement. Drywall is compatible with any slab without added reinforcement.',
  porQueP5: 'The inside of a drywall partition (70 mm cavity) houses electrical wiring, HVAC piping, air ducts, built-in speakers and home-automation cabling. No wall chasing: services are laid between the studs before closing with board. Installations stay protected and accessible through register hatches when needed.',
  porQueP6Pre: 'For the full technical details of drywall installation, visit our ',
  porQueP6Link: 'drywall installation in Menorca page',
  porQueP6LinkHref: '/en/instalacion-pladur-menorca',
  porQueP6Post: ', where we explain the process step by step and the board types available.',
