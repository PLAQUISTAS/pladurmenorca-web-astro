---
export const prerender = true
import type { Lang } from '@/i18n'
import BaseLayout from '@/layouts/BaseLayout.astro'
import TestimonioCard from '@/components/ui/TestimonioCard.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import FormPresupuesto from '@/components/forms/FormPresupuesto'
import { getPresupuestoFaqs } from '@/data/faqs/presupuesto'
import { getContactoFaqs } from '@/data/faqs/contacto'
import { siteConfig } from '@/data/site'
import { testimonios } from '@/data/testimonios'

const lang = (Astro.currentLocale ?? 'es') as Lang

const presupuestoFaqs = getPresupuestoFaqs(lang)
const contactoPageFaqs = getContactoFaqs(lang)

const allFaqs = [...presupuestoFaqs, ...contactoPageFaqs]
const sidebarFaqs = [
  contactoPageFaqs[0],
  presupuestoFaqs[0],
]
const contactoFaqs = allFaqs
const miniTestimonios = [testimonios[0], testimonios[1], testimonios[2]]

const t = lang === 'en' ? {
  heroBadges: ['Reply 24-48h', 'Free quote', 'Drywall since 2004'],
  heroTitle: 'Contact Pladur Menorca',
  heroDescription: 'Plaquistas y Acabados SL answers on +34 627 829 723, WhatsApp, info@plaquistas.com and the form, with a written reply within 24-48h (same day if you reach us before 16:00).',
  formTitle: 'Request your free drywall quote',
  formDescription: 'Send us the details of your project (m², service, location). We review it from our Mallorca office and deliver the fixed, itemised quote in under 24h.',
  directContact: 'Direct contact',
  hoursShort: 'Mon-Fri 8:00-18:00 · Sat 8:00-14:00',
  callNow: 'Call now',
  whatsappLabel: 'Message on WhatsApp',
  whatsappAria: 'Contact via WhatsApp',
  locationHeading: 'Location & hours',
  viewMaps: 'View on Google Maps',
  monFri: 'Monday - Friday',
  saturday: 'Saturdays',
  sunday: 'Sundays & holidays',
  closed: 'Closed',
  quickFaqsHeading: 'Quick answers',
  topServicesHeading: 'Most requested services',
  services: [
    { href: '/en/falsos-techos-pladur-menorca', label: 'False ceilings' },
    { href: '/en/tabiques-pladur-menorca', label: 'Drywall partitions' },
    { href: '/en/aislamiento-acustico-menorca', label: 'Soundproofing' },
    { href: '/en/reformas-interiores-pladur-menorca', label: 'Interior renovations' },
    { href: '/en/precios-pladur-menorca', label: 'Prices' },
  ],
  processBadge: 'How we work',
  processTitle: 'Three steps from enquiry to installed drywall',
  step1Title: 'Contact us',
  step1Desc: 'Call 627 829 723, WhatsApp, email info@plaquistas.com or submit the form. Mon-Fri 8:00-18:00 and Sat 8:00-14:00; closed Sundays and public holidays.',
  step2Title: 'Site visit',
  step2Desc: 'A specialist travels from our Mallorca office to your home to measure, photograph and check the structure. Project logistics (crew travel and materials transport) are reflected transparently inside the fixed quote, with no surprise charges later.',
  step3Title: 'Quote within 24-48h',
  step3Desc: 'You receive a fixed quote itemising Placo, Knauf or Lafarge boards, CW/UW profiles, insulation, labour and waste management. VAT (21%) shown separately; offer valid 30 days.',
  mapBadge: 'Our location',
  mapTitle: 'Mallorca office · Drywall coverage across all Menorca',
  mapAria: 'View Pladur Menorca location on Google Maps',
  mapIframeTitle: 'Pladur Menorca · Oficina en Mallorca, servicio en toda Menorca',
  reviewsBadge: 'What our clients say',
  reviewsTitle: 'Verified Google reviews',
  leaveReview: 'Leave us a review on Google',
  faqTitle: 'Frequently asked questions on contact and quotes',
  faqSubtitle: 'Reply times, channels, coverage and how our drywall quote process works in Menorca.',
  relatedBadge: 'You may also like',
  relatedLinks: [
    { href: '/en/falsos-techos-pladur-menorca', label: 'Drywall False Ceilings', descripcion: 'Continuous, decorative, acoustic ceilings with LED lighting' },
    { href: '/en/tabiques-pladur-menorca', label: 'Drywall Partitions', descripcion: 'Fast, clean space layout without traditional building work' },
    { href: '/en/aislamiento-acustico-menorca', label: 'Soundproofing', descripcion: 'Noise reduction between homes, offices and commercial premises' },
    { href: '/en/reformas-interiores-pladur-menorca', label: 'Interior Renovations', descripcion: 'Full drywall renovations for homes and premises' },
    { href: '/en/precios-pladur-menorca', label: 'Drywall Prices', descripcion: 'See our rates and indicative prices per m²' },
    { href: '/en/instalacion-pladur-menorca', label: 'Drywall Installation', descripcion: 'Full installation service since 2004' },
    { href: '/en/pladur-mao', label: 'Drywall in Maó', descripcion: 'Drywall installers in Maó and nearby districts' },
    { href: '/en/pladur-sant-lluis', label: 'Drywall in Sant Lluís', descripcion: 'Drywall service in Sant Lluís, Punta Prima, Binibeca Vell and surrounding areas' },
    { href: '/en/presupuesto-pladur', label: 'Drywall Quote', descripcion: 'Request your free quote with no obligation' },
  ],
  srOnly: 'Pladur Menorca (Plaquistas y Acabados SL). Office in Mallorca (SL matriz since 2004). Service across all Menorca. Phone +34 627 829 723. Email info@plaquistas.com. Hours Mon-Fri 8:00-18:00 and Sat 8:00-14:00. Coverage across Menorca, quote in 24-48h. Drywall specialists since 2004.',
  breadcrumbHome: 'Home',
  breadcrumbContact: 'Contact',
} : {
  heroBadges: ['Respuesta 24-48h', 'Presupuesto gratis', 'Pladur desde 2004'],
  heroTitle: 'Contacto Pladur Menorca',
  heroDescription: 'Plaquistas y Acabados SL atiende en el 627 829 723, WhatsApp, info@plaquistas.com y el formulario, con respuesta escrita en 24-48h (mismo día si contactas antes de las 16:00).',
  formTitle: 'Solicita tu presupuesto gratuito de pladur',
  formDescription: 'Envíanos los datos del proyecto (m², servicio, ubicación). Lo revisamos desde nuestra oficina en Mallorca y te entregamos el presupuesto cerrado y desglosado en menos de 24h.',
  directContact: 'Contacto directo',
  hoursShort: 'L–V 8:00–18:00 · Sáb 8:00–14:00',
  callNow: 'Llamar ahora',
  whatsappLabel: 'Escribir por WhatsApp',
  whatsappAria: 'Contactar por WhatsApp',
  locationHeading: 'Ubicación y horario',
  viewMaps: 'Ver en Google Maps',
  monFri: 'Lunes – Viernes',
  saturday: 'Sábados',
  sunday: 'Domingos y festivos',
  closed: 'Cerrado',
  quickFaqsHeading: 'Dudas rápidas',
  topServicesHeading: 'Servicios más solicitados',
  services: [
    { href: '/falsos-techos-pladur-menorca', label: 'Falsos techos' },
    { href: '/tabiques-pladur-menorca', label: 'Tabiques' },
    { href: '/aislamiento-acustico-menorca', label: 'Aislamiento acústico' },
    { href: '/reformas-interiores-pladur-menorca', label: 'Reformas interiores' },
    { href: '/precios-pladur-menorca', label: 'Precios' },
  ],
  processBadge: 'Cómo trabajamos',
  processTitle: 'Tres pasos del primer contacto al pladur instalado',
  step1Title: 'Contactas con nosotros',
  step1Desc: 'Llama al 627 829 723, escribe al WhatsApp, envía un email a info@plaquistas.com o rellena el formulario. Atendemos L-V 8:00-18:00 y S 8:00-14:00; cerramos domingos y festivos.',
  step2Title: 'Visita técnica',
  step2Desc: 'Un técnico sale desde nuestra oficina en Mallorca hasta tu domicilio para medir, fotografiar y revisar la estructura. La logística de obra (desplazamiento del equipo y transporte de materiales) queda reflejada de forma transparente dentro del presupuesto cerrado, sin cargos sorpresa posteriores.',
  step3Title: 'Presupuesto en 24-48h',
  step3Desc: 'Recibes un presupuesto cerrado que detalla placas Placo, Knauf o Lafarge, perfilería CW/UW, aislante, mano de obra y gestión de residuos. IVA (21%) desglosado y validez de 30 días.',
  mapBadge: 'Nuestra ubicación',
  mapTitle: 'Oficina en Mallorca · Servicio de pladur en toda Menorca',
  mapAria: 'Ver ubicación de Pladur Menorca en Google Maps',
  mapIframeTitle: 'Pladur Menorca · Oficina en Mallorca, servicio en toda Menorca',
  reviewsBadge: 'Lo que dicen nuestros clientes',
  reviewsTitle: 'Reseñas verificadas en Google',
  leaveReview: 'Déjanos tu reseña en Google',
  faqTitle: 'Preguntas frecuentes sobre contacto y presupuestos',
  faqSubtitle: 'Plazos de respuesta, canales disponibles, cobertura y cómo funciona el proceso de presupuesto de pladur en Menorca.',
  relatedBadge: 'También te puede interesar',
  relatedLinks: [
    { href: '/falsos-techos-pladur-menorca', label: 'Falsos Techos de Pladur', descripcion: 'Techos continuos, decorativos, acústicos y con iluminación LED' },
    { href: '/tabiques-pladur-menorca', label: 'Tabiques de Pladur', descripcion: 'Distribución de espacios rápida, limpia y sin obra tradicional' },
    { href: '/aislamiento-acustico-menorca', label: 'Aislamiento Acústico', descripcion: 'Reducción de ruido entre viviendas, oficinas y locales comerciales' },
    { href: '/reformas-interiores-pladur-menorca', label: 'Reformas Interiores', descripcion: 'Reformas completas con pladur para viviendas y locales' },
    { href: '/precios-pladur-menorca', label: 'Precios de Pladur', descripcion: 'Consulta nuestras tarifas y precios orientativos por m²' },
    { href: '/instalacion-pladur-menorca', label: 'Instalación de Pladur', descripcion: 'Servicio completo de instalación desde 2004' },
    { href: '/pladur-mao', label: 'Pladur en Maó', descripcion: 'Instaladores de pladur en Maó y barrios cercanos' },
    { href: '/pladur-sant-lluis', label: 'Pladur en Sant Lluís', descripcion: 'Servicio de pladur en Sant Lluís, Punta Prima, Binibeca Vell y alrededores' },
    { href: '/presupuesto-pladur', label: 'Presupuesto de Pladur', descripcion: 'Solicita tu presupuesto gratis y sin compromiso' },
  ],
  srOnly: 'Pladur Menorca (Plaquistas y Acabados SL). Oficina en Mallorca (SL matriz desde 2004). Servicio en toda Menorca. Tel 627 829 723. Email info@plaquistas.com. Horario L-V 8:00-18:00 y S 8:00-14:00. Cobertura en toda Menorca, presupuesto en 24-48h. Especialistas en pladur desde 2004.',
  breadcrumbHome: 'Inicio',
  breadcrumbContact: 'Contacto',
}

const meta = lang === 'en' ? {
  title: 'Contact | Pladur Menorca — Drywall Quote in 24-48h',
  description: 'Pladur Menorca contact: +34 627 829 723, info@plaquistas.com, WhatsApp. Mallorca office, service across Menorca, Mon-Fri 8:00-18:00. Quote in 24-48h, no obligation.',
  canonical: '/en/contacto',
  alternateEs: '/contacto',
} : {
  title: 'Contacto | Pladur Menorca · Presupuesto en 24-48h',
  description: 'Contacto Pladur Menorca: 627 829 723, info@plaquistas.com, WhatsApp. Oficina en Mallorca, servicio en toda Menorca, L-V 8:00-18:00. Presupuesto en 24-48h, sin compromiso.',
  canonical: '/contacto',
  alternateEn: '/en/contacto',
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en/' : '/' }, { label: t.breadcrumbContact, href: lang === 'en' ? '/en/contacto' : '/contacto' }]} />
    {contactoFaqs.length > 0 && <SchemaFAQ faqs={contactoFaqs} />}
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">
    {t.srOnly}
  </p>

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-3xl text-center mx-auto">
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            {t.heroBadges.map((tag) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-surface text-foreground border border-warm-border/60">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            {t.heroTitle}
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto">
            {t.heroDescription}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main grid: Form + Sidebar -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- LEFT: Form -->
        <div class="lg:col-span-7">
          <div class="bg-white rounded-2xl border border-warm-border p-8 lg:p-10 shadow-soft-lg">
            <h2 class="text-2xl font-bold text-foreground mb-2">
              {t.formTitle}
            </h2>
            <p class="text-muted text-sm mb-8">
              {t.formDescription}
            </p>
            <FormPresupuesto client:load />
          </div>
        </div>

        <!-- RIGHT: Sidebar -->
        <div class="lg:col-span-5 space-y-6">

          <!-- Contacto directo -->
          <div class="relative overflow-hidden rounded-3xl bg-foreground-dark p-8 text-white shadow-card">
            <div aria-hidden="true" class="pointer-events-none absolute -top-16 -right-16 size-40 rounded-full bg-white/[0.04] blur-3xl"></div>
            <div class="relative">
              <p class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60 mb-4">
                <span class="size-1.5 rounded-full bg-white/60 animate-pulse motion-reduce:animate-none"></span>
                {t.directContact}
              </p>
              <a href={`tel:${siteConfig.phoneRaw}`} class="block font-bold text-3xl sm:text-[34px] text-white mb-2 tracking-tight tabular-nums hover:opacity-90 transition-opacity">
                {siteConfig.phone}
              </a>
              <p class="text-[13px] text-white/55 mb-6">{t.hoursShort}</p>

              <div class="flex flex-col gap-2.5">
                <a
                  href={`tel:${siteConfig.phoneRaw}`}
                  class="group inline-flex items-center justify-between gap-3 rounded-xl border border-white/15 bg-white/5 hover:bg-white/10 hover:border-white/25 px-4 py-3 text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-foreground-dark"
                >
                  <span class="flex items-center gap-3">
                    <svg aria-hidden="true" class="size-4 text-white/80" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                    </svg>
                    <span class="text-sm font-bold">{t.callNow}</span>
                  </span>
                  <svg aria-hidden="true" class="size-4 text-white/60 group-hover:text-white group-hover:translate-x-0.5 transition-[color,transform] duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
                <a
                  href={`https://wa.me/${siteConfig.whatsapp}?text=${siteConfig.whatsappText}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={t.whatsappAria}
                  class="group inline-flex items-center justify-between gap-3 rounded-xl border border-white/15 bg-white/5 hover:bg-white/10 hover:border-white/25 px-4 py-3 text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-foreground-dark"
                >
                  <span class="flex items-center gap-3">
                    <svg aria-hidden="true" class="size-4 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                    </svg>
                    <span class="text-sm font-bold">{t.whatsappLabel}</span>
                  </span>
                  <svg aria-hidden="true" class="size-4 text-white/60 group-hover:text-white group-hover:translate-x-0.5 transition-[color,transform] duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Ubicación y horario -->
          <div class="rounded-3xl bg-white border border-warm-border/40 p-8 shadow-card">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground mb-6">
              {t.locationHeading}
            </p>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <span class="shrink-0 flex size-10 items-center justify-center rounded-xl bg-surface border border-nav-border text-foreground">
                  <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                </span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-foreground leading-snug">{siteConfig.address.street}</p>
                  <p class="text-xs text-muted mt-0.5">{siteConfig.address.postalCode} {siteConfig.address.city}, {siteConfig.address.province}</p>
                  <a
                    href={siteConfig.social.google}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex items-center gap-1 mt-2 text-xs font-semibold text-foreground hover:text-foreground-dark transition-colors"
                  >
                    {t.viewMaps}
                    <svg aria-hidden="true" class="size-3 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                    </svg>
                  </a>
                </div>
              </div>

              <div class="h-px bg-warm-border/60"></div>

              <div class="flex items-start gap-4">
                <span class="shrink-0 flex size-10 items-center justify-center rounded-xl bg-surface border border-nav-border text-foreground">
                  <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </span>
                <div class="min-w-0">
                  <dl class="space-y-1">
                    <div class="flex items-baseline justify-between gap-3">
                      <dt class="text-xs text-muted">{t.monFri}</dt>
                      <dd class="text-sm font-semibold text-foreground tabular-nums">8:00 – 18:00</dd>
                    </div>
                    <div class="flex items-baseline justify-between gap-3">
                      <dt class="text-xs text-muted">{t.saturday}</dt>
                      <dd class="text-sm font-semibold text-foreground tabular-nums">8:00 – 14:00</dd>
                    </div>
                    <div class="flex items-baseline justify-between gap-3">
                      <dt class="text-xs text-muted">{t.sunday}</dt>
                      <dd class="text-xs font-semibold text-muted">{t.closed}</dd>
                    </div>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <!-- Dudas rápidas -->
          <div class="rounded-3xl bg-white border border-warm-border/40 p-8 shadow-card">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground mb-6">
              {t.quickFaqsHeading}
            </p>
            <div class="divide-y divide-warm-border/60">
              {sidebarFaqs.map((faq, i) => (
                <div class="py-4 first:pt-0 last:pb-0">
                  <p class="flex items-start gap-3 text-sm font-semibold text-foreground leading-snug mb-1.5">
                    <span class="shrink-0 inline-flex items-center justify-center size-5 rounded-full bg-surface border border-nav-border text-[10px] font-bold text-muted tabular-nums mt-0.5">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span>{faq.pregunta}</span>
                  </p>
                  <p class="text-xs text-muted leading-relaxed pl-8">{faq.respuesta}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Servicios más solicitados -->
          <div class="rounded-3xl bg-white border border-warm-border/40 p-8 shadow-card">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground mb-5">
              {t.topServicesHeading}
            </p>
            <div class="flex flex-wrap gap-2">
              {t.services.map((s) => (
                <a href={s.href} class="inline-flex items-center gap-1.5 rounded-full border border-warm-border bg-white px-3.5 py-1.5 text-xs font-semibold text-foreground hover:bg-foreground-dark hover:border-foreground-dark hover:text-white transition-colors duration-200">
                  {s.label}
                </a>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- El proceso es sencillo -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.processBadge}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          {t.processTitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.step1Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.step1Desc}</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.step2Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.step2Desc}</p>
        </div>

        <div class="group bg-white/70 rounded-3xl border border-warm-border/50 p-8 h-full shadow-card hover:shadow-elevated hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300">
          <div class="size-12 rounded-2xl bg-surface border border-nav-border flex items-center justify-center mb-5 group-hover:bg-foreground-dark group-hover:border-foreground-dark transition-colors duration-300">
            <svg class="size-5 text-foreground group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{t.step3Title}</h3>
          <p class="text-muted text-sm leading-relaxed">{t.step3Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.mapBadge}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          {t.mapTitle}
        </h2>
        <p class="text-muted text-base mt-3 max-w-2xl mx-auto">
          Carrer Jacint Verdaguer, 37, ESC. A 4º 2ª — 07004 Palma de Mallorca, Illes Balears
        </p>
      </div>
      <a
        href={siteConfig.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="block overflow-hidden border border-warm-border rounded-3xl shadow-card hover:shadow-elevated transition-shadow duration-300 relative group"
        aria-label={t.mapAria}
      >
        <iframe
          src="https://www.google.com/maps?q=Carrer+Jacint+Verdaguer+37,+07004+Palma+de+Mallorca,+Illes+Balears&output=embed"
          width="100%"
          height="350"
          style="border:0;pointer-events:none"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={t.mapIframeTitle}
          tabindex="-1"
        ></iframe>
        <div class="absolute inset-0 bg-transparent group-hover:bg-black/5 transition-colors duration-300"></div>
      </a>
    </div>
  </section>

  <!-- Testimonios -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.reviewsBadge}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          {t.reviewsTitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {miniTestimonios.map((testimonio) => (
          <TestimonioCard testimonio={testimonio} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href={siteConfig.googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-white border-2 border-warm-border hover:border-google hover:shadow-google text-foreground font-bold text-sm tracking-wide transition-[border-color,box-shadow,transform] duration-300 active:scale-95"
        >
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          {t.leaveReview}
          <svg class="size-4 text-muted group-hover:text-google group-hover:translate-x-0.5 transition-[color,transform]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FaqAccordion
    client:visible
    lang={lang}
    faqs={contactoFaqs}
    titulo={t.faqTitle}
    subtitulo={t.faqSubtitle}
  />

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">{t.relatedBadge}</span>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {t.relatedLinks.map((link) => (
          <a
            href={link.href}
            class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300"
          >
            <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
            <p class="text-muted text-sm mb-4">{link.descripcion}</p>
            <div class="h-0.5 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-0 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
