---
export const prerender = true
import { localizedHref } from '@/i18n'
import type { Lang } from '@/i18n'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import { Image } from 'astro:assets'
import { siteConfig } from '@/data/site'
import Hero from '@/components/sections/Hero.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import { getProyectosFaqs } from '@/data/faqs/proyectos'
import GalleryMasonry from '@/components/gallery/GalleryMasonry'
import Button from '@/components/ui/Button.astro'
import { galleryItems } from '@/data/proyectos'

const lang = (Astro.currentLocale ?? 'es') as Lang
const p = (h: string) => localizedHref(h, lang)
const pageFaqs = getProyectosFaqs(lang)

const t = lang === 'en' ? {
  heroTitle: 'Drywall Project Gallery in Menorca — 6,000+ Works Since 2004',
  heroDescription: 'We have delivered 6,000+ drywall projects in Menorca since 2004: apartments (40-120 m²), villas (150-500 m²), hotels (60-300 rooms), offices and holiday rentals across all 8 Menorca municipalities.',
  heroBadges: ['6,000+ Works', 'Since 2004', 'All 8 Municipalities'],
  ctaPrimary: 'Request a free quote',
  ctaSecondary: `Call: ${siteConfig.phone}`,
  featuredBadge: 'Real cases',
  featuredTitle: 'Featured projects with technical detail',
  proyectos: [
    {
      image: '/images/proyectos/reforma-integral-piso.webp',
      imageAlt: 'Full drywall renovation in 85 m² apartment, the Balearics',
      title: 'Full drywall renovation — 85 m² apartment in the Balearics',
      location: 'Balearic Islands',
      description: '85 m² apartment: 6 Placo BA13 partitions with 48 mm Rockwool (47 dBA reduction), 3 false ceilings with recessed LED and thermal lining on the north façade. Delivered in 8 working days with Q3 finish. 1-year workmanship warranty plus Placo/Knauf 10-25 year manufacturer warranty.',
      stats: [{ value: '85 m²', label: 'Area' }, { value: '8 days', label: 'Duration' }, { value: '€12,800', label: 'Investment' }],
      tags: ['Partitions', 'False ceilings', 'Insulation'],
    },
    {
      image: '/images/proyectos/aislamiento-acustico-apartamento-turistico.webp',
      imageAlt: 'Soundproofing with Placo Phonique in 60 m² ETV holiday apartment, the Balearics',
      title: 'Acoustic soundproofing — 60 m² ETV holiday apartment in the Balearics',
      location: 'Balearic Islands',
      description: '60 m² licensed ETV (Estancias Turísticas Vacacionales) apartment: Placo Phonique wall linings with 48 mm Rockwool on party walls (52 dBA reduction, CTE-HR compliant), acoustic false ceiling with anti-vibration hangers. Executed in 5 days to avoid tourist-season void. Guest scores improved from 7.2 to 9.1.',
      stats: [{ value: '60 m²', label: 'Area' }, { value: '5 days', label: 'Duration' }, { value: '52 dBA', label: 'Reduction' }],
      tags: ['Soundproofing', 'Holiday rental'],
    },
    {
      image: '/images/proyectos/oficina-open-space-tabiques.webp',
      imageAlt: 'Open-space office compartmentation with Knauf Diamant partitions, the Balearics',
      title: 'Open-space office compartmentation — 120 m² in the Balearics',
      location: 'Balearic Islands',
      description: '120 m² open warehouse converted into 4 private offices, a meeting room and a reception area. Double Knauf Diamant board partitions with Isover mineral wool for 45 dBA inter-office isolation. Demountable false ceiling for access to HVAC, electrical and data services. Completed in 6 working days with no disruption to adjacent tenants.',
      stats: [{ value: '120 m²', label: 'Area' }, { value: '6 days', label: 'Duration' }, { value: '€9,600', label: 'Investment' }],
      tags: ['Partitions', 'Offices'],
    },
    {
      image: '/images/proyectos/salon-falso-techo-villa.webp',
      imageAlt: 'Continuous Placo BA13 false ceilings with LED cove lighting, Balearic villa',
      title: 'False ceilings with integrated LED — 200 m² villa in the Balearics',
      location: 'Balearic Islands',
      description: '200 m² luxury villa: continuous Placo BA13 false ceilings with recessed perimeter LED cove in living room, dining room and 4 bedrooms. Q4 finish prepared for premium matt paint, integrated ducted air-conditioning and concealed blinds. 10-day execution coordinated with interior designer and AC installer.',
      stats: [{ value: '200 m²', label: 'Area' }, { value: '10 days', label: 'Duration' }, { value: 'Q4', label: 'Finish' }],
      tags: ['False ceilings', 'Integrated LED'],
    },
  ],
  seoEyebrow: 'Our track record',
  seoH2: '6,000+ Drywall Projects in Menorca since 2004',
  seoP1: 'Pladur Menorca (Plaquistas y Acabados SL) has delivered over 6,000 drywall and plasterboard projects across Menorca since 2004. Typical turnaround: a 50 m² false ceiling in 1-2 working days, a full apartment in 1-2 weeks, and a 120-room hotel in 8-10 weeks. Every job is closed at a fixed price with a 1-year workmanship warranty, on top of the 10-25 year manufacturer warranty from Placo, Knauf and Lafarge.',
  seoH3a: 'Projects in every type of space',
  seoH3aP: 'We execute drywall works in apartments (40-120 m²), villas (150-500 m²), licensed ETV holiday rentals, commercial premises, professional offices, and 3- to 5-star hotels (60-300 rooms). Typical cases include full renovations in Santa Catalina or Portixol (Maó), acoustic refits of ETVs in Sant Lluís and Es Castell, and phased hotel works in Son Bou and Cala Galdana. Our <a href="/en/instalacion-pladur-menorca">drywall installation</a> covers <a href="/en/falsos-techos-pladur-menorca">false ceilings</a>, partition walls, wall linings with thermal and acoustic insulation, and Q2-Q4 decorative finishes.',
  seoH3b: 'Coverage in all 8 Menorca municipalities',
  seoH3bP: 'We operate in every Menorca municipality. High-volume zones include Maó (Santa Catalina, Portixol, Son Parc), Sant Lluís (Binibeca Vell, Punta Prima, Cala en Bosc), Es Castell, Ferreries, Es Mercadal (Son Parc, Arenal d\'en Castell), plus Alaior, Ciutadella, Es Migjorn Gran, Son Bou, Fornells and Cala Galdana. Island-wide coverage with a transparent fixed quote — logistics already included.',
  seoH3c: 'Representative systems and materials',
  seoH3cP: 'We install only materials from Placo (Saint-Gobain), Knauf and Lafarge, with full CE marking and technical datasheets. Recurring systems: Placo BA13/BA15 for standard partitions and ceilings, Knauf Diamant for high-performance acoustics, Placo Phonique for ETVs and hotels, Glasroc H Ocean for humid environments near the coast, fire-resistant boards (CTE-DB-SI) for premises and hotel corridors, and Rockwool or Isover mineral wool for acoustic and thermal insulation (CTE-HR and CTE-HE compliant).',
  seoH3d: 'Warranty and CTE compliance',
  seoH3dP: 'Every project carries a 1-year workmanship warranty, combined with the 10-25 year manufacturer warranty from Placo, Knauf and Lafarge. All works are certified against the Spanish Building Code: CTE-HR (acoustic), CTE-DB-SI (fire) and CTE-HE (thermal). Dry construction also means up to 80% less waste than traditional wet works (in line with RD 105/2008). See our <a href="/en/precios-pladur-menorca">drywall price list for Menorca</a> for indicative per-m² rates by system.',
  seoBtn: 'Request a free quote',
  sidebarBadge: 'Key figures',
  sidebarStats: [
    { valor: '6,000+', label: 'Projects completed' },
    { valor: 'Since 2004', label: 'Years of experience' },
    { valor: '1 year', label: 'Warranty included' },
    { valor: '8/8', label: 'Menorca covered' },
  ],
  sidebarCta: 'Request a free quote',
  faqTitle: 'Frequently asked questions about our projects',
  faqSubtitle: 'Common questions about timelines, coverage and examples of work delivered in Menorca.',
  ctaTitle: 'Like what you see? Your project could be next',
  ctaSubtitle: 'Free fixed-price quote, no obligation. On-site survey anywhere in Menorca.',
  relatedBadge: 'You may also like',
  relatedTitle: 'Related services',
  relatedLinks: [
    { href: '/en/instalacion-pladur-menorca', label: 'Drywall Installation in Menorca', descripcion: 'Everything about our drywall installation services on the island.' },
    { href: '/en/falsos-techos-pladur-menorca', label: 'Drywall False Ceilings', descripcion: 'Flat, decorative and insulated ceilings for all kinds of spaces.' },
    { href: '/en/tabiques-pladur-menorca', label: 'Drywall Partitions', descripcion: 'Redesign your home or premises with fast, clean drywall partitions.' },
    { href: '/en/aislamiento-termico-menorca', label: 'Thermal Insulation', descripcion: 'Improve your home\'s energy efficiency with insulating wall linings.' },
    { href: '/en/precios-pladur-menorca', label: 'Drywall Prices in Menorca', descripcion: 'See our rates and indicative prices per m².' },
    { href: '/en/reformas-interiores-pladur-menorca', label: 'Interior Renovations', descripcion: 'Full drywall renovations for homes, offices and premises.' },
  ],
  srOnly: 'Pladur Menorca — project gallery: false ceilings, partitions, acoustic and thermal insulation. 6,000+ projects completed since 2004 in Maó, Sant Lluís, Es Castell, Ferreries, Es Mercadal and all 8 Menorca municipalities. Phone: +34 627 829 723.',
  breadcrumbHome: 'Home',
  breadcrumbProjects: 'Projects',
  statLabelProjects: 'Projects completed',
  statLabelYears: 'Years of experience',
  statLabelWarranty: 'Warranty included',
  statLabelCoverage: 'Menorca covered',
} : {
  heroTitle: 'Galería de Proyectos de Pladur en Menorca — 6.000+ Obras desde 2004',
  heroDescription: 'Pladur Menorca acumula 6.000+ obras de pladur desde 2004: pisos (40-120 m²), villas (150-500 m²), hoteles (60-300 habitaciones), oficinas y ETV en los 8 municipios de Menorca.',
  heroBadges: ['6.000+ Obras', 'Desde 2004', '8 Municipios'],
  ctaPrimary: 'Pedir presupuesto gratis',
  ctaSecondary: `Llamar: ${siteConfig.phone}`,
  featuredBadge: 'Casos reales',
  featuredTitle: 'Proyectos destacados con detalle técnico',
  proyectos: [
    {
      image: '/images/proyectos/reforma-integral-piso.webp',
      imageAlt: 'Reforma integral de piso de 85 m² con pladur en Baleares',
      title: 'Reforma integral con pladur — Piso 85 m² en Baleares',
      location: 'Baleares',
      description: 'Piso de 85 m²: 6 tabiques Placo BA13 con lana de roca Rockwool 48 mm (reducción de 47 dBA), 3 falsos techos con LED empotrado y trasdosado térmico en fachada norte. Ejecución en 8 días laborables con acabado Q3. Garantía de 1 año de mano de obra más garantía de fabricante Placo/Knauf (10-25 años).',
      stats: [{ value: '85 m²', label: 'Superficie' }, { value: '8 días', label: 'Duración' }, { value: '12.800€', label: 'Inversión' }],
      tags: ['Tabiques', 'Falsos techos', 'Aislamiento'],
    },
    {
      image: '/images/proyectos/aislamiento-acustico-apartamento-turistico.webp',
      imageAlt: 'Insonorización con Placo Phonique en apartamento turístico ETV de 60 m² en Baleares',
      title: 'Aislamiento acústico — ETV 60 m² en Baleares',
      location: 'Baleares',
      description: 'Apartamento turístico ETV de 60 m²: trasdosados con placa Placo Phonique y lana de roca Rockwool 48 mm en medianeras (52 dBA de reducción, conforme a CTE-HR), falso techo acústico con suspensión antivibratoria. Obra ejecutada en 5 días para evitar huecos en temporada alta. La valoración media en plataformas pasó de 7,2 a 9,1.',
      stats: [{ value: '60 m²', label: 'Superficie' }, { value: '5 días', label: 'Duración' }, { value: '52 dBA', label: 'Reducción' }],
      tags: ['Aislamiento acústico', 'Turístico'],
    },
    {
      image: '/images/proyectos/oficina-open-space-tabiques.webp',
      imageAlt: 'Compartimentación de oficina open space con tabiques Knauf Diamant en Baleares',
      title: 'Compartimentación oficina open space — 120 m² en Baleares',
      location: 'Baleares',
      description: 'Nave diáfana de 120 m² convertida en 4 despachos privados, sala de reuniones y zona de recepción. Tabiques con doble placa Knauf Diamant y lana mineral Isover para aislamiento acústico de 45 dBA entre despachos. Falso techo registrable para acceso a climatización, eléctrica y datos. Ejecución en 6 días laborables sin afectar a locales colindantes.',
      stats: [{ value: '120 m²', label: 'Superficie' }, { value: '6 días', label: 'Duración' }, { value: '9.600€', label: 'Inversión' }],
      tags: ['Tabiques', 'Oficinas'],
    },
    {
      image: '/images/proyectos/salon-falso-techo-villa.webp',
      imageAlt: 'Falsos techos continuos Placo BA13 con cornisa LED en villa de Baleares',
      title: 'Falsos techos con LED integrado — Villa 200 m² en Baleares',
      location: 'Baleares',
      description: 'Villa de lujo de 200 m²: falsos techos continuos Placo BA13 con cornisa perimetral LED empotrada en salón, comedor y 4 dormitorios. Acabado Q4 preparado para pintura mate premium, integración de climatización por conductos y cortineros ocultos. Obra de 10 días coordinada con interiorista e instalador de climatización.',
      stats: [{ value: '200 m²', label: 'Superficie' }, { value: '10 días', label: 'Duración' }, { value: 'Q4', label: 'Acabado' }],
      tags: ['Falsos techos', 'LED integrado'],
    },
  ],
  seoEyebrow: 'Nuestra trayectoria',
  seoH2: '6.000+ Proyectos de Pladur en Menorca desde 2004',
  seoP1: 'Pladur Menorca (Plaquistas y Acabados SL) ha ejecutado más de 6.000 obras de pladur y yeso laminado en Menorca desde 2004. Plazos tipo: un falso techo de 50 m² en 1-2 días laborables, un piso completo en 1-2 semanas y un hotel de 120 habitaciones en 8-10 semanas. Cada obra se cierra a precio fijo con 1 año de garantía de mano de obra, sumados a la garantía de fabricante de 10-25 años de Placo, Knauf y Lafarge.',
  seoH3a: 'Proyectos en todo tipo de espacios',
  seoH3aP: 'Realizamos pladur en pisos (40-120 m²), villas (150-500 m²), apartamentos turísticos ETV, locales comerciales, oficinas profesionales y hoteles de 3 a 5 estrellas (60-300 habitaciones). Casos habituales: reformas integrales en Santa Catalina o Portixol (Maó), acondicionamiento acústico de ETV en Sant Lluís y Es Castell, y obras por fases en hoteles de Son Bou y Cala Galdana. Nuestros servicios de <a href="/instalacion-pladur-menorca">instalación de pladur</a> cubren <a href="/falsos-techos-pladur-menorca">falsos techos</a>, tabiques divisorios, trasdosados con aislamiento térmico y acústico, y acabados decorativos Q2-Q4.',
  seoH3b: 'Cobertura en los 8 municipios de Menorca',
  seoH3bP: 'Trabajamos en los 8 municipios de la isla. Zonas de alto volumen: Maó (Santa Catalina, Portixol, Son Parc), Sant Lluís (Binibeca Vell, Punta Prima, Cala en Bosc), Es Castell, Ferreries, Es Mercadal (Son Parc, Arenal d\'en Castell), además de Alaior, Ciutadella, Es Migjorn Gran, Son Bou, Fornells y Cala Galdana. Cobertura en toda la isla con presupuesto cerrado y logística incluida de forma transparente.',
  seoH3c: 'Sistemas y materiales representativos',
  seoH3cP: 'Solo instalamos materiales de Placo (Saint-Gobain), Knauf y Lafarge, con marcado CE y ficha técnica completa. Sistemas recurrentes: Placo BA13/BA15 para tabiques y techos estándar, Knauf Diamant para acústica de alta exigencia, Placo Phonique para ETV y hoteles, Glasroc H Ocean en ambientes húmedos junto al mar, placas ignífugas (CTE-DB-SI) para locales y pasillos de hotel, y lana mineral Rockwool o Isover para aislamiento acústico y térmico (CTE-HR y CTE-HE).',
  seoH3d: 'Garantía y cumplimiento CTE',
  seoH3dP: 'Cada obra incluye 1 año de garantía de mano de obra, combinados con la garantía de fabricante de 10-25 años de Placo, Knauf y Lafarge. Todos los trabajos se certifican conforme al Código Técnico de la Edificación: CTE-HR (acústica), CTE-DB-SI (incendios) y CTE-HE (térmica). La construcción en seco genera además hasta un 80% menos de residuos que la obra tradicional (RD 105/2008). Consulta nuestra <a href="/precios-pladur-menorca">tabla de precios de pladur en Menorca</a> para ver tarifas orientativas por m² de cada sistema.',
  seoBtn: 'Solicitar presupuesto gratuito',
  sidebarBadge: 'Cifras clave',
  sidebarStats: [
    { valor: '6.000+', label: 'Proyectos completados' },
    { valor: 'Desde 2004', label: 'Años de experiencia' },
    { valor: '1 año', label: 'Garantía incluida' },
    { valor: '8/8', label: 'Menorca cubierta' },
  ],
  sidebarCta: 'Pedir presupuesto gratis',
  faqTitle: 'Preguntas frecuentes sobre nuestros proyectos',
  faqSubtitle: 'Dudas habituales sobre plazos, cobertura y ejemplos de trabajos realizados en Menorca.',
  ctaTitle: '¿Te gusta lo que ves? Tu proyecto puede ser el siguiente',
  ctaSubtitle: 'Presupuesto cerrado gratuito y sin compromiso. Visita técnica en toda Menorca.',
  relatedBadge: 'También te puede interesar',
  relatedTitle: 'Servicios relacionados',
  relatedLinks: [
    { href: '/instalacion-pladur-menorca', label: 'Instalación de Pladur en Menorca', descripcion: 'Todo sobre nuestros servicios de instalación de pladur en la isla.' },
    { href: '/falsos-techos-pladur-menorca', label: 'Falsos Techos de Pladur', descripcion: 'Techos lisos, decorativos y con aislamiento para todo tipo de espacios.' },
    { href: '/tabiques-pladur-menorca', label: 'Tabiques de Pladur', descripcion: 'Redistribuye tu vivienda o local con tabiques de pladur rápidos y limpios.' },
    { href: '/aislamiento-termico-menorca', label: 'Aislamiento Térmico', descripcion: 'Mejora la eficiencia energética de tu vivienda con trasdosados aislantes.' },
    { href: '/precios-pladur-menorca', label: 'Precios de Pladur en Menorca', descripcion: 'Consulta nuestras tarifas y precios orientativos por m².' },
    { href: '/reformas-interiores-pladur-menorca', label: 'Reformas Interiores', descripcion: 'Reformas integrales con pladur para viviendas, oficinas y locales.' },
  ],
  srOnly: 'Pladur Menorca — galería de proyectos: falsos techos, tabiques, aislamiento acústico y térmico. 6.000+ obras desde 2004 en Maó, Sant Lluís, Es Castell, Ferreries, Es Mercadal y los 8 municipios de Menorca. Tel: 627 829 723.',
  breadcrumbHome: 'Inicio',
  breadcrumbProjects: 'Proyectos',
  statLabelProjects: 'Proyectos completados',
  statLabelYears: 'Años de experiencia',
  statLabelWarranty: 'Garantía incluida',
  statLabelCoverage: 'Menorca cubierta',
}

const meta = lang === 'en' ? {
  title: '6,000+ Drywall Projects in Menorca since 2004 | Gallery',
  description: 'Real gallery of 6,000+ drywall projects in Menorca since 2004: apartments, villas, hotels, offices and ETV rentals. Placo, Knauf, Lafarge systems.',
  canonical: '/en/proyectos',
  alternateEs: '/proyectos',
} : {
  title: '6.000+ Proyectos de Pladur en Menorca desde 2004 | Galería',
  description: 'Galería real de 6.000+ obras de pladur en Menorca desde 2004: pisos, villas, hoteles, oficinas y ETV. Sistemas Placo, Knauf, Lafarge con garantía 1 año.',
  canonical: '/proyectos',
  alternateEn: '/en/proyectos',
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en/' : '/' }, { label: t.breadcrumbProjects, href: lang === 'en' ? '/en/proyectos' : '/proyectos' }]} />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">
    {t.srOnly}
  </p>

  <Hero
    dark
    title={t.heroTitle}
    description={t.heroDescription}
    badges={t.heroBadges}
    ctaPrimario={{ texto: t.ctaPrimary, href: p('/presupuesto-pladur') }}
    ctaSecundario={{ texto: t.ctaSecondary, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <GalleryMasonry client:visible items={galleryItems} />

  <!-- Proyectos destacados con microdata -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">{t.featuredBadge}</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">{t.featuredTitle}</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-14 stagger-children">
        {t.proyectos.map((proyecto) => (
          <article
            itemscope
            itemtype="https://schema.org/CreativeWork"
            class="group flex flex-col"
          >
            <!-- Imagen editorial, sin marco ni sombras -->
            <div class="relative overflow-hidden rounded-2xl mb-6 aspect-[4/3] bg-warm-100">
              <Image
                itemprop="image"
                src={proyecto.image}
                alt={proyecto.imageAlt}
                width={800}
                height={600}
                class="w-full h-full object-cover transition-transform duration-[800ms] ease-out group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>

            <meta itemprop="locationCreated" content={proyecto.location} />

            <!-- Meta row: ubicación + stats separados por midots -->
            <div class="flex items-center flex-wrap gap-x-2 gap-y-1 text-[11px] uppercase tracking-[0.15em] text-muted font-semibold mb-3">
              <span>{proyecto.location.split(',')[0]}</span>
              {proyecto.stats.map((stat) => (
                <>
                  <span class="text-warm-border select-none" aria-hidden="true">·</span>
                  <span class="tabular-nums">{stat.value} <span class="font-medium opacity-70">{stat.label}</span></span>
                </>
              ))}
            </div>

            <!-- Título grande, tipografía primero -->
            <h3 itemprop="name" class="text-xl lg:text-2xl font-semibold text-foreground leading-tight tracking-tight mb-3 group-hover:text-foreground-dark transition-colors duration-300">
              {proyecto.title}
            </h3>

            <!-- Descripción -->
            <p itemprop="description" class="text-[15px] text-muted leading-relaxed mb-5">
              {proyecto.description}
            </p>

            <!-- Tags inline como texto, sin chips -->
            <p class="text-xs text-muted/80 mt-auto flex flex-wrap gap-x-2 gap-y-1">
              {proyecto.tags.map((tag, i) => (
                <>
                  <span>{tag}</span>
                  {i < proyecto.tags.length - 1 && <span class="text-warm-border select-none" aria-hidden="true">·</span>}
                </>
              ))}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Texto SEO -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8">
          <span class="animate-fade-up inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
            {t.seoEyebrow}
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">
            {t.seoH2}
          </h2>

          <div class="prose-pladur max-w-prose">
            <p>{t.seoP1}</p>

            <h3>{t.seoH3a}</h3>
            <p set:html={t.seoH3aP}></p>

            <h3>{t.seoH3b}</h3>
            <p>{t.seoH3bP}</p>

            <h3>{t.seoH3c}</h3>
            <p>{t.seoH3cP}</p>

            <h3>{t.seoH3d}</h3>
            <p set:html={t.seoH3dP}></p>
          </div>

          <div class="mt-10">
            <Button href={p('/presupuesto-pladur')} variant="primary" size="lg" withArrow>
              {t.seoBtn}
            </Button>
          </div>
        </div>

        <div class="lg:col-span-4">
          <div class="sticky top-28">
            <div class="bg-white/70 rounded-3xl border border-warm-border/50 shadow-card relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-0.5 bg-foreground-dark"></div>
              <div class="p-7">
                <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-6">{t.sidebarBadge}</span>
                <div class="space-y-5">
                  {t.sidebarStats.map((stat) => (
                    <div class="flex items-center gap-4 border-b border-warm-border/50 pb-5 last:border-0 last:pb-0">
                      <div class="size-11 shrink-0 rounded-xl bg-surface border border-nav-border flex items-center justify-center text-foreground">
                        {stat.label === t.statLabelProjects && (
                          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                          </svg>
                        )}
                        {stat.label === t.statLabelYears && (
                          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                          </svg>
                        )}
                        {stat.label === t.statLabelWarranty && (
                          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                          </svg>
                        )}
                        {stat.label === t.statLabelCoverage && (
                          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                          </svg>
                        )}
                      </div>
                      <div>
                        <span class="block text-2xl font-bold text-foreground-dark leading-tight">{stat.valor}</span>
                        <span class="text-sm text-muted">{stat.label}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="border-t border-warm-border/50 px-7 py-5">
                <Button href={p('/presupuesto-pladur')} variant="primary" size="md" block withArrow>
                  {t.sidebarCta}
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FaqAccordion
    client:visible
    lang={lang}
    faqs={pageFaqs}
    titulo={t.faqTitle}
    subtitulo={t.faqSubtitle}
  />

  <CtaBanner
    lang={lang}
    titulo={t.ctaTitle}
    subtitulo={t.ctaSubtitle}
    showForm={true}
  />

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">{t.relatedBadge}</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight">
          {t.relatedTitle}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {t.relatedLinks.map((link) => (
          <a
            href={link.href}
            class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
          >
            <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
            <p class="text-muted text-sm mb-4">{link.descripcion}</p>
            <div class="h-0.5 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-0 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
