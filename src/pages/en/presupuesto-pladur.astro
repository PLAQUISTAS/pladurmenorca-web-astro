---
export const prerender = true
import type { Lang } from '@/i18n'
import BaseLayout from '@/layouts/BaseLayout.astro'
import TestimonioCard from '@/components/ui/TestimonioCard.astro'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton.astro'
import CookieBanner from '@/components/layout/CookieBanner.astro'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import FormPresupuesto from '@/components/forms/FormPresupuesto'
import { testimonios } from '@/data/testimonios'
import { siteConfig } from '@/data/site'
import { getPresupuestoFaqs } from '@/data/faqs/presupuesto'

const lang = (Astro.currentLocale ?? 'es') as Lang
const faqsPresupuesto = getPresupuestoFaqs(lang)

const miniTestimonios = testimonios.slice(0, 3)

const t = lang === 'en' ? {
  heroBadges: ['No obligation', 'Reply 24-48h', 'Coverage across Menorca'],
  heroTitle: 'Free Drywall Quote in Menorca — Written Reply in 24-48h',
  heroDescription: 'Plaquistas y Acabados SL delivers a free, itemised drywall quote in 24-48h with Placo, Knauf or Lafarge boards, labour and waste management included; VAT 21% apart, valid 30 days.',
  formTitle: 'Tell us about your drywall project',
  formDescription: 'Fill in the form with m², service and location. We review it from our Mallorca office and send your fixed, itemised quote in under 24h.',
  directContact: 'Direct contact',
  hoursShort: 'Mon-Fri 8:00-18:00 · Sat 8:00-14:00',
  callNow: 'Call now',
  whatsappLabel: 'Message on WhatsApp',
  whatsappAria: 'Contact via WhatsApp',
  trustBlockTitle: 'Why trust us',
  badges: [
    { label: 'Drywall specialists since 2004', icon: 'calendar' },
    { label: '6,000+ drywall projects delivered', icon: 'check' },
    ...(siteConfig.aggregateRating ? [{ label: `${siteConfig.aggregateRating.ratingValue}/5 on Google`, icon: 'star' }] : []),
    { label: 'Fixed price, VAT itemised', icon: 'lock' },
    { label: '1-year workmanship warranty', icon: 'shield' },
  ],
  quickFaqsHeading: 'Quick answers',
  manifestoBadge: 'Our commitment',
  manifestoTitle: 'Why ask Pladur Menorca for your quote',
  manifestoFreeTitle: 'Free and no-obligation',
  manifestoFreeRich: 'The drywall quote is completely <strong class="text-foreground">free</strong> and <strong class="text-foreground">no-obligation</strong>. A specialist visits the property to measure, assess the conditions of the space and answer your questions anywhere in Menorca (Maó, Ciutadella, Alaior, Es Mercadal, Ferreries, Sant Lluís, Es Castell, Es Migjorn Gran and the rest of the island). Our parent company is based in Mallorca, so project logistics (crew travel and materials transport) are factored transparently into the fixed quote from the first line — the price you see is the price you pay.',
  manifestoVisitTitle: 'On-site visit',
  manifestoVisitRich: 'We do not quote by phone or from photos. A reliable drywall quote can only be prepared after inspecting the space <strong class="text-foreground">in person</strong>. A specialist from Plaquistas y Acabados SL measures, photographs the existing structure and assesses every variable that affects the final price: surface, height, state of the support, CW/UW profile type, insulation needed and access for materials.',
  manifestoFixedTitle: 'Fixed price, VAT itemised',
  manifestoFixedRich: 'Once accepted, the price is the price. <strong class="text-foreground">No extras or hidden costs</strong> at delivery. The quote lists materials (Placo, Knauf or Lafarge board plus insulation), labour, waste management and execution time; VAT (21%) is shown separately and the offer is valid for 30 days. Any unforeseen issue is communicated immediately and agreed in writing before proceeding.',
  reviewsBadge: 'What our clients say',
  reviewsTitle: 'Verified Google reviews',
  leaveReview: 'Leave us a review on Google',
  processBadge: 'The process',
  processH2: 'How our drywall quote works: 5 steps',
  processBody: 'Getting a drywall quote from Pladur Menorca takes 5 steps: (1) you submit the form, call 627 829 723 or WhatsApp; (2) we schedule an on-site visit anywhere in Menorca within 24-72h; (3) a specialist measures and assesses the space in person; (4) we send the itemised quote within 24-48h of the visit; (5) once accepted, we agree a start date and execute the work with a 1-year warranty. Urgent cases (tourist licences before season) are quoted in 24h.',
  includesH2: 'What is included in the quote',
  includesBody: 'Each Pladur Menorca quote lists, line by line: boards (brand and model — Placo, Knauf or Lafarge — with thickness and format), CW/UW profilework, insulation (mineral wool, XPS or acoustic), labour itemised by unit, waste management, estimated execution time and a 1-year workmanship warranty. VAT (21%) is shown separately and the offer is valid for 30 days. The quoted price is the final price.',
  includesQuote: '"According to the Col·legi d\'Aparelladors de les Illes Balears, a detailed quote must include description of work units, measurements, unit prices and execution timeframe"',
  includesQuoteSource: '— Col·legi d\'Aparelladors de les Illes Balears',
  faqsH2: 'Frequently asked questions on quotes',
  faqQ1: 'Is the drywall quote really free?',
  faqA1: 'Yes. The quote is 100% free and no-obligation anywhere in Menorca. If you go ahead with the work, project logistics (crew travel and materials transport from our Mallorca base) are reflected transparently inside the fixed quote — there are no surprise charges at the end.',
  faqQ2: 'How long does it take to receive the quote?',
  faqA2: '24-48 hours from the site visit. Urgent cases (for example tourist licences before season) can be quoted in 24h if the visit is arranged the same day.',
  faqQ3: 'Is the quote price fixed and does it include VAT?',
  faqA3: 'The quote is closed: materials, labour and waste management are included at a fixed price, and VAT (21%) is itemised separately. The offer is valid for 30 days; only client-requested changes during the work alter the final amount.',
  relatedBadge: 'You may also like',
  relatedLinks: [
    { href: '/en/falsos-techos-pladur-menorca', label: 'Drywall False Ceilings', descripcion: 'Continuous, decorative, accessible and acoustic ceilings' },
    { href: '/en/tabiques-pladur-menorca', label: 'Drywall Partitions', descripcion: 'Fast, clean space layout with no building work' },
    { href: '/en/aislamiento-acustico-menorca', label: 'Soundproofing', descripcion: 'Noise reduction between homes and commercial premises' },
    { href: '/en/reformas-interiores-pladur-menorca', label: 'Interior Renovations', descripcion: 'Full renovations of homes and premises with drywall' },
    { href: '/en/precios-pladur-menorca', label: 'Drywall Prices in Menorca', descripcion: 'See our rates and indicative prices per m²' },
    { href: '/en/instalacion-pladur-menorca', label: 'Drywall Installation', descripcion: 'Everything about our drywall installation services' },
    { href: '/en/pladur-mao', label: 'Drywall in Maó', descripcion: 'Specialists across every district of Maó' },
    { href: '/en/pladur-sant-lluis', label: 'Drywall in Sant Lluís — Punta Prima, Binibeca Vell, S\'Algar and more', descripcion: 'Cala en Bosc, Son Xoriguer, Cala Santandria and Punta Prima' },
    { href: '/en/pladur-apartamentos-turisticos-menorca', label: 'Holiday Apartments', descripcion: 'Quick refurbishment between seasons across Menorca' },
  ],
  srOnly: 'Pladur Menorca (Plaquistas y Acabados SL). Office in Mallorca (SL matriz since 2004). Service across all Menorca. Free drywall quote in Menorca delivered in 24-48h after an on-site visit. Fixed price with Placo, Knauf or Lafarge boards, labour and waste management; VAT 21% itemised; valid 30 days. Phone +34 627 829 723. Email info@plaquistas.com. Drywall specialists since 2004.',
  breadcrumbHome: 'Home',
  breadcrumbQuote: 'Drywall Quote',
} : {
  heroBadges: ['Sin compromiso', 'Respuesta 24-48h', 'Cobertura en toda Menorca'],
  heroTitle: 'Presupuesto Pladur gratis en Menorca — Respuesta por escrito en 24-48h',
  heroDescription: 'Plaquistas y Acabados SL entrega un presupuesto gratuito y desglosado en 24-48h con placas Placo, Knauf o Lafarge, mano de obra y gestión de residuos incluidos; IVA 21% aparte y validez de 30 días.',
  formTitle: 'Cuéntanos tu proyecto de pladur',
  formDescription: 'Rellena el formulario indicando m², servicio y ubicación. Lo revisamos desde nuestra oficina en Mallorca y te enviamos el presupuesto cerrado y desglosado en menos de 24h.',
  directContact: 'Contacto directo',
  hoursShort: 'L–V 8:00–18:00 · Sáb 8:00–14:00',
  callNow: 'Llamar ahora',
  whatsappLabel: 'Escribir por WhatsApp',
  whatsappAria: 'Contactar por WhatsApp',
  trustBlockTitle: 'Por qué confiar en nosotros',
  badges: [
    { label: 'Especialistas en pladur desde 2004', icon: 'calendar' },
    { label: '6.000+ obras de pladur entregadas', icon: 'check' },
    ...(siteConfig.aggregateRating ? [{ label: `${siteConfig.aggregateRating.ratingValue}/5 en Google`, icon: 'star' }] : []),
    { label: 'Precio cerrado con IVA desglosado', icon: 'lock' },
    { label: 'Garantía de mano de obra 1 año', icon: 'shield' },
  ],
  quickFaqsHeading: 'Dudas rápidas',
  manifestoBadge: 'Nuestro compromiso',
  manifestoTitle: 'Por qué pedirnos el presupuesto de pladur',
  manifestoFreeTitle: 'Gratis y sin compromiso',
  manifestoFreeRich: 'El presupuesto de pladur es completamente <strong class="text-foreground">gratuito</strong> y <strong class="text-foreground">sin compromiso</strong>. Un técnico se desplaza a tu propiedad para medir, evaluar las condiciones del espacio y resolver tus dudas en cualquier punto de Menorca (Maó, Ciutadella, Alaior, Es Mercadal, Ferreries, Sant Lluís, Es Castell, Es Migjorn Gran y resto de la isla). Nuestra SL matriz está en Mallorca, así que la logística de obra (desplazamiento del equipo y transporte de materiales) va reflejada de forma transparente dentro del presupuesto cerrado desde la primera línea: el precio que ves es el precio que pagas.',
  manifestoVisitTitle: 'Visita técnica',
  manifestoVisitRich: 'No hacemos presupuestos por teléfono ni a partir de fotos. El único presupuesto de pladur fiable se elabora tras inspeccionar el espacio <strong class="text-foreground">en persona</strong>. Un técnico de Plaquistas y Acabados SL mide, fotografía la estructura existente y evalúa todas las variables que afectan al precio final: superficie, altura, estado del soporte, tipo de perfilería CW/UW, aislamiento necesario y acceso de materiales.',
  manifestoFixedTitle: 'Precio cerrado con IVA desglosado',
  manifestoFixedRich: 'Una vez aceptado, el precio es el precio. <strong class="text-foreground">No añadimos extras ni costes ocultos</strong> al final de la obra. El presupuesto detalla materiales (placas Placo, Knauf o Lafarge y aislante), mano de obra, gestión de residuos y plazo de ejecución; el IVA (21%) figura desglosado y la oferta tiene validez de 30 días. Cualquier imprevisto relevante se comunica de inmediato y se acuerda por escrito antes de ejecutarlo.',
  reviewsBadge: 'Lo que dicen nuestros clientes',
  reviewsTitle: 'Reseñas verificadas en Google',
  leaveReview: 'Déjanos tu reseña en Google',
  processBadge: 'El proceso',
  processH2: 'Cómo funciona el presupuesto de pladur: 5 pasos',
  processBody: 'Obtener un presupuesto de pladur con Pladur Menorca requiere 5 pasos: (1) envías el formulario, llamas al 627 829 723 o escribes por WhatsApp; (2) programamos la visita técnica en cualquier punto de Menorca en 24-72h; (3) un técnico mide y evalúa el espacio en persona; (4) recibes el presupuesto desglosado en las 24-48h siguientes; (5) tras aceptarlo acordamos fecha de inicio y ejecutamos la obra con garantía de 1 año. En urgencias (licencias ETV antes de temporada) el presupuesto puede emitirse en 24h.',
  includesH2: 'Qué incluye el presupuesto',
  includesBody: 'Cada presupuesto de Pladur Menorca detalla, línea por línea: placas (marca y modelo — Placo, Knauf o Lafarge — con espesor y formato), perfilería CW/UW, aislante (lana mineral, XPS o acústico), mano de obra desglosada por partida, gestión de residuos, tiempo estimado de ejecución y garantía de 1 año sobre la mano de obra. El IVA (21%) se muestra aparte y la oferta tiene validez de 30 días. El precio presupuestado es el precio final.',
  includesQuote: '"Según el Colegio de Aparejadores de Baleares, un presupuesto detallado debe incluir descripción de unidades de obra, mediciones, precios unitarios y plazo de ejecución"',
  includesQuoteSource: '— Col·legi d\'Aparelladors de les Illes Balears',
  faqsH2: 'Preguntas frecuentes sobre presupuestos',
  faqQ1: '¿El presupuesto de pladur es realmente gratis?',
  faqA1: 'Sí. El presupuesto es 100% gratuito y sin compromiso en toda Menorca. Si finalmente se ejecuta la obra, la logística (desplazamiento del equipo y transporte de materiales desde nuestra SL matriz en Mallorca) queda reflejada de forma transparente dentro del presupuesto cerrado, sin cargos sorpresa al final.',
  faqQ2: '¿Cuánto tardan en darme el presupuesto?',
  faqA2: 'Entre 24 y 48 horas desde la visita técnica. En urgencias (por ejemplo, licencias ETV antes de temporada) se puede entregar en 24h si la visita se coordina el mismo día.',
  faqQ3: '¿El precio es cerrado e incluye IVA?',
  faqA3: 'El presupuesto es cerrado: materiales, mano de obra y gestión de residuos se entregan a precio fijo, y el IVA (21%) figura desglosado. La oferta tiene validez de 30 días; solo los cambios que el cliente solicite durante la obra modifican el importe final.',
  relatedBadge: 'También te puede interesar',
  relatedLinks: [
    { href: '/falsos-techos-pladur-menorca', label: 'Falsos Techos de Pladur', descripcion: 'Techos continuos, decorativos, registrables y acústicos' },
    { href: '/tabiques-pladur-menorca', label: 'Tabiques de Pladur', descripcion: 'Distribución de espacios rápida, limpia y sin obra' },
    { href: '/aislamiento-acustico-menorca', label: 'Aislamiento Acústico', descripcion: 'Reducción de ruido entre viviendas y locales' },
    { href: '/reformas-interiores-pladur-menorca', label: 'Reformas Interiores', descripcion: 'Reforma integral de viviendas y locales con pladur' },
    { href: '/precios-pladur-menorca', label: 'Precios de Pladur en Menorca', descripcion: 'Consulta nuestras tarifas y precios orientativos por m²' },
    { href: '/instalacion-pladur-menorca', label: 'Instalación de Pladur', descripcion: 'Todo sobre nuestros servicios de instalación de pladur' },
    { href: '/pladur-mao', label: 'Pladur en Maó', descripcion: 'Especialistas en todos los barrios de Maó' },
    { href: '/pladur-sant-lluis', label: 'Pladur en Sant Lluís', descripcion: 'Cala en Bosc, Son Xoriguer, Cala Santandria y Punta Prima' },
    { href: '/pladur-apartamentos-turisticos-menorca', label: 'Apartamentos Turísticos', descripcion: 'Reforma rápida entre temporadas en toda Menorca' },
  ],
  srOnly: 'Pladur Menorca (Plaquistas y Acabados SL). Oficina en Mallorca (SL matriz desde 2004). Servicio en toda Menorca. Presupuesto gratuito de pladur en Menorca entregado en 24-48h tras visita técnica. Precio cerrado con placas Placo, Knauf o Lafarge, mano de obra y gestión de residuos; IVA 21% desglosado; validez 30 días. Tel 627 829 723. Email info@plaquistas.com. Especialistas en pladur desde 2004.',
  breadcrumbHome: 'Inicio',
  breadcrumbQuote: 'Presupuesto Pladur',
}

const meta = lang === 'en' ? {
  title: 'Free Drywall Quote Menorca | Written Reply in 24-48h',
  description: 'Free drywall quote in Menorca by Plaquistas y Acabados SL. Fixed price with Placo/Knauf/Lafarge, VAT 21% apart, valid 30 days. Reply 24-48h, no obligation.',
  canonical: '/en/presupuesto-pladur',
  alternateEs: '/presupuesto-pladur',
} : {
  title: 'Presupuesto Pladur Menorca Gratis | Respuesta en 24-48h',
  description: 'Presupuesto de pladur gratis en Menorca por Plaquistas y Acabados SL. Precio cerrado Placo/Knauf/Lafarge, IVA 21% aparte, validez 30 días. Sin compromiso.',
  canonical: '/presupuesto-pladur',
  alternateEn: '/en/presupuesto-pladur',
}
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en/' : '/' }, { label: t.breadcrumbQuote, href: lang === 'en' ? '/en/presupuesto-pladur' : '/presupuesto-pladur' }]} />
    {faqsPresupuesto.length > 0 && <SchemaFAQ faqs={faqsPresupuesto} />}
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">
    {t.srOnly}
  </p>

  <!-- Hero -->
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white/70 border border-warm-border/50 rounded-3xl px-6 sm:px-10 lg:px-16 py-14 lg:py-20 relative overflow-hidden shadow-warm animate-fade-up">
        <div class="max-w-3xl text-center mx-auto">
          <div class="flex flex-wrap items-center justify-center gap-2 mb-8">
            {t.heroBadges.map((tag) => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-surface text-foreground border border-warm-border/60">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-foreground leading-tight text-balance mb-6">
            {t.heroTitle}
          </h1>
          <p class="text-xl text-muted leading-relaxed max-w-2xl mx-auto">
            {t.heroDescription}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Main grid: Form + Social Proof -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">

        <!-- LEFT: Form -->
        <div class="lg:col-span-7">
          <div class="bg-white rounded-2xl border border-warm-border p-8 lg:p-10 shadow-soft-lg">
            <h2 class="text-2xl font-bold text-foreground mb-2">
              {t.formTitle}
            </h2>
            <p class="text-muted text-sm mb-8">
              {t.formDescription}
            </p>
            <FormPresupuesto client:load />
          </div>
        </div>

        <!-- RIGHT: Social proof -->
        <div class="lg:col-span-5 space-y-6">

          <!-- Teléfono directo -->
          <div class="relative overflow-hidden rounded-3xl bg-foreground-dark p-8 text-white shadow-card">
            <div aria-hidden="true" class="pointer-events-none absolute -top-16 -right-16 size-40 rounded-full bg-white/[0.04] blur-3xl"></div>
            <div class="relative">
              <p class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60 mb-4">
                <span class="size-1.5 rounded-full bg-white/60 animate-pulse motion-reduce:animate-none"></span>
                {t.directContact}
              </p>
              <a href={`tel:${siteConfig.phoneRaw}`} class="block font-bold text-3xl sm:text-[34px] text-white mb-2 tracking-tight tabular-nums hover:opacity-90 transition-opacity">
                {siteConfig.phone}
              </a>
              <p class="text-[13px] text-white/55 mb-6">{t.hoursShort}</p>

              <div class="flex flex-col gap-2.5">
                <a
                  href={`tel:${siteConfig.phoneRaw}`}
                  class="group inline-flex items-center justify-between gap-3 rounded-xl border border-white/15 bg-white/5 hover:bg-white/10 hover:border-white/25 px-4 py-3 text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-foreground-dark"
                >
                  <span class="flex items-center gap-3">
                    <svg aria-hidden="true" class="size-4 text-white/80" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                    </svg>
                    <span class="text-sm font-bold">{t.callNow}</span>
                  </span>
                  <svg aria-hidden="true" class="size-4 text-white/60 group-hover:text-white group-hover:translate-x-0.5 transition-[color,transform] duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
                <a
                  href={`https://wa.me/${siteConfig.whatsapp}?text=${siteConfig.whatsappText}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={t.whatsappAria}
                  class="group inline-flex items-center justify-between gap-3 rounded-xl border border-white/15 bg-white/5 hover:bg-white/10 hover:border-white/25 px-4 py-3 text-white transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-foreground-dark"
                >
                  <span class="flex items-center gap-3">
                    <svg aria-hidden="true" class="size-4 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                    </svg>
                    <span class="text-sm font-bold">{t.whatsappLabel}</span>
                  </span>
                  <svg aria-hidden="true" class="size-4 text-white/60 group-hover:text-white group-hover:translate-x-0.5 transition-[color,transform] duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Badges de confianza -->
          <div class="bg-white rounded-2xl border border-warm-border p-6 shadow-soft">
            <p class="text-xs font-bold uppercase tracking-widest text-foreground mb-5">
              {t.trustBlockTitle}
            </p>
            <div class="space-y-3.5">
              {t.badges.map((badge) => (
                <div class="flex items-center gap-3">
                  <div class="shrink-0 w-9 h-9 bg-surface border border-nav-border rounded-xl flex items-center justify-center">
                    {badge.icon === 'star' && (
                      <svg class="size-4 text-foreground" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    )}
                    {badge.icon === 'check' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    )}
                    {badge.icon === 'calendar' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                    )}
                    {badge.icon === 'lock' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                    )}
                    {badge.icon === 'shield' && (
                      <svg class="size-4 text-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                    )}
                  </div>
                  <span class="text-sm font-semibold text-foreground">{badge.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Dudas rápidas -->
          <div class="rounded-3xl bg-white border border-warm-border/40 p-8 shadow-card">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground mb-6">
              {t.quickFaqsHeading}
            </p>
            <div class="divide-y divide-warm-border/60">
              {faqsPresupuesto.map((faq, i) => (
                <div class="py-4 first:pt-0 last:pb-0">
                  <p class="flex items-start gap-3 text-sm font-semibold text-foreground leading-snug mb-1.5">
                    <span class="shrink-0 inline-flex items-center justify-center size-5 rounded-full bg-surface border border-nav-border text-[10px] font-bold text-muted tabular-nums mt-0.5">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span>{faq.pregunta}</span>
                  </p>
                  <p class="text-xs text-muted leading-relaxed pl-8">{faq.respuesta}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Por qué pedirnos presupuesto -->
  <section class="py-20 lg:py-28">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      {/* Header */}
      <div class="text-center mb-14 lg:mb-16 animate-fade-up">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.manifestoBadge}
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance max-w-2xl mx-auto">
          {t.manifestoTitle}
        </h2>
      </div>

      {/* Manifesto card */}
      <div class="relative rounded-3xl border border-warm-border/60 bg-white shadow-card overflow-hidden">
        <ul class="divide-y divide-warm-border/60">

          <li class="group flex flex-col sm:flex-row gap-5 sm:gap-8 p-8 lg:p-10 transition-colors duration-300 hover:bg-surface/30">
            <div class="flex items-center gap-4 sm:gap-5 sm:w-60 shrink-0">
              <span class="flex size-11 items-center justify-center rounded-2xl bg-surface border border-nav-border text-foreground group-hover:bg-foreground-dark group-hover:border-foreground-dark group-hover:text-white transition-colors duration-300">
                <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                </svg>
              </span>
              <h3 class="text-base lg:text-lg font-bold text-foreground leading-snug">
                {t.manifestoFreeTitle}
              </h3>
            </div>
            <p class="text-sm text-muted leading-relaxed flex-1 max-w-2xl" set:html={t.manifestoFreeRich}></p>
          </li>

          <li class="group flex flex-col sm:flex-row gap-5 sm:gap-8 p-8 lg:p-10 transition-colors duration-300 hover:bg-surface/30">
            <div class="flex items-center gap-4 sm:gap-5 sm:w-60 shrink-0">
              <span class="flex size-11 items-center justify-center rounded-2xl bg-surface border border-nav-border text-foreground group-hover:bg-foreground-dark group-hover:border-foreground-dark group-hover:text-white transition-colors duration-300">
                <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </span>
              <h3 class="text-base lg:text-lg font-bold text-foreground leading-snug">
                {t.manifestoVisitTitle}
              </h3>
            </div>
            <p class="text-sm text-muted leading-relaxed flex-1 max-w-2xl" set:html={t.manifestoVisitRich}></p>
          </li>

          <li class="group flex flex-col sm:flex-row gap-5 sm:gap-8 p-8 lg:p-10 transition-colors duration-300 hover:bg-surface/30">
            <div class="flex items-center gap-4 sm:gap-5 sm:w-60 shrink-0">
              <span class="flex size-11 items-center justify-center rounded-2xl bg-surface border border-nav-border text-foreground group-hover:bg-foreground-dark group-hover:border-foreground-dark group-hover:text-white transition-colors duration-300">
                <svg aria-hidden="true" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                </svg>
              </span>
              <h3 class="text-base lg:text-lg font-bold text-foreground leading-snug">
                {t.manifestoFixedTitle}
              </h3>
            </div>
            <p class="text-sm text-muted leading-relaxed flex-1 max-w-2xl" set:html={t.manifestoFixedRich}></p>
          </li>

        </ul>
      </div>
    </div>
  </section>

  <!-- Testimonios mini -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">
          {t.reviewsBadge}
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance">
          {t.reviewsTitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {miniTestimonios.map((testimonio) => (
          <TestimonioCard testimonio={testimonio} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href={siteConfig.googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-white border-2 border-warm-border hover:border-google hover:shadow-google text-foreground font-bold text-sm tracking-wide transition-[border-color,box-shadow,transform] duration-300 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-google focus-visible:ring-offset-2"
        >
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          {t.leaveReview}
          <svg class="size-4 text-muted group-hover:text-google group-hover:translate-x-0.5 transition-[color,transform]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Cómo funciona + qué incluye -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto space-y-12">

        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">{t.processBadge}</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">{t.processH2}</h2>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>{t.processBody}</p>
          </div>
        </div>

        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">{t.includesH2}</h2>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>{t.includesBody}</p>
            <blockquote class="border-l-4 border-foreground/20 pl-5 my-6 italic text-muted">
              <p>{t.includesQuote}</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">{t.includesQuoteSource}</cite>
            </blockquote>
          </div>
        </div>

        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight text-balance mb-6">{t.faqsH2}</h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">{t.faqQ1}</h3>
              <p class="text-muted leading-relaxed">{t.faqA1}</p>
            </div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">{t.faqQ2}</h3>
              <p class="text-muted leading-relaxed">{t.faqA2}</p>
            </div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">{t.faqQ3}</h3>
              <p class="text-muted leading-relaxed">{t.faqA3}</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Enlazado interno -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-8">{t.relatedBadge}</span>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {t.relatedLinks.map((link) => (
          <a
            href={link.href}
            class="group block bg-white/70 rounded-3xl border border-warm-border/50 p-7 shadow-soft hover:shadow-soft-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-foreground focus-visible:ring-offset-2"
          >
            <h3 class="font-bold text-foreground text-base mb-1">{link.label}</h3>
            <p class="text-muted text-sm mb-4">{link.descripcion}</p>
            <div class="h-0.5 bg-warm-border rounded-full overflow-hidden">
              <div class="h-full w-0 bg-foreground-dark group-hover:w-full transition-[width] duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer lang={lang} slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
