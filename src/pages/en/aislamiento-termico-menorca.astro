const pagePathBase = lang === 'en' ? '/en/aislamiento-termico-menorca' : '/aislamiento-termico-menorca'
const urlBase = `https://www.pladurmenorca.com${pagePathBase}`
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: t.breadcrumbHome, href: lang === 'en' ? '/en/' : '/' }, { label: t.breadcrumbCurrent, href: pagePathBase }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService name={servicio.schema.name} description={servicio.schema.description} serviceType={servicio.schema.serviceType} url={urlBase} image="https://www.pladurmenorca.com/images/proyectos/detalle-perfileria-aislamiento-pladur.webp" />
    <SchemaHowTo name={t.howToName} description={t.howToDescription} totalTime="PT24H" steps={t.howToSteps} />
    <SchemaOffers offers={t.offers} />
  </Fragment>

  <Header slot="header" lang={lang} alternateHref={lang === 'en' ? meta.alternateEs : meta.alternateEn} />

  <p class="sr-only" aria-hidden="false">{t.srOnly}</p>

  <!-- Hero -->
  <Hero title={t.heroTitle} subtitle={t.heroSubtitle} description={t.heroDescription} dark={true} badges={t.heroBadges} ctaPrimario={{ texto: t.ctaPrimarioHero, href: p('/presupuesto-pladur') }} ctaSecundario={{ texto: `${t.ctaLlamar}: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }} />

  <!-- El clima de Menorca y el aislamiento -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.secContext}</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">{t.secContextH2}</h2>
          </div>
          <div class="space-y-7 text-muted leading-relaxed">
            <p class="text-lg">{t.ctxP1}</p>

            {/* Climate zone strip */}
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-warm-border/50 rounded-3xl overflow-hidden border border-warm-border/50">
              {[
                { k: lang === 'en' ? 'Climate zone' : 'Zona climática', v: 'B3 (CTE-HE)' },
                { k: lang === 'en' ? 'Summer peak' : 'Verano pico', v: '32–35 °C' },
                { k: 'U máx.', v: '0,38 W/m²K' },
                { k: lang === 'en' ? 'AC savings' : 'Ahorro A/C', v: '20–30 %' },
              ].map((s) => (
                <div class="bg-white/80 px-4 py-5 text-center">
                  <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted/80 mb-1">{s.k}</p>
                  <p class="text-sm font-bold text-foreground">{s.v}</p>
                </div>
              ))}
            </div>

            <blockquote class="border-l-4 border-foreground/20 pl-5 italic text-muted">
              <p>{t.ctxQuote}</p>
              <cite class="block mt-2 text-sm not-italic text-muted/70">{t.ctxQuoteCite}</cite>
            </blockquote>

            {/* Two-season card split */}
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div class="bg-white/70 border border-warm-border/50 rounded-2xl p-5">
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground-dark mb-2">{lang === 'en' ? 'Summer · Block heat' : 'Verano · Bloquea el calor'}</p>
                <p class="text-sm text-muted leading-relaxed">{t.ctxP1.split('. ').slice(-1)[0]}</p>
              </div>
              <div class="bg-white/70 border border-warm-border/50 rounded-2xl p-5">
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground-dark mb-2">{lang === 'en' ? 'Winter · Keep heat in' : 'Invierno · Retiene el calor'}</p>
                <p class="text-sm text-muted leading-relaxed">{t.ctxP2}</p>
              </div>
            </div>

            <p>{t.ctxP3}</p>

            <p class="text-sm pt-2">
              {t.ctxSeeAlso}
              <a href={t.ctxLink1Href} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">{t.ctxLink1}</a>
              &middot;
              <a href={t.ctxLink2Href} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">{t.ctxLink2}</a>
              &middot;
              <a href={t.ctxLink3Href} class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">{t.ctxLink3}</a>
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <ContactoRapidoCard lang={lang} />
            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-3">{t.datosTitle}</p>
              <div class="space-y-2">
                {t.datosReferencia.map((d) => (
                  <div class="flex justify-between items-center py-1.5 border-b border-warm-border/50 last:border-0">
                    <span class="text-xs text-muted">{d.label}</span>
                    <span class="text-xs font-bold text-foreground">{d.valor}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tipos de aislante térmico -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.matBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">{t.matH2}</h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">{t.matLead}</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 stagger-children">
        {t.tiposAislante.map((mat) => (
          <div class={`bg-white/70 border-t-4 ${mat.color} border border-warm-border/50 p-7 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default`}>
            <h3 class="text-lg font-bold text-foreground mb-3">{mat.nombre}</h3>
            <p class="text-sm text-muted leading-relaxed mb-5">{mat.desc}</p>
            <div class="mb-4">
              <p class="text-xs font-bold text-muted uppercase tracking-wider mb-2">{t.matVentajas}</p>
              <ul class="space-y-1">
                {mat.ventajas.map((v) => (
                  <li class="flex items-center gap-2 text-xs text-muted">
                    <svg class="size-3 text-foreground shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    {v}
                  </li>
                ))}
              </ul>
            </div>
            <div class="space-y-2 pt-4 border-t border-warm-border/50">
              <div class="flex justify-between items-center"><span class="text-xs font-bold text-foreground">{t.matResistencia}</span><span class="text-xs font-semibold text-foreground">{mat.rValue}</span></div>
              <div class="flex justify-between items-center"><span class="text-xs font-bold text-foreground">{t.matPrecio}</span><span class="text-xs font-semibold text-foreground">{mat.precio}</span></div>
              <div class="pt-1"><span class="text-xs font-bold text-foreground">{t.matMejorPara} </span><span class="text-xs text-muted">{mat.mejorPara}</span></div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Tabla comparativa aislantes -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">{t.compBadge}</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">{t.compH2}</h2>
        <p class="text-muted leading-relaxed mb-12 max-w-2xl">{t.compLead}</p>
      </div>
      <div class="space-y-3">
        {t.tablaComparativa.map((a) => (
          <div class={`flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 bg-white/70 rounded-2xl border ${a.destacado ? 'border-foreground-dark' : 'border-warm-border/50'} shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 px-5 py-4 cursor-default`}>
            <div class="sm:w-44 shrink-0 flex items-center gap-3">
              <h3 class="text-sm font-bold text-foreground">{a.nombre}</h3>
              {a.destacado && (<span class="inline-flex items-center px-2 py-0.5 rounded-md bg-foreground-dark text-white text-[9px] font-bold uppercase tracking-wider">{t.compTop}</span>)}
            </div>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 sm:flex-1">
              <div><p class="text-[10px] font-bold uppercase tracking-wider text-muted">{t.compValor}</p><p class="text-sm font-bold text-foreground">{a.valorR} <span class="text-xs font-normal text-muted">m²K/W</span></p></div>
              <div><p class="text-[10px] font-bold uppercase tracking-wider text-muted">{t.compEspesor}</p><p class="text-sm font-bold text-foreground">{a.espesor}</p></div>
              <div><p class="text-[10px] font-bold uppercase tracking-wider text-muted">{t.compPrecio}</p><p class="text-sm font-bold text-foreground">{a.precio}</p></div>
              <div class="sm:ml-auto"><p class="text-[10px] font-bold uppercase tracking-wider text-muted">{t.compMejor}</p><p class="text-sm text-foreground">{a.mejorPara}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-xs text-muted mt-4">{t.compFootnote}</p>
    </Container>
  </section>

  <!-- Trasdosados térmicos con pladur -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.solBadge}</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">{t.solH2}</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>{t.solP1}</p>
            <p>{t.solP2}</p>
            <p>{t.solP3}</p>
            <div class="p-5 bg-foreground text-white mt-6 rounded-3xl">
              <p class="font-bold text-base mb-2">{t.roiTitle}</p>
              <p class="text-gray-300 text-sm leading-relaxed">{t.roiText}</p>
            </div>
          </div>
        </div>

        <!-- Proceso paso a paso -->
        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-2 inline-flex items-center px-3 py-1 rounded-lg">{t.procesoBadge}</p>
          {t.pasosInstalacion.map((paso) => (
            <div class="bg-white/70 border border-warm-border/50 p-5 flex gap-4 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
              <div class="shrink-0 size-10 bg-foreground-dark flex items-center justify-center rounded-xl">
                <span class="text-white font-bold text-xs">{paso.num}</span>
              </div>
              <div>
                <p class="font-bold text-foreground text-sm mb-1">{paso.titulo}</p>
                <p class="text-xs text-muted leading-relaxed">{paso.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Enlace a subvenciones -->
  <section class="pb-10 lg:pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-foreground rounded-3xl p-7 sm:p-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <p class="text-white/80 text-sm leading-relaxed">{t.subvCta} <strong class="text-white">{t.subvCtaStrong}</strong> {t.subvCta2}</p>
        <a href={p('/blog/subvenciones-aislamiento-baleares-2026')} class="inline-flex items-center gap-2 text-white font-semibold underline underline-offset-2 text-sm shrink-0">
          {t.subvCtaLink}
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CtaBanner intermedio -->
  <CtaBanner lang={lang} titulo={t.ctaIntTitulo} subtitulo={t.ctaIntSubtitulo} showForm={false} />

  <!-- Certificado energético -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.certBadge}</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">{t.certH2}</h2>
          </div>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>{t.certP1}</p>
            <p>{t.certP2}</p>
            <p>{t.certP3}</p>
          </div>
        </div>

        <!-- Subvenciones y ayudas -->
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.subvBadge}</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">{t.subvH2}</h2>
          </div>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>{t.subvP1}</p>
            <p>{t.subvP2}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
              {t.programasAyudas.map((prog) => (
                <div class="p-4 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
                  <p class="font-bold text-foreground text-sm">{prog.programa}</p>
                  <p class="text-foreground font-bold text-sm">{prog.cobertura}</p>
                  <p class="text-xs text-muted mt-1">{prog.tipo}</p>
                </div>
              ))}
            </div>
            <p class="text-xs text-muted">{t.subvFootnote}</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Aislamiento por tipo de vivienda -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">{t.appBadge}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">{t.appH2}</h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">{t.appLead}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {t.tipoVivienda.map((v) => (
          <div class="bg-white/70 border border-warm-border/50 p-7 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
            <div class="size-10 bg-foreground-dark flex items-center justify-center rounded-xl mb-4">
              <svg class="size-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
            </div>
            <h3 class="text-lg font-bold text-foreground mb-2">{v.titulo}</h3>
            <p class="text-sm text-muted leading-relaxed mb-4">{v.desc}</p>
            <p class="text-xs text-foreground font-semibold">{v.foot}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- NuestrosDatos — benchmarks reales de aislamiento térmico -->
  <NuestrosDatos
    lang={lang}
    eyebrow={lang === 'en' ? 'Our numbers — thermal insulation' : 'Nuestras cifras — aislamiento térmico'}
    title={lang === 'en' ? 'Every thermal lining we install meets CTE DB-HE' : 'Cada trasdosado que instalamos cumple CTE DB-HE'}
    intro={lang === 'en'
      ? 'Thermal drywall wall linings are one of our most in-demand systems in the Balearics. Real figures from the Mallorca parent company.'
      : 'El trasdosado térmico es uno de los sistemas con más demanda en Baleares. Cifras reales de la SL matriz.'}
    metrics={lang === 'en' ? [
      { value: '6,000+', label: 'cumulative works', context: 'Track record since 2004 across the Balearics' },
      { value: 'B3', label: 'Menorca climate zone', context: 'Per CTE DB-HE — we design for this specifically' },
      { value: 'Rockwool · Isover', label: 'mineral wools we use', context: '40-100 mm depending on the system' },
      { value: '22', label: 'years of thermal systems', context: 'Placo · Knauf · Lafarge exclusively' },
    ] : [
      { value: '+6.000', label: 'obras acumuladas', context: 'Histórico en Baleares desde 2004' },
      { value: 'B3', label: 'zona climática de Menorca', context: 'Según CTE DB-HE — diseñamos para esto específicamente' },
      { value: 'Rockwool · Isover', label: 'lanas minerales que usamos', context: '40-100 mm según sistema' },
      { value: '22', label: 'años en sistemas térmicos', context: 'Placo · Knauf · Lafarge exclusivamente' },
    ]}
  />

  <!-- PreciosTable -->
  <PreciosTable lang={lang} variant="Aislamiento Térmico" />

  <!-- GaleriaTrabajos -->
  <GaleriaTrabajos imagenes={t.gallery} />

  <!-- ZonasServicio -->
  <ZonasServicio lang={lang} />

  <!-- Artículos relacionados -->
  <ArticulosRelacionados articulos={t.articulos} />

  <!-- FaqAccordion -->
  <FaqAccordion client:visible lang={lang} faqs={pageFaqs} titulo={t.faqTitle} subtitulo={t.faqSubtitle} />

  <!-- CtaBanner final -->
  <CtaBanner lang={lang} titulo={t.ctaFinalTitulo} subtitulo={t.ctaFinalSubtitulo} showForm={true} />

  <ServiciosRelacionados currentPath={pagePathBase} />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton />
    <CookieBanner />
  </Fragment>
</BaseLayout>
