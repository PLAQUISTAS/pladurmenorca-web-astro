const t = lang === 'en' ? {
  heroTitle: 'About Pladur Menorca — Drywall Specialists since 2004',
  heroSubtitle: 'Plaquistas y Acabados SL is a family-run Mallorca company expanding to Menorca in 2026, exclusively dedicated to pladur (laminated plasterboard) and plaster since 2004. 6,000+ works delivered across the Balearic Islands. Over 50 installers certified by Placo and Knauf.',
  historyBadge: 'Our history',
  historyTitle: 'From family workshop to Menorca-wide drywall specialist',
  historyP1Rich: 'Pladur Menorca operates as <strong class="text-foreground">Plaquistas y Acabados SL</strong>, a family-run company founded in <strong class="text-foreground">2004</strong> with office in <a href="https://www.pladurmallorca.com" target="_blank" rel="noopener" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">Mallorca</a>. It started with 3 people and a single conviction: specialise exclusively in pladur (yeso laminado) and plaster, and master every system end-to-end. In 2004, dry construction with laminated plasterboard was still emerging in the Balearic Islands, handled mostly by generalist builders who offered it as one service among many.',
  historyP2Rich: 'We made a deliberate choice: <strong class="text-foreground">do not run general building works</strong>. We trained our installers at the Placo and Knauf technical centres, invested in professional tooling, and negotiated direct supply with distributors. The result showed quickly — jobs delivered faster, with fewer incidents and a fixed price agreed before starting.',
  historyP3Rich: 'Today we are a team of <strong class="text-foreground font-semibold">over 50 installers</strong> certified by Placo and Knauf, all focused solely on pladur and plaster systems. Since 2004 we have completed more than <strong class="text-foreground font-semibold">6,000 works</strong> across the Balearic Islands — from <a href="/en/falsos-techos-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">false ceilings</a> and <a href="/en/tabiques-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">partitions</a> in 40 m² flats in Maó to <a href="/en/reformas-interiores-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">interior renovations</a> of 150-500 m² villas in Ciutadella and Sant Lluís and phased refits of 60-300 room hotels in Son Bou, Fornells and Punta Prima.',
  historyP4Rich: 'Our scope is strictly dry construction: <a href="/en/aislamiento-acustico-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">acoustic insulation</a> (CTE-HR), <a href="/en/aislamiento-termico-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">thermal insulation</a> (CTE-HE, climate zone B3 for Menorca), fire-resistant partitions (CTE-DB-SI), wall linings, full layout changes and Q2-Q4 decorative finishes. We carry €600,000 professional liability insurance plus project-specific coverage, and we are collaborators of the Colegio APIs Baleares.',
  historyP5Rich: 'We are still a close-contact company: the client always talks directly to the technical lead. The commitment we started with in 2004 has not changed — do each job right the first time, on the agreed schedule, and at the fixed <a href="/en/precios-pladur-menorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-muted transition-colors">price</a> quoted before works begin. Dry construction also means up to 80% less waste than traditional wet works (in line with RD 105/2008).',
  statsBadge: 'In numbers',
  statsTitle: 'Since 2004, exclusively pladur and plaster',
  stats: [
    { valor: '6,000+', etiqueta: 'Projects completed', descripcion: 'Across the Balearic Islands' },
    { valor: 'Since 2004', etiqueta: 'Years of experience', descripcion: 'Family-run Plaquistas y Acabados SL' },
    { valor: '8', etiqueta: 'Menorca municipalities', descripcion: 'Full coverage across inland Menorca and the coast' },
    { valor: '50+', etiqueta: 'Installers', descripcion: 'Certified by Placo and Knauf' },
  ],
