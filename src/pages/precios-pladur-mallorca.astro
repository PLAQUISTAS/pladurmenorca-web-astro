        {ejemplos.map((ejemplo) => (
          <div class="bg-white/70 border border-warm-border/50 overflow-hidden rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
            <div class="bg-foreground p-5">
              <h3 class="font-bold text-white text-base leading-snug">{ejemplo.titulo}</h3>
            </div>
            <div class="p-6">
              <p class="text-sm text-muted leading-relaxed mb-5">{ejemplo.desc}</p>
              <div class="space-y-2 mb-5">
                {ejemplo.desglose.map((d) => (
                  <div class="flex justify-between items-center text-sm py-1.5 border-b border-warm-border/50 last:border-0">
                    <span class="text-muted">{d.concepto}</span>
                    <span class="font-semibold text-foreground">{d.precio}</span>
