---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import SchemaAggregateOffer from '@/components/seo/SchemaAggregateOffer.astro'
import { siteConfig } from '@/data/site'
import FaqAccordion from '@/components/sections/FaqAccordion'
import Hero from '@/components/sections/Hero'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ArticulosRelacionados from '@/components/sections/ArticulosRelacionados.astro'
import Container from '@/components/ui/Container.astro'
import { preciosFaqs } from '@/data/faqs/precios'
import { getServicioBySlug } from '@/data/servicios'

const servicio = getServicioBySlug('precios-pladur-mallorca')!
const pageFaqs = preciosFaqs

const meta = {
  title: 'Precios Pladur Mallorca 2026 | Tabla Desde 29€/m²',
  description: 'Compara precios del pladur en Mallorca 2026. Falsos techos desde 29€/m², tabiques desde 45€/m², aislamiento desde 6€/m². Tabla completa. Presupuesto gratis.',
  canonical: '/precios-pladur-mallorca',
}

const factores = [
  { factor: 'Tipo de sistema', desc: 'Un falso techo básico cuesta el 50% de uno acústico. La complejidad técnica del sistema es el factor más determinante del precio.' },
  { factor: 'Tipo de placa', desc: 'La placa estándar BA13 es la más económica. Las placas cortafuego (DF90), acústicas o de alta dureza pueden costar el doble.' },
  { factor: 'Superficie total', desc: 'A mayor superficie, mejor precio unitario. Los proyectos de más de 100 m² tienen economías de escala significativas.' },
  { factor: 'Accesibilidad', desc: 'Trabajar en edificios sin ascensor, con escaleras estrechas (centro histórico de Palma) o en alturas inusuales encarece la obra.' },
  { factor: 'Instalaciones a integrar', desc: 'Si hay que integrar eléctrica, climatización o fontanería, el precio aumenta proporcionalmente al trabajo de instalación.' },
  { factor: 'Forma y geometría', desc: 'Los espacios rectangulares son los más económicos. Las formas curvas, techos inclinados o geometrías irregulares elevan el coste.' },
]

const sidebarPrecios = [
  { servicio: 'Falso techo básico', precio: '29€/m²' },
  { servicio: 'Falso techo acústico', precio: '35€/m²' },
  { servicio: 'Tabique distribución', precio: '45€/m²' },
  { servicio: 'Tabique acústico', precio: '52€/m²' },
  { servicio: 'Aislamiento acústico', precio: '6€/m²' },
  { servicio: 'Aislamiento térmico', precio: '7€/m²' },
]

const sidebarLinks = [
  { label: 'Falsos Techos', href: '/falsos-techos-pladur-mallorca' },
  { label: 'Tabiques Pladur', href: '/tabiques-pladur-mallorca' },
  { label: 'Aislamiento Acústico', href: '/aislamiento-acustico-mallorca' },
  { label: 'Instalación Pladur', href: '/instalacion-pladur-mallorca' },
]

const tablaComparativaCostes = [
  ['Materiales', 'Medio', 'Bajo-Medio'],
  ['Mano de obra', 'Bajo (3-4x más rápido)', 'Alto'],
  ['Retirada escombros', 'Mínima', 'Alta (contenedor)'],
  ['Protección espacio', 'Básica', 'Extensiva'],
  ['Tiempo de obra', '1-5 días', '1-4 semanas'],
  ['Total aproximado/m²', '25-60€', '40-80€'],
]

const ejemplos = [
  {
    titulo: 'Piso de 80 m² con falso techo en toda la vivienda',
    desc: 'Reforma de un piso estándar de 80 m² que no tiene falso techo. Se instala un falso techo continuo básico en toda la vivienda (salón, dormitorios, baños, cocina) con integración de puntos de luz LED en salón y dormitorios.',
    desglose: [
      { concepto: 'Falso techo 80 m² (básico)', precio: '2.320-2.800€' },
      { concepto: '8 focos LED empotrados', precio: '400-640€' },
      { concepto: 'Tratamiento de juntas y acabado', precio: 'incluido' },
    ],
    total: '1.840-2.640€',
    plazo: '3-5 días',
    iva: 'Sin IVA',
  },
  {
    titulo: 'Habitación nueva con tabique acústico (15 m² de tabique)',
    desc: 'División de una habitación grande en dos mediante un tabique acústico con doble placa y lana mineral. Incluye puerta interior y marco. La habitación resultante de 12 m² queda lista para pintar.',
    desglose: [
      { concepto: 'Tabique acústico 15 m²', precio: '780-870€' },
      { concepto: 'Puerta interior + marco', precio: '200-400€' },
      { concepto: 'Paso instalación eléctrica', precio: '80-150€' },
    ],
    total: '850-1.375€',
    plazo: '1-2 días',
    iva: 'Sin IVA',
  },
  {
    titulo: 'Salón insonorizado (techo + paredes)',
    desc: 'Proyecto de mejora acústica integral de un salón de 25 m² con vecino ruidoso arriba y al lado. Se instala falso techo antivibración y se trasdosan dos paredes con sistema desvinculado.',
    desglose: [
      { concepto: 'Falso techo acústico 25 m²', precio: '875-1.250€' },
      { concepto: 'Trasdosado 2 paredes 30 m²', precio: '870-1.440€' },
      { concepto: 'Materiales antivibratorios', precio: 'incluido' },
    ],
    total: '2.075-3.200€',
    plazo: '4-7 días',
    iva: 'Sin IVA',
  },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Precios Pladur', href: '/precios-pladur-mallorca' }]} />
    <SchemaFAQ faqs={pageFaqs} />
    <SchemaService name={servicio.schema.name} description={servicio.schema.description} serviceType={servicio.schema.serviceType} url="https://www.pladurmallorca.com/precios-pladur-mallorca" image="https://www.pladurmallorca.com/images/proyectos/reforma-integral-piso-santa-catalina-pladur-mallorca.webp" />
    <SchemaAggregateOffer
      name="Servicios de Pladur en Mallorca"
      description="Precios actualizados de instalación de pladur, falsos techos, tabiques y aislamiento en Mallorca"
      lowPrice="6"
      highPrice="300"
      offerCount={14}
    />
    <SchemaOffers offers={[
      { name: 'Falso techo continuo básico', price: '29', description: 'Falso techo de placa estándar BA13 sobre estructura metálica. Incluye material y mano de obra.' },
      { name: 'Tabique de distribución simple', price: '45', description: 'Tabique de pladur con estructura de 48mm y placa BA13 a cada lado. Incluye tratamiento de juntas.' },
      { name: 'Tabique acústico reforzado', price: '52', description: 'Tabique de pladur con doble placa y lana mineral de alta densidad para aislamiento acústico.' },
      { name: 'Aislamiento acústico con pladur', price: '6', description: 'Sistema de trasdosado desvinculado con placa acústica y lana mineral para máxima reducción de ruido.' },
      { name: 'Trasdosado térmico con pladur', price: '35', description: 'Trasdosado de pladur con aislamiento térmico integrado para mejorar la eficiencia energética.' },
    ]} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — precios de pladur actualizados en Mallorca 2026. Falsos techos desde 29€/m², tabiques desde 45€/m², aislamiento acústico desde 45€/m². Presupuesto cerrado sin sorpresas. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <Hero
    client:visible
    title="Precio del Pladur en Mallorca 2026 — Guía Completa"
    subtitle="Tabla actualizada por tipo de servicio. Sin letra pequeña."
    description="La guía de precios más completa del pladur en Mallorca para 2026. Falsos techos desde 29€/m², tabiques desde 45€/m², aislamiento acústico desde 6€/m². Precios reales, con IVA desglosado, actualizados a los costes de Mallorca."
    dark={true}
    badges={['Desde 29€/m²', 'IVA desglosado', 'Actualizado 2026']}
    ctaPrimario={{ texto: 'Pedir presupuesto gratis', href: '/presupuesto-pladur' }}
    ctaSecundario={{ texto: `Llamar: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- Introducción -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">Guía de precios 2026</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">¿Por qué varían los precios del pladur?</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>El precio del pladur en Mallorca depende de varios factores clave que es importante entender antes de solicitar presupuesto. No existe un precio fijo por metro cuadrado que sea válido para todos los proyectos: la variación entre el precio mínimo y el máximo puede ser de hasta el 300% dependiendo de la complejidad y las especificaciones del trabajo.</p>
            <p>Los precios en Mallorca son, en promedio, un 12-20% superiores a los de la Península por los costes de transporte marítimo de materiales y la mayor demanda de mano de obra especializada en la isla. A pesar de ello, el pladur sigue siendo entre un 20% y un 40% más económico que la tabiquería o los techos de ladrillo cuando se considera el coste total (materiales + mano de obra + limpieza de escombros + tiempo).</p>

            <h3 class="text-xl font-bold text-foreground mt-8 mb-3">Factores que determinan el precio final</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
              {factores.map((f) => (
                <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card">
                  <p class="font-bold text-foreground text-sm mb-1">{f.factor}</p>
                  <p class="text-xs text-muted leading-relaxed">{f.desc}</p>
                </div>
              ))}
            </div>

            <div class="mt-6 p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-1">Importante: los precios de esta página son orientativos</p>
              <p class="text-sm text-muted leading-relaxed">
                Para obtener el precio exacto de tu proyecto es imprescindible una visita técnica gratuita. Realizamos visita, tomamos medidas y enviamos presupuesto cerrado y desglosado en 24-48 horas. Sin compromiso.
                <a href="/presupuesto-pladur" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark">Solicita tu presupuesto ahora.</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <div class="p-6 bg-foreground text-white rounded-3xl">
              <p class="text-xs font-semibold uppercase tracking-wide text-white/60 mb-3">Presupuesto exacto</p>
              <p class="font-bold text-lg mb-2">Precio cerrado para tu proyecto</p>
              <p class="text-white/60 text-sm mb-5 leading-relaxed">Visita técnica gratuita. Presupuesto en 24h. Sin sorpresas.</p>
              <a href="/presupuesto-pladur" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide transition-colors">Presupuesto online</a>
              <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-2 w-full py-3 mt-3 rounded-xl border border-white/30 hover:border-white text-white font-bold text-sm tracking-wide transition-colors">Llamar: {siteConfig.phone}</a>
            </div>

            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-4 uppercase tracking-wider">Precios desde</p>
              {sidebarPrecios.map((p) => (
                <div class="flex justify-between items-center py-2 border-b border-warm-border/50 last:border-0">
                  <span class="text-xs text-muted">{p.servicio}</span>
                  <span class="text-sm font-bold text-foreground-dark">{p.precio}</span>
                </div>
              ))}
            </div>

            <div class="p-4 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default text-sm text-muted">
              <p class="font-semibold text-foreground mb-1">Servicios de precio:</p>
              <ul class="space-y-1.5">
                {sidebarLinks.map((s) => (
                  <li>
                    <a href={s.href} class="flex items-center gap-2 text-muted hover:text-foreground transition-colors">
                      <svg aria-hidden="true" class="size-3 text-muted shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tabla resumen general -->
  <PreciosTable variant="resumen" />

  <!-- CtaBanner 1 -->
  <CtaBanner titulo="¿Quieres saber el precio exacto de tu proyecto?" subtitulo="La visita técnica es gratuita. Presupuesto en 24h. Precio cerrado sin sorpresas." showForm={false} />

  <!-- Falsos Techos - Precios detallados -->
  <section class="py-20 lg:py-28" id="falsos-techos">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">Desglose por servicio</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">Precio falsos techos pladur en Mallorca 2026</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">Los precios de falsos techos varían principalmente según el tipo de sistema (continuo básico, registrable, acústico, decorativo o con LED) y la complejidad de la instalación. La superficie mínima que solemos presupuestar es de 15 m².</p>
        <a href="/falsos-techos-pladur-mallorca" class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          Ver página completa de falsos techos
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable variant="Falsos Techos" hideHeader />
  </section>

  <!-- Tabiques - Precios detallados -->
  <section class="py-20 lg:py-28" id="tabiques">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">Desglose por servicio</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">Precio tabiques pladur en Mallorca 2026</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">Los precios de tabiques se calculan por m² de pared terminada (ambas caras incluidas). El precio varía según la tipología: distribución simple, acústico reforzado, cortafuego o trasdosado.</p>
        <a href="/tabiques-pladur-mallorca" class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          Ver página completa de tabiques
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable variant="Tabiques y Particiones" hideHeader />
    <Container size="xl">
      <p class="mt-6 text-sm text-muted leading-relaxed">Para precios de placa hidrófuga (baños y cocinas), consulta nuestra página de <a href="/pladur-hidrofugo-mallorca" class="text-foreground font-semibold underline underline-offset-2">pladur hidrófugo en Mallorca</a>.</p>
    </Container>
  </section>

  <!-- Aislamiento - Precios detallados -->
  <section class="py-20 lg:py-28" id="aislamiento">
    <Container size="xl">
      <div class="mb-10 animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-3 inline-flex items-center px-3 py-1 rounded-lg">Desglose por servicio</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4">Precio aislamiento acústico pladur en Mallorca 2026</h2>
        <p class="text-lg text-muted leading-relaxed max-w-3xl">El aislamiento acústico con pladur tiene un coste mayor que los sistemas estándar porque requiere materiales específicos (lana mineral de alta densidad, sistemas antivibratorios) y mayor tiempo de instalación.</p>
        <a href="/aislamiento-acustico-mallorca" class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-foreground hover:text-foreground-dark transition-colors">
          Ver página completa de aislamiento acústico
          <svg aria-hidden="true" class="size-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </Container>
    <PreciosTable variant="Aislamiento Acústico" hideHeader />
  </section>

  <!-- CtaBanner 2 -->
  <CtaBanner titulo="Los precios exactos están en tu presupuesto personalizado" subtitulo="Gratuito, sin compromiso. Respuesta en menos de 24 horas." showForm={false} />

  <!-- Factores que afectan al precio -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">Guía avanzada</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6 max-w-2xl">Factores que afectan al precio final del pladur</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="space-y-6 text-muted leading-relaxed">
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">1. Superficie total del proyecto</h3>
            <p>Es el factor con mayor impacto en el precio unitario. Un proyecto de 20 m² de falso techo tiene un coste por m² entre un 25% y un 40% superior al de un proyecto de 100 m², porque los costes fijos (desplazamiento, montaje/desmontaje de andamios, mezcla de materiales) se distribuyen entre menos metros.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">2. Tipo de placa y sistema</h3>
            <p>La placa BA13 estándar cuesta entre 5 y 7€/m². La placa DF90 cortafuego puede llegar a 15-18€/m². La placa acústica BA15 cuesta entre 8 y 12€/m². A esto se suman los materiales auxiliares (montantes, pasta, cinta, lana mineral), que también varían según el sistema elegido.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">3. Complejidad y geometría</h3>
            <p>Un techo rectangular de superficies lisas es el escenario más económico. Las formas curvas, los techos con desniveles, las columnas que hay que esquivar, los artesonados decorativos o las geometrías con muchos ángulos aumentan significativamente el tiempo de instalación y, por tanto, el precio de la mano de obra.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">4. Accesibilidad y condiciones de obra</h3>
            <p>Trabajar en el centro histórico de Palma o en municipios alejados no supone sobrecoste en sí mismo, pero sí puede implicar dificultades de acceso (escaleras estrechas, sin ascensor, materiales que hay que subir a mano) que aumentan el tiempo de trabajo. También influye el estado del inmueble: techos muy irregulares o paredes fuera de plomo requieren más trabajo de nivelación.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-foreground mb-2">5. Instalaciones a integrar</h3>
            <p>La integración de instalaciones eléctricas (puntos de luz, dimmers, interruptores), de climatización (difusores, rejillas) o de telecomunicaciones (puntos de datos, antenas) supone un sobrecoste que depende de la cantidad de puntos y la complejidad del cableado. Un punto de luz empotrado en falso techo tiene un coste de entre 45 y 80€ instalado.</p>
          </div>
        </div>

        <div class="space-y-6 text-muted leading-relaxed">
          <h2 class="text-2xl font-bold text-foreground leading-tight text-balance mb-6">Pladur vs obra tradicional: comparativa de coste total</h2>
          <p>Cuando comparamos el coste total de un proyecto con pladur frente a la misma solución con obra tradicional de ladrillo, el pladur resulta siempre más económico cuando se tienen en cuenta todos los costes reales:</p>
          <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
            <div class="rounded-3xl overflow-hidden border border-warm-border shadow-card min-w-[420px]">
              <table class="min-w-full">
                <thead>
                  <tr class="bg-foreground">
                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider">Coste</th>
                    <th class="px-4 py-3 text-left text-xs font-bold text-white uppercase tracking-wider">Pladur</th>
                    <th class="px-4 py-3 text-left text-xs font-bold text-white/70 uppercase tracking-wider">Ladrillo</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-warm-border">
                  {tablaComparativaCostes.map(([coste, pladur, ladrillo], i) => (
                    <tr class={`${i % 2 === 0 ? 'bg-white/70' : 'bg-white/40'} hover:bg-surface/50 transition-colors`}>
                      <td class="px-4 py-3.5 text-sm font-semibold text-foreground">{coste}</td>
                      <td class="px-4 py-3.5 text-sm text-foreground font-bold">{pladur}</td>
                      <td class="px-4 py-3.5 text-sm text-muted">{ladrillo}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          <p class="text-sm text-muted">El ahorro total con pladur puede ser del 25-40% respecto a la obra tradicional cuando se calcula el coste completo del proyecto.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Ejemplos prácticos -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
