---
export const prerender = true
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/layout/Header'
import Footer from '@/components/layout/Footer.astro'
import WhatsAppButton from '@/components/layout/WhatsAppButton'
import CookieBanner from '@/components/layout/CookieBanner'
import SchemaLocalBusiness from '@/components/seo/SchemaLocalBusiness.astro'
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro'
import SchemaService from '@/components/seo/SchemaService.astro'
import SchemaFAQ from '@/components/seo/SchemaFAQ.astro'
import SchemaHowTo from '@/components/seo/SchemaHowTo.astro'
import SchemaOffers from '@/components/seo/SchemaOffers.astro'
import FaqAccordion from '@/components/sections/FaqAccordion'
import PreciosTable from '@/components/sections/PreciosTable.astro'
import ZonasServicio from '@/components/sections/ZonasServicio.astro'
import GaleriaTrabajos from '@/components/sections/GaleriaTrabajos.astro'
import CtaBanner from '@/components/sections/CtaBanner.astro'
import ServiciosRelacionados from '@/components/sections/ServiciosRelacionados.astro'
import Hero from '@/components/sections/Hero'
import Container from '@/components/ui/Container.astro'
import { escayolaFaqs } from '@/data/faqs/escayola'
import { siteConfig } from '@/data/site'

const meta = {
  title: 'Escayola en Mallorca | Techos, Molduras y Restauración | +20 Años',
  description: 'Escayola en Mallorca. Techos de escayola, molduras, cornisas y restauración de edificios históricos. +20 años, +6.000 proyectos. Presupuesto gratis ☎ 627 829 723',
  canonical: '/escayola-mallorca',
}

const pageFaqs = escayolaFaqs

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Escayola en Mallorca', href: '/escayola-mallorca' },
]

const tiposEscayola = [
  {
    titulo: 'Techos de escayola',
    desc: 'Techos continuos lisos con acabado impecable. La escayola proporciona una superficie perfectamente plana, sin juntas visibles, ideal para techos de viviendas y locales donde se busca un acabado noble y tradicional. Disponible en escayola blanca (E-30) y escayola de alta dureza (E-45).',
    iconPath: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  },
  {
    titulo: 'Escayola decorativa — Molduras y cornisas',
    desc: 'Molduras, cornisas, rosetones y elementos ornamentales fabricados con moldes tradicionales. Transforman un techo plano en un elemento decorativo con carácter. Disponemos de más de 50 modelos de molduras y cornisas, desde las más sencillas hasta las de mayor complejidad ornamental.',
    iconPath: 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  },
  {
    titulo: 'Escayola proyectada',
    desc: 'Sistema de aplicación mecanizada que permite revestir grandes superficies en menos tiempo. Ideal para techos de nueva construcción, naves industriales reformadas y locales comerciales de gran tamaño. Acabado liso y uniforme con menor tiempo de ejecución que la aplicación manual.',
    iconPath: 'M11.42 15.17l-5.384-3.065A1.5 1.5 0 005.25 13.5v5.25a1.5 1.5 0 001.786 1.47l5.384-1.436a1.5 1.5 0 001.08-1.442V15.17zm0 0l5.384-3.065A1.5 1.5 0 0018.75 10.5V5.25a1.5 1.5 0 00-1.786-1.47l-5.384 1.436a1.5 1.5 0 00-1.08 1.442v8.512z',
  },
  {
    titulo: 'Restauración de escayola histórica',
    desc: 'Reproducción y restauración de elementos ornamentales en edificios antiguos de Mallorca. Fabricamos moldes a partir de las piezas originales para reproducir cornisas, ménsulas, rosetones y cualquier elemento decorativo dañado o desaparecido, respetando la estética y técnicas tradicionales.',
    iconPath: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z',
  },
  {
    titulo: 'Pladur con acabado de escayola',
    desc: 'La combinación perfecta: la versatilidad del pladur para tabiques, techos y aislamiento, con el acabado noble de la escayola en la capa final. Obtenemos superficies perfectas con la calidez estética de la escayola tradicional, aprovechando las ventajas técnicas del sistema de placa de yeso laminado.',
    iconPath: 'M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
  },
  {
    titulo: 'Escayola para baños y zonas húmedas',
    desc: 'Escayola de alta densidad y resistencia a la humedad para techos y paredes de baños, duchas y cocinas. Combinamos escayola hidrófuga con sistemas de impermeabilización para garantizar durabilidad en las zonas más exigentes de la vivienda.',
    iconPath: 'M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z',
  },
]

const datosEscayola = [
  { label: 'Acabado', valor: 'Sin juntas visibles' },
  { label: 'Secado', valor: '24-48 horas' },
  { label: 'Espesor placa', valor: '12,5 - 15 mm' },
  { label: 'Aislamiento acústico', valor: '+5 dB vs ladrillo' },
  { label: 'Durabilidad', valor: 'Vida del edificio' },
]
---

<BaseLayout meta={meta}>
  <Fragment slot="head">
    <SchemaLocalBusiness />
    <SchemaBreadcrumb items={breadcrumbs} />
    <SchemaService
      name="Escayola en Mallorca"
      description="Instalación de escayola en Mallorca: techos continuos, molduras decorativas, cornisas, restauración de edificios históricos y escayola proyectada. Más de 20 años de experiencia."
      serviceType="Instalación de Escayola"
      url="/escayola-mallorca"
    />
    <SchemaHowTo
      name="Cómo instalamos escayola en Mallorca"
      description="Proceso completo de instalación de escayola: desde la visita técnica gratuita hasta la entrega con acabado perfecto."
      totalTime="PT48H"
      steps={[
        { name: 'Visita técnica gratuita', text: 'Evaluamos el espacio, tomamos medidas y te asesoramos sobre el tipo de escayola más adecuado: lisa, decorativa, proyectada o restauración.' },
        { name: 'Presupuesto detallado en 24h', text: 'Presupuesto cerrado con desglose de materiales, mano de obra y plazo de ejecución. Sin compromiso.' },
        { name: 'Preparación del soporte', text: 'Limpiamos y preparamos la superficie. En restauraciones, fabricamos moldes de las piezas originales para reproducirlas fielmente.' },
        { name: 'Instalación y acabado', text: 'Aplicamos la escayola, tratamos las uniones y realizamos el acabado final. Listo para pintar en 24-48 horas.' },
      ]}
    />
    <SchemaOffers
      offers={[
        { name: 'Techo de escayola lisa', price: '25', description: 'Techo continuo de escayola con acabado perfectamente liso. Precio por m².' },
        { name: 'Molduras y cornisas', price: '12', description: 'Instalación de molduras y cornisas decorativas de escayola. Precio por metro lineal.' },
        { name: 'Escayola proyectada', price: '18', description: 'Aplicación mecanizada de escayola para grandes superficies. Precio por m².' },
        { name: 'Restauración de escayola', price: '35', description: 'Restauración y reproducción de elementos ornamentales en edificios históricos. Precio por m².' },
      ]}
    />
    <SchemaFAQ faqs={pageFaqs} />
  </Fragment>

  <Header client:idle slot="header" />

  <p class="sr-only" aria-hidden="false">
    Pladur Mallorca — empresa de pladur y escayola en Mallorca. Techos de escayola, molduras, cornisas, restauración histórica y escayola proyectada. Más de 20 años y 6.000 proyectos. Tel: 627 829 723.
  </p>

  <!-- Hero -->
  <Hero client:visible
    title="Escayola en Mallorca — Pladur y Escayola con +20 Años de Experiencia"
    subtitle="Techos, molduras, cornisas y restauración"
    description="Empresa especializada en pladur y escayola en Mallorca. Techos de escayola continua, molduras decorativas, cornisas y restauración de edificios históricos. Más de 6.000 proyectos completados en toda la isla."
    dark={true}
    badges={['Pladur y escayola', '+6.000 proyectos', 'Toda Mallorca']}
    ctaPrimario={{ texto: 'Pedir presupuesto gratis', href: '/presupuesto-pladur' }}
    ctaSecundario={{ texto: `Llamar: ${siteConfig.phone}`, href: `tel:${siteConfig.phoneRaw}` }}
  />

  <!-- Qué es la escayola y por qué combinarla con pladur -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-8">
          <div class="animate-fade-up">
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">Pladur y escayola</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">Somos la empresa de pladur y escayola en Mallorca con más experiencia</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>La escayola es un material de construcción a base de yeso de alta pureza, utilizado desde la antigüedad para crear techos, molduras y elementos decorativos en interiores. A diferencia del pladur (placa de yeso laminado industrializada), la escayola se aplica de forma artesanal, lo que permite obtener acabados sin juntas visibles y superficies perfectamente lisas con una calidez estética que la placa prefabricada no puede igualar.</p>
            <p>En Pladur Mallorca trabajamos con ambos materiales desde hace más de 20 años. Esta doble especialización nos permite ofrecer a nuestros clientes la solución más adecuada para cada caso: pladur cuando se necesita versatilidad, aislamiento y rapidez; escayola cuando se busca acabado noble, restauración o elementos decorativos; y la combinación de ambos cuando el proyecto lo requiere.</p>
            <p class="text-sm">
              Ver también:
              <a href="/instalacion-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">instalación de pladur</a>
              &middot;
              <a href="/falsos-techos-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">falsos techos</a>
              &middot;
              <a href="/precios-pladur-mallorca" class="text-foreground font-semibold underline underline-offset-2 hover:text-foreground-dark transition-colors">precios</a>
            </p>
          </div>
        </div>

        <aside class="lg:col-span-4">
          <div class="sticky top-24 space-y-6">
            <div class="p-6 bg-foreground text-white rounded-3xl">
              <p class="text-xs font-bold uppercase tracking-widest text-nav-border/60 mb-3">Presupuesto gratis</p>
              <p class="font-bold text-lg mb-2">¿Necesitas pladur o escayola en Mallorca?</p>
              <p class="text-gray-300 text-sm mb-5 leading-relaxed">Te visitamos sin compromiso y te asesoramos sobre el material más adecuado para tu proyecto.</p>
              <a href="/presupuesto-pladur" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-accent hover:bg-accent-600 text-white font-bold text-sm tracking-wide transition-colors">Pedir presupuesto online</a>
              <a href={`tel:${siteConfig.phoneRaw}`} class="flex items-center justify-center gap-2 w-full py-3 mt-3 rounded-xl border border-white/30 hover:border-white hover:bg-white/10 text-white font-bold text-sm tracking-wide transition-colors">{siteConfig.phone}</a>
            </div>
            <div class="p-5 bg-white/70 border border-warm-border/50 rounded-3xl shadow-card cursor-default">
              <p class="font-bold text-foreground text-sm mb-3">Datos de referencia:</p>
              <div class="space-y-2">
                {datosEscayola.map((d) => (
                  <div class="flex justify-between items-center py-1.5 border-b border-warm-border/50 last:border-0">
                    <span class="text-xs text-muted">{d.label}</span>
                    <span class="text-xs font-bold text-foreground">{d.valor}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Tipos de escayola -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="animate-fade-up">
        <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">Nuestros servicios de escayola</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">Tipos de escayola que instalamos en Mallorca</h2>
        <p class="text-lg text-muted leading-relaxed mb-14 max-w-3xl">Desde un techo liso de escayola en un piso moderno hasta la restauración de molduras del siglo XIX en el centro de Palma. Estos son los trabajos que realizamos:</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {tiposEscayola.map((tipo) => (
          <div class="bg-white/70 p-8 border border-warm-border/50 rounded-3xl shadow-soft hover:shadow-soft-hover hover:-translate-y-1 transition-[transform,box-shadow] duration-300 group h-full relative overflow-hidden">
            <div class="absolute top-0 left-0 w-0 h-0.5 bg-foreground-dark group-hover:w-full transition-[width] duration-500" />
            <div class="size-12 bg-surface border border-nav-border rounded-2xl group-hover:bg-foreground-dark group-hover:border-foreground-dark flex items-center justify-center mb-6 transition-[transform,box-shadow,background-color,border-color] duration-300">
              <svg class="size-5 text-foreground group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={tipo.iconPath} />
              </svg>
            </div>
            <h3 class="font-bold text-foreground text-lg mb-3">{tipo.titulo}</h3>
            <div class="text-muted text-sm leading-relaxed">
              <p>{tipo.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Escayola en edificios históricos de Mallorca -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-4 inline-flex items-center px-3 py-1 rounded-lg">Restauración</p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-6">Restauración de escayola en edificios históricos de Mallorca</h2>
          </div>
          <div class="space-y-5 text-muted leading-relaxed">
            <p>El casco antiguo de Palma de Mallorca concentra uno de los patrimonios arquitectónicos más importantes del Mediterráneo. Edificios de los siglos XVII, XVIII y XIX con techos de escayola decorada que necesitan restauración tras décadas —o siglos— de deterioro: cornisas rotas, molduras agrietadas, rosetones parcialmente desaparecidos.</p>
            <p>Nuestro equipo reproduce cualquier elemento ornamental original utilizando moldes de yeso tomados de las piezas conservadas. Trabajamos con las mismas técnicas tradicionales: enriquecimiento de la escayola con fibras, aplicación en capas sucesivas, pulido a mano y acabado con estuco cuando el proyecto lo requiere.</p>
            <p>También trabajamos en possessions, fincas rústicas y casas señoriales del resto de la isla: Sóller, Valldemossa, Deià, Bunyola y otros municipios con patrimonio arquitectónico relevante.</p>
          </div>
        </div>

        <div class="space-y-4">
          <p class="text-xs font-semibold uppercase tracking-wide bg-surface text-foreground mb-2 inline-flex items-center px-3 py-1 rounded-lg">Proceso de restauración</p>
          {[
            { num: '01', titulo: 'Estudio de las piezas originales', desc: 'Documentamos el estado de conservación de las piezas existentes, identificamos el tipo de escayola original y tomamos medidas para la reproducción.' },
            { num: '02', titulo: 'Fabricación de moldes', desc: 'Creamos moldes de silicona o yeso a partir de las piezas conservadas para reproducir fielemente los elementos ornamentales dañados o desaparecidos.' },
            { num: '03', titulo: 'Preparación del soporte', desc: 'Limpiamos, consolidamos y preparamos la superficie donde se instalarán las nuevas piezas, eliminando restos de escayola deteriorada.' },
            { num: '04', titulo: 'Instalación y acabado', desc: 'Fijamos las piezas reproducidas, sellamos las uniones y realizamos el acabado final para que la integración con los elementos originales sea perfecta.' },
          ].map((paso) => (
            <div class="bg-white/70 border border-warm-border/50 p-5 flex gap-4 rounded-3xl shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 cursor-default">
              <div class="shrink-0 size-10 bg-foreground-dark flex items-center justify-center rounded-xl">
                <span class="text-white font-bold text-xs">{paso.num}</span>
              </div>
              <div>
                <p class="font-bold text-foreground text-sm mb-1">{paso.titulo}</p>
                <p class="text-xs text-muted leading-relaxed">{paso.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- CtaBanner intermedio -->
  <CtaBanner titulo="¿Necesitas un techo de escayola o restaurar molduras?" subtitulo="Te asesoramos gratis sobre el material más adecuado para tu proyecto." showForm={false} />

  <!-- Pladur vs escayola -->
  <section class="py-20 lg:py-28">
    <Container size="xl">
      <div>
        <span class="inline-flex items-center px-3 py-1 rounded-lg bg-surface text-foreground text-xs font-semibold uppercase tracking-wide mb-4">Comparativa</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground leading-tight text-balance mb-4 max-w-3xl">¿Cuándo elegir pladur, escayola o la combinación de ambos?</h2>
        <p class="text-muted leading-relaxed mb-12 max-w-2xl">Cada material tiene sus puntos fuertes. Te ayudamos a elegir la mejor opción.</p>
      </div>
      <div class="space-y-3">
        {[
          { material: 'Pladur (placa de yeso laminado)', ventaja: 'Versatilidad y rapidez', desc: 'Ideal para tabiques, techos con instalaciones ocultas, aislamiento acústico y térmico. Permite integrar iluminación LED, aire acondicionado y domótica. Instalación rápida y seca.', destacar: false },
          { material: 'Escayola', ventaja: 'Acabado noble y tradicional', desc: 'Perfecta para techos lisos sin juntas, molduras, cornisas y elementos decorativos. Acabado artesanal de máxima calidad. Ideal para restauración de edificios antiguos.', destacar: false },
          { material: 'Pladur + acabado de escayola', ventaja: 'Lo mejor de ambos mundos', desc: 'Estructura de pladur con todas sus ventajas técnicas (aislamiento, instalaciones, rapidez) más capa de escayola para un acabado sin juntas y calidez estética. Nuestra recomendación para reformas de calidad.', destacar: true },
        ].map((item) => (
          <div class={`flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 bg-white/70 rounded-2xl border ${item.destacar ? 'border-foreground-dark' : 'border-warm-border/50'} shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-[transform,box-shadow] duration-300 px-5 py-4 cursor-default`}>
            <div class="sm:w-52 shrink-0 flex items-center gap-3">
              <h3 class="text-sm font-bold text-foreground">{item.material}</h3>
              {item.destacar && (<span class="inline-flex items-center px-2 py-0.5 rounded-md bg-foreground-dark text-white text-[9px] font-bold uppercase tracking-wider">Recomendado</span>)}
            </div>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 sm:flex-1">
              <div><p class="text-[10px] font-bold uppercase tracking-wider text-muted">Ventaja principal</p><p class="text-sm font-bold text-foreground">{item.ventaja}</p></div>
              <div class="sm:ml-auto"><p class="text-[10px] font-bold uppercase tracking-wider text-muted">Descripción</p><p class="text-sm text-foreground">{item.desc}</p></div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Precios -->
  <PreciosTable variant="resumen" />

  <!-- Zonas -->
  <ZonasServicio />

  <!-- Galería -->
  <GaleriaTrabajos imagenes={[
    { src: '/images/proyectos/reforma-integral-piso-santa-catalina-pladur-mallorca.webp', alt: 'Techo de escayola lisa en reforma de piso en Santa Catalina' },
    { src: '/images/proyectos/acabados-pladur-madera-cocina-mallorca.webp', alt: 'Molduras de escayola en cocina reformada en Mallorca' },
    { src: '/images/proyectos/salon-falso-techo-pladur-villa-mallorca.webp', alt: 'Techo de escayola decorativa en villa de Mallorca' },
    { src: '/images/proyectos/villa-obra-nueva-pladur-integral-mallorca.webp', alt: 'Escayola en obra nueva de villa en Mallorca' },
  ]} />

  <!-- FAQ -->
  <FaqAccordion client:visible faqs={pageFaqs} titulo="Preguntas frecuentes sobre escayola en Mallorca" subtitulo="Resolvemos las dudas más habituales sobre nuestros servicios de pladur y escayola." />

  <!-- CTA final -->
  <CtaBanner titulo="¿Tu proyecto necesita pladur o escayola?" subtitulo="Presupuesto gratis en 24 horas. Te asesoramos sin compromiso." showForm={true} />

  <ServiciosRelacionados currentPath="/escayola-mallorca" />

  <Footer slot="footer" />
  <Fragment slot="after-footer">
    <WhatsAppButton client:visible />
    <CookieBanner client:idle />
  </Fragment>
</BaseLayout>
