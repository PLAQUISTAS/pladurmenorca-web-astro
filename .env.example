# ─────────────────────────────────────────────────────────
# Pladur Menorca — Environment variables
# Copiar a .env o .env.local para desarrollo local. En producción definir en
# el panel del hosting (Netlify / Vercel / Coolify / etc.).
# ─────────────────────────────────────────────────────────

# Site URL (sobreescribe el default en astro.config.mjs)
PUBLIC_SITE_URL=https://www.pladurmenorca.com

# ─── Analytics / Tracking (opcional — todo público, client-side) ────────────
# Google Search Console verification meta tag (solo el valor content=...)
PUBLIC_GOOGLE_VERIFICATION=

# Google Analytics 4 — ID de medición (G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager — ID del contenedor (GTM-XXXXXXX)
PUBLIC_GTM_ID=

# Google Ads conversion ID (AW-XXXXXXXXX)
PUBLIC_GOOGLE_ADS_ID=

# Meta Pixel (Facebook) — ID numérico
PUBLIC_META_PIXEL_ID=

# ─── Email transaccional — Gmail API ────────────────────────────────────────
# Credenciales OAuth para enviar emails del formulario de contacto.
# Generar en https://console.cloud.google.com → OAuth 2.0 Client IDs.
# IMPORTANTE: NO públicas. No llevan prefijo PUBLIC_ ni se exponen al cliente.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=info@plaquistas.com
